@namespace NeoUI.Blazor.Primitives
@typeparam TData where TData : class
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<tr @ref="_elementRef"
    role="row"
    aria-selected="@(IsSelected ? "true" : "false")"
    tabindex="@(IsKeyboardNavigable ? 0 : -1)"
    class="@ComputedClass"
    @onclick="HandleClick"
    @onkeydown="HandleKeyDown"
    @oncontextmenu="OnContextMenu"
    @oncontextmenu:preventDefault="@OnContextMenu.HasDelegate"
    @attributes="AdditionalAttributes">
    @ChildContent
</tr>

@code {
    private ElementReference _elementRef;
    private bool _spaceKeyHandlerAttached = false;
    private bool _clickInterceptAttached = false;
    private IJSObjectReference? _tableRowNavModule;
    private IJSObjectReference? _spaceKeyCleanup;
    private IJSObjectReference? _clickInterceptCleanup;

    [CascadingParameter]
    private TableContext<TData> Context { get; set; } = default!;

    /// <summary>
    /// The data item for this row.
    /// </summary>
    [Parameter]
    public TData? Item { get; set; }

    /// <summary>
    /// Child content for the row (typically TableCell components).
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Additional CSS classes to apply to the tr element.
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// Additional attributes to apply to the tr element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Event callback invoked when the row is right-clicked.
    /// Prevents the browser's native context menu when a delegate is provided.
    /// </summary>
    [Parameter]
    public EventCallback<MouseEventArgs> OnContextMenu { get; set; }

    private bool IsSelected => Item != null && Context != null && Context.IsSelected(Item);

    private bool IsSelectable => Context != null && Context.SelectionMode != SelectionMode.None;

    private bool IsKeyboardNavigable => Context != null && Context.EnableKeyboardNavigation;

    // Intercept clicks when selection is active so user-provided interactive
    // content in cell templates (buttons, links, inputs) doesn't accidentally
    // trigger row selection.
    private bool NeedsClickIntercept => IsSelectable;

    /// <summary>
    /// Suppress the browser's native focus outline — the ring is drawn
    /// via per-cell inset box-shadows in CSS (components-input.css) so it
    /// works correctly in all browsers including Safari.
    /// </summary>
    private const string FocusRingClasses = "focus:outline-none";

    /// <summary>
    /// Computed class that suppresses the native outline when row is keyboard navigable.
    /// </summary>
    private string ComputedClass => IsKeyboardNavigable ? $"{FocusRingClasses} {Class}" : Class ?? "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            if (IsKeyboardNavigable && !_spaceKeyHandlerAttached)
            {
                _tableRowNavModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>(
                    "import", "./_content/NeoUI.Blazor.Primitives/js/primitives/table-row-nav.js");

                _spaceKeyCleanup = await _tableRowNavModule.InvokeAsync<IJSObjectReference>(
                    "preventSpaceKeyScroll", _elementRef);
                _spaceKeyHandlerAttached = true;
            }

            if (NeedsClickIntercept && !_clickInterceptAttached)
            {
                _tableRowNavModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>(
                    "import", "./_content/NeoUI.Blazor.Primitives/js/primitives/table-row-nav.js");

                _clickInterceptCleanup = await _tableRowNavModule.InvokeAsync<IJSObjectReference>(
                    "interceptInteractiveClicks", _elementRef);
                _clickInterceptAttached = true;
            }
            else if (!NeedsClickIntercept && _clickInterceptAttached)
            {
                // Selection mode was disabled after initial render — detach the intercept.
                if (_clickInterceptCleanup != null)
                {
                    await _clickInterceptCleanup.InvokeVoidAsync("dispose");
                    await _clickInterceptCleanup.DisposeAsync();
                    _clickInterceptCleanup = null;
                }
                _clickInterceptAttached = false;
            }
        }
        catch (InvalidOperationException)
        {
            // Silently fail during prerendering when JS interop is not available.
        }
        catch (JSDisconnectedException)
        {
            // Silently fail when the server circuit has disconnected.
        }
    }

    private async Task HandleClick()
    {
        if (Item != null && IsSelectable)
        {
            // Skip row selection when the click originated from an interactive
            // child element (user-provided button/link/input in a cell template).
            if (_clickInterceptAttached && _tableRowNavModule != null)
            {
                var wasInteractive = await _tableRowNavModule.InvokeAsync<bool>(
                    "consumeInteractiveClickFlag", _elementRef);
                if (wasInteractive) return;
            }

            Context.ToggleRowSelection(Item);
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        // Arrow key navigation only works when keyboard navigation is enabled
        if (IsKeyboardNavigable)
        {
            switch (e.Key)
            {
                case "ArrowUp":
                    await MoveFocusToPreviousRow();
                    return;

                case "ArrowDown":
                    await MoveFocusToNextRow();
                    return;
            }
        }

        // Enter/Space selection works when row is selectable (even without keyboard nav)
        if (IsSelectable && Item != null)
        {
            switch (e.Key)
            {
                case "Enter":
                case " ":
                    Context.ToggleRowSelection(Item);
                    break;
            }
        }
    }

    private async Task MoveFocusToPreviousRow()
    {
        try
        {
            _tableRowNavModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./_content/NeoUI.Blazor.Primitives/js/primitives/table-row-nav.js");
            await _tableRowNavModule.InvokeVoidAsync("moveFocusToPreviousRow", _elementRef);
        }
        catch (InvalidOperationException)
        {
            // Ignore JS interop errors during prerendering.
        }
        catch (JSDisconnectedException)
        {
            // Ignore JS interop errors when the server circuit has disconnected.
        }
    }

    private async Task MoveFocusToNextRow()
    {
        try
        {
            _tableRowNavModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./_content/NeoUI.Blazor.Primitives/js/primitives/table-row-nav.js");
            await _tableRowNavModule.InvokeVoidAsync("moveFocusToNextRow", _elementRef);
        }
        catch (InvalidOperationException)
        {
            // Ignore JS interop errors during prerendering.
        }
        catch (JSDisconnectedException)
        {
            // Ignore JS interop errors when the server circuit has disconnected.
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_spaceKeyCleanup != null)
        {
            try
            {
                await _spaceKeyCleanup.InvokeVoidAsync("dispose");
                await _spaceKeyCleanup.DisposeAsync();
            }
            catch { }
        }

        if (_clickInterceptCleanup != null)
        {
            try
            {
                await _clickInterceptCleanup.InvokeVoidAsync("dispose");
                await _clickInterceptCleanup.DisposeAsync();
            }
            catch { }
        }

        if (_tableRowNavModule != null)
        {
            try { await _tableRowNavModule.DisposeAsync(); }
            catch { }
        }
    }
}
