@namespace NeoUI.Blazor.Primitives
@implements IDisposable

@* NavigationMenuTriggerPrimitive - button that opens the content panel *@
@if (AsChild)
{
    <CascadingValue Value="TriggerContext" Name="TriggerContext">
        @ChildContent
    </CascadingValue>
}
else
{
    <button type="button"
            id="@ItemContext.TriggerId"
            @onclick="HandleClick"
            @onmouseenter="HandleMouseEnter"
            @onmouseleave="HandleMouseLeave"
            @onkeydown="HandleKeyDown"
            @onkeydown:preventDefault="@_shouldPreventDefault"
            @attributes="AdditionalAttributes"
            role="menuitem"
            aria-haspopup="true"
            aria-expanded="@IsActive.ToString().ToLowerInvariant()"
            aria-controls="@ItemContext.ContentId"
            data-state="@(IsActive ? "open" : "closed")">
        @ChildContent
    </button>
}

@code {
    [CascadingParameter]
    private NavigationMenuContext Context { get; set; } = null!;

    [CascadingParameter]
    private NavigationMenuItemContext ItemContext { get; set; } = null!;

    /// <summary>
    /// The child content to render within the trigger.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Additional attributes to apply to the button element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// When true, the trigger does not render its own button element.
    /// Instead, it passes trigger behavior via TriggerContext to child components.
    /// </summary>
    [Parameter]
    public bool AsChild { get; set; } = false;

    private TriggerContext TriggerContext => new()
    {
        TriggerId = ItemContext.TriggerId,
        IsOpen = IsActive,
        Toggle = HandleClick,
        OnMouseEnter = HandleMouseEnter,
        OnMouseLeave = HandleMouseLeave,
        AriaHasPopup = "menu",
        AriaControls = ItemContext.ContentId,
    };

    private bool IsActive => Context?.IsItemActive(ItemContext?.Value ?? string.Empty) ?? false;
    private bool _shouldPreventDefault = false;

    protected override void OnInitialized()
    {
        if (Context == null)
        {
            throw new InvalidOperationException(
                "NavigationMenuTriggerPrimitive must be used within a NavigationMenuRoot component.");
        }

        if (ItemContext == null)
        {
            throw new InvalidOperationException(
                "NavigationMenuTriggerPrimitive must be used within a NavigationMenuItemPrimitive component.");
        }

        Context.OnStateChanged += HandleContextStateChanged;
    }

    private void HandleContextStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void HandleClick()
    {
        if (!IsActive)
        {
            Context.SetActiveItem(ItemContext.Value);
        }
    }

    private void HandleMouseEnter()
    {
        Context.ScheduleOpen(ItemContext.Value);
    }

    private void HandleMouseLeave()
    {
        Context.CancelOpenTimer();
        if (IsActive)
        {
            Context.ScheduleClose();
        }
    }

    private void HandleKeyDown(KeyboardEventArgs args)
    {
        // Prevent default for space key to avoid page scrolling
        _shouldPreventDefault = args.Key == " ";
        
        if (args.Key == "Enter" || args.Key == " ")
        {
            HandleClick();
        }
        else if (args.Key == "ArrowDown" && !IsActive)
        {
            Context.SetActiveItem(ItemContext.Value);
        }
    }

    public void Dispose()
    {
        if (Context != null)
        {
            Context.OnStateChanged -= HandleContextStateChanged;
        }
    }
}
