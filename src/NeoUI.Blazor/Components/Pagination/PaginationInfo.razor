@namespace NeoUI.Blazor
@inject ILocalizer Localizer

<div class="@CssClass">
    @if (Context?.State != null)
    {
        var state = Context.State;
        @if (state.TotalItems > 0)
        {
            <span>@string.Format(EffectiveFormat, state.FirstItemIndex, state.LastItemIndex, state.TotalItems)</span>
        }
        else
        {
            <span>@EffectiveEmptyText</span>
        }
    }
    else
    {
        @ChildContent
    }
</div>

@code {
    [CascadingParameter]
    private PaginationContext? Context { get; set; }

    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// Format string for displaying item range. Use {0} for start, {1} for end, {2} for total.
    /// When null, falls back to the localizer value for "Pagination.ShowingFormat".
    /// </summary>
    [Parameter]
    public string? Format { get; set; }

    /// <summary>
    /// Text to display when there are no items.
    /// When null, falls back to the localizer value for "Pagination.NoItems".
    /// </summary>
    [Parameter]
    public string? EmptyText { get; set; }

    /// <summary>
    /// Custom content to display when not using pagination state.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string EffectiveFormat => Format ?? Localizer["Pagination.ShowingFormat"];
    private string EffectiveEmptyText => EmptyText ?? Localizer["Pagination.NoItems"];

    private string CssClass => ClassNames.cn(
        "flex-1 text-sm text-muted-foreground",
        Class
    );
}
