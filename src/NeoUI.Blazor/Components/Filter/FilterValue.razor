@namespace NeoUI.Blazor.Filter

@* Custom control (EditorType.Custom or when CustomControl RenderFragment is provided) *@
@if (EffectiveEditorType == FilterEditorType.Custom && FieldDefinition?.CustomControl != null)
{
    @FieldDefinition.CustomControl(Condition)
}
else if (!IsValueNotNeeded())
{
    @* ── Text ── *@
    if (EffectiveEditorType == FilterEditorType.Input)
    {
        if (IsBetween)
        {
            <div class="flex items-center gap-1 @(Compact ? "h-full" : "")">
                <NeoUI.Blazor.Input @bind-Value="@TextValue"
                       Placeholder="@(FieldDefinition?.Placeholder ?? "From")"
                       Class="@CompactOrFullInput" />
                <span class="text-xs text-muted-foreground px-1">and</span>
                <NeoUI.Blazor.Input @bind-Value="@SecondaryTextValue"
                       Placeholder="To"
                       Class="@CompactOrFullInput" />
            </div>
        }
        else
        {
            <NeoUI.Blazor.Input @bind-Value="@TextValue"
                   Placeholder="@(FieldDefinition?.Placeholder ?? "Value")"
                   Class="@CompactOrFullInput" />
        }
    }
    @* ── Number (standard HTML number input via Input component) ── *@
    else if (EffectiveEditorType == FilterEditorType.Numeric)
    {
        if (IsBetween)
        {
            <div class="flex items-center gap-1 @(Compact ? "h-full" : "")">
                <NumericInput TValue="decimal?"
                              @bind-Value="@NumericDecimalValue"
                              Placeholder="@(FieldDefinition?.Placeholder ?? "Min")"
                              Min="@FieldDefinition?.Min?.ToString()"
                              Max="@FieldDefinition?.Max?.ToString()"
                              Class="@CompactOrFullInput" />
                <span class="text-xs text-muted-foreground px-1">and</span>
                <NumericInput TValue="decimal?"
                              @bind-Value="@SecondaryNumericDecimalValue"
                              Placeholder="Max"
                              Min="@FieldDefinition?.Min?.ToString()"
                              Max="@FieldDefinition?.Max?.ToString()"
                              Class="@CompactOrFullInput" />
            </div>
        }
        else
        {
            <NumericInput TValue="decimal?"
                          @bind-Value="@NumericDecimalValue"
                          Placeholder="@(FieldDefinition?.Placeholder ?? "Value")"
                          Min="@FieldDefinition?.Min?.ToString()"
                          Max="@FieldDefinition?.Max?.ToString()"
                          Class="@CompactOrFullInput" />
        }
    }
    @* ── Currency ── *@
    else if (EffectiveEditorType == FilterEditorType.Currency)
    {
        if (IsBetween)
        {
            <div class="flex items-center gap-1 @(Compact ? "h-full" : "")">
                <CurrencyInput TValue="decimal?"
                               @bind-Value="@CurrencyDecimalValue"
                               Placeholder="@(FieldDefinition?.Placeholder ?? "Min")"
                               Class="@CompactOrFullInput" />
                <span class="text-xs text-muted-foreground px-1">and</span>
                <CurrencyInput TValue="decimal?"
                               @bind-Value="@SecondaryCurrencyDecimalValue"
                               Placeholder="Max"
                               Class="@CompactOrFullInput" />
            </div>
        }
        else
        {
            <CurrencyInput TValue="decimal?"
                           @bind-Value="@CurrencyDecimalValue"
                           Placeholder="@(FieldDefinition?.Placeholder ?? "Value")"
                           Class="@CompactOrFullInput" />
        }
    }
    @* ── Masked ── *@
    else if (EffectiveEditorType == FilterEditorType.Masked)
    {
        <MaskedInput @bind-Value="@TextValue"
                     Placeholder="@(FieldDefinition?.Placeholder ?? "Value")"
                     Class="@CompactOrFullInput" />
    }
    @* ── Date ── *@
    else if (EffectiveEditorType == FilterEditorType.Date)
    {
        if (IsBetween)
        {
            <div class="flex items-center gap-1 @(Compact ? "h-full" : "")">
                <DatePicker @bind-SelectedDate="@DateValue"
                            Placeholder="Start"
                            ButtonVariant="ButtonVariant.Ghost"
                            ButtonSize="ButtonSize.Small"
                            Class="@(Compact ? "h-full" : "")" />
                <span class="text-xs text-muted-foreground px-1">to</span>
                <DatePicker @bind-SelectedDate="@SecondaryDateValue"
                            Placeholder="End"
                            ButtonVariant="ButtonVariant.Ghost"
                            ButtonSize="ButtonSize.Small"
                            Class="@(Compact ? "h-full" : "")" />
            </div>
        }
        else
        {
            <DatePicker @bind-SelectedDate="@DateValue"
                        Placeholder="@(FieldDefinition?.Placeholder ?? "Pick date")"
                        ButtonVariant="ButtonVariant.Ghost"
                        ButtonSize="ButtonSize.Small"
                        Class="@(Compact ? "h-full" : "")" />
        }
    }
    @* ── DateRange ── *@
    else if (EffectiveEditorType == FilterEditorType.DateRange)
    {
        <DateRangePicker @bind-StartDate="@DateValue"
                         @bind-EndDate="@SecondaryDateValue"
                         ButtonVariant="@(Compact ? ButtonVariant.Ghost : ButtonVariant.Outline)"
                         ButtonSize="ButtonSize.Small"
                         Class="@(Compact ? "h-full" : "")" />
    }
    @* ── Boolean ── *@
    else if (EffectiveEditorType == FilterEditorType.Boolean)
    {
        <Switch @bind-Checked="@BoolValue" />
    }
    @* ── Select (single) ── *@
    else if (EffectiveEditorType == FilterEditorType.Select)
    {
        @if (FieldDefinition?.Options != null && FieldDefinition.Options.Any())
        {
            if (Compact)
            {
                @* Compact: native select styled transparent *@
                <select class="h-full px-2 bg-transparent border-0 outline-none cursor-pointer text-sm"
                        value="@SelectValue"
                        @onchange="HandleSelectChange">
                    @if (string.IsNullOrEmpty(SelectValue))
                    {
                        <option value="" disabled>@(FieldDefinition.Placeholder ?? "Select...")</option>
                    }
                    @foreach (var option in FieldDefinition.Options)
                    {
                        var opt = option;
                        <option value="@opt.Value">@opt.Label</option>
                    }
                </select>
            }
            else
            {
                <Select @bind-Value="@SelectValue" TValue="string">
                    <SelectTrigger>
                        <SelectValue Placeholder="@(FieldDefinition.Placeholder ?? "Select option")" />
                    </SelectTrigger>
                    <SelectContent TValue="string">
                        @foreach (var option in FieldDefinition.Options)
                        {
                            var opt = option;
                            <SelectItem Value="@opt.Value" TValue="string">@opt.Label</SelectItem>
                        }
                    </SelectContent>
                </Select>
            }
        }
        else
        {
            <span class="text-xs text-muted-foreground px-2">No options</span>
        }
    }
    @* ── MultiSelect ── *@
    else if (EffectiveEditorType == FilterEditorType.MultiSelect)
    {
        @if (FieldDefinition?.Options != null && FieldDefinition.Options.Any())
        {
            <MultiSelect TItem="SelectOption"
                         Items="@(FieldDefinition.Options)"
                         @bind-Values="@MultiSelectValues"
                         ValueSelector="@(o => o.Value)"
                         DisplaySelector="@(o => o.Label)"
                         Placeholder="@(FieldDefinition.Placeholder ?? "Select...")"
                         ShowSelectAll="false"
                         MaxDisplayTags="@(Compact ? 1 : 3)"
                         Class="@(Compact ? "border-0 shadow-none rounded-none min-w-[120px]" : "")" />
        }
        else
        {
            <span class="text-xs text-muted-foreground px-2">No options</span>
        }
    }
    @* ── Default fallback (Input) ── *@
    else
    {
        <NeoUI.Blazor.Input @bind-Value="@TextValue"
               Placeholder="@(FieldDefinition?.Placeholder ?? "Value")"
               Class="@CompactOrFullInput" />
    }
}
else
{
    @* Operator is value-less (IsEmpty, IsTrue, etc.) — render nothing *@
}
