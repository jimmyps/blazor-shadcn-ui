@namespace NeoUI.Blazor
@typeparam TData where TData : class
@using NeoUI.Icons.Lucide

<div class="@WrapperCssClass">
    @* Hidden child-content slots — render field/preset definitions, no visible output *@
    <CascadingValue Value="@((IFilterBuilderContext)this)" IsFixed="true">
        @FilterFields
        @FilterPresets
    </CascadingValue>

    <div class="flex flex-wrap items-center gap-2">
        @* ── Add Filter button (opens field-picker dropdown) ── *@
        <DropdownMenu>
            <DropdownMenuTrigger>
                <Button Variant="ButtonVariant.Outline"
                        Size="ButtonSize.Small"
                        Class="h-8 gap-1.5 px-2.5 text-muted-foreground hover:text-foreground"
                        Disabled="@(!_fields.Any())">
                    <LucideIcon Name="list-filter" Size="14" />
                    @if (!_conditions.Any())
                    {
                        <span class="text-sm">@ButtonText</span>
                    }
                </Button>
            </DropdownMenuTrigger>
            <DropdownMenuContent Align="PopoverAlign.Start" Class="w-48">
                @foreach (var field in _fields)
                {
                    var f = field;
                    <DropdownMenuItem OnClick="@((MouseEventArgs _) => AddCondition(f))">
                        @if (!string.IsNullOrEmpty(f.Icon))
                        {
                            <LucideIcon Name="@f.Icon" Size="14" Class="mr-2 opacity-70 shrink-0" />
                        }
                        <span>@f.Label</span>
                    </DropdownMenuItem>
                }
            </DropdownMenuContent>
        </DropdownMenu>

        @* ── Active filter chips ── *@
        @foreach (var condition in _conditions.ToList())
        {
            var cond = condition;
            var fieldDef = _fields.FirstOrDefault(f => f.Field == cond.Field);
            <FilterChip Condition="@cond"
                        FieldDefinition="@fieldDef"
                        ConditionChanged="@HandleConditionChanged"
                        OnRemove="@(() => RemoveCondition(cond))" />
        }

        @* ── Presets dropdown (only when presets are registered) ── *@
        @if (_presets.Any())
        {
            <DropdownMenu>
                <DropdownMenuTrigger>
                    <Button Variant="ButtonVariant.Ghost"
                            Size="ButtonSize.Small"
                            Class="h-8 px-2.5 text-xs text-muted-foreground hover:text-foreground">
                        Presets
                    </Button>
                </DropdownMenuTrigger>
                <DropdownMenuContent Align="PopoverAlign.Start" Class="w-52">
                    @foreach (var preset in _presets)
                    {
                        var p = preset;
                        <DropdownMenuItem OnClick="@((MouseEventArgs _) => ApplyPreset(p))">
                            @if (!string.IsNullOrEmpty(p.Icon))
                            {
                                <LucideIcon Name="@p.Icon" Size="14" Class="mr-2 opacity-70 shrink-0" />
                            }
                            <span>@p.Name</span>
                        </DropdownMenuItem>
                    }
                </DropdownMenuContent>
            </DropdownMenu>
        }

        @* ── Clear all button (only when filters are active) ── *@
        @if (_conditions.Any())
        {
            <Button Variant="ButtonVariant.Outline"
                    Size="ButtonSize.Small"
                    OnClick="@ClearAll"
                    Class="h-8 gap-1.5 px-2.5 text-muted-foreground hover:text-foreground">
                <LucideIcon Name="filter-x" Size="14" />
                <span class="text-sm">Clear</span>
            </Button>
        }
    </div>
</div>
