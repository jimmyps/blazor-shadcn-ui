@namespace NeoUI.Blazor

<div class="@CssClass" @attributes="AdditionalAttributes">
    <p class="text-sm text-muted-foreground">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            <text>No timeline items to display.</text>
        }
    </p>
</div>
