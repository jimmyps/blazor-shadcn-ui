@namespace NeoUI.Blazor

<ol aria-label="@Localizer["Timeline.AriaLabel"]" class="@CssClass" @attributes="AdditionalAttributes">
    <CascadingValue Value="this" IsFixed="true">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            <li class="text-sm text-muted-foreground py-4 text-center">@Localizer["Timeline.NoItems"]</li>
        }
    </CascadingValue>
</ol>
