@namespace NeoUI.Blazor

<ol aria-label="Timeline" class="@CssClass" @attributes="AdditionalAttributes">
    <CascadingValue Value="this" IsFixed="true">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            <li class="text-sm text-muted-foreground py-4 text-center">No timeline items.</li>
        }
    </CascadingValue>
</ol>
