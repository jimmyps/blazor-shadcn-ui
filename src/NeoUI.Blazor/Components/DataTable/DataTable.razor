@namespace NeoUI.Blazor
@typeparam TData where TData : class
@using Microsoft.AspNetCore.Components.Web.Virtualization
<CascadingValue Value="this" IsFixed="true">
    <div class="@ContainerCssClass">
        @if (ShowToolbar)
        {
            <DataTableToolbar TData="TData"
                              GlobalSearchValue="@_globalSearchValue"
                              OnGlobalSearchChanged="HandleGlobalSearchChanged"
                              Columns="@_columns"
                              OnColumnVisibilityChanged="HandleColumnVisibilityChanged"
                              ShowColumnsVisibility="@ColumnsVisibility">
                @ToolbarActions
            </DataTableToolbar>
        }

        <div class="@TableContainerCssClass"
             style="@TableContainerStyle"
             data-pinned-table="@(HasPinnedColumns ? "true" : null)">
            @if (IsLoading)
            {
                @if (LoadingTemplate != null)
                {
                    @LoadingTemplate
                }
                else
                {
                    <div class="flex items-center justify-center p-8 text-muted-foreground">
                        <div class="text-sm">Loading...</div>
                    </div>
                }
            }
            else if (!IsVirtualized && (IsTreeMode ? !_treeRows.Any() : !_processedData.Any()))
            {
                @if (EmptyTemplate != null)
                {
                    @EmptyTemplate
                }
                else
                {
                    <Empty>
                        <EmptyTitle>No results found</EmptyTitle>
                    </Empty>
                }
            }
            else
            {
                <Table TData="TData"
                                                 Data="@_processedData"
                                                 @bind-State="@_tableState"
                                                 SelectionMode="@GetPrimitiveSelectionMode()"
                                                 ManualPagination="true"
                                                 EnableKeyboardNavigation="@EnableKeyboardNavigation"
                                                 OnSortChange="HandleSortChange"
                                                 OnSelectionChange="HandleSelectionChange"
                                                 Class="@TableCssClass"
                                                 style="@TableBorderStyle"
                                                 AriaLabel="@AriaLabel">
                    @if (HasTableFixed)
                    {
                        <colgroup>
                            @if (SelectionMode == DataTableSelectionMode.Multiple)
                            {
                                <col style="width: @(SelectionColumnWidthPx)px" />
                            }
                            @foreach (var col in _columns.Where(c => c.Visible))
                            {
                                <col style="@GetColStyle(col)" />
                            }
                        </colgroup>
                    }
                    <TableHeader Class="@ClassNames.cn(HeaderClass, IsVirtualized ? "sticky top-0 z-10 bg-background" : null)">
                        <TableRow TData="TData" Class="@ComputedHeaderRowClass">
                            @if (SelectionMode == DataTableSelectionMode.Multiple)
                            {
                                <TableHeaderCell TData="TData" Class="@ClassNames.cn(HeaderCellPaddingClass, "text-left align-middle font-medium text-muted-foreground w-12", GetSelectionColumnClass(isHeader: true))" role="columnheader"
                                                 data-pinned="@(HasLeftPinnedColumns ? "true" : null)"
                                                 style="@GetSelectionColumnStyle()">
                                    <div @onclick:stopPropagation="true">
                                        @if (ShouldShowSelectAllPrompt())
                                        {
                                            <DropdownMenu @bind-Open="_selectAllDropdownOpen">
                                                <DropdownMenuTrigger Class="inline-flex items-center justify-center p-0 bg-transparent border-0 hover:bg-transparent focus:outline-none">
                                                    <Checkbox Checked="@IsAllSelected()"
                                                              Indeterminate="@IsSomeSelected()"
                                                              AriaLabel="Select rows - click to see options"
                                                              Class="pointer-events-none" />
                                                </DropdownMenuTrigger>
                                                <DropdownMenuContent Side="PopoverSide.Bottom" Align="PopoverAlign.Start">
                                                    <DropdownMenuItem OnClick="@HandleSelectAllOnCurrentPage">
                                                        Select all on this page (@_processedData.Count() items)
                                                    </DropdownMenuItem>
                                                    <DropdownMenuItem OnClick="@HandleSelectAllItems">
                                                        Select all @GetTotalFilteredItemCount() items
                                                    </DropdownMenuItem>
                                                    @if (_tableState.Selection.HasSelection)
                                                    {
                                                        <DropdownMenuSeparator />
                                                        <DropdownMenuItem OnClick="@HandleClearSelection">
                                                            Clear selection
                                                        </DropdownMenuItem>
                                                    }
                                                </DropdownMenuContent>
                                            </DropdownMenu>
                                        }
                                        else
                                        {
                                            <Checkbox Checked="@IsAllSelected()"
                                                      CheckedChanged="@(async (bool isChecked) => await HandleSelectAllChanged(isChecked))"
                                                      Indeterminate="@IsSomeSelected()"
                                                      AriaLabel="Select all rows" />
                                        }
                                    </div>
                                </TableHeaderCell>
                            }
                            @foreach (var column in _columns.Where(c => c.Visible))
                            {
                                var ariaSortValue = column.Sortable && _tableState.Sorting.SortedColumn == column.Id
                                    ? (_tableState.Sorting.Direction == SortDirection.Ascending ? "ascending" : "descending")
                                    : (column.Sortable ? "none" : null);
                                
                                var alignmentClass = column.Alignment switch
                                {
                                    ColumnAlignment.Center => "text-center",
                                    ColumnAlignment.Right => "text-right",
                                    _ => "text-left"
                                };
                                
                                var flexJustify = column.Alignment switch
                                {
                                    ColumnAlignment.Center => "justify-center",
                                    ColumnAlignment.Right => "justify-end",
                                    _ => ""
                                };

                                <TableHeaderCell TData="TData" ColumnId="@(column.Sortable ? column.Id : null)"
                                                 Class="@ClassNames.cn(HeaderCellPaddingClass, "align-middle font-medium text-muted-foreground", alignmentClass, column.Sortable ? "cursor-pointer select-none" : "", column.HeaderClass, GetPinnedCellClass(column, isHeader: true))"
                                                 style="@GetColumnStyle(column)"
                                                 data-pinned="@(column.Pinned != ColumnPinnedSide.None ? "true" : null)"
                                                 aria-sort="@ariaSortValue">
                                    <div class="@ClassNames.cn("flex items-center gap-2", flexJustify)">
                                        <span>@column.Header</span>
                                        @if (column.Sortable && _tableState.Sorting.SortedColumn == column.Id)
                                        {
                                            @if (_tableState.Sorting.Direction == SortDirection.Ascending)
                                            {
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                                                </svg>
                                            }
                                            else if (_tableState.Sorting.Direction == SortDirection.Descending)
                                            {
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                                </svg>
                                            }
                                        }
                                        else if (column.Sortable)
                                        {
                                            <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" />
                                            </svg>
                                        }
                                    </div>
                                </TableHeaderCell>
                            }
                        </TableRow>
                    </TableHeader>
                    <TableBody>
                        @if (IsVirtualizedServerMode)
                        {
                            <Virtualize @ref="_virtualizeRef"
                                        ItemsProvider="VirtualizeProviderAdapter"
                                        ItemSize="@ItemHeight"
                                        OverscanCount="@VirtualizeOverscanCount"
                                        SpacerElement="tr"
                                        Context="item">
                                <ItemContent>
                                    @{ var isSelectedVS = _tableState.Selection.IsSelected(item); }
                                    <TableRow TData="TData" Item="@item" Class="@GetBodyRowClass(isSelectedVS)" style="@($"height:{ItemHeight}px")">
                                        @RenderRowCells(item, isSelectedVS)
                                    </TableRow>
                                </ItemContent>
                                <Placeholder>
                                    <tr style="height:@(ItemHeight)px">
                                        <td colspan="@VisibleColumnCount" class="@ClassNames.cn(BodyCellPaddingClass, "align-middle")">
                                            <div class="h-3 w-3/4 rounded bg-muted animate-pulse" />
                                        </td>
                                    </tr>
                                </Placeholder>
                            </Virtualize>
                        }
                        else if (Virtualize && !IsTreeMode)
                        {
                            <Virtualize Items="@_virtualizeItems"
                                        ItemSize="@ItemHeight"
                                        OverscanCount="@VirtualizeOverscanCount"
                                        SpacerElement="tr"
                                        Context="item">
                                @{ var isSelectedVC = _tableState.Selection.IsSelected(item); }
                                <TableRow TData="TData" Item="@item" Class="@GetBodyRowClass(isSelectedVC)" style="@($"height:{ItemHeight}px")">
                                    @RenderRowCells(item, isSelectedVC)
                                </TableRow>
                            </Virtualize>
                        }
                        else if (IsTreeMode)
                        {
                            @foreach (var treeRow in _treeRows)
                            {
                                var isSelected = _tableState.Selection.IsSelected(treeRow.Item);
                                <TableRow TData="TData" Item="@treeRow.Item" Class="@GetBodyRowClass(isSelected)">
                                    @RenderTreeRowCells(treeRow, isSelected)
                                </TableRow>
                            }
                        }
                        else
                        {
                            @foreach (var item in _processedData)
                            {
                                var isSelected = _tableState.Selection.IsSelected(item);
                                <TableRow TData="TData" Item="@item" Class="@GetBodyRowClass(isSelected)">
                                    @RenderRowCells(item, isSelected)
                                </TableRow>
                            }
                        }
                    </TableBody>
                </Table>
            }
        </div>

        @if (ShowPagination && !IsLoading && !IsVirtualized && !IsTreeMode && _processedData.Any())
        {
            <Pagination State="@_tableState.Pagination"
                        PageSizes="@PageSizes"
                        OnPageChanged="@HandlePageChanged"
                        OnPageSizeChanged="@HandlePageSizeChanged"
                        Class="flex items-center justify-between px-2 py-4">
                <PaginationInfo />
                <PaginationContent Class="flex items-center gap-6 lg:gap-8">
                    <PaginationPageSizeSelector />
                    <div class="flex items-center gap-2">
                        <PaginationPageDisplay />
                        <div class="flex items-center gap-1">
                            <PaginationItem><PaginationFirst /></PaginationItem>
                            <PaginationItem><PaginationPrevious ShowText="false" /></PaginationItem>
                            <PaginationItem><PaginationNext ShowText="false" /></PaginationItem>
                            <PaginationItem><PaginationLast /></PaginationItem>
                        </div>
                    </div>
                </PaginationContent>
            </Pagination>
        }
    </div>

    @* Capture column definitions *@
    @Columns

</CascadingValue>

@* ── Shared row-cell render fragment ────────────────────────────────────── *@
@* Extracted to avoid duplicating the cell markup across three Virtualize    *@
@* branches while keeping it accessible to the razor template.              *@
@code {
    private RenderFragment RenderRowCells(TData item, bool isSelected) =>
        @<text>
            @if (SelectionMode == DataTableSelectionMode.Multiple)
            {
                <TableCell Class="@ClassNames.cn(BodyCellPaddingClass, "align-middle w-12", GetSelectionColumnClass())"
                           data-pinned="@(HasLeftPinnedColumns ? "true" : null)"
                           style="@GetSelectionColumnStyle()">
                    <div @onclick:stopPropagation="true">
                        <Checkbox Checked="@isSelected"
                                  CheckedChanged="@(async (bool chk) => await HandleRowSelectionChanged(item, chk))"
                                  AriaLabel="Select this row" />
                    </div>
                </TableCell>
            }
            @foreach (var col in _columns.Where(c => c.Visible))
            {
                var cellAlign = col.Alignment switch
                {
                    ColumnAlignment.Center => "text-center",
                    ColumnAlignment.Right  => "text-right",
                    _                      => "text-left"
                };
                <TableCell Class="@ClassNames.cn(BodyCellPaddingClass, "align-middle [&:has([role=checkbox])]:pr-0", cellAlign, col.CellClass, GetPinnedCellClass(col))"
                           data-pinned="@(col.Pinned != ColumnPinnedSide.None ? "true" : null)"
                           style="@GetColumnStyle(col)">
                    @if (col.CellTemplate != null)
                    {
                        @col.CellTemplate(item)
                    }
                    else
                    {
                        @(col.Property(item)?.ToString() ?? "")
                    }
                </TableCell>
            }
        </text>;

    private RenderFragment RenderTreeRowCells(TreeRow treeRow, bool isSelected) =>
        @<text>
            @if (SelectionMode == DataTableSelectionMode.Multiple)
            {
                <TableCell Class="@ClassNames.cn(BodyCellPaddingClass, "align-middle w-12", GetSelectionColumnClass())"
                           data-pinned="@(HasLeftPinnedColumns ? "true" : null)"
                           style="@GetSelectionColumnStyle()">
                    <div @onclick:stopPropagation="true">
                        <Checkbox Checked="@isSelected"
                                  CheckedChanged="@(async (bool chk) => await HandleRowSelectionChanged(treeRow.Item, chk))"
                                  AriaLabel="Select this row" />
                    </div>
                </TableCell>
            }
            @{
                var visibleCols = _columns.Where(c => c.Visible).ToList();
            }
            @for (var colIndex = 0; colIndex < visibleCols.Count; colIndex++)
            {
                var col = visibleCols[colIndex];
                var cellAlign = col.Alignment switch
                {
                    ColumnAlignment.Center => "text-center",
                    ColumnAlignment.Right  => "text-right",
                    _                      => "text-left"
                };
                var isTreeCol = colIndex == 0;
                var depthPad = isTreeCol && treeRow.Depth > 0 ? $"padding-left:{treeRow.Depth * 20 + 16}px" : null;
                var baseStyle = GetColumnStyle(col);
                var cellStyle = depthPad is null ? baseStyle : (baseStyle is null ? depthPad : $"{baseStyle};{depthPad}");
                <TableCell Class="@ClassNames.cn(BodyCellPaddingClass, "align-middle [&:has([role=checkbox])]:pr-0", cellAlign, col.CellClass, GetPinnedCellClass(col))"
                           style="@cellStyle">
                    @if (isTreeCol)
                    {
                        <span class="inline-flex items-center gap-1">
                            @if (treeRow.HasChildren || treeRow.IsLoading)
                            {
                                <button type="button"
                                        @onclick="@(async () => await ToggleExpand(treeRow.Item))"
                                        @onclick:stopPropagation="true"
                                        class="inline-flex items-center justify-center w-5 h-5 rounded-sm hover:bg-accent transition-colors shrink-0"
                                        aria-label="@(treeRow.IsExpanded ? "Collapse" : "Expand")">
                                    @if (treeRow.IsLoading)
                                    {
                                        <svg class="w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                                        </svg>
                                    }
                                    else if (treeRow.IsExpanded)
                                    {
                                        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                        </svg>
                                    }
                                    else
                                    {
                                        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                                        </svg>
                                    }
                                </button>
                            }
                            else
                            {
                                <span class="w-5 h-5 shrink-0 inline-block" />
                            }
                            @if (col.CellTemplate != null)
                            {
                                @col.CellTemplate(treeRow.Item)
                            }
                            else
                            {
                                @(col.Property(treeRow.Item)?.ToString() ?? "")
                            }
                        </span>
                    }
                    else
                    {
                        @if (col.CellTemplate != null)
                        {
                            @col.CellTemplate(treeRow.Item)
                        }
                        else
                        {
                            @(col.Property(treeRow.Item)?.ToString() ?? "")
                        }
                    }
                </TableCell>
            }
        </text>;
}
