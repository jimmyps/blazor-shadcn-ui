@typeparam TValue
@namespace NeoUI.Blazor
<RadioGroupPrimitive TValue="TValue"
    Value="@Value"
    ValueChanged="@HandleValueChanged"
    Disabled="@Disabled"
    Name="@Name"
    Required="@Required"
    AriaLabel="@AriaLabel"
    class="@CssClass"
    aria-invalid="@(IsInvalid ? "true" : null)">
    @ChildContent
</RadioGroupPrimitive>
