@typeparam TValue
@namespace NeoUI.Blazor.RadioGroup
@using NeoUI.Blazor.Primitives.RadioGroup

<NeoUI.Blazor.Primitives.RadioGroup.RadioGroup TValue="TValue"
    Value="@Value"
    ValueChanged="@HandleValueChanged"
    Disabled="@Disabled"
    Name="@Name"
    Required="@Required"
    AriaLabel="@AriaLabel"
    class="@CssClass"
    aria-invalid="@(IsInvalid ? "true" : null)">
    @ChildContent
</NeoUI.Blazor.Primitives.RadioGroup.RadioGroup>
