@namespace NeoUI.Blazor

<button 
    type="button"
    role="@(ParentGroup?.Type == ToggleGroupType.Single ? "radio" : "checkbox")"
    aria-checked="@(IsSelected ? "true" : "false")"
    disabled="@(Disabled || ParentGroup?.Disabled == true)"
    @onclick="OnClickAsync"
    class="@CssClass">
    @ChildContent
</button>
