@namespace NeoUI.Blazor
@typeparam TValue

@* Styled DropdownMenuRadioItem - wrapper with shadcn Tailwind classes *@
<DropdownMenuRadioItemPrimitive TValue="TValue"
                                                        class="@CssClass"
                                                        Disabled="@Disabled"
                                                        Value="@Value"
                                                        CloseOnSelect="@CloseOnSelect">
    <span class="absolute left-2 flex h-3.5 w-3.5 items-center justify-center">
        @if (IsSelectedInternal)
        {
            <svg xmlns="http://www.w3.org/2000/svg"
                 width="8"
                 height="8"
                 viewBox="0 0 8 8"
                 fill="currentColor">
                <circle cx="4" cy="4" r="4" />
            </svg>
        }
    </span>
    <span>@ChildContent</span>
</DropdownMenuRadioItemPrimitive>

@code {
    [CascadingParameter]
    private DropdownMenuRadioGroupContext<TValue>? RadioGroupContext { get; set; }

    [CascadingParameter(Name = "StyleVariant")]
    private StyleVariant _styleVariant { get; set; } = StyleVariant.Default;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public bool Disabled { get; set; } = false;

    [Parameter]
    public TValue? Value { get; set; }

    [Parameter]
    public bool CloseOnSelect { get; set; } = true;

    private bool IsSelectedInternal => RadioGroupContext != null &&
                                       EqualityComparer<TValue?>.Default.Equals(RadioGroupContext.Value, Value);

    private string CssClass => ClassNames.cn(
        "relative flex cursor-default select-none items-center rounded-sm py-1.5 pl-8 pr-2 text-sm outline-none transition-colors",
        "focus:bg-accent focus:text-accent-foreground",
        "hover:bg-accent hover:text-accent-foreground",
        "data-[disabled]:pointer-events-none data-[disabled]:opacity-50",
        _styleVariant.GetClasses("Menu.RadioItem"),
        Class
    );
}
