@namespace NeoUI.Blazor

@if (Title is not null || Description is not null)
{
    @if (Collapsible)
    {
        <div class="rounded-lg border border-border bg-card">
            <Collapsible DefaultOpen="@DefaultExpanded">
                <CollapsibleTrigger AsChild="false" Class="flex w-full items-center gap-3 px-5 py-4 cursor-pointer group hover:bg-muted/40 transition-colors rounded-t-lg">
                    <div class="flex-1 text-left min-w-0">
                        <h3 class="text-sm font-semibold text-foreground leading-tight">@Title</h3>
                        @if (Description is not null)
                        {
                            <p class="text-xs text-muted-foreground mt-0.5">@Description</p>
                        }
                    </div>
                    <LucideIcon Name="chevron-down" Size="16"
                        Class="shrink-0 text-muted-foreground transition-transform duration-200 group-data-[state=open]:rotate-180" />
                </CollapsibleTrigger>
                <CollapsibleContent>
                    <div class="px-5 pb-5 pt-1">
                        <Separator Class="mb-4" />
                        @ChildContent
                    </div>
                </CollapsibleContent>
            </Collapsible>
        </div>
    }
    else
    {
        <div class="space-y-4">
            <div class="mb-2">
                <h3 class="text-lg font-semibold text-foreground leading-tight">@Title</h3>
                @if (Description is not null)
                {
                    <p class="text-sm text-muted-foreground mt-1">@Description</p>
                }
            </div>
            <Separator Class="mb-6" />
            @ChildContent
        </div>
    }
}
else
{
    @ChildContent
}
