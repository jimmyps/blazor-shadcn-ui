@namespace NeoUI.Blazor.Charts
@inherits SeriesBase

<CascadingValue Value="this" IsFixed="true">
    @ChildContent
</CascadingValue>

@code {
    [CascadingParameter] private IHeatmapSeriesParent? Parent { get; set; }

    /// <summary>Gets or sets the property name for the X coordinate (column index or category).</summary>
    [Parameter] public string? XKey { get; set; }
    /// <summary>Gets or sets the property name for the Y coordinate (row index or category).</summary>
    [Parameter] public string? YKey { get; set; }
    /// <summary>Gets or sets the property name for the cell value.</summary>
    [Parameter] public string? ValueKey { get; set; }

    /// <summary>Gets or sets whether data labels are displayed in each cell.</summary>
    [Parameter] public string? LabelColor { get; set; }
    /// <summary>Gets or sets the label font size in pixels.</summary>
    [Parameter] public int? LabelFontSize { get; set; }

    protected override void OnInitialized() => Parent?.RegisterHeatmap(this);
}
