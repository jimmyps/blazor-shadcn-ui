@namespace NeoUI.Blazor

@*
    SidebarPillInset — content wrapper for use inside <SidebarInset> when
    SidebarCollapsedMode.Pill is active.

    Switches between ExpandedClass and CollapsedClass based on sidebar state,
    and must be paired with <SidebarPillFade /> as the sticky top anchor so that
    <main> remains the sole scroll container:

        <SidebarInset>
            <SidebarPillFade />
            <SidebarPillInset>
                ...
            </SidebarPillInset>
        </SidebarInset>

    Override either state's layout via the dedicated parameters:

        <SidebarPillInset ExpandedClass="p-8" CollapsedClass="p-8 pt-0" />
*@

<div class="@GetClasses()" @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [CascadingParameter]
    private SidebarContext? Context { get; set; }

    /// <summary>The content to render.</summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Additional classes merged on top of the expanded-state base (<c>p-6 lg:p-8</c>).
    /// </summary>
    [Parameter]
    public string? ExpandedClass { get; set; }

    /// <summary>
    /// Additional classes merged on top of the collapsed-state base (<c>p-6 lg:p-8 pt-0 lg:pt-0</c>).
    /// </summary>
    [Parameter]
    public string? CollapsedClass { get; set; }

    /// <summary>Additional CSS classes always applied to the wrapper.</summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>Additional HTML attributes applied to the wrapper element.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsPillActive =>
        Context?.CollapsedMode == SidebarCollapsedMode.Pill
        && !Context.Open;

    private string GetClasses() => ClassNames.cn(
        "shrink-0",
        "transition-[padding] duration-500 ease-in-out",
        // On narrow viewports (< 640px), always use collapsed-state padding regardless of
        // Blazor state — mirrors the SidebarPillNav max-sm: CSS override approach.
        // On wider viewports, Blazor state drives the padding transition.
        IsPillActive
            ? ClassNames.cn("p-4 lg:p-4 pt-0 lg:pt-0", CollapsedClass)
            : ClassNames.cn("p-2 lg:p-2 max-sm:pt-0", ExpandedClass),
        Class
    );
}
