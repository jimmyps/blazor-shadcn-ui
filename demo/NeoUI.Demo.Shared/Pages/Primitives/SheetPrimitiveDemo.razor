@page "/primitives/sheet"

<PageTitle>Sheet Primitive - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Sheet Primitive"
        Description="Headless, unstyled sheet primitive with slide-in animations and full accessibility support." />

    <DemoSection
        Title="AsChild Pattern"
        Description="Use AsChild to compose triggers with your own styled elements.">
        <DemoBlock Code="@_asChildCode">
            <div class="grid md:grid-cols-2 gap-6">
                <div class="space-y-3 p-4 border rounded-lg">
                    <h3 class="text-lg font-medium">Without AsChild</h3>
                    <p class="text-sm text-muted-foreground">SheetTriggerPrimitive renders its own button element.</p>
                    <SheetPrimitive>
                        <SheetTriggerPrimitive class="px-3 py-2 border rounded text-sm">Open SheetPrimitive</SheetTriggerPrimitive>
                        <SheetPortal>
                            <SheetOverlay class="fixed inset-0 bg-black/50 z-50" />
                            <SheetContentPrimitive class="fixed right-0 top-0 z-50 h-full w-3/4 sm:max-w-sm bg-background p-6 border-l">
                                <SheetTitlePrimitive class="text-lg font-semibold mb-2">Without AsChild</SheetTitlePrimitive>
                                <SheetDescriptionPrimitive class="text-sm text-muted-foreground mb-4">Trigger rendered its own button element.</SheetDescriptionPrimitive>
                                <SheetClosePrimitive class="px-3 py-2 border rounded text-sm">Close</SheetClosePrimitive>
                            </SheetContentPrimitive>
                        </SheetPortal>
                    </SheetPrimitive>
                </div>
                <div class="space-y-3 p-4 border rounded-lg">
                    <h3 class="text-lg font-medium">With AsChild</h3>
                    <p class="text-sm text-muted-foreground">Button receives click behavior via TriggerContext.</p>
                    <SheetPrimitive>
                        <SheetTriggerPrimitive AsChild>
                            <Button Variant="ButtonVariant.Outline">Open SheetPrimitive</Button>
                        </SheetTriggerPrimitive>
                        <SheetPortal>
                            <SheetOverlay class="fixed inset-0 bg-black/50 z-50" />
                            <SheetContentPrimitive class="fixed right-0 top-0 z-50 h-full w-3/4 sm:max-w-sm bg-background p-6 border-l">
                                <SheetTitlePrimitive class="text-lg font-semibold mb-2">With AsChild</SheetTitlePrimitive>
                                <SheetDescriptionPrimitive class="text-sm text-muted-foreground mb-4">Button component handles the trigger behavior.</SheetDescriptionPrimitive>
                                <SheetClosePrimitive AsChild><Button Variant="ButtonVariant.Secondary">Close</Button></SheetClosePrimitive>
                            </SheetContentPrimitive>
                        </SheetPortal>
                    </SheetPrimitive>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Basic Headless Primitive"
        Description="The primitive provides behavior and accessibility without styling.">
        <DemoBlock Code="@_basicCode">
            <div class="rounded-lg border bg-card p-6 max-w-md">
                <SheetPrimitive>
                    <SheetTriggerPrimitive class="px-3 py-2 border rounded text-sm">Open SheetPrimitive</SheetTriggerPrimitive>
                    <SheetPortal>
                        <SheetOverlay class="fixed inset-0 bg-black/50 z-50" />
                        <SheetContentPrimitive class="fixed right-0 top-0 z-50 h-full w-3/4 sm:max-w-sm bg-background p-6 border-l">
                            <SheetTitlePrimitive class="text-lg font-semibold mb-2">Sheet Title</SheetTitlePrimitive>
                            <SheetDescriptionPrimitive class="text-sm text-muted-foreground mb-4">This is a basic sheet using the unstyled primitive components.</SheetDescriptionPrimitive>
                            <div class="flex justify-end gap-2">
                                <SheetClosePrimitive class="px-3 py-2 border rounded text-sm">Close</SheetClosePrimitive>
                            </div>
                        </SheetContentPrimitive>
                    </SheetPortal>
                </SheetPrimitive>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Different Sides"
        Description="Sheets can slide in from any side: top, right, bottom, or left.">
        <DemoBlock Code="@_sidesCode">
            <div class="flex flex-wrap gap-2">
                <SheetPrimitive Side="SheetSide.Top">
                    <SheetTriggerPrimitive class="px-3 py-2 border rounded text-sm">Top</SheetTriggerPrimitive>
                    <SheetPortal>
                        <SheetOverlay class="fixed inset-0 bg-black/50 z-50" />
                        <SheetContentPrimitive class="fixed top-0 inset-x-0 z-50 border-b bg-background p-6">
                            <SheetTitlePrimitive class="text-lg font-semibold mb-2">Sheet from Top</SheetTitlePrimitive>
                            <SheetDescriptionPrimitive class="text-sm text-muted-foreground">This sheet slides in from the top.</SheetDescriptionPrimitive>
                            <SheetClosePrimitive class="px-3 py-2 border rounded text-sm mt-4">Close</SheetClosePrimitive>
                        </SheetContentPrimitive>
                    </SheetPortal>
                </SheetPrimitive>
                <SheetPrimitive Side="SheetSide.Right">
                    <SheetTriggerPrimitive class="px-3 py-2 border rounded text-sm">Right</SheetTriggerPrimitive>
                    <SheetPortal>
                        <SheetOverlay class="fixed inset-0 bg-black/50 z-50" />
                        <SheetContentPrimitive class="fixed right-0 top-0 z-50 h-full w-3/4 sm:max-w-sm border-l bg-background p-6">
                            <SheetTitlePrimitive class="text-lg font-semibold mb-2">Sheet from Right</SheetTitlePrimitive>
                            <SheetDescriptionPrimitive class="text-sm text-muted-foreground">Right side (default).</SheetDescriptionPrimitive>
                            <SheetClosePrimitive class="px-3 py-2 border rounded text-sm mt-4">Close</SheetClosePrimitive>
                        </SheetContentPrimitive>
                    </SheetPortal>
                </SheetPrimitive>
                <SheetPrimitive Side="SheetSide.Bottom">
                    <SheetTriggerPrimitive class="px-3 py-2 border rounded text-sm">Bottom</SheetTriggerPrimitive>
                    <SheetPortal>
                        <SheetOverlay class="fixed inset-0 bg-black/50 z-50" />
                        <SheetContentPrimitive class="fixed bottom-0 inset-x-0 z-50 border-t bg-background p-6">
                            <SheetTitlePrimitive class="text-lg font-semibold mb-2">Sheet from Bottom</SheetTitlePrimitive>
                            <SheetDescriptionPrimitive class="text-sm text-muted-foreground">This sheet slides in from the bottom.</SheetDescriptionPrimitive>
                            <SheetClosePrimitive class="px-3 py-2 border rounded text-sm mt-4">Close</SheetClosePrimitive>
                        </SheetContentPrimitive>
                    </SheetPortal>
                </SheetPrimitive>
                <SheetPrimitive Side="SheetSide.Left">
                    <SheetTriggerPrimitive class="px-3 py-2 border rounded text-sm">Left</SheetTriggerPrimitive>
                    <SheetPortal>
                        <SheetOverlay class="fixed inset-0 bg-black/50 z-50" />
                        <SheetContentPrimitive class="fixed left-0 top-0 z-50 h-full w-3/4 sm:max-w-sm border-r bg-background p-6">
                            <SheetTitlePrimitive class="text-lg font-semibold mb-2">Sheet from Left</SheetTitlePrimitive>
                            <SheetDescriptionPrimitive class="text-sm text-muted-foreground">This sheet slides in from the left.</SheetDescriptionPrimitive>
                            <SheetClosePrimitive class="px-3 py-2 border rounded text-sm mt-4">Close</SheetClosePrimitive>
                        </SheetContentPrimitive>
                    </SheetPortal>
                </SheetPrimitive>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Controlled State"
        Description="Control the sheet's open state from your component code.">
        <DemoBlock Code="@_controlledCode">
            <div class="space-y-4">
                <div class="flex gap-2">
                    <button @onclick="() => isControlledOpen = true" class="px-3 py-2 border rounded text-sm">Open Sheet</button>
                    <button @onclick="() => isControlledOpen = false" class="px-3 py-2 border rounded text-sm" disabled="@(!isControlledOpen)">Close from Outside</button>
                </div>
                <SheetPrimitive @bind-Open="isControlledOpen">
                    <SheetPortal>
                        <SheetOverlay class="fixed inset-0 bg-black/50 z-50" />
                        <SheetContentPrimitive class="fixed right-0 top-0 z-50 h-full w-3/4 sm:max-w-sm bg-background p-6 border-l">
                            <SheetTitlePrimitive class="text-lg font-semibold mb-2">Controlled Sheet</SheetTitlePrimitive>
                            <SheetDescriptionPrimitive class="text-sm text-muted-foreground mb-4">The "Close from Outside" button demonstrates external state control.</SheetDescriptionPrimitive>
                            <p class="mb-4">Open state: <strong>@isControlledOpen</strong></p>
                            <SheetClosePrimitive class="px-3 py-2 border rounded text-sm">Close</SheetClosePrimitive>
                        </SheetContentPrimitive>
                    </SheetPortal>
                </SheetPrimitive>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_sheetProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private bool isControlledOpen = false;

    private static readonly IReadOnlyList<DemoPropRow> _sheetProps =
    [
        new("Open",          "bool?",                     "—",              "Controls open state (controlled mode). Use with bind-Open."),
        new("OpenChanged",   "EventCallback&lt;bool&gt;", "—",              "Callback invoked when the open state changes."),
        new("DefaultOpen",   "bool",                      "false",          "Initial open state (uncontrolled mode)."),
        new("Side",          "SheetSide",                 "Right",          "Which side the sheet slides in from: Top, Right, Bottom, Left."),
        new("Modal",         "bool",                      "true",           "When true, blocks interaction with the rest of the page."),
        new("AsChild",       "bool (on trigger/close)",   "false",          "Merges trigger/close behavior into the child element."),
        new("CloseOnClick",  "bool (on overlay)",         "true",           "Whether clicking the overlay closes the sheet."),
        new("CloseOnEscape", "bool (on content)",         "true",           "Whether pressing Escape closes the sheet."),
        new("TrapFocus",     "bool (on content)",         "true",           "Whether to trap focus inside the sheet."),
        new("LockScroll",    "bool (on content)",         "true",           "Whether to prevent body scroll when sheet is open."),
    ];

    private const string _asChildCode =
        """
        <!-- Without AsChild -->
        <SheetPrimitive>
            <SheetTriggerPrimitive class="px-3 py-2 border rounded text-sm">Open</SheetTriggerPrimitive>
            <SheetPortal>
                <SheetOverlay class="fixed inset-0 bg-black/50 z-50" />
                <SheetContentPrimitive class="fixed right-0 top-0 z-50 h-full w-3/4 sm:max-w-sm bg-background p-6 border-l">
                    <SheetTitlePrimitive class="...">Title</SheetTitlePrimitive>
                    <SheetClosePrimitive class="...">Close</SheetClosePrimitive>
                </SheetContentPrimitive>
            </SheetPortal>
        </SheetPrimitive>

        <!-- With AsChild -->
        <SheetPrimitive>
            <SheetTriggerPrimitive AsChild>
                <Button Variant="ButtonVariant.Outline">Open</Button>
            </SheetTriggerPrimitive>
            ...
        </SheetPrimitive>
        """;

    private const string _basicCode =
        """
        <SheetPrimitive>
            <SheetTriggerPrimitive class="px-3 py-2 border rounded text-sm">Open</SheetTriggerPrimitive>
            <SheetPortal>
                <SheetOverlay class="fixed inset-0 bg-black/50 z-50" />
                <SheetContentPrimitive class="fixed right-0 top-0 z-50 h-full w-3/4 sm:max-w-sm bg-background p-6 border-l">
                    <SheetTitlePrimitive class="text-lg font-semibold mb-2">Sheet Title</SheetTitlePrimitive>
                    <SheetDescriptionPrimitive class="text-sm text-muted-foreground mb-4">Description here.</SheetDescriptionPrimitive>
                    <SheetClosePrimitive class="px-3 py-2 border rounded text-sm">Close</SheetClosePrimitive>
                </SheetContentPrimitive>
            </SheetPortal>
        </SheetPrimitive>
        """;

    private const string _sidesCode =
        """
        <SheetPrimitive Side="SheetSide.Top">...</SheetPrimitive>
        <SheetPrimitive Side="SheetSide.Right">...</SheetPrimitive>
        <SheetPrimitive Side="SheetSide.Bottom">...</SheetPrimitive>
        <SheetPrimitive Side="SheetSide.Left">...</SheetPrimitive>
        """;

    private const string _controlledCode =
        """
        <SheetPrimitive @bind-Open="isOpen">
            <SheetPortal>
                <SheetOverlay class="fixed inset-0 bg-black/50 z-50" />
                <SheetContentPrimitive class="fixed right-0 top-0 z-50 h-full ...">
                    <SheetTitlePrimitive class="...">Title</SheetTitlePrimitive>
                    <SheetClosePrimitive class="...">Close</SheetClosePrimitive>
                </SheetContentPrimitive>
            </SheetPortal>
        </SheetPrimitive>
        """;
}
