@page "/primitives/collapsible"

<PageTitle>Collapsible Primitive - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Collapsible Primitive"
        Description="Unstyled, accessible primitive component for building custom collapsibles." />

    <DemoSection
        Title="AsChild Pattern"
        Description="Use AsChild to compose triggers with your own styled elements.">
        <DemoBlock Code="@_asChildCode">
            <div class="grid md:grid-cols-2 gap-6">
                <div class="space-y-3 p-4 border rounded-lg">
                    <h3 class="text-lg font-medium">Without AsChild</h3>
                    <p class="text-sm text-muted-foreground">CollapsibleTriggerPrimitive renders its own button element.</p>
                    <CollapsiblePrimitive>
                        <CollapsibleTriggerPrimitive class="h-9 px-3 py-2 border rounded text-sm cursor-pointer">
                            Click to toggle
                        </CollapsibleTriggerPrimitive>
                        <CollapsibleContentPrimitive class="mt-2">
                            Without AsChild - content controlled by the primitive.
                        </CollapsibleContentPrimitive>
                    </CollapsiblePrimitive>
                </div>
                <div class="space-y-3 p-4 border rounded-lg">
                    <h3 class="text-lg font-medium">With AsChild</h3>
                    <p class="text-sm text-muted-foreground">Button receives click behavior via TriggerContext.</p>
                    <CollapsiblePrimitive>
                        <CollapsibleTriggerPrimitive AsChild>
                            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Small">
                                Click to toggle
                                <LucideIcon Name="chevron-down" Size="16" Class="ml-2" />
                            </Button>
                        </CollapsibleTriggerPrimitive>
                        <CollapsibleContentPrimitive class="mt-2">
                            With AsChild - Button handles the trigger behavior.
                        </CollapsibleContentPrimitive>
                    </CollapsiblePrimitive>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Basic Headless Primitive"
        Description="The primitive provides behavior and accessibility without styling.">
        <DemoBlock Code="@_basicCode">
            <div class="rounded-lg border bg-card p-6 max-w-md">
                <CollapsiblePrimitive>
                    <CollapsibleTriggerPrimitive class="cursor-pointer">
                        Click to toggle (unstyled primitive)
                    </CollapsibleTriggerPrimitive>
                    <CollapsibleContentPrimitive class="mt-2">
                        This content is controlled by the headless primitive. Style it however you want!
                    </CollapsibleContentPrimitive>
                </CollapsiblePrimitive>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Controlled State"
        Description="Control the primitive state externally.">
        <DemoBlock Code="@_controlledCode">
            <div class="space-y-4">
                <div class="flex gap-2">
                    <button @onclick="@(() => isPrimitiveOpen = true)" class="px-3 py-2 border rounded text-sm">Open</button>
                    <button @onclick="@(() => isPrimitiveOpen = false)" class="px-3 py-2 border rounded text-sm">Close</button>
                </div>
                <div class="rounded-lg border bg-card p-6 max-w-md">
                    <CollapsiblePrimitive @bind-Open="isPrimitiveOpen">
                        <CollapsibleTriggerPrimitive class="cursor-pointer">
                            Controlled Primitive (State: @(isPrimitiveOpen ? "Open" : "Closed"))
                        </CollapsibleTriggerPrimitive>
                        <CollapsibleContentPrimitive class="mt-2">
                            External buttons control this primitive's state.
                        </CollapsibleContentPrimitive>
                    </CollapsiblePrimitive>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Accessibility"
        Description="aria-expanded, data-state (open|closed), role=&quot;region&quot; with aria-hidden, and disabled attribute are automatically applied." />

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_collapsibleProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private bool isPrimitiveOpen = false;

    private static readonly IReadOnlyList<DemoPropRow> _collapsibleProps =
    [
        new("Open",         "bool",                     "false", "Controls whether the collapsible is expanded. Use with @bind-Open."),
        new("OpenChanged",  "EventCallback&lt;bool&gt;","—",     "Callback invoked when the open state changes."),
        new("Disabled",     "bool",                     "false", "Prevents toggling when true."),
        new("ChildContent", "RenderFragment?",           "—",     "On CollapsibleTriggerPrimitive or CollapsibleContentPrimitive: rendered content."),
        new("AsChild",      "bool",                     "false", "On CollapsibleTriggerPrimitive: merges trigger behavior into child element."),
    ];

    private const string _asChildCode =
        """
        <!-- Without AsChild -->
        <CollapsiblePrimitive>
            <CollapsibleTriggerPrimitive class="h-9 px-3 py-2 border rounded text-sm cursor-pointer">
                Click to toggle
            </CollapsibleTriggerPrimitive>
            <CollapsibleContentPrimitive class="mt-2">Content here.</CollapsibleContentPrimitive>
        </CollapsiblePrimitive>

        <!-- With AsChild -->
        <CollapsiblePrimitive>
            <CollapsibleTriggerPrimitive AsChild>
                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Small">Click to toggle</Button>
            </CollapsibleTriggerPrimitive>
            <CollapsibleContentPrimitive class="mt-2">Content here.</CollapsibleContentPrimitive>
        </CollapsiblePrimitive>
        """;

    private const string _basicCode =
        """
        <CollapsiblePrimitive>
            <CollapsibleTriggerPrimitive class="cursor-pointer">
                Click to toggle (unstyled primitive)
            </CollapsibleTriggerPrimitive>
            <CollapsibleContentPrimitive class="mt-2">
                This content is controlled by the headless primitive.
            </CollapsibleContentPrimitive>
        </CollapsiblePrimitive>
        """;

    private const string _controlledCode =
        """
        <CollapsiblePrimitive @bind-Open="isPrimitiveOpen">
            <CollapsibleTriggerPrimitive class="cursor-pointer">
                Controlled Primitive (State: @(isPrimitiveOpen ? "Open" : "Closed"))
            </CollapsibleTriggerPrimitive>
            <CollapsibleContentPrimitive class="mt-2">
                External buttons control this primitive's state.
            </CollapsibleContentPrimitive>
        </CollapsiblePrimitive>
        """;
}
