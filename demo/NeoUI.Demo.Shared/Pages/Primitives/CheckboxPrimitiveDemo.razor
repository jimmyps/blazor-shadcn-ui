@page "/primitives/checkbox"

<PageTitle>Checkbox Primitive - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Checkbox Primitive"
        Description="Unstyled, accessible primitive component for building custom checkboxes." />

    <DemoSection
        Title="Basic Headless Primitive"
        Description="The primitive provides behavior and accessibility without styling.">
        <DemoBlock Code="@_basicCode">
            <div class="rounded-lg border bg-card p-6 max-w-md">
                <div class="flex items-center gap-3">
                    <CheckboxPrimitive @bind-Checked="basicChecked" Id="basic" class="h-5 w-5 border rounded cursor-pointer flex items-center justify-center">
                        @if (basicChecked)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                        }
                    </CheckboxPrimitive>
                    <label for="basic">Unstyled primitive checkbox</label>
                </div>
                <p class="text-sm text-muted-foreground mt-2">State: <strong>@(basicChecked ? "Checked" : "Unchecked")</strong></p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Controlled State"
        Description="Control the primitive state externally.">
        <DemoBlock Code="@_controlledCode">
            <div class="space-y-4">
                <div class="flex gap-2">
                    <button @onclick="@(() => controlledChecked = true)" class="px-3 py-2 border rounded text-sm">Check</button>
                    <button @onclick="@(() => controlledChecked = false)" class="px-3 py-2 border rounded text-sm">Uncheck</button>
                </div>
                <div class="rounded-lg border bg-card p-6 max-w-md">
                    <div class="flex items-center gap-3">
                        <CheckboxPrimitive @bind-Checked="controlledChecked" Id="controlled" class="h-5 w-5 border rounded cursor-pointer flex items-center justify-center">
                            @if (controlledChecked)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                            }
                        </CheckboxPrimitive>
                        <label for="controlled">Controlled Checkbox (State: @(controlledChecked ? "Checked" : "Unchecked"))</label>
                    </div>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Indeterminate State"
        Description="Useful for &quot;select all&quot; scenarios when only some items are selected.">
        <DemoBlock Code="@_indeterminateCode">
            <div class="rounded-lg border bg-card p-6 max-w-md">
                <div class="space-y-3">
                    <div class="flex items-center gap-3">
                        <CheckboxPrimitive Checked="@allChecked" class="h-5 w-5 border rounded cursor-pointer flex items-center justify-center"
                                           Indeterminate="@indeterminate"
                                           CheckedChanged="@HandleParentChanged"
                                           Id="parent">
                            @if (allChecked)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                            }
                            else if (indeterminate)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                </svg>
                            }
                        </CheckboxPrimitive>
                        <label for="parent" class="font-medium">Select All</label>
                    </div>
                    <div class="ml-6 space-y-2">
                        <div class="flex items-center gap-3">
                            <CheckboxPrimitive Checked="@child1" class="h-5 w-5 border rounded cursor-pointer flex items-center justify-center" CheckedChanged="@(v => { child1 = v; HandleChildChanged(); })" Id="child1">
                                @if (child1)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                }
                            </CheckboxPrimitive>
                            <label for="child1">Option 1</label>
                        </div>
                        <div class="flex items-center gap-3">
                            <CheckboxPrimitive Checked="@child2" class="h-5 w-5 border rounded cursor-pointer flex items-center justify-center" CheckedChanged="@(v => { child2 = v; HandleChildChanged(); })" Id="child2">
                                @if (child2)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                }
                            </CheckboxPrimitive>
                            <label for="child2">Option 2</label>
                        </div>
                        <div class="flex items-center gap-3">
                            <CheckboxPrimitive Checked="@child3" class="h-5 w-5 border rounded cursor-pointer flex items-center justify-center" CheckedChanged="@(v => { child3 = v; HandleChildChanged(); })" Id="child3">
                                @if (child3)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                }
                            </CheckboxPrimitive>
                            <label for="child3">Option 3</label>
                        </div>
                    </div>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Accessibility"
        Description="role=&quot;checkbox&quot;, aria-checked (true/false/mixed), data-state, and disabled attributes are automatically applied." />

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_checkboxProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private bool basicChecked = false;
    private bool controlledChecked = false;

    private bool child1 = true;
    private bool child2 = false;
    private bool child3 = true;
    private bool allChecked = false;
    private bool indeterminate = true;

    protected override void OnInitialized() => UpdateParentState();

    private void HandleChildChanged() => UpdateParentState();

    private void HandleParentChanged(bool value)
    {
        allChecked = value;
        indeterminate = false;
        child1 = value;
        child2 = value;
        child3 = value;
    }

    private void UpdateParentState()
    {
        var checkedCount = (child1 ? 1 : 0) + (child2 ? 1 : 0) + (child3 ? 1 : 0);
        if (checkedCount == 0) { allChecked = false; indeterminate = false; }
        else if (checkedCount == 3) { allChecked = true; indeterminate = false; }
        else { allChecked = false; indeterminate = true; }
    }

    private static readonly IReadOnlyList<DemoPropRow> _checkboxProps =
    [
        new("Checked",              "bool",                     "false", "Whether the checkbox is checked. Use with @bind-Checked."),
        new("CheckedChanged",       "EventCallback&lt;bool&gt;","—",     "Callback invoked when the checked state changes."),
        new("Indeterminate",        "bool",                     "false", "Sets the checkbox to indeterminate state. Sets aria-checked=&quot;mixed&quot;."),
        new("IndeterminateChanged", "EventCallback&lt;bool&gt;","—",     "Callback invoked when the indeterminate state changes."),
        new("Disabled",             "bool",                     "false", "Prevents toggling when true."),
        new("Id",                   "string?",                  "—",     "Unique identifier for label association."),
        new("ChildContent",         "RenderFragment?",          "—",     "Content rendered inside the checkbox (typically a checkmark icon)."),
    ];

    private const string _basicCode =
        """
        <CheckboxPrimitive @bind-Checked="isChecked" Id="basic"
                           class="h-5 w-5 border rounded cursor-pointer flex items-center justify-center">
            @if (isChecked)
            {
                <svg ...><polyline points="20 6 9 17 4 12"></polyline></svg>
            }
        </CheckboxPrimitive>
        <label for="basic">Unstyled primitive checkbox</label>
        """;

    private const string _controlledCode =
        """
        <button @onclick="@(() => controlledChecked = true)">Check</button>
        <button @onclick="@(() => controlledChecked = false)">Uncheck</button>

        <CheckboxPrimitive @bind-Checked="controlledChecked" Id="controlled"
                           class="h-5 w-5 border rounded cursor-pointer flex items-center justify-center">
            @if (controlledChecked) { <svg ...>...</svg> }
        </CheckboxPrimitive>
        """;

    private const string _indeterminateCode =
        """
        <CheckboxPrimitive Checked="@allChecked"
                           Indeterminate="@indeterminate"
                           CheckedChanged="@HandleParentChanged"
                           Id="parent"
                           class="h-5 w-5 border rounded cursor-pointer flex items-center justify-center">
            @if (allChecked) { /* check mark */ }
            else if (indeterminate) { /* minus mark */ }
        </CheckboxPrimitive>
        <label for="parent">Select All</label>

        <CheckboxPrimitive Checked="@child1"
                           CheckedChanged="@(v => { child1 = v; HandleChildChanged(); })"
                           Id="child1"
                           class="h-5 w-5 border rounded cursor-pointer flex items-center justify-center">
            @if (child1) { <svg ...>...</svg> }
        </CheckboxPrimitive>
        <label for="child1">Option 1</label>
        """;
}
