@page "/primitives/dialog"

<PageTitle>Dialog Primitive - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Dialog Primitive"
        Description="Headless, unstyled dialog primitive with full accessibility support." />

    <DemoSection
        Title="AsChild Pattern"
        Description="Use AsChild to compose triggers with your own styled elements.">
        <DemoBlock Code="@_asChildCode">
            <div class="grid md:grid-cols-2 gap-6">
                <div class="space-y-3 p-4 border rounded-lg">
                    <h3 class="text-lg font-medium">Without AsChild</h3>
                    <p class="text-sm text-muted-foreground">DialogTriggerPrimitive renders its own button element.</p>
                    <DialogPrimitive>
                        <DialogTriggerPrimitive class="px-3 py-2 border rounded text-sm">Open Dialog</DialogTriggerPrimitive>
                        <DialogPortal>
                            <DialogOverlay class="fixed inset-0 bg-black/50 z-50" />
                            <DialogContentPrimitive class="fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 bg-background p-6 rounded-lg border max-w-md z-50">
                                <DialogTitlePrimitive class="text-lg font-semibold mb-2">Without AsChild</DialogTitlePrimitive>
                                <DialogDescriptionPrimitive class="text-sm text-muted-foreground mb-4">Trigger rendered its own button element.</DialogDescriptionPrimitive>
                                <DialogClosePrimitive class="px-3 py-2 border rounded text-sm">Close</DialogClosePrimitive>
                            </DialogContentPrimitive>
                        </DialogPortal>
                    </DialogPrimitive>
                </div>
                <div class="space-y-3 p-4 border rounded-lg">
                    <h3 class="text-lg font-medium">With AsChild</h3>
                    <p class="text-sm text-muted-foreground">Button receives click behavior via TriggerContext.</p>
                    <DialogPrimitive>
                        <DialogTriggerPrimitive AsChild>
                            <Button Variant="ButtonVariant.Outline">Open Dialog</Button>
                        </DialogTriggerPrimitive>
                        <DialogPortal>
                            <DialogOverlay class="fixed inset-0 bg-black/50 z-50" />
                            <DialogContentPrimitive class="fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 bg-background p-6 rounded-lg border max-w-md z-50">
                                <DialogTitlePrimitive class="text-lg font-semibold mb-2">With AsChild</DialogTitlePrimitive>
                                <DialogDescriptionPrimitive class="text-sm text-muted-foreground mb-4">Button component handles the trigger behavior.</DialogDescriptionPrimitive>
                                <DialogClosePrimitive AsChild>
                                    <Button Variant="ButtonVariant.Secondary">Close</Button>
                                </DialogClosePrimitive>
                            </DialogContentPrimitive>
                        </DialogPortal>
                    </DialogPrimitive>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Basic Headless Primitive"
        Description="The primitive provides behavior and accessibility without styling.">
        <DemoBlock Code="@_basicCode">
            <div class="rounded-lg border bg-card p-6 max-w-md">
                <DialogPrimitive>
                    <DialogTriggerPrimitive class="px-3 py-2 border rounded text-sm">Open Dialog</DialogTriggerPrimitive>
                    <DialogPortal>
                        <DialogOverlay class="fixed inset-0 bg-black/50 z-50" />
                        <DialogContentPrimitive class="fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 bg-background p-6 rounded-lg border max-w-md z-50">
                            <DialogTitlePrimitive class="text-lg font-semibold mb-2">Dialog Title</DialogTitlePrimitive>
                            <DialogDescriptionPrimitive class="text-sm text-muted-foreground mb-4">
                                This is a basic dialog using the unstyled primitive components.
                            </DialogDescriptionPrimitive>
                            <div class="flex justify-end gap-2">
                                <DialogClosePrimitive class="px-3 py-2 border rounded text-sm">Close</DialogClosePrimitive>
                            </div>
                        </DialogContentPrimitive>
                    </DialogPortal>
                </DialogPrimitive>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Controlled State"
        Description="Control the dialog's open state from your component code.">
        <DemoBlock Code="@_controlledCode">
            <div class="space-y-4">
                <div class="flex gap-2">
                    <button @onclick="() => isControlledOpen = true" class="px-3 py-2 border rounded text-sm">Open Dialog</button>
                    <button @onclick="() => isControlledOpen = false" class="px-3 py-2 border rounded text-sm" disabled="@(!isControlledOpen)">Close from Outside</button>
                </div>
                <DialogPrimitive @bind-Open="isControlledOpen">
                    <DialogPortal>
                        <DialogOverlay class="fixed inset-0 bg-black/50 z-50" />
                        <DialogContentPrimitive class="fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 bg-background p-6 rounded-lg border max-w-md z-50">
                            <DialogTitlePrimitive class="text-lg font-semibold mb-2">Controlled Dialog</DialogTitlePrimitive>
                            <DialogDescriptionPrimitive class="text-sm text-muted-foreground mb-4">
                                This dialog's state is controlled by the parent component.
                            </DialogDescriptionPrimitive>
                            <p class="mb-4">Open state: <strong>@isControlledOpen</strong></p>
                            <DialogClosePrimitive class="px-3 py-2 border rounded text-sm">Close</DialogClosePrimitive>
                        </DialogContentPrimitive>
                    </DialogPortal>
                </DialogPrimitive>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Modal Behavior"
        Description="By default, dialogs are modal. Clicking the overlay or pressing Escape closes the dialog." />

    <DemoSection
        Title="Accessibility"
        Description="role=&quot;dialog&quot;, aria-labelledby, aria-describedby, automatic focus trap and restoration, and body scroll lock are all built in." />

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_dialogProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private bool isControlledOpen = false;

    private static readonly IReadOnlyList<DemoPropRow> _dialogProps =
    [
        new("Open",          "bool?",                    "—",     "Controls whether the dialog is open (controlled mode)."),
        new("OpenChanged",   "EventCallback&lt;bool&gt;","—",     "Callback invoked when the open state changes."),
        new("DefaultOpen",   "bool",                     "false", "Initial open state (uncontrolled mode)."),
        new("Modal",         "bool",                     "true",  "Whether the dialog blocks interaction with the rest of the page."),
        new("CloseOnClick",  "bool",                     "true",  "On DialogOverlay: whether clicking the overlay closes the dialog."),
        new("CloseOnEscape", "bool",                     "true",  "On DialogContentPrimitive: whether pressing Escape closes the dialog."),
        new("TrapFocus",     "bool",                     "true",  "On DialogContentPrimitive: whether to trap focus inside the dialog."),
        new("LockScroll",    "bool",                     "true",  "On DialogContentPrimitive: whether to prevent body scroll when open."),
        new("ChildContent",  "RenderFragment?",           "—",     "Content rendered inside trigger, portal, title, description, or close components."),
    ];

    private const string _asChildCode =
        """
        <!-- Without AsChild -->
        <DialogPrimitive>
            <DialogTriggerPrimitive class="px-3 py-2 border rounded text-sm">Open Dialog</DialogTriggerPrimitive>
            <DialogPortal>...</DialogPortal>
        </DialogPrimitive>

        <!-- With AsChild -->
        <DialogPrimitive>
            <DialogTriggerPrimitive AsChild>
                <Button Variant="ButtonVariant.Outline">Open Dialog</Button>
            </DialogTriggerPrimitive>
            <DialogPortal>...</DialogPortal>
        </DialogPrimitive>
        """;

    private const string _basicCode =
        """
        <DialogPrimitive>
            <DialogTriggerPrimitive class="px-3 py-2 border rounded text-sm">Open Dialog</DialogTriggerPrimitive>
            <DialogPortal>
                <DialogOverlay class="fixed inset-0 bg-black/50 z-50" />
                <DialogContentPrimitive class="fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 bg-background p-6 rounded-lg border max-w-md z-50">
                    <DialogTitlePrimitive class="text-lg font-semibold mb-2">Dialog Title</DialogTitlePrimitive>
                    <DialogDescriptionPrimitive class="text-sm text-muted-foreground mb-4">
                        This is a basic dialog using the unstyled primitive components.
                    </DialogDescriptionPrimitive>
                    <DialogClosePrimitive class="px-3 py-2 border rounded text-sm">Close</DialogClosePrimitive>
                </DialogContentPrimitive>
            </DialogPortal>
        </DialogPrimitive>
        """;

    private const string _controlledCode =
        """
        <DialogPrimitive @bind-Open="isControlledOpen">
            <DialogPortal>
                <DialogOverlay class="fixed inset-0 bg-black/50 z-50" />
                <DialogContentPrimitive class="fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 bg-background p-6 rounded-lg border max-w-md z-50">
                    <DialogTitlePrimitive class="text-lg font-semibold mb-2">Controlled Dialog</DialogTitlePrimitive>
                    <DialogClosePrimitive class="px-3 py-2 border rounded text-sm">Close</DialogClosePrimitive>
                </DialogContentPrimitive>
            </DialogPortal>
        </DialogPrimitive>
        """;
}
