@page "/primitives/dialog"
<PageTitle>Dialog Primitive - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">
    <DemoPageHeader
        Title="Dialog Primitive"
        Description="Headless, unstyled dialog primitive with full accessibility support." />

    <DemoSection Title="AsChild Pattern" Description="Use AsChild to compose triggers with your own styled elements.">
        <DemoBlock Code="@_asChildCode">
            <div class="grid md:grid-cols-2 gap-6">
                <div class="space-y-3 p-4 border rounded-lg">
                    <h3 class="text-lg font-medium">Without AsChild</h3>
                    <p class="text-sm text-muted-foreground">DialogTriggerPrimitive renders its own button element.</p>
                    <DialogPrimitive>
                        <DialogTriggerPrimitive class="px-3 py-2 border rounded text-sm">Open DialogPrimitive</DialogTriggerPrimitive>
                        <DialogPortal>
                            <DialogOverlay class="fixed inset-0 bg-black/50 z-50" />
                            <DialogContentPrimitive class="fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 bg-background p-6 rounded-lg border max-w-md z-50">
                                <DialogTitlePrimitive class="text-lg font-semibold mb-2">Without AsChild</DialogTitlePrimitive>
                                <DialogDescriptionPrimitive class="text-sm text-muted-foreground mb-4">Trigger rendered its own button element.</DialogDescriptionPrimitive>
                                <DialogClosePrimitive class="px-3 py-2 border rounded text-sm">Close</DialogClosePrimitive>
                            </DialogContentPrimitive>
                        </DialogPortal>
                    </DialogPrimitive>
                </div>

                <div class="space-y-3 p-4 border rounded-lg">
                    <h3 class="text-lg font-medium">With AsChild</h3>
                    <p class="text-sm text-muted-foreground">Button receives click behavior via TriggerContext.</p>
                    <DialogPrimitive>
                        <DialogTriggerPrimitive AsChild>
                            <Button Variant="ButtonVariant.Outline">Open DialogPrimitive</Button>
                        </DialogTriggerPrimitive>
                        <DialogPortal>
                            <DialogOverlay class="fixed inset-0 bg-black/50 z-50" />
                            <DialogContentPrimitive class="fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 bg-background p-6 rounded-lg border max-w-md z-50">
                                <DialogTitlePrimitive class="text-lg font-semibold mb-2">With AsChild</DialogTitlePrimitive>
                                <DialogDescriptionPrimitive class="text-sm text-muted-foreground mb-4">Button component handles the trigger behavior.</DialogDescriptionPrimitive>
                                <DialogClosePrimitive AsChild>
                                    <Button Variant="ButtonVariant.Secondary">Close</Button>
                                </DialogClosePrimitive>
                            </DialogContentPrimitive>
                        </DialogPortal>
                    </DialogPrimitive>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="Basic Headless Primitive" Description="The primitive provides behavior and accessibility without styling.">
        <DemoBlock Code="@_basicCode">
            <div class="rounded-lg border bg-card p-6 max-w-md">
                <DialogPrimitive>
                    <DialogTriggerPrimitive class="px-3 py-2 border rounded text-sm">Open DialogPrimitive</DialogTriggerPrimitive>
                    <DialogPortal>
                        <DialogOverlay class="fixed inset-0 bg-black/50 z-50" />
                        <DialogContentPrimitive class="fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 bg-background p-6 rounded-lg border max-w-md z-50">
                            <DialogTitlePrimitive class="text-lg font-semibold mb-2">Dialog Title</DialogTitlePrimitive>
                            <DialogDescriptionPrimitive class="text-sm text-muted-foreground mb-4">This is a basic dialog using the unstyled primitive components.</DialogDescriptionPrimitive>
                            <div class="flex justify-end gap-2">
                                <DialogClosePrimitive class="px-3 py-2 border rounded text-sm">Close</DialogClosePrimitive>
                            </div>
                        </DialogContentPrimitive>
                    </DialogPortal>
                </DialogPrimitive>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="Controlled State" Description="Control the dialog's open state from your component code.">
        <DemoBlock Code="@_controlledCode">
            <div class="space-y-4">
                <div class="flex gap-2">
                    <button @onclick="() => isControlledOpen = true" class="px-3 py-2 border rounded text-sm">Open DialogPrimitive</button>
                    <button @onclick="() => isControlledOpen = false" class="px-3 py-2 border rounded text-sm" disabled="@(!isControlledOpen)">Close from Outside</button>
                </div>

                <div class="rounded-lg border bg-card p-6 max-w-md">
                    <DialogPrimitive @bind-Open="isControlledOpen">
                        <DialogPortal>
                            <DialogOverlay class="fixed inset-0 bg-black/50 z-50" />
                            <DialogContentPrimitive class="fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 bg-background p-6 rounded-lg border max-w-md z-50">
                                <DialogTitlePrimitive class="text-lg font-semibold mb-2">Controlled DialogPrimitive</DialogTitlePrimitive>
                                <DialogDescriptionPrimitive class="text-sm text-muted-foreground mb-4">This dialog's state is controlled by the parent component.</DialogDescriptionPrimitive>
                                <p class="mb-4">Open state: <strong>@isControlledOpen</strong></p>
                                <DialogClosePrimitive class="px-3 py-2 border rounded text-sm">Close</DialogClosePrimitive>
                            </DialogContentPrimitive>
                        </DialogPortal>
                    </DialogPrimitive>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="Modal Behavior" Description="By default, dialogs are modal. Clicking overlay or pressing Escape closes the dialog.">
        <DemoBlock Code="@_modalCode">
            <div class="rounded-lg border bg-card p-6 max-w-md">
                <DialogPrimitive>
                    <DialogTriggerPrimitive class="px-3 py-2 border rounded text-sm">Open Modal DialogPrimitive</DialogTriggerPrimitive>
                    <DialogPortal>
                        <DialogOverlay class="fixed inset-0 bg-black/50 z-50" />
                        <DialogContentPrimitive class="fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 bg-background p-6 rounded-lg border max-w-md z-50">
                            <DialogTitlePrimitive class="text-lg font-semibold mb-2">Modal DialogPrimitive</DialogTitlePrimitive>
                            <DialogDescriptionPrimitive class="text-sm text-muted-foreground mb-4">Try clicking the overlay or pressing Escape to close this dialog.</DialogDescriptionPrimitive>
                            <DialogClosePrimitive class="px-3 py-2 border rounded text-sm">Close</DialogClosePrimitive>
                        </DialogContentPrimitive>
                    </DialogPortal>
                </DialogPrimitive>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="Accessibility Features" Description="Built-in accessibility features following WAI-ARIA design patterns.">
        <Alert Variant="AlertVariant.Success" AccentBorder="true">
            <Icon><LucideIcon Name="circle-check" Class="h-4 w-4" /></Icon>
            <ChildContent>
                <AlertTitle>Included by default</AlertTitle>
                <AlertDescription>
                    <code class="text-xs bg-muted px-1 rounded">role=&quot;dialog&quot;</code>, <code class="text-xs bg-muted px-1 rounded">aria-labelledby</code>, <code class="text-xs bg-muted px-1 rounded">aria-describedby</code>, focus trap, and scroll lock.
                </AlertDescription>
            </ChildContent>
        </Alert>
    </DemoSection>

    <DemoSection Title="Keyboard Shortcuts" Description="Navigate and interact with dialogs using keyboard.">
        <div class="rounded-lg border p-6 space-y-3 bg-muted/50">
            <div class="grid gap-3">
                <div class="flex items-center justify-between"><span class="text-sm font-medium">Open dialog</span><Kbd>Enter / Space</Kbd></div>
                <div class="flex items-center justify-between"><span class="text-sm font-medium">Close dialog</span><Kbd>Escape</Kbd></div>
                <div class="flex items-center justify-between"><span class="text-sm font-medium">Navigate between elements</span><Kbd>Tab</Kbd></div>
            </div>
        </div>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component properties and parameters.">
        <DemoPropsTable Rows="_dialogProps" />
    </DemoSection>

    <DemoSection Title="When to Use Primitives" Description="Choose between primitives and styled components based on your needs.">
        <div class="grid md:grid-cols-2 gap-4">
            <div class="rounded-lg border p-4 space-y-3">
                <h3 class="font-semibold text-primary">Use Dialog Primitive</h3>
                <ul class="space-y-2 text-sm text-muted-foreground">
                    <li class="flex items-start gap-2"><span class="text-green-600 dark:text-green-400">✓</span><span>Building a custom design system</span></li>
                    <li class="flex items-start gap-2"><span class="text-green-600 dark:text-green-400">✓</span><span>Need complete control over styling</span></li>
                    <li class="flex items-start gap-2"><span class="text-green-600 dark:text-green-400">✓</span><span>Want to apply your own CSS framework</span></li>
                    <li class="flex items-start gap-2"><span class="text-green-600 dark:text-green-400">✓</span><span>Creating unique visual designs</span></li>
                </ul>
            </div>
            <div class="rounded-lg border p-4 space-y-3">
                <h3 class="font-semibold text-primary">Use Styled Component</h3>
                <ul class="space-y-2 text-sm text-muted-foreground">
                    <li class="flex items-start gap-2"><span class="text-blue-600 dark:text-blue-400">●</span><span>Want shadcn/ui design out of the box</span></li>
                    <li class="flex items-start gap-2"><span class="text-blue-600 dark:text-blue-400">●</span><span>Need quick implementation</span></li>
                    <li class="flex items-start gap-2"><span class="text-blue-600 dark:text-blue-400">●</span><span>Like the default styling</span></li>
                    <li class="flex items-start gap-2"><span class="text-blue-600 dark:text-blue-400">●</span><span>Prefer convention over configuration</span></li>
                </ul>
            </div>
        </div>
    </DemoSection>

    <DemoPageNav />
</div>

@code {
private bool isControlledOpen = false;
}
