@page "/primitives/tabs"
<div class="space-y-8 max-w-4xl">
    <div>
        <h1 class="text-4xl font-bold">Tabs Primitive</h1>
        <p class="text-xl text-muted-foreground">
            Headless, unstyled tabs primitive with full keyboard navigation and accessibility support.
        </p>
    </div>

    <div class="space-y-6">
        <h2 class="text-2xl font-semibold">Basic Usage</h2>
        <p class="text-sm text-muted-foreground">
            A simple tabs implementation with minimal inline styles. Use arrow keys to navigate between tabs.
        </p>

        <NeoUI.Blazor.Primitives.Tabs DefaultValue="tab1">
            <NeoUI.Blazor.Primitives.TabsList class="flex gap-1 p-1 bg-muted rounded-md w-fit">
                <NeoUI.Blazor.Primitives.TabsTrigger Value="tab1" class="px-4 py-2 border-none bg-transparent cursor-pointer rounded text-sm aria-[selected=true]:bg-background aria-[selected=true]:shadow-sm">
                    Tab 1
                </NeoUI.Blazor.Primitives.TabsTrigger>
                <NeoUI.Blazor.Primitives.TabsTrigger Value="tab2" class="px-4 py-2 border-none bg-transparent cursor-pointer rounded text-sm aria-[selected=true]:bg-background aria-[selected=true]:shadow-sm">
                    Tab 2
                </NeoUI.Blazor.Primitives.TabsTrigger>
                <NeoUI.Blazor.Primitives.TabsTrigger Value="tab3" class="px-4 py-2 border-none bg-transparent cursor-pointer rounded text-sm aria-[selected=true]:bg-background aria-[selected=true]:shadow-sm">
                    Tab 3
                </NeoUI.Blazor.Primitives.TabsTrigger>
            </NeoUI.Blazor.Primitives.TabsList>

            <NeoUI.Blazor.Primitives.TabsContent Value="tab1" class="p-4 mt-2 border border-border rounded-md">
                <h3 class="font-semibold mb-2">Tab 1 Content</h3>
                <p>This is the content for the first tab. Navigate using arrow keys or click to switch tabs.</p>
            </NeoUI.Blazor.Primitives.TabsContent>

            <NeoUI.Blazor.Primitives.TabsContent Value="tab2" class="p-4 mt-2 border border-border rounded-md">
                <h3 class="font-semibold mb-2">Tab 2 Content</h3>
                <p>This is the content for the second tab. The primitive handles all keyboard navigation automatically.</p>
            </NeoUI.Blazor.Primitives.TabsContent>

            <NeoUI.Blazor.Primitives.TabsContent Value="tab3" class="p-4 mt-2 border border-border rounded-md">
                <h3 class="font-semibold mb-2">Tab 3 Content</h3>
                <p>This is the content for the third tab. Press Home/End to jump to first/last tab.</p>
            </NeoUI.Blazor.Primitives.TabsContent>
        </NeoUI.Blazor.Primitives.Tabs>
    </div>

    <div class="space-y-6">
        <h2 class="text-2xl font-semibold">Controlled Tabs</h2>
        <p class="text-sm text-muted-foreground">
            Control the active tab from your component code using @@bind-Value.
        </p>

        <div class="flex gap-2 mb-4">
            <button @onclick='() => controlledValue = "account"'
                    class="inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-9 px-3">
                Show Account
            </button>
            <button @onclick='() => controlledValue = "password"'
                    class="inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-9 px-3">
                Show Password
            </button>
        </div>

        <p class="text-xs text-muted-foreground">Current tab: <strong>@controlledValue</strong></p>

        <NeoUI.Blazor.Primitives.Tabs @bind-Value="controlledValue">
            <NeoUI.Blazor.Primitives.TabsList class="flex gap-1 p-1 bg-muted rounded-md w-fit">
                <NeoUI.Blazor.Primitives.TabsTrigger Value="account" class="px-4 py-2 border-none bg-transparent cursor-pointer rounded text-sm data-[state=active]:bg-background data-[state=active]:shadow-sm">
                    Account
                </NeoUI.Blazor.Primitives.TabsTrigger>
                <NeoUI.Blazor.Primitives.TabsTrigger Value="password" class="px-4 py-2 border-none bg-transparent cursor-pointer rounded text-sm data-[state=active]:bg-background data-[state=active]:shadow-sm">
                    Password
                </NeoUI.Blazor.Primitives.TabsTrigger>
            </NeoUI.Blazor.Primitives.TabsList>

            <NeoUI.Blazor.Primitives.TabsContent Value="account" class="p-4 mt-2 border border-border rounded-md">
                <h3 class="font-semibold mb-2">Account Settings</h3>
                <p>Make changes to your account here.</p>
            </NeoUI.Blazor.Primitives.TabsContent>

            <NeoUI.Blazor.Primitives.TabsContent Value="password" class="p-4 mt-2 border border-border rounded-md">
                <h3 class="font-semibold mb-2">Password Settings</h3>
                <p>Change your password here.</p>
            </NeoUI.Blazor.Primitives.TabsContent>
        </NeoUI.Blazor.Primitives.Tabs>
    </div>

    <div class="space-y-6">
        <h2 class="text-2xl font-semibold">Vertical Tabs</h2>
        <p class="text-sm text-muted-foreground">
            Tabs can be arranged vertically. Use arrow up/down keys to navigate.
        </p>

        <NeoUI.Blazor.Primitives.Tabs DefaultValue="general" Orientation="TabsOrientation.Vertical">
            <div class="flex gap-4">
                <NeoUI.Blazor.Primitives.TabsList class="flex flex-col gap-1 p-1 bg-muted rounded-md w-[150px]">
                    <NeoUI.Blazor.Primitives.TabsTrigger Value="general" class="px-4 py-2 border-none bg-transparent cursor-pointer rounded text-sm text-left data-[state=active]:bg-background data-[state=active]:shadow-sm">
                        General
                    </NeoUI.Blazor.Primitives.TabsTrigger>
                    <NeoUI.Blazor.Primitives.TabsTrigger Value="security" class="px-4 py-2 border-none bg-transparent cursor-pointer rounded text-sm text-left data-[state=active]:bg-background data-[state=active]:shadow-sm">
                        Security
                    </NeoUI.Blazor.Primitives.TabsTrigger>
                    <NeoUI.Blazor.Primitives.TabsTrigger Value="notifications" class="px-4 py-2 border-none bg-transparent cursor-pointer rounded text-sm text-left data-[state=active]:bg-background data-[state=active]:shadow-sm">
                        Notifications
                    </NeoUI.Blazor.Primitives.TabsTrigger>
                </NeoUI.Blazor.Primitives.TabsList>

                <div class="flex-1">
                    <NeoUI.Blazor.Primitives.TabsContent Value="general" class="p-4 border border-border rounded-md">
                        <h3 class="font-semibold mb-2">General Settings</h3>
                        <p>Configure general application settings.</p>
                    </NeoUI.Blazor.Primitives.TabsContent>

                    <NeoUI.Blazor.Primitives.TabsContent Value="security" class="p-4 border border-border rounded-md">
                        <h3 class="font-semibold mb-2">Security Settings</h3>
                        <p>Manage your security preferences.</p>
                    </NeoUI.Blazor.Primitives.TabsContent>

                    <NeoUI.Blazor.Primitives.TabsContent Value="notifications" class="p-4 border border-border rounded-md">
                        <h3 class="font-semibold mb-2">Notification Settings</h3>
                        <p>Control how you receive notifications.</p>
                    </NeoUI.Blazor.Primitives.TabsContent>
                </div>
            </div>
        </NeoUI.Blazor.Primitives.Tabs>
    </div>

    <div class="space-y-6">
        <h2 class="text-2xl font-semibold">Manual Activation Mode</h2>
        <p class="text-sm text-muted-foreground">
            In manual mode, tabs must be clicked or activated with Enter/Space. Arrow keys only move focus.
        </p>

        <NeoUI.Blazor.Primitives.Tabs DefaultValue="overview" ActivationMode="TabsActivationMode.Manual">
            <NeoUI.Blazor.Primitives.TabsList class="flex gap-1 p-1 bg-muted rounded-md w-fit">
                <NeoUI.Blazor.Primitives.TabsTrigger Value="overview" class="px-4 py-2 border-none bg-transparent cursor-pointer rounded text-sm data-[state=active]:bg-background data-[state=active]:shadow-sm">
                    Overview
                </NeoUI.Blazor.Primitives.TabsTrigger>
                <NeoUI.Blazor.Primitives.TabsTrigger Value="analytics" class="px-4 py-2 border-none bg-transparent cursor-pointer rounded text-sm data-[state=active]:bg-background data-[state=active]:shadow-sm">
                    Analytics
                </NeoUI.Blazor.Primitives.TabsTrigger>
                <NeoUI.Blazor.Primitives.TabsTrigger Value="reports" class="px-4 py-2 border-none bg-transparent cursor-pointer rounded text-sm data-[state=active]:bg-background data-[state=active]:shadow-sm">
                    Reports
                </NeoUI.Blazor.Primitives.TabsTrigger>
            </NeoUI.Blazor.Primitives.TabsList>

            <NeoUI.Blazor.Primitives.TabsContent Value="overview" class="p-4 mt-2 border border-border rounded-md">
                <h3 class="font-semibold mb-2">Overview</h3>
                <p>Use arrow keys to move focus, then press Enter or Space to activate a tab.</p>
            </NeoUI.Blazor.Primitives.TabsContent>

            <NeoUI.Blazor.Primitives.TabsContent Value="analytics" class="p-4 mt-2 border border-border rounded-md">
                <h3 class="font-semibold mb-2">Analytics</h3>
                <p>View your analytics data here.</p>
            </NeoUI.Blazor.Primitives.TabsContent>

            <NeoUI.Blazor.Primitives.TabsContent Value="reports" class="p-4 mt-2 border border-border rounded-md">
                <h3 class="font-semibold mb-2">Reports</h3>
                <p>Generate and download reports.</p>
            </NeoUI.Blazor.Primitives.TabsContent>
        </NeoUI.Blazor.Primitives.Tabs>
    </div>

    <div class="space-y-6">
        <h2 class="text-2xl font-semibold">Disabled Tab</h2>
        <p class="text-sm text-muted-foreground">
            Tabs can be disabled. Keyboard navigation will skip over disabled tabs.
        </p>

        <NeoUI.Blazor.Primitives.Tabs DefaultValue="enabled1">
            <NeoUI.Blazor.Primitives.TabsList class="flex gap-1 p-1 bg-muted rounded-md w-fit">
                <NeoUI.Blazor.Primitives.TabsTrigger Value="enabled1" class="px-4 py-2 border-none bg-transparent cursor-pointer rounded text-sm data-[state=active]:bg-background data-[state=active]:shadow-sm">
                    Enabled 1
                </NeoUI.Blazor.Primitives.TabsTrigger>
                <NeoUI.Blazor.Primitives.TabsTrigger Value="disabled" Disabled="true" class="px-4 py-2 border-none bg-transparent cursor-not-allowed rounded text-sm opacity-50">
                    Disabled
                </NeoUI.Blazor.Primitives.TabsTrigger>
                <NeoUI.Blazor.Primitives.TabsTrigger Value="enabled2" class="px-4 py-2 border-none bg-transparent cursor-pointer rounded text-sm data-[state=active]:bg-background data-[state=active]:shadow-sm">
                    Enabled 2
                </NeoUI.Blazor.Primitives.TabsTrigger>
            </NeoUI.Blazor.Primitives.TabsList>

            <NeoUI.Blazor.Primitives.TabsContent Value="enabled1" class="p-4 mt-2 border border-border rounded-md">
                <p>First enabled tab content. Try using arrow keys - they'll skip the disabled tab.</p>
            </NeoUI.Blazor.Primitives.TabsContent>

            <NeoUI.Blazor.Primitives.TabsContent Value="disabled" class="p-4 mt-2 border border-border rounded-md">
                <p>This content won't be shown because the tab is disabled.</p>
            </NeoUI.Blazor.Primitives.TabsContent>

            <NeoUI.Blazor.Primitives.TabsContent Value="enabled2" class="p-4 mt-2 border border-border rounded-md">
                <p>Second enabled tab content.</p>
            </NeoUI.Blazor.Primitives.TabsContent>
        </NeoUI.Blazor.Primitives.Tabs>
    </div>

    <div class="space-y-6">
        <h2 class="text-2xl font-semibold">Accessibility Features</h2>
        <div class="rounded-lg border bg-card text-card-foreground p-4">
            <h3 class="font-semibold mb-2">Keyboard Navigation</h3>
            <ul class="space-y-1 text-sm text-muted-foreground">
                <li><Kbd>Tab</Kbd> - Focus the tab list</li>
                <li><Kbd>Arrow Left/Right</Kbd> - Navigate between tabs (horizontal)</li>
                <li><Kbd>Arrow Up/Down</Kbd> - Navigate between tabs (vertical)</li>
                <li><Kbd>Home</Kbd> - Jump to first tab</li>
                <li><Kbd>End</Kbd> - Jump to last tab</li>
                <li><Kbd>Enter/Space</Kbd> - Activate focused tab (manual mode)</li>
            </ul>

            <h3 class="font-semibold mb-2 mt-4">ARIA Attributes</h3>
            <ul class="space-y-1 text-sm text-muted-foreground">
                <li><code>role="tablist"</code> on the tabs list</li>
                <li><code>role="tab"</code> on each tab trigger</li>
                <li><code>role="tabpanel"</code> on each tab content</li>
                <li><code>aria-selected</code> indicates the active tab</li>
                <li><code>aria-controls</code> links trigger to content panel</li>
                <li><code>aria-labelledby</code> links content to trigger</li>
                <li><code>aria-orientation</code> indicates horizontal or vertical layout</li>
            </ul>
        </div>
    </div>
</div>

@code {
    private string? controlledValue = "account";
}
