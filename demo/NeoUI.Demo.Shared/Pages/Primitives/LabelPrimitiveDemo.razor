@page "/primitives/label"

<PageTitle>Label Primitive - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Label Primitive"
        Description="Headless, unstyled label primitive with full accessibility support." />

    <DemoSection
        Title="Basic Headless Primitive"
        Description="The primitive provides semantic HTML label element without styling.">
        <DemoBlock Code="@_basicCode">
            <div class="rounded-lg border bg-card p-6 max-w-md">
                <div class="space-y-2">
                    <LabelPrimitive For="basic-input" class="text-sm font-medium">Basic label</LabelPrimitive>
                    <input type="text" id="basic-input" placeholder="Click the label to focus" class="w-full px-3 py-2 border border-input rounded-md bg-background" />
                </div>
                <p class="text-sm text-muted-foreground mt-3">Click the label to focus the input field.</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Form Elements"
        Description="Labels work with all form input types.">
        <DemoBlock Code="@_formCode">
            <div class="rounded-lg border bg-card p-6 max-w-md space-y-4">
                <div class="space-y-2">
                    <LabelPrimitive For="text-input" class="block text-sm font-medium">Text Input</LabelPrimitive>
                    <input type="text" id="text-input" class="w-full px-3 py-2 border border-input rounded-md bg-background" placeholder="Enter text" />
                </div>
                <div class="space-y-2">
                    <LabelPrimitive For="select-input" class="block text-sm font-medium">Select Dropdown</LabelPrimitive>
                    <select id="select-input" class="w-full px-3 py-2 border border-input rounded-md bg-background">
                        <option>Option 1</option>
                        <option>Option 2</option>
                        <option>Option 3</option>
                    </select>
                </div>
                <div class="flex items-center gap-2">
                    <input type="checkbox" id="checkbox-input" class="h-4 w-4 border border-input rounded cursor-pointer" />
                    <LabelPrimitive For="checkbox-input" class="text-sm font-medium cursor-pointer">Checkbox Label (clickable)</LabelPrimitive>
                </div>
                <div class="flex items-center gap-2">
                    <input type="radio" id="radio-input" name="radio-group" class="h-4 w-4 border border-input rounded-full cursor-pointer" />
                    <LabelPrimitive For="radio-input" class="text-sm font-medium cursor-pointer">Radio Label (clickable)</LabelPrimitive>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Required Fields"
        Description="Common pattern for showing required fields.">
        <DemoBlock Code="@_requiredCode">
            <div class="rounded-lg border bg-card p-6 max-w-md space-y-4">
                <div class="space-y-2">
                    <LabelPrimitive For="required-input" class="block text-sm font-medium">
                        Username <span class="text-red-500">*</span>
                    </LabelPrimitive>
                    <input type="text" id="required-input" required class="w-full px-3 py-2 border border-input rounded-md bg-background" placeholder="Required field" />
                </div>
                <div class="space-y-2">
                    <LabelPrimitive For="optional-input" class="block text-sm font-medium">
                        Nickname <span class="text-muted-foreground text-xs">(optional)</span>
                    </LabelPrimitive>
                    <input type="text" id="optional-input" class="w-full px-3 py-2 border border-input rounded-md bg-background" placeholder="Optional field" />
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Accessibility"
        Description="Uses native &lt;label&gt; element. The for attribute links the label to the input, clicking the label focuses the associated input, and screen readers announce label text on focus." />

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_labelProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private static readonly IReadOnlyList<DemoPropRow> _labelProps =
    [
        new("For",          "string?",       "—", "The ID of the form element this label is associated with. Maps to the HTML for attribute."),
        new("ChildContent", "RenderFragment?","—", "The label text or content rendered inside the label element."),
    ];

    private const string _basicCode =
        """
        <LabelPrimitive For="basic-input" class="text-sm font-medium">Basic label</LabelPrimitive>
        <input type="text" id="basic-input" placeholder="Click the label to focus" />
        """;

    private const string _formCode =
        """
        <LabelPrimitive For="text-input" class="block text-sm font-medium">Text Input</LabelPrimitive>
        <input type="text" id="text-input" />

        <LabelPrimitive For="select-input" class="block text-sm font-medium">Select Dropdown</LabelPrimitive>
        <select id="select-input">...</select>

        <input type="checkbox" id="checkbox-input" />
        <LabelPrimitive For="checkbox-input" class="text-sm font-medium cursor-pointer">Checkbox Label</LabelPrimitive>
        """;

    private const string _requiredCode =
        """
        <LabelPrimitive For="required-input" class="block text-sm font-medium">
            Username <span class="text-red-500">*</span>
        </LabelPrimitive>
        <input type="text" id="required-input" required />

        <LabelPrimitive For="optional-input" class="block text-sm font-medium">
            Nickname <span class="text-muted-foreground text-xs">(optional)</span>
        </LabelPrimitive>
        <input type="text" id="optional-input" />
        """;
}
