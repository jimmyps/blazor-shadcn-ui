@page "/primitives/radio-group"

<PageTitle>RadioGroup Primitive - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="RadioGroup Primitive"
        Description="Headless, unstyled radio group primitive with full keyboard navigation and accessibility." />

    <DemoSection
        Title="Basic Headless Primitive"
        Description="The primitive provides behavior, accessibility, and arrow key navigation.">
        <DemoBlock Code="@_basicCode">
            <div class="rounded-lg border bg-card p-6 max-w-md">
                <RadioGroupPrimitive @bind-Value="basicValue" AriaLabel="Basic radio group">
                    @foreach (var option in new[] { "Option 1", "Option 2", "Option 3" })
                    {
                        <div class="flex items-center gap-3 mb-2">
                            <RadioGroupItemPrimitive Value="@option" Id="@($"basic-{option}")"
                                                     class="h-4 w-4 rounded-full border-2 border-input cursor-pointer data-[state=checked]:border-primary data-[state=checked]:bg-primary flex items-center justify-center">
                                <span class="h-2 w-2 rounded-full bg-background data-[state=unchecked]:scale-0 transition-transform" data-state="@(basicValue == option ? "checked" : "unchecked")"></span>
                            </RadioGroupItemPrimitive>
                            <label for="@($"basic-{option}")" class="cursor-pointer">@option</label>
                        </div>
                    }
                </RadioGroupPrimitive>
                <p class="text-sm text-muted-foreground mt-3">Selected: @(basicValue ?? "None")</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Controlled State"
        Description="Control the primitive state externally with buttons.">
        <DemoBlock Code="@_controlledCode">
            <div class="space-y-4">
                <div class="flex gap-2">
                    <button @onclick='@(() => controlledValue = "Small")' class="px-3 py-2 border rounded text-sm">Select Small</button>
                    <button @onclick='@(() => controlledValue = "Medium")' class="px-3 py-2 border rounded text-sm">Select Medium</button>
                    <button @onclick='@(() => controlledValue = "Large")' class="px-3 py-2 border rounded text-sm">Select Large</button>
                </div>
                <div class="rounded-lg border bg-card p-6 max-w-md">
                    <RadioGroupPrimitive @bind-Value="controlledValue" AriaLabel="Size selection">
                        @foreach (var size in new[] { "Small", "Medium", "Large" })
                        {
                            <div class="flex items-center gap-3 mb-2">
                                <RadioGroupItemPrimitive Value="@size" Id="@($"size-{size}")"
                                                         class="h-4 w-4 rounded-full border-2 border-input cursor-pointer data-[state=checked]:border-primary data-[state=checked]:bg-primary flex items-center justify-center">
                                    <span class="h-2 w-2 rounded-full bg-background data-[state=unchecked]:scale-0 transition-transform" data-state="@(controlledValue == size ? "checked" : "unchecked")"></span>
                                </RadioGroupItemPrimitive>
                                <label for="@($"size-{size}")" class="cursor-pointer">@size</label>
                            </div>
                        }
                    </RadioGroupPrimitive>
                    <p class="text-sm text-muted-foreground mt-3">Selected size: @(controlledValue ?? "None")</p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Disabled State"
        Description="Disable the entire group or individual items.">
        <DemoBlock Code="@_disabledCode">
            <div class="rounded-lg border bg-card p-6 max-w-md">
                <RadioGroupPrimitive Value="@disabledValue" Disabled="true" AriaLabel="Disabled group" class="space-y-2 opacity-50">
                    @foreach (var opt in new[] { "Option A", "Option B" })
                    {
                        <div class="flex items-center gap-3">
                            <RadioGroupItemPrimitive Value="@opt" Id="@($"disabled-{opt}")"
                                                     class="h-4 w-4 rounded-full border-2 border-input flex items-center justify-center cursor-not-allowed">
                                <span class="h-2 w-2 rounded-full bg-muted"></span>
                            </RadioGroupItemPrimitive>
                            <label for="@($"disabled-{opt}")" class="cursor-not-allowed">@opt</label>
                        </div>
                    }
                </RadioGroupPrimitive>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Accessibility"
        Description="role=&quot;radiogroup&quot; and role=&quot;radio&quot;, aria-checked, aria-disabled, and roving tab index are automatically applied. Arrow keys navigate between options." />

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_radioGroupProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private string? basicValue = "Option 1";
    private string? controlledValue = "Medium";
    private string? navValue = "North";
    private string? disabledValue = "Option A";

    private static readonly IReadOnlyList<DemoPropRow> _radioGroupProps =
    [
        new("Value",        "TValue?",                  "—",     "The currently selected value. Use with @bind-Value."),
        new("ValueChanged", "EventCallback&lt;TValue&gt;","—",   "Callback invoked when the selected value changes."),
        new("Disabled",     "bool",                     "false", "Disables the entire radio group when true."),
        new("AriaLabel",    "string?",                  "—",     "Accessible label for screen readers (on RadioGroupPrimitive)."),
        new("Value (Item)", "TValue",                   "required","On RadioGroupItemPrimitive: the value this item represents."),
        new("Disabled (Item)","bool",                   "false", "On RadioGroupItemPrimitive: disables this individual item."),
    ];

    private const string _basicCode =
        """
        <RadioGroupPrimitive @bind-Value="selectedValue" AriaLabel="Basic radio group">
            <div class="flex items-center gap-3 mb-2">
                <RadioGroupItemPrimitive Value="Option 1" Id="opt1"
                                         class="h-4 w-4 rounded-full border-2 border-input cursor-pointer data-[state=checked]:border-primary">
                    <span class="h-2 w-2 rounded-full bg-background" data-state="@(selectedValue == "Option 1" ? "checked" : "unchecked")"></span>
                </RadioGroupItemPrimitive>
                <label for="opt1">Option 1</label>
            </div>
        </RadioGroupPrimitive>
        """;

    private const string _controlledCode =
        """
        <button @onclick='() => controlledValue = "Small"'>Select Small</button>
        <button @onclick='() => controlledValue = "Medium"'>Select Medium</button>

        <RadioGroupPrimitive @bind-Value="controlledValue" AriaLabel="Size selection">
            <!-- radio items here -->
        </RadioGroupPrimitive>
        """;

    private const string _disabledCode =
        """
        <RadioGroupPrimitive Value="optionA" Disabled="true" AriaLabel="Disabled group" class="opacity-50">
            <RadioGroupItemPrimitive Value="Option A" Id="disabled-a" class="cursor-not-allowed">
                <span class="h-2 w-2 rounded-full bg-muted"></span>
            </RadioGroupItemPrimitive>
            <label for="disabled-a" class="cursor-not-allowed">Option A</label>
        </RadioGroupPrimitive>
        """;
}
