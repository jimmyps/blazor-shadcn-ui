@page "/primitives/switch"

<PageTitle>Switch Primitive - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Switch Primitive"
        Description="Headless, unstyled switch primitive with full accessibility support." />

    <DemoSection
        Title="Basic Headless Primitive"
        Description="The primitive provides behavior and accessibility without styling.">
        <DemoBlock Code="@_basicCode">
            <div class="rounded-lg border bg-card p-6 max-w-md">
                <div class="flex items-center gap-3">
                    <SwitchPrimitive @bind-Checked="basicChecked" Id="basic"
                                     class="relative inline-flex h-6 w-11 shrink-0 cursor-pointer items-center rounded-full border-2 border-input transition-colors data-[state=checked]:bg-primary data-[state=unchecked]:bg-muted">
                        <span class="pointer-events-none block h-5 w-5 rounded-full bg-background shadow-lg ring-0 transition-transform data-[state=checked]:translate-x-5 data-[state=unchecked]:translate-x-0" data-state="@(basicChecked ? "checked" : "unchecked")"></span>
                    </SwitchPrimitive>
                    <label for="basic" class="cursor-pointer">Basic primitive switch</label>
                </div>
                <p class="text-sm text-muted-foreground mt-2">State: @(basicChecked ? "On" : "Off")</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Controlled State"
        Description="Control the primitive state externally with buttons.">
        <DemoBlock Code="@_controlledCode">
            <div class="space-y-4">
                <div class="flex gap-2">
                    <button @onclick="@(() => controlledChecked = true)" class="px-3 py-2 border rounded text-sm">Turn On</button>
                    <button @onclick="@(() => controlledChecked = false)" class="px-3 py-2 border rounded text-sm">Turn Off</button>
                </div>
                <div class="rounded-lg border bg-card p-6 max-w-md">
                    <div class="flex items-center gap-3">
                        <SwitchPrimitive @bind-Checked="controlledChecked" Id="controlled"
                                         class="relative inline-flex h-6 w-11 shrink-0 cursor-pointer items-center rounded-full border-2 border-input transition-colors data-[state=checked]:bg-primary data-[state=unchecked]:bg-muted">
                            <span class="pointer-events-none block h-5 w-5 rounded-full bg-background shadow-lg ring-0 transition-transform data-[state=checked]:translate-x-5 data-[state=unchecked]:translate-x-0" data-state="@(controlledChecked ? "checked" : "unchecked")"></span>
                        </SwitchPrimitive>
                        <label for="controlled" class="cursor-pointer">Controlled Switch (State: @(controlledChecked ? "On" : "Off"))</label>
                    </div>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Disabled State"
        Description="Switches can be disabled to prevent interaction.">
        <DemoBlock Code="@_disabledCode">
            <div class="rounded-lg border bg-card p-6 max-w-md space-y-3">
                <div class="flex items-center gap-3">
                    <SwitchPrimitive Checked="true" Disabled="true" Id="disabled-on"
                                     class="relative inline-flex h-6 w-11 shrink-0 items-center rounded-full border-2 border-input transition-colors data-[state=checked]:bg-primary disabled:opacity-50 disabled:cursor-not-allowed">
                        <span class="pointer-events-none block h-5 w-5 rounded-full bg-background shadow-lg ring-0 transition-transform data-[state=checked]:translate-x-5 data-[state=unchecked]:translate-x-0" data-state="checked"></span>
                    </SwitchPrimitive>
                    <label for="disabled-on" class="opacity-50">Disabled (On)</label>
                </div>
                <div class="flex items-center gap-3">
                    <SwitchPrimitive Checked="false" Disabled="true" Id="disabled-off"
                                     class="relative inline-flex h-6 w-11 shrink-0 items-center rounded-full border-2 border-input transition-colors data-[state=unchecked]:bg-muted disabled:opacity-50 disabled:cursor-not-allowed">
                        <span class="pointer-events-none block h-5 w-5 rounded-full bg-background shadow-lg ring-0 transition-transform data-[state=checked]:translate-x-5 data-[state=unchecked]:translate-x-0" data-state="unchecked"></span>
                    </SwitchPrimitive>
                    <label for="disabled-off" class="opacity-50">Disabled (Off)</label>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_switchProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private bool basicChecked = false;
    private bool controlledChecked = false;

    private static readonly IReadOnlyList<DemoPropRow> _switchProps =
    [
        new("Checked",        "bool",                      "false", "Controls whether the switch is on. Use with bind-Checked for two-way binding."),
        new("CheckedChanged", "EventCallback&lt;bool&gt;", "—",     "Callback invoked when the checked state changes."),
        new("Disabled",       "bool",                      "false", "Prevents toggling when true."),
        new("Id",             "string?",                   "—",     "HTML id attribute forwarded to the button element."),
    ];

    private const string _basicCode =
        """
        <SwitchPrimitive @bind-Checked="isChecked" Id="my-switch"
                         class="relative inline-flex h-6 w-11 cursor-pointer items-center rounded-full border-2 data-[state=checked]:bg-primary data-[state=unchecked]:bg-muted">
            <span class="block h-5 w-5 rounded-full bg-background transition-transform data-[state=checked]:translate-x-5 data-[state=unchecked]:translate-x-0"
                  data-state="@(isChecked ? "checked" : "unchecked")"></span>
        </SwitchPrimitive>
        <label for="my-switch">Toggle</label>
        """;

    private const string _controlledCode =
        """
        <button @onclick="@(() => isChecked = true)">Turn On</button>
        <button @onclick="@(() => isChecked = false)">Turn Off</button>

        <SwitchPrimitive @bind-Checked="isChecked" Id="controlled" class="...">
            <span class="..." data-state="@(isChecked ? "checked" : "unchecked")"></span>
        </SwitchPrimitive>
        """;

    private const string _disabledCode =
        """
        <SwitchPrimitive Checked="true" Disabled="true" class="... disabled:opacity-50 disabled:cursor-not-allowed">
            <span class="..." data-state="checked"></span>
        </SwitchPrimitive>
        """;
}
