@page "/primitives/popover"

<PageTitle>Popover Primitive - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Popover Primitive"
        Description="Headless, unstyled popover primitive with full positioning control." />

    <DemoSection
        Title="AsChild Pattern"
        Description="Use AsChild to compose triggers with your own styled elements.">
        <DemoBlock Code="@_asChildCode">
            <div class="grid md:grid-cols-2 gap-6">
                <div class="space-y-3 p-4 border rounded-lg">
                    <h3 class="text-lg font-medium">Without AsChild</h3>
                    <p class="text-sm text-muted-foreground">PopoverTriggerPrimitive renders its own button element.</p>
                    <PopoverPrimitive>
                        <PopoverTriggerPrimitive class="px-3 py-2 border rounded text-sm cursor-pointer hover:bg-accent">Open Popover</PopoverTriggerPrimitive>
                        <PopoverContentPrimitive class="z-50 w-72 rounded-md border bg-popover p-4 text-popover-foreground shadow-md">
                            <p class="text-sm">Without AsChild content</p>
                        </PopoverContentPrimitive>
                    </PopoverPrimitive>
                </div>
                <div class="space-y-3 p-4 border rounded-lg">
                    <h3 class="text-lg font-medium">With AsChild</h3>
                    <p class="text-sm text-muted-foreground">Button receives click behavior via TriggerContext.</p>
                    <PopoverPrimitive>
                        <PopoverTriggerPrimitive AsChild>
                            <Button Variant="ButtonVariant.Outline">Open Popover</Button>
                        </PopoverTriggerPrimitive>
                        <PopoverContentPrimitive class="z-50 w-72 rounded-md border bg-popover p-4 text-popover-foreground shadow-md">
                            <p class="text-sm">With AsChild content</p>
                        </PopoverContentPrimitive>
                    </PopoverPrimitive>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Basic Headless Primitive"
        Description="The primitive provides behavior and accessibility without styling.">
        <DemoBlock Code="@_basicCode">
            <div class="rounded-lg border bg-card p-6 max-w-md">
                <PopoverPrimitive>
                    <PopoverTriggerPrimitive class="px-3 py-2 border rounded text-sm cursor-pointer hover:bg-accent">Open Popover</PopoverTriggerPrimitive>
                    <PopoverContentPrimitive class="z-50 w-72 rounded-md border bg-popover p-4 text-popover-foreground shadow-md">
                        <div class="space-y-2">
                            <h4 class="font-medium leading-none">Primitive Popover</h4>
                            <p class="text-sm text-muted-foreground">This is a headless popover primitive with basic styling.</p>
                        </div>
                    </PopoverContentPrimitive>
                </PopoverPrimitive>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Controlled State"
        Description="Control the popover's open state from your component code.">
        <DemoBlock Code="@_controlledCode">
            <div class="space-y-4">
                <div class="flex gap-2">
                    <button @onclick="() => isOpen = !isOpen" class="px-3 py-2 border rounded text-sm">Toggle Popover</button>
                    <span class="text-sm text-muted-foreground self-center">State: @(isOpen ? "Open" : "Closed")</span>
                </div>
                <div class="rounded-lg border bg-card p-6 max-w-md">
                    <PopoverPrimitive @bind-Open="isOpen">
                        <PopoverTriggerPrimitive class="px-3 py-2 border rounded text-sm cursor-pointer hover:bg-accent">
                            @(isOpen ? "Close" : "Open") Controlled
                        </PopoverTriggerPrimitive>
                        <PopoverContentPrimitive class="z-50 w-72 rounded-md border bg-popover p-4 text-popover-foreground shadow-md">
                            <p class="text-sm">Controlled by parent state: @isOpen</p>
                            <button @onclick="() => isOpen = false" class="mt-2 text-sm text-primary underline-offset-4 hover:underline">Close from content</button>
                        </PopoverContentPrimitive>
                    </PopoverPrimitive>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Positioning Options"
        Description="Position the popover on different sides of the trigger.">
        <DemoBlock Code="@_positioningCode">
            <div class="rounded-lg border bg-card p-6">
                <div class="flex gap-4">
                    <PopoverPrimitive>
                        <PopoverTriggerPrimitive class="px-3 py-2 border rounded text-sm cursor-pointer hover:bg-accent">Top</PopoverTriggerPrimitive>
                        <PopoverContentPrimitive Side="@PopoverSide.Top" class="z-50 w-64 rounded-md border bg-popover p-4 text-popover-foreground shadow-md"><p class="text-sm">Positioned on top</p></PopoverContentPrimitive>
                    </PopoverPrimitive>
                    <PopoverPrimitive>
                        <PopoverTriggerPrimitive class="px-3 py-2 border rounded text-sm cursor-pointer hover:bg-accent">Right</PopoverTriggerPrimitive>
                        <PopoverContentPrimitive Side="@PopoverSide.Right" class="z-50 w-64 rounded-md border bg-popover p-4 text-popover-foreground shadow-md"><p class="text-sm">Positioned on right</p></PopoverContentPrimitive>
                    </PopoverPrimitive>
                    <PopoverPrimitive>
                        <PopoverTriggerPrimitive class="px-3 py-2 border rounded text-sm cursor-pointer hover:bg-accent">Left</PopoverTriggerPrimitive>
                        <PopoverContentPrimitive Side="@PopoverSide.Left" class="z-50 w-64 rounded-md border bg-popover p-4 text-popover-foreground shadow-md"><p class="text-sm">Positioned on left</p></PopoverContentPrimitive>
                    </PopoverPrimitive>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Accessibility"
        Description="Proper role and aria-expanded are applied. Escape closes the popover, clicking outside closes it, and focus is managed automatically." />

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_popoverProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private bool isOpen = false;

    private static readonly IReadOnlyList<DemoPropRow> _popoverProps =
    [
        new("Open",         "bool?",                    "—",      "Controls whether the popover is open (controlled mode)."),
        new("OpenChanged",  "EventCallback&lt;bool&gt;","—",      "Callback invoked when the open state changes."),
        new("Side",         "PopoverSide",              "Bottom", "On PopoverContentPrimitive: which side to position the content."),
        new("Align",        "PopoverAlign",             "Center", "On PopoverContentPrimitive: how to align the content relative to the trigger."),
        new("AsChild",      "bool",                     "false",  "On PopoverTriggerPrimitive: merges trigger behavior into child element."),
        new("ChildContent", "RenderFragment?",           "—",      "Content rendered inside trigger or content primitives."),
    ];

    private const string _asChildCode =
        """
        <!-- Without AsChild -->
        <PopoverPrimitive>
            <PopoverTriggerPrimitive class="px-3 py-2 border rounded text-sm cursor-pointer">Open Popover</PopoverTriggerPrimitive>
            <PopoverContentPrimitive class="z-50 w-72 rounded-md border bg-popover p-4 shadow-md">Content</PopoverContentPrimitive>
        </PopoverPrimitive>

        <!-- With AsChild -->
        <PopoverPrimitive>
            <PopoverTriggerPrimitive AsChild>
                <Button Variant="ButtonVariant.Outline">Open Popover</Button>
            </PopoverTriggerPrimitive>
            <PopoverContentPrimitive class="z-50 w-72 rounded-md border bg-popover p-4 shadow-md">Content</PopoverContentPrimitive>
        </PopoverPrimitive>
        """;

    private const string _basicCode =
        """
        <PopoverPrimitive>
            <PopoverTriggerPrimitive class="px-3 py-2 border rounded text-sm cursor-pointer hover:bg-accent">Open Popover</PopoverTriggerPrimitive>
            <PopoverContentPrimitive class="z-50 w-72 rounded-md border bg-popover p-4 shadow-md">
                <h4 class="font-medium leading-none">Primitive Popover</h4>
                <p class="text-sm text-muted-foreground">Headless popover with basic styling.</p>
            </PopoverContentPrimitive>
        </PopoverPrimitive>
        """;

    private const string _controlledCode =
        """
        <PopoverPrimitive @bind-Open="isOpen">
            <PopoverTriggerPrimitive class="px-3 py-2 border rounded text-sm cursor-pointer hover:bg-accent">
                @(isOpen ? "Close" : "Open") Controlled
            </PopoverTriggerPrimitive>
            <PopoverContentPrimitive class="z-50 w-72 rounded-md border bg-popover p-4 shadow-md">
                <p class="text-sm">Controlled by parent state: @isOpen</p>
            </PopoverContentPrimitive>
        </PopoverPrimitive>
        """;

    private const string _positioningCode =
        """
        <PopoverPrimitive>
            <PopoverTriggerPrimitive class="px-3 py-2 border rounded text-sm cursor-pointer hover:bg-accent">Top</PopoverTriggerPrimitive>
            <PopoverContentPrimitive Side="@PopoverSide.Top" class="z-50 w-64 rounded-md border bg-popover p-4 shadow-md">Positioned on top</PopoverContentPrimitive>
        </PopoverPrimitive>
        """;
}
