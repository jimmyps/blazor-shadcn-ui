@page "/components/datagrid"
@using NeoUI.Demo.Shared.Pages.Components.Grid

<PageTitle>Data Grid Component - NeoUI</PageTitle>

<div class="space-y-8 max-w-7xl">
    <DemoPageHeader
        Title="Data Grid Component"
        Description="A powerful, renderer-agnostic data grid with support for sorting, filtering, pagination, and virtualization." />

    <Tabs DefaultValue="basic">
        <TabsList Class="flex flex-wrap h-auto w-full gap-1 justify-start">
            <TabsTrigger Value="basic">Basic</TabsTrigger>
            <TabsTrigger Value="templating">Templating</TabsTrigger>
            <TabsTrigger Value="selection">Selection</TabsTrigger>
            <TabsTrigger Value="transactions">Transactions</TabsTrigger>
            <TabsTrigger Value="sorting">Sorting & Filtering</TabsTrigger>
            <TabsTrigger Value="state">State</TabsTrigger>
            <TabsTrigger Value="server-side">Server-Side</TabsTrigger>
            <TabsTrigger Value="advanced">Advanced</TabsTrigger>
            <TabsTrigger Value="theming">Theming</TabsTrigger>
        </TabsList>

        <TabsContent Value="basic" Class="space-y-8">
            <Basic />
        </TabsContent>

        <TabsContent Value="templating" Class="space-y-8">
            <Templating />
        </TabsContent>

        <TabsContent Value="selection" Class="space-y-8">
            <Selection />
        </TabsContent>

        <TabsContent Value="transactions" Class="space-y-8">
            <Transactions />
        </TabsContent>

        <TabsContent Value="sorting" Class="space-y-8">
            <SortingFiltering />
        </TabsContent>

        <TabsContent Value="state" Class="space-y-8">
            <State />
        </TabsContent>

        <TabsContent Value="server-side" Class="space-y-8">
            <ServerSide />
        </TabsContent>

        <TabsContent Value="advanced" Class="space-y-8">
            <Advanced />
        </TabsContent>

        <TabsContent Value="theming" Class="space-y-8">
            <Theming />
        </TabsContent>
    </Tabs>
</div>
