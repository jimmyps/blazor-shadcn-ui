@page "/components/currency-input"
@using System.ComponentModel.DataAnnotations

<PageTitle>Currency Input - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Currency Input"
        Description="A numeric input field for currency values with automatic formatting." />

    <DemoSection
        Title="Default (USD)"
        Description="A currency input formatted as US Dollars.">
        <DemoBlock Code="@_defaultCode">
            <ChildContent>
                <div class="space-y-2 max-w-sm">
                    <Label>Amount (USD)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="usdValue" Currency="USD" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@usdValue</strong></p>
                </div>
            </ChildContent>
            <AdditionalContent>
                <Alert Variant="AlertVariant.Info">
                    <Icon><LucideIcon Name="info" Size="16" /></Icon>
                    <ChildContent>
                        <AlertTitle>Optimized for Performance &amp; Best Typing Experience</AlertTitle>
                        <AlertDescription>
                            <p class="mb-3">
                                By default, CurrencyInput uses <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">UpdateOn="Change"</code> for better performance and UX.
                                The displayed value is automatically formatted based on the <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">Currency</code> and <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">Culture</code> parameters.
                            </p>
                            <Collapsible>
                                <CollapsibleTrigger Class="inline-flex items-center gap-1 text-sm font-normal hover:underline [&_svg]:transition-transform [&_svg]:duration-200 data-[state=open]:[&_svg]:rotate-180">
                                    <span>Read more</span>
                                    <LucideIcon Name="chevron-down" Size="14" />
                                </CollapsibleTrigger>
                                <CollapsibleContent>
                                    <div class="space-y-3 pt-3">
                                        <div>
                                            <p class="font-medium mb-2">Benefits:</p>
                                            <ul class="list-disc list-inside space-y-1 ml-2 text-sm">
                                                <li><strong>Better typing UX:</strong> No interruptions while typing — validation tooltips won't get in your way</li>
                                                <li><strong>Better performance:</strong> Value updates and validation only run when you tab away (blur)</li>
                                                <li><strong>Fewer re-renders:</strong> Your bound value updates once on blur, not on every keystroke</li>
                                            </ul>
                                        </div>
                                        <div>
                                            <p class="font-medium mb-2">UpdateOn Modes:</p>
                                            <div class="grid gap-2 text-sm">
                                                <div>
                                                    <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">UpdateOn="Change"</code>
                                                    <span class="text-muted-foreground ml-2">→ Updates on blur (default, recommended)</span>
                                                </div>
                                                <div>
                                                    <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">UpdateOn="Input"</code>
                                                    <span class="text-muted-foreground ml-2">→ Updates on every keystroke</span>
                                                </div>
                                            </div>
                                        </div>
                                        <p class="text-xs text-muted-foreground flex items-start gap-1.5">
                                            <LucideIcon Name="lightbulb" Size="14" Class="mt-0.5 flex-shrink-0" />
                                            <span><strong>Tip:</strong> Use <code class="px-1 py-0.5 bg-muted rounded">UpdateOn="Input"</code> only when you need real-time updates (e.g., live total calculation, instant feedback), or when targeting WebAssembly where interactivity is fully client-side.</span>
                                        </p>
                                    </div>
                                </CollapsibleContent>
                            </Collapsible>
                        </AlertDescription>
                    </ChildContent>
                </Alert>
            </AdditionalContent>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Different Currencies"
        Description="Support for multiple international currencies.">
        <DemoBlock Code="@_currenciesCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Euro (EUR)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="eurValue" Currency="EUR" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@eurValue</strong></p>
                </div>
                <div class="space-y-2">
                    <Label>British Pound (GBP)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="gbpValue" Currency="GBP" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@gbpValue</strong></p>
                </div>
                <div class="space-y-2">
                    <Label>Japanese Yen (JPY)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="jpyValue" Currency="JPY" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@jpyValue</strong></p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Different Cultures"
        Description="Format values according to regional conventions.">
        <DemoBlock Code="@_culturesCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>English (en-US) — 1,234.56</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="enUsValue" Currency="USD" Culture="en-US" />
                </div>
                <div class="space-y-2">
                    <Label>German (de-DE) — 1.234,56</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="deDeValue" Currency="EUR" Culture="de-DE" />
                </div>
                <div class="space-y-2">
                    <Label>French (fr-FR) — 1 234,56</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="frFrValue" Currency="EUR" Culture="fr-FR" />
                </div>
                <div class="space-y-2">
                    <Label>Brazilian Portuguese (pt-BR) — 1.234,56</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="ptBrValue" Currency="BRL" Culture="pt-BR" />
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="High Precision Values"
        Description="Handle large and precise currency values.">
        <DemoBlock Code="@_precisionCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Large Amount</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="largeValue" Currency="USD" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@largeValue</strong></p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Without Currency Symbol"
        Description="Hide the currency symbol for a cleaner look.">
        <DemoBlock Code="@_noSymbolCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Amount (no symbol)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="noSymbolValue" Currency="USD" ShowCurrencySymbol="false" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@noSymbolValue</strong></p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Double Type"
        Description="Use double instead of decimal for floating-point storage.">
        <DemoBlock Code="@_doubleCode">
            <div class="space-y-2 max-w-sm">
                <Label>Amount (double)</Label>
                <CurrencyInput TValue="double" @bind-Value="doubleValue" Currency="USD" />
                <p class="text-sm text-muted-foreground">Value: <strong>@doubleValue</strong></p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Min/Max Constraints"
        Description="Enforce minimum and maximum allowed values.">
        <DemoBlock Code="@_minMaxCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Budget (0 — 10,000)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="budgetValue" Currency="USD" Min="0" Max="10000" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@budgetValue</strong></p>
                </div>
                <div class="space-y-2">
                    <Label>Temperature (can be negative)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="tempValue" Currency="USD" Min="-999" Max="999" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@tempValue</strong></p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Disabled"
        Description="Input with disabled state.">
        <DemoBlock Code="@_disabledCode">
            <div class="max-w-md">
                <CurrencyInput TValue="decimal" Currency="USD" Placeholder="Disabled input" Disabled="true" Value="99.99m" />
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Readonly"
        Description="Input in readonly mode - focusable but not editable.">
        <DemoBlock Code="@_readonlyCode">
            <div class="max-w-md">
                <CurrencyInput TValue="decimal" Currency="EUR" Value="249.99m" Readonly="true" />
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Required"
        Description="Input with HTML5 required validation.">
        <DemoBlock Code="@_requiredCode">
            <div class="max-w-md">
                <form class="space-y-4">
                    <div class="space-y-2">
                        <label class="text-sm font-medium">Amount (required)</label>
                        <CurrencyInput TValue="decimal?" @bind-Value="requiredValue" Currency="USD" Placeholder="Enter amount" Required="true" />
                    </div>
                    <button type="submit" class="inline-flex items-center justify-center rounded-md text-sm font-medium h-10 px-4 py-2 bg-primary text-primary-foreground hover:bg-primary/90">
                        Submit
                    </button>
                </form>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Error State"
        Description="Input with error visualization using aria-invalid.">
        <DemoBlock Code="@_errorCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <label class="text-sm font-medium">Invalid price</label>
                    <CurrencyInput TValue="decimal" @bind-Value="errorValue" Currency="USD" AriaInvalid="true" Placeholder="This field has an error" />
                    <p class="text-sm text-destructive">
                        Please enter a valid amount. Current: @errorValue
                    </p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Form Validation"
        Description="Integrate with Blazor EditForm and DataAnnotations.">
        <DemoBlock Code="@_validationCode">
            <div class="max-w-sm">
                <EditForm Model="@currencyModel" OnValidSubmit="HandleCurrencySubmit">
                    <DataAnnotationsValidator />
                    <div class="space-y-4">
                        <div class="space-y-2">
                            <Label>Amount <span class="text-destructive">*</span></Label>
                            <CurrencyInput TValue="decimal?" @bind-Value="currencyModel.Amount" Currency="USD" Required="true" />
                            <ValidationMessage For="@(() => currencyModel.Amount)" class="text-sm text-destructive" />
                        </div>
                        <Button Type="ButtonType.Submit">Submit</Button>
                    </div>
                </EditForm>
                @if (currencyFormSubmitted)
                {
                    <p class="mt-4 text-sm text-green-600 font-medium">Submitted! Amount: @currencyModel.Amount</p>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="ARIA Attributes"
        Description="Enhance accessibility with ARIA attributes.">
        <DemoBlock Code="@_ariaCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Total Amount</Label>
                    <CurrencyInput TValue="decimal"
                        @bind-Value="ariaValue"
                        Currency="USD"
                        AriaLabel="Total amount in US dollars"
                        AriaDescribedBy="amount-hint" />
                    <p id="amount-hint" class="text-sm text-muted-foreground">Enter the total amount in USD.</p>
                </div>
                <div class="space-y-2">
                    <Label>Invalid Amount</Label>
                    <CurrencyInput TValue="decimal"
                        @bind-Value="ariaInvalidValue"
                        Currency="USD"
                        AriaInvalid="true"
                        AriaDescribedBy="amount-error" />
                    <p id="amount-error" class="text-sm text-destructive">Amount exceeds the maximum allowed.</p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="International Currencies"
        Description="Examples showcasing 40+ currencies with correct decimal places and Unicode symbols.">
        <DemoBlock Code="@_internationalCode">
            <div class="grid grid-cols-2 gap-4 max-w-3xl">
                <div class="space-y-2">
                    <Label>Canadian Dollar (CAD)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="cadValue" Currency="CAD" />
                    <p class="text-xs text-muted-foreground">2 decimals</p>
                </div>
                <div class="space-y-2">
                    <Label>Australian Dollar (AUD)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="audValue" Currency="AUD" />
                    <p class="text-xs text-muted-foreground">2 decimals</p>
                </div>
                <div class="space-y-2">
                    <Label>Swiss Franc (CHF)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="chfValue" Currency="CHF" />
                    <p class="text-xs text-muted-foreground">2 decimals</p>
                </div>
                <div class="space-y-2">
                    <Label>Chinese Yuan (CNY)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="cnyValue" Currency="CNY" />
                    <p class="text-xs text-muted-foreground">¥ symbol, 2 decimals</p>
                </div>
                <div class="space-y-2">
                    <Label>Indian Rupee (INR)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="inrValue" Currency="INR" />
                    <p class="text-xs text-muted-foreground">₹ symbol, 2 decimals</p>
                </div>
                <div class="space-y-2">
                    <Label>Brazilian Real (BRL)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="brlValue" Currency="BRL" />
                    <p class="text-xs text-muted-foreground">R$ symbol, 2 decimals</p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Special Decimal Places"
        Description="Currencies with 0 decimals (JPY, KRW) and 3 decimals (KWD, BHD, OMR).">
        <DemoBlock Code="@_specialDecimalsCode">
            <div class="grid grid-cols-2 gap-4 max-w-3xl">
                <div class="space-y-2">
                    <Label>Japanese Yen (JPY) — 0 decimals</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="jpySpecialValue" Currency="JPY" />
                    <p class="text-xs text-green-600 dark:text-green-400">✓ <code>¥10000</code> not <code>¥10000.00</code></p>
                </div>
                <div class="space-y-2">
                    <Label>South Korean Won (KRW) — 0 decimals</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="krwValue" Currency="KRW" />
                    <p class="text-xs text-green-600 dark:text-green-400">✓ <code>₩50000</code></p>
                </div>
                <div class="space-y-2">
                    <Label>Kuwaiti Dinar (KWD) — 3 decimals</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="kwdValue" Currency="KWD" />
                    <p class="text-xs text-green-600 dark:text-green-400">✓ Three decimal places</p>
                </div>
                <div class="space-y-2">
                    <Label>Bahraini Dinar (BHD) — 3 decimals</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="bhdValue" Currency="BHD" />
                    <p class="text-xs text-green-600 dark:text-green-400">✓ Three decimal places</p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Symbol Positioning"
        Description="Some currencies like Vietnamese Dong (VND) display the symbol after the amount.">
        <DemoBlock Code="@_symbolPositionCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Vietnamese Dong (VND) — Symbol After</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="vndValue" Currency="VND" />
                    <p class="text-xs text-green-600 dark:text-green-400">✓ Symbol after amount: <code>250000₫</code></p>
                </div>
                <div class="space-y-2">
                    <Label>US Dollar (USD) — Symbol Before</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="usdSymbolValue" Currency="USD" />
                    <p class="text-xs text-muted-foreground">Symbol before amount: <code>$250.00</code></p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Unicode Currency Symbols"
        Description="Proper Unicode symbols for international currencies.">
        <DemoBlock Code="@_unicodeCode">
            <div class="grid grid-cols-2 gap-4 max-w-3xl">
                <div class="space-y-2">
                    <Label>Thai Baht (THB) — ฿</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="thbValue" Currency="THB" />
                </div>
                <div class="space-y-2">
                    <Label>Philippine Peso (PHP) — ₱</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="phpValue" Currency="PHP" />
                </div>
                <div class="space-y-2">
                    <Label>Israeli Shekel (ILS) — ₪</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="ilsValue" Currency="ILS" />
                </div>
                <div class="space-y-2">
                    <Label>Turkish Lira (TRY) — ₺</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="tryValue" Currency="TRY" />
                </div>
                <div class="space-y-2">
                    <Label>Nigerian Naira (NGN) — ₦</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="ngnValue" Currency="NGN" />
                </div>
                <div class="space-y-2">
                    <Label>Russian Ruble (RUB) — ₽</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="rubValue" Currency="RUB" />
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_currencyProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private decimal usdValue = 0m;
    private decimal eurValue = 0m;
    private decimal gbpValue = 0m;
    private decimal jpyValue = 0m;
    private decimal enUsValue = 1234.56m;
    private decimal deDeValue = 1234.56m;
    private decimal frFrValue = 1234.56m;
    private decimal ptBrValue = 1234.56m;
    private decimal largeValue = 1000000.00m;
    private decimal noSymbolValue = 0m;
    private double doubleValue = 0.0;
    private decimal budgetValue = 0m;
    private decimal tempValue = 0m;
    private decimal? requiredValue;
    private decimal ariaValue = 0m;
    private decimal ariaInvalidValue = 0m;
    private bool currencyFormSubmitted = false;

    // New sections
    private decimal errorValue = -10m;
    private decimal cadValue = 120.00m;
    private decimal audValue = 180.00m;
    private decimal chfValue = 95.00m;
    private decimal cnyValue = 750.00m;
    private decimal inrValue = 8500.00m;
    private decimal brlValue = 550.00m;
    private decimal jpySpecialValue = 10000m;
    private decimal krwValue = 50000m;
    private decimal kwdValue = 123.456m;
    private decimal bhdValue = 45.678m;
    private decimal vndValue = 250000m;
    private decimal usdSymbolValue = 250.00m;
    private decimal thbValue = 3500.00m;
    private decimal phpValue = 5500.00m;
    private decimal ilsValue = 385.00m;
    private decimal tryValue = 2850.00m;
    private decimal ngnValue = 45000.00m;
    private decimal rubValue = 9500.00m;

    private CurrencyInputModel currencyModel = new();

    private void HandleCurrencySubmit() => currencyFormSubmitted = true;

    private class CurrencyInputModel
    {
        [Required(ErrorMessage = "Amount is required")]
        [Range(typeof(decimal), "0.01", "1000000", ErrorMessage = "Amount must be between $0.01 and $1,000,000")]
        public decimal? Amount { get; set; }
    }

}
