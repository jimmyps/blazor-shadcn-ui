@page "/components/currency-input"
@using System.ComponentModel.DataAnnotations

<PageTitle>Currency Input - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Currency Input"
        Description="A numeric input field for currency values with automatic formatting." />

    <DemoSection
        Title="Default (USD)"
        Description="A currency input formatted as US Dollars.">
        <DemoBlock Code="@_defaultCode">
            <ChildContent>
                <div class="space-y-2 max-w-sm">
                    <Label>Amount (USD)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="usdValue" Currency="USD" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@usdValue</strong></p>
                </div>
            </ChildContent>
            <AdditionalContent>
                <Alert Variant="AlertVariant.Default">
                    <AlertTitle>
                        <LucideIcon Name="circle-alert" Size="16" Class="mr-2 inline" />
                        @@bind-Value and UpdateOn
                    </AlertTitle>
                    <AlertDescription>
                        When using <code>@@bind-Value</code>, the value is updated on blur (when the input loses focus).
                        The displayed value is automatically formatted based on the <code>Currency</code> and <code>Culture</code> parameters.
                    </AlertDescription>
                </Alert>
            </AdditionalContent>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Different Currencies"
        Description="Support for multiple international currencies.">
        <DemoBlock Code="@_currenciesCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Euro (EUR)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="eurValue" Currency="EUR" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@eurValue</strong></p>
                </div>
                <div class="space-y-2">
                    <Label>British Pound (GBP)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="gbpValue" Currency="GBP" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@gbpValue</strong></p>
                </div>
                <div class="space-y-2">
                    <Label>Japanese Yen (JPY)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="jpyValue" Currency="JPY" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@jpyValue</strong></p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Different Cultures"
        Description="Format values according to regional conventions.">
        <DemoBlock Code="@_culturesCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>English (en-US) — 1,234.56</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="enUsValue" Currency="USD" Culture="en-US" />
                </div>
                <div class="space-y-2">
                    <Label>German (de-DE) — 1.234,56</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="deDeValue" Currency="EUR" Culture="de-DE" />
                </div>
                <div class="space-y-2">
                    <Label>French (fr-FR) — 1 234,56</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="frFrValue" Currency="EUR" Culture="fr-FR" />
                </div>
                <div class="space-y-2">
                    <Label>Brazilian Portuguese (pt-BR) — 1.234,56</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="ptBrValue" Currency="BRL" Culture="pt-BR" />
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="High Precision Values"
        Description="Handle large and precise currency values.">
        <DemoBlock Code="@_precisionCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Large Amount</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="largeValue" Currency="USD" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@largeValue</strong></p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Without Currency Symbol"
        Description="Hide the currency symbol for a cleaner look.">
        <DemoBlock Code="@_noSymbolCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Amount (no symbol)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="noSymbolValue" Currency="USD" ShowCurrencySymbol="false" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@noSymbolValue</strong></p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Double Type"
        Description="Use double instead of decimal for floating-point storage.">
        <DemoBlock Code="@_doubleCode">
            <div class="space-y-2 max-w-sm">
                <Label>Amount (double)</Label>
                <CurrencyInput TValue="double" @bind-Value="doubleValue" Currency="USD" />
                <p class="text-sm text-muted-foreground">Value: <strong>@doubleValue</strong></p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Min/Max Constraints"
        Description="Enforce minimum and maximum allowed values.">
        <DemoBlock Code="@_minMaxCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Budget (0 — 10,000)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="budgetValue" Currency="USD" Min="0" Max="10000" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@budgetValue</strong></p>
                </div>
                <div class="space-y-2">
                    <Label>Temperature (can be negative)</Label>
                    <CurrencyInput TValue="decimal" @bind-Value="tempValue" Currency="USD" Min="-999" Max="999" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@tempValue</strong></p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Disabled / Readonly / Required"
        Description="Input states that affect interaction.">
        <DemoBlock Code="@_statesCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Disabled</Label>
                    <CurrencyInput TValue="decimal" Value="1234.56m" Currency="USD" Disabled="true" />
                </div>
                <div class="space-y-2">
                    <Label>Readonly</Label>
                    <CurrencyInput TValue="decimal" Value="1234.56m" Currency="USD" Readonly="true" />
                </div>
                <div class="space-y-2">
                    <Label>Required <span class="text-destructive">*</span></Label>
                    <CurrencyInput TValue="decimal?" @bind-Value="requiredValue" Currency="USD" Required="true" ShowValidationError="true" />
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Form Validation"
        Description="Integrate with Blazor EditForm and DataAnnotations.">
        <DemoBlock Code="@_validationCode">
            <div class="max-w-sm">
                <EditForm Model="@currencyModel" OnValidSubmit="HandleCurrencySubmit">
                    <DataAnnotationsValidator />
                    <div class="space-y-4">
                        <div class="space-y-2">
                            <Label>Amount <span class="text-destructive">*</span></Label>
                            <CurrencyInput TValue="decimal?" @bind-Value="currencyModel.Amount" Currency="USD" Required="true" />
                            <ValidationMessage For="@(() => currencyModel.Amount)" class="text-sm text-destructive" />
                        </div>
                        <Button Type="ButtonType.Submit">Submit</Button>
                    </div>
                </EditForm>
                @if (currencyFormSubmitted)
                {
                    <p class="mt-4 text-sm text-green-600 font-medium">Submitted! Amount: @currencyModel.Amount</p>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="ARIA Attributes"
        Description="Enhance accessibility with ARIA attributes.">
        <DemoBlock Code="@_ariaCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Total Amount</Label>
                    <CurrencyInput TValue="decimal"
                        @bind-Value="ariaValue"
                        Currency="USD"
                        AriaLabel="Total amount in US dollars"
                        AriaDescribedBy="amount-hint" />
                    <p id="amount-hint" class="text-sm text-muted-foreground">Enter the total amount in USD.</p>
                </div>
                <div class="space-y-2">
                    <Label>Invalid Amount</Label>
                    <CurrencyInput TValue="decimal"
                        @bind-Value="ariaInvalidValue"
                        Currency="USD"
                        AriaInvalid="true"
                        AriaDescribedBy="amount-error" />
                    <p id="amount-error" class="text-sm text-destructive">Amount exceeds the maximum allowed.</p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_currencyProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private decimal usdValue = 0m;
    private decimal eurValue = 0m;
    private decimal gbpValue = 0m;
    private decimal jpyValue = 0m;
    private decimal enUsValue = 1234.56m;
    private decimal deDeValue = 1234.56m;
    private decimal frFrValue = 1234.56m;
    private decimal ptBrValue = 1234.56m;
    private decimal largeValue = 1000000.00m;
    private decimal noSymbolValue = 0m;
    private double doubleValue = 0.0;
    private decimal budgetValue = 0m;
    private decimal tempValue = 0m;
    private decimal? requiredValue;
    private decimal ariaValue = 0m;
    private decimal ariaInvalidValue = 0m;
    private bool currencyFormSubmitted = false;

    private CurrencyInputModel currencyModel = new();

    private void HandleCurrencySubmit() => currencyFormSubmitted = true;

    private class CurrencyInputModel
    {
        [Required(ErrorMessage = "Amount is required")]
        [Range(typeof(decimal), "0.01", "1000000", ErrorMessage = "Amount must be between $0.01 and $1,000,000")]
        public decimal? Amount { get; set; }
    }

    private static readonly IReadOnlyList<DemoPropRow> _currencyProps =
    [
        new("TValue",             "type param",  "—",      "Value type. Options: decimal, decimal?, double, double?."),
        new("Value",              "TValue",       "—",      "Current value. Use @bind-Value for two-way binding."),
        new("Currency",           "string",       "USD",    "ISO 4217 currency code (e.g., USD, EUR, GBP, JPY)."),
        new("Culture",            "string?",      "null",   "Culture for number formatting (e.g., en-US, de-DE, fr-FR)."),
        new("ShowCurrencySymbol", "bool",         "true",   "Whether to show the currency symbol prefix."),
        new("Min",                "TValue?",      "null",   "Minimum allowed value."),
        new("Max",                "TValue?",      "null",   "Maximum allowed value."),
        new("Disabled",           "bool",         "false",  "Disables the input when true."),
        new("Readonly",           "bool",         "false",  "Makes the input read-only when true."),
        new("Required",           "bool",         "false",  "Marks the input as required for native form validation."),
        new("AriaInvalid",        "bool",         "false",  "Marks the input as invalid for screen readers."),
        new("ShowValidationError","bool",         "false",  "Shows browser native validation tooltip on invalid state."),
        new("Placeholder",        "string?",      "null",   "Placeholder text when the input is empty."),
        new("AriaLabel",          "string?",      "null",   "ARIA label for accessibility when no visible label exists."),
        new("AriaDescribedBy",    "string?",      "null",   "ID of the element that describes this input."),
        new("Class",              "string?",      "null",   "Additional CSS classes appended to the input element."),
    ];

    private const string _defaultCode = """
        <CurrencyInput TValue="decimal" @bind-Value="amount" Currency="USD" />

        @code {
            private decimal amount = 0m;
        }
        """;

    private const string _currenciesCode = """
        <CurrencyInput TValue="decimal" @bind-Value="eurValue" Currency="EUR" />
        <CurrencyInput TValue="decimal" @bind-Value="gbpValue" Currency="GBP" />
        <CurrencyInput TValue="decimal" @bind-Value="jpyValue" Currency="JPY" />
        """;

    private const string _culturesCode = """
        <!-- 1,234.56 (en-US) -->
        <CurrencyInput TValue="decimal" @bind-Value="value" Currency="USD" Culture="en-US" />

        <!-- 1.234,56 (de-DE) -->
        <CurrencyInput TValue="decimal" @bind-Value="value" Currency="EUR" Culture="de-DE" />

        <!-- 1 234,56 (fr-FR) -->
        <CurrencyInput TValue="decimal" @bind-Value="value" Currency="EUR" Culture="fr-FR" />
        """;

    private const string _precisionCode = """
        <CurrencyInput TValue="decimal" @bind-Value="largeValue" Currency="USD" />
        """;

    private const string _noSymbolCode = """
        <CurrencyInput TValue="decimal" @bind-Value="value" Currency="USD" ShowCurrencySymbol="false" />
        """;

    private const string _doubleCode = """
        <CurrencyInput TValue="double" @bind-Value="doubleValue" Currency="USD" />
        """;

    private const string _minMaxCode = """
        <CurrencyInput TValue="decimal" @bind-Value="budget" Currency="USD" Min="0" Max="10000" />
        """;

    private const string _statesCode = """
        <CurrencyInput TValue="decimal" Value="1234.56m" Currency="USD" Disabled="true" />
        <CurrencyInput TValue="decimal" Value="1234.56m" Currency="USD" Readonly="true" />
        <CurrencyInput TValue="decimal?" @bind-Value="required" Currency="USD" Required="true" ShowValidationError="true" />
        """;

    private const string _validationCode = """
        <EditForm Model="@model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <CurrencyInput TValue="decimal?" @bind-Value="model.Amount" Currency="USD" Required="true" />
            <ValidationMessage For="@(() => model.Amount)" class="text-sm text-destructive" />
        </EditForm>
        """;

    private const string _ariaCode = """
        <CurrencyInput TValue="decimal"
            @bind-Value="value"
            Currency="USD"
            AriaLabel="Total amount in US dollars"
            AriaDescribedBy="amount-hint" />
        """;
}
