@page "/components/motion"

<PageTitle>Motion - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Motion"
        Description="Animate elements with smooth, physics-based transitions using the Motion component." />

    <DemoSection
        Title="Fade In"
        Description="Smoothly fade elements in when they appear.">
        <DemoBlock Code="@_fadeCode">
            <div class="flex flex-wrap gap-4 items-center">
                <Button @onclick="TriggerFade">Replay</Button>
                @if (showFade)
                {
                    <Motion>
                        <Fade />
                        <div class="rounded-md border bg-card p-6 text-center">Fade In</div>
                    </Motion>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Scale In with Spring"
        Description="Scale elements in with a spring physics animation.">
        <DemoBlock Code="@_scaleCode">
            <div class="flex flex-wrap gap-4 items-center">
                <Button @onclick="TriggerScale">Replay</Button>
                @if (showScale)
                {
                    <Motion>
                        <Scale Spring="0.4" />
                        <div class="rounded-md border bg-card p-6 text-center">Scale In</div>
                    </Motion>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Slide In"
        Description="Slide elements in from different directions.">
        <DemoBlock Code="@_slideCode">
            <div class="flex flex-col gap-4">
                <div class="flex flex-wrap gap-4">
                    <Button @onclick="TriggerSlide">Replay</Button>
                </div>
                @if (showSlide)
                {
                    <div class="grid grid-cols-2 gap-4">
                        <Motion>
                            <SlideUp />
                            <div class="rounded-md border bg-card p-4 text-center text-sm">Slide Up</div>
                        </Motion>
                        <Motion>
                            <SlideDown />
                            <div class="rounded-md border bg-card p-4 text-center text-sm">Slide Down</div>
                        </Motion>
                        <Motion>
                            <SlideLeft />
                            <div class="rounded-md border bg-card p-4 text-center text-sm">Slide Left</div>
                        </Motion>
                        <Motion>
                            <SlideRight />
                            <div class="rounded-md border bg-card p-4 text-center text-sm">Slide Right</div>
                        </Motion>
                    </div>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Combined Animations"
        Description="Combine multiple animation presets for richer effects.">
        <DemoBlock Code="@_combinedCode">
            <div class="flex flex-wrap gap-4 items-center">
                <Button @onclick="TriggerCombined">Replay</Button>
                @if (showCombined)
                {
                    <Motion>
                        <Fade />
                        <Scale Spring="0.3" />
                        <SlideUp />
                        <div class="rounded-md border bg-card p-6 text-center">Fade + Scale + Slide Up</div>
                    </Motion>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Micro-Interactions"
        Description="Subtle animations for interactive elements like buttons.">
        <DemoBlock Code="@_microCode">
            <div class="flex flex-wrap gap-4 items-center">
                <Button @onclick="TriggerMicro">Replay</Button>
                @if (showMicro)
                {
                    <Motion>
                        <Scale Spring="0.3" InitialScale="0.95" />
                        <Button>
                            <LucideIcon Name="heart" Size="16" Class="mr-2" />
                            Like
                        </Button>
                    </Motion>
                    <Motion>
                        <Scale Spring="0.5" InitialScale="0.9" />
                        <Button Variant="ButtonVariant.Outline">
                            <LucideIcon Name="share-2" Size="16" Class="mr-2" />
                            Share
                        </Button>
                    </Motion>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Pulse Animation"
        Description="Draw attention with continuous pulse animations.">
        <DemoBlock Code="@_pulseCode">
            <div class="flex flex-wrap gap-6 items-center">
                <Button @onclick="TriggerPulse">Replay</Button>
                @if (showPulse)
                {
                    <Motion>
                        <Pulse />
                        <Badge Variant="BadgeVariant.Destructive">Live</Badge>
                    </Motion>
                    <Motion>
                        <Pulse Repeat="3" />
                        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-500 text-white text-sm font-bold">3</div>
                    </Motion>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Scroll-Triggered Animations"
        Description="Animate elements as they enter the viewport while scrolling.">
        <DemoBlock Code="@_scrollCode">
            <ChildContent>
                <div class="space-y-2">
                    <p class="text-sm text-muted-foreground">Scroll down inside this container to see animations trigger.</p>
                    <div class="h-64 overflow-y-auto border rounded-md p-4 space-y-4">
                        <div class="h-32 flex items-center justify-center text-sm text-muted-foreground border rounded-md border-dashed">
                            Scroll down ↓
                        </div>
                        @for (int i = 1; i <= 5; i++)
                        {
                            int index = i;
                            <Motion Trigger="MotionTrigger.OnInView">
                                <Fade />
                                <SlideUp />
                                <div class="rounded-md border bg-card p-4">
                                    <p class="font-medium">Item @index</p>
                                    <p class="text-sm text-muted-foreground">This item fades and slides up when scrolled into view.</p>
                                </div>
                            </Motion>
                        }
                    </div>
                </div>
            </ChildContent>
            <AdditionalContent>
                <p class="text-sm text-muted-foreground">
                    Use <code>Trigger="MotionTrigger.OnInView"</code> to animate elements as they enter the viewport.
                    This is great for landing pages and long-form content.
                </p>
            </AdditionalContent>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Staggered List"
        Description="Animate list items one by one with a stagger delay.">
        <DemoBlock Code="@_staggerListCode">
            <div class="space-y-2">
                <Button @onclick="TriggerStaggerList">Replay</Button>
                @if (showStaggerList)
                {
                    <Motion StaggerChildren="0.08">
                        <ul class="space-y-2 max-w-xs">
                            @foreach (var item in listItems)
                            {
                                <Motion>
                                    <Fade />
                                    <SlideLeft />
                                    <li class="flex items-center gap-3 rounded-lg border p-3 bg-card">
                                        <LucideIcon Name="check-circle-2" Size="16" Class="text-green-500 shrink-0" />
                                        <span class="text-sm">@item</span>
                                    </li>
                                </Motion>
                            }
                        </ul>
                    </Motion>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Staggered Grid"
        Description="Animate grid items with a cascade effect.">
        <DemoBlock Code="@_staggerGridCode">
            <div class="space-y-2">
                <Button @onclick="TriggerStaggerGrid">Replay</Button>
                @if (showStaggerGrid)
                {
                    <Motion StaggerChildren="0.05">
                        <div class="grid grid-cols-3 gap-3">
                            @foreach (var card in gridCards)
                            {
                                <Motion>
                                    <Fade />
                                    <Scale Spring="0.3" />
                                    <div class="flex flex-col items-center justify-center rounded-lg border bg-card p-4 text-center aspect-square">
                                        <LucideIcon Name="@card.Icon" Size="24" Class="mb-2 text-muted-foreground" />
                                        <span class="text-xs font-medium">@card.Name</span>
                                    </div>
                                </Motion>
                            }
                        </div>
                    </Motion>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Easing Functions"
        Description="Choose from different easing functions for varied animation feels.">
        <DemoBlock Code="@_easingCode">
            <div class="space-y-4">
                <Button @onclick="TriggerEasing">Replay</Button>
                @if (showEasing)
                {
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <p class="text-xs text-muted-foreground mb-2">Ease In</p>
                            <Motion>
                                <SlideLeft Easing="MotionEasing.EaseIn" />
                                <div class="rounded-md border bg-card p-3 text-sm text-center">ease-in</div>
                            </Motion>
                        </div>
                        <div>
                            <p class="text-xs text-muted-foreground mb-2">Ease Out</p>
                            <Motion>
                                <SlideLeft Easing="MotionEasing.EaseOut" />
                                <div class="rounded-md border bg-card p-3 text-sm text-center">ease-out</div>
                            </Motion>
                        </div>
                        <div>
                            <p class="text-xs text-muted-foreground mb-2">Ease In Out</p>
                            <Motion>
                                <SlideLeft Easing="MotionEasing.EaseInOut" />
                                <div class="rounded-md border bg-card p-3 text-sm text-center">ease-in-out</div>
                            </Motion>
                        </div>
                        <div>
                            <p class="text-xs text-muted-foreground mb-2">Linear</p>
                            <Motion>
                                <SlideLeft Easing="MotionEasing.Linear" />
                                <div class="rounded-md border bg-card p-3 text-sm text-center">linear</div>
                            </Motion>
                        </div>
                    </div>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_motionProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private bool showFade = true;
    private bool showScale = true;
    private bool showSlide = true;
    private bool showCombined = true;
    private bool showMicro = true;
    private bool showPulse = true;
    private bool showStaggerList = true;
    private bool showStaggerGrid = true;
    private bool showEasing = true;

    private List<string> listItems = ["Design the UI", "Build components", "Write tests", "Deploy to production", "Monitor performance"];

    private List<(string Icon, string Name)> gridCards =
    [
        ("layout-dashboard", "Dashboard"), ("users", "Users"), ("settings", "Settings"),
        ("bar-chart-3", "Analytics"), ("file-text", "Reports"), ("bell", "Notifications"),
        ("shield", "Security"), ("database", "Database"), ("code-2", "API"),
    ];

    private async Task TriggerFade() { showFade = false; await Task.Delay(50); showFade = true; }
    private async Task TriggerScale() { showScale = false; await Task.Delay(50); showScale = true; }
    private async Task TriggerSlide() { showSlide = false; await Task.Delay(50); showSlide = true; }
    private async Task TriggerCombined() { showCombined = false; await Task.Delay(50); showCombined = true; }
    private async Task TriggerMicro() { showMicro = false; await Task.Delay(50); showMicro = true; }
    private async Task TriggerPulse() { showPulse = false; await Task.Delay(50); showPulse = true; }
    private async Task TriggerStaggerList() { showStaggerList = false; await Task.Delay(50); showStaggerList = true; }
    private async Task TriggerStaggerGrid() { showStaggerGrid = false; await Task.Delay(50); showStaggerGrid = true; }
    private async Task TriggerEasing() { showEasing = false; await Task.Delay(50); showEasing = true; }

    private static readonly IReadOnlyList<DemoPropRow> _motionProps =
    [
        new("Trigger",            "MotionTrigger",    "OnAppear", "Animation trigger. Options: OnAppear, OnInView."),
        new("StaggerChildren",    "double?",          "null",     "Delay in seconds between each child animation."),
        new("DisableOnPrerender", "bool",             "false",    "Prevents animation if content was server pre-rendered."),
        new("ChildContent",       "RenderFragment?",  "null",     "Animation preset components and the content to animate."),
    ];

    private const string _fadeCode = """
        <Motion>
            <Fade />
            <div class="rounded-md border bg-card p-6">Fade In</div>
        </Motion>
        """;

    private const string _scaleCode = """
        <Motion>
            <Scale Spring="0.4" />
            <div class="rounded-md border bg-card p-6">Scale In</div>
        </Motion>
        """;

    private const string _slideCode = """
        <Motion><SlideUp /><div>Slide Up</div></Motion>
        <Motion><SlideDown /><div>Slide Down</div></Motion>
        <Motion><SlideLeft /><div>Slide Left</div></Motion>
        <Motion><SlideRight /><div>Slide Right</div></Motion>
        """;

    private const string _combinedCode = """
        <Motion>
            <Fade />
            <Scale Spring="0.3" />
            <SlideUp />
            <div class="rounded-md border bg-card p-6">Fade + Scale + Slide Up</div>
        </Motion>
        """;

    private const string _microCode = """
        <Motion>
            <Scale Spring="0.3" InitialScale="0.95" />
            <Button><LucideIcon Name="heart" Size="16" Class="mr-2" /> Like</Button>
        </Motion>
        """;

    private const string _pulseCode = """
        <Motion>
            <Pulse />
            <Badge Variant="BadgeVariant.Destructive">Live</Badge>
        </Motion>

        <!-- Repeat 3 times -->
        <Motion>
            <Pulse Repeat="3" />
            <div class="notification-badge">3</div>
        </Motion>
        """;

    private const string _scrollCode = """
        <!-- Animate on scroll into view -->
        <Motion Trigger="MotionTrigger.OnInView">
            <Fade />
            <SlideUp />
            <div class="rounded-md border bg-card p-4">
                Animates when scrolled into view
            </div>
        </Motion>
        """;

    private const string _staggerListCode = """
        <Motion StaggerChildren="0.08">
            <ul class="space-y-2">
                @foreach (var item in listItems)
                {
                    <Motion>
                        <Fade />
                        <SlideLeft />
                        <li class="rounded-lg border p-3">@item</li>
                    </Motion>
                }
            </ul>
        </Motion>
        """;

    private const string _staggerGridCode = """
        <Motion StaggerChildren="0.05">
            <div class="grid grid-cols-3 gap-3">
                @foreach (var card in gridCards)
                {
                    <Motion>
                        <Fade />
                        <Scale Spring="0.3" />
                        <div class="rounded-lg border p-4">@card.Name</div>
                    </Motion>
                }
            </div>
        </Motion>
        """;

    private const string _easingCode = """
        <Motion><SlideLeft Easing="MotionEasing.EaseIn" /><div>ease-in</div></Motion>
        <Motion><SlideLeft Easing="MotionEasing.EaseOut" /><div>ease-out</div></Motion>
        <Motion><SlideLeft Easing="MotionEasing.EaseInOut" /><div>ease-in-out</div></Motion>
        <Motion><SlideLeft Easing="MotionEasing.Linear" /><div>linear</div></Motion>
        """;
}
