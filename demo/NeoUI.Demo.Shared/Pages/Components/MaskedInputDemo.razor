@page "/components/masked-input"
@using System.ComponentModel.DataAnnotations

<PageTitle>Masked Input - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Masked Input"
        Description="A text input that formats user input according to a defined mask pattern." />

    <DemoSection
        Title="Phone Number (US Format)"
        Description="Format phone numbers as users type.">
        <DemoBlock Code="@_phoneCode">
            <ChildContent>
                <div class="space-y-4 max-w-sm">
                    <div class="space-y-2">
                        <Label>Phone Number</Label>
                        <MaskedInput Mask="@MaskedInput.Masks.PhoneUS" @bind-Value="phoneValue" Placeholder="Enter phone number" />
                        <p class="text-sm text-muted-foreground">Value (digits only): <strong>@phoneValue</strong></p>
                    </div>
                    <div class="space-y-2">
                        <Label>Without mask display</Label>
                        <MaskedInput Mask="@MaskedInput.Masks.PhoneUS" @bind-Value="phoneValueNoMask" ShowMask="false" Placeholder="(555) 000-0000" />
                        <p class="text-sm text-muted-foreground">Value: <strong>@phoneValueNoMask</strong></p>
                    </div>
                </div>
            </ChildContent>
            <AdditionalContent>
                <Alert Variant="AlertVariant.Default">
                    <AlertTitle>
                        <LucideIcon Name="circle-alert" Size="16" Class="mr-2 inline" />
                        @@bind-Value and UpdateOn
                    </AlertTitle>
                    <AlertDescription>
                        MaskedInput uses <code>@@bind-Value</code> for two-way binding. The bound value contains only the raw digit/letter characters, not the mask characters.
                        Use <code>ShowMask="false"</code> with a <code>Placeholder</code> to show the format without the mask overlay.
                    </AlertDescription>
                </Alert>
            </AdditionalContent>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="International Phone"
        Description="Format international phone numbers with country codes.">
        <DemoBlock Code="@_intlPhoneCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>US Phone</Label>
                    <MaskedInput Mask="+1 (000) 000-0000" @bind-Value="usPhoneValue" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@usPhoneValue</strong></p>
                </div>
                <div class="space-y-2">
                    <Label>UK Phone</Label>
                    <MaskedInput Mask="+44 0000 000000" @bind-Value="ukPhoneValue" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@ukPhoneValue</strong></p>
                </div>
                <div class="space-y-2">
                    <Label>Brazilian Phone</Label>
                    <MaskedInput Mask="+55 (00) 00000-0000" @bind-Value="brPhoneValue" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@brPhoneValue</strong></p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="SSN"
        Description="Format Social Security Numbers.">
        <DemoBlock Code="@_ssnCode">
            <div class="space-y-2 max-w-sm">
                <Label>Social Security Number</Label>
                <MaskedInput Mask="@MaskedInput.Masks.SSN" @bind-Value="ssnValue" />
                <p class="text-sm text-muted-foreground">Value: <strong>@ssnValue</strong></p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Credit Card"
        Description="Format credit card numbers with space separators.">
        <DemoBlock Code="@_creditCardCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Card Number</Label>
                    <MaskedInput Mask="@MaskedInput.Masks.CreditCard" @bind-Value="cardValue" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@cardValue</strong></p>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <Label>Expiry</Label>
                        <MaskedInput Mask="00/00" @bind-Value="cardExpiry" Placeholder="MM/YY" ShowMask="false" />
                    </div>
                    <div class="space-y-2">
                        <Label>CVV</Label>
                        <MaskedInput Mask="000" @bind-Value="cardCvv" Placeholder="CVV" ShowMask="false" />
                    </div>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Date Input"
        Description="Format date inputs with different regional formats.">
        <DemoBlock Code="@_dateCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>US Date (MM/DD/YYYY)</Label>
                    <MaskedInput Mask="@MaskedInput.Masks.Date" @bind-Value="usDateValue" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@usDateValue</strong></p>
                </div>
                <div class="space-y-2">
                    <Label>ISO Date (YYYY-MM-DD)</Label>
                    <MaskedInput Mask="0000-00-00" @bind-Value="isoDateValue" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@isoDateValue</strong></p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Time Input"
        Description="Format time inputs in 12-hour or 24-hour format.">
        <DemoBlock Code="@_timeCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Time (HH:MM)</Label>
                    <MaskedInput Mask="@MaskedInput.Masks.Time" @bind-Value="timeValue" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@timeValue</strong></p>
                </div>
                <div class="space-y-2">
                    <Label>Time with seconds (HH:MM:SS)</Label>
                    <MaskedInput Mask="00:00:00" @bind-Value="timeWithSecondsValue" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@timeWithSecondsValue</strong></p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="ZIP Code"
        Description="Format ZIP codes in US formats.">
        <DemoBlock Code="@_zipCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>ZIP Code</Label>
                    <MaskedInput Mask="@MaskedInput.Masks.ZIP" @bind-Value="zipValue" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@zipValue</strong></p>
                </div>
                <div class="space-y-2">
                    <Label>ZIP+4</Label>
                    <MaskedInput Mask="@MaskedInput.Masks.ZIP4" @bind-Value="zipPlusFourValue" />
                    <p class="text-sm text-muted-foreground">Value: <strong>@zipPlusFourValue</strong></p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Custom Masks"
        Description="Create custom masks for specialized formats.">
        <DemoBlock Code="@_customCode">
            <ChildContent>
                <div class="space-y-4 max-w-sm">
                    <div class="space-y-2">
                        <Label>Product Code (AAA-000)</Label>
                        <MaskedInput Mask="AAA-000" @bind-Value="productCodeValue" />
                        <p class="text-sm text-muted-foreground">Value: <strong>@productCodeValue</strong></p>
                    </div>
                    <div class="space-y-2">
                        <Label>License Plate</Label>
                        <MaskedInput Mask="AAA-0000" @bind-Value="licensePlateValue" />
                        <p class="text-sm text-muted-foreground">Value: <strong>@licensePlateValue</strong></p>
                    </div>
                </div>
            </ChildContent>
            <AdditionalContent>
                <div class="text-sm space-y-1 text-muted-foreground">
                    <p class="font-medium text-foreground">Mask Characters:</p>
                    <ul class="list-disc list-inside space-y-1">
                        <li><code>0</code> — digits (0-9)</li>
                        <li><code>A</code> — letters (a-z, A-Z)</li>
                        <li><code>*</code> — any character</li>
                        <li>Any other character is treated as a literal separator</li>
                    </ul>
                </div>
            </AdditionalContent>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Indonesian National ID (KTP)"
        Description="Indonesian National Identity Card (Kartu Tanda Penduduk) — 16 digit format with dots as separators.">
        <DemoBlock Code="@_indonesianIdCode">
            <div class="space-y-2 max-w-sm">
                <Label>NIK (Nomor Induk Kependudukan)</Label>
                <MaskedInput Mask="00.00.00.000000.0000" @bind-Value="indonesianIdValue" Placeholder="00.00.00.DDMMYY.0000" ShowMask="true" />
                <p class="text-sm text-muted-foreground">Value: <strong>@indonesianIdValue</strong></p>
                <p class="text-xs text-blue-600 dark:text-blue-400">💡 Format: Province.Regency.District.BirthDate.Sequence</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Disabled / Readonly"
        Description="States that prevent user interaction.">
        <DemoBlock Code="@_statesCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Disabled</Label>
                    <MaskedInput Mask="@MaskedInput.Masks.PhoneUS" Value="5555551234" Disabled="true" />
                </div>
                <div class="space-y-2">
                    <Label>Readonly</Label>
                    <MaskedInput Mask="@MaskedInput.Masks.PhoneUS" Value="5555551234" Readonly="true" />
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Form Validation"
        Description="Integrate with Blazor EditForm and DataAnnotations.">
        <DemoBlock Code="@_validationCode">
            <div class="max-w-sm">
                <EditForm Model="@maskedModel" OnValidSubmit="HandleMaskedSubmit">
                    <DataAnnotationsValidator />
                    <div class="space-y-4">
                        <div class="space-y-2">
                            <Label>Phone Number <span class="text-destructive">*</span></Label>
                            <MaskedInput Mask="@MaskedInput.Masks.PhoneUS" @bind-Value="maskedModel.Phone" ShowMask="false" Placeholder="(555) 000-0000" Required="true" />
                            <ValidationMessage For="@(() => maskedModel.Phone)" class="text-sm text-destructive" />
                        </div>
                        <Button Type="ButtonType.Submit">Submit</Button>
                    </div>
                </EditForm>
                @if (maskedFormSubmitted)
                {
                    <p class="mt-4 text-sm text-green-600 font-medium">Form submitted! Phone: @maskedModel.Phone</p>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Error State"
        Description="Input with error visualization using aria-invalid.">
        <DemoBlock Code="@_errorStateCode">
            <div class="space-y-2 max-w-sm">
                <Label>Invalid Phone</Label>
                <MaskedInput Mask="@MaskedInput.Masks.PhoneUS" @bind-Value="errorPhoneValue" AriaInvalid="true" ShowMask="true" />
                <p class="text-sm text-destructive">This phone number is invalid.</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Required State"
        Description="Input with HTML5 required validation.">
        <DemoBlock Code="@_requiredStateCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Phone (Required) <span class="text-destructive">*</span></Label>
                    <MaskedInput Mask="@MaskedInput.Masks.PhoneUS" @bind-Value="requiredPhoneValue" Required="true" ShowMask="true" ShowValidationError="true" />
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_maskedInputProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private string? phoneValue;
    private string? phoneValueNoMask;
    private string? usPhoneValue;
    private string? ukPhoneValue;
    private string? brPhoneValue;
    private string? ssnValue;
    private string? cardValue;
    private string? cardExpiry;
    private string? cardCvv;
    private string? usDateValue;
    private string? isoDateValue;
    private string? timeValue;
    private string? timeWithSecondsValue;
    private string? zipValue;
    private string? zipPlusFourValue;
    private string? productCodeValue;
    private string? licensePlateValue;
    private string? indonesianIdValue;
    private string? errorPhoneValue = "5551234";
    private string? requiredPhoneValue;
    private bool maskedFormSubmitted = false;

    private MaskedInputModel maskedModel = new();

    private void HandleMaskedSubmit() => maskedFormSubmitted = true;

    private class MaskedInputModel
    {
        [Required(ErrorMessage = "Phone number is required")]
        [MinLength(10, ErrorMessage = "Please enter a complete phone number")]
        public string? Phone { get; set; }
    }

    private static readonly IReadOnlyList<DemoPropRow> _maskedInputProps =
    [
        new("Mask",               "string",   "—",      "Mask pattern. 0=digit, A=letter, *=any character. Other chars are literals."),
        new("Value",              "string?",  "null",   "Current value (raw digits/letters only). Use @bind-Value for two-way binding."),
        new("ValueChanged",       "EventCallback&lt;string?&gt;", "—", "Callback invoked when the value changes."),
        new("ShowMask",           "bool",     "true",   "Whether to show the mask template as placeholder text."),
        new("Placeholder",        "string?",  "null",   "Placeholder text when ShowMask is false."),
        new("Disabled",           "bool",     "false",  "Disables the input when true."),
        new("Readonly",           "bool",     "false",  "Makes the input read-only when true."),
        new("Required",           "bool",     "false",  "Marks the input as required for native form validation."),
        new("AriaInvalid",        "bool",     "false",  "Marks the input as invalid for screen readers."),
        new("ShowValidationError","bool",     "false",  "Shows browser native validation tooltip on invalid state."),
        new("Class",              "string?",  "null",   "Additional CSS classes appended to the input element."),
    ];

    private const string _phoneCode = """
        <MaskedInput Mask="@MaskedInput.Masks.PhoneUS" @bind-Value="phoneValue" />

        <!-- Without mask display -->
        <MaskedInput Mask="@MaskedInput.Masks.PhoneUS" @bind-Value="phoneValue" ShowMask="false" Placeholder="(555) 000-0000" />
        """;

    private const string _intlPhoneCode = """
        <MaskedInput Mask="+1 (000) 000-0000" @bind-Value="usPhoneValue" />
        <MaskedInput Mask="+44 0000 000000" @bind-Value="ukPhoneValue" />
        """;

    private const string _ssnCode = """
        <MaskedInput Mask="@MaskedInput.Masks.SSN" @bind-Value="ssnValue" />
        """;

    private const string _creditCardCode = """
        <MaskedInput Mask="@MaskedInput.Masks.CreditCard" @bind-Value="cardValue" />
        <MaskedInput Mask="00/00" @bind-Value="cardExpiry" Placeholder="MM/YY" ShowMask="false" />
        <MaskedInput Mask="000" @bind-Value="cardCvv" Placeholder="CVV" ShowMask="false" />
        """;

    private const string _dateCode = """
        <!-- US format -->
        <MaskedInput Mask="@MaskedInput.Masks.Date" @bind-Value="dateValue" />

        <!-- ISO format -->
        <MaskedInput Mask="0000-00-00" @bind-Value="isoDateValue" />
        """;

    private const string _timeCode = """
        <MaskedInput Mask="@MaskedInput.Masks.Time" @bind-Value="timeValue" />
        <MaskedInput Mask="00:00:00" @bind-Value="timeWithSecondsValue" />
        """;

    private const string _zipCode = """
        <MaskedInput Mask="@MaskedInput.Masks.ZIP" @bind-Value="zipValue" />
        <MaskedInput Mask="@MaskedInput.Masks.ZIP4" @bind-Value="zipPlusFourValue" />
        """;

    private const string _customCode = """
        <!-- Letters only (A = letter) -->
        <MaskedInput Mask="AAA-000" @bind-Value="productCode" />

        <!-- License plate -->
        <MaskedInput Mask="AAA-0000" @bind-Value="licensePlate" />
        """;

    private const string _indonesianIdCode = """
        <MaskedInput Mask="00.00.00.000000.0000"
            @bind-Value="nikValue"
            Placeholder="00.00.00.DDMMYY.0000"
            ShowMask="true" />
        """;

    private const string _errorStateCode = """
        <MaskedInput Mask="@MaskedInput.Masks.PhoneUS"
            @bind-Value="phoneValue"
            AriaInvalid="true"
            ShowMask="true" />
        <p class="text-sm text-destructive">This phone number is invalid.</p>
        """;

    private const string _requiredStateCode = """
        <MaskedInput Mask="@MaskedInput.Masks.PhoneUS"
            @bind-Value="phoneValue"
            Required="true"
            ShowMask="true"
            ShowValidationError="true" />
        """;

    private const string _statesCode = """
        <MaskedInput Mask="@MaskedInput.Masks.PhoneUS" Value="5555551234" Disabled="true" />
        <MaskedInput Mask="@MaskedInput.Masks.PhoneUS" Value="5555551234" Readonly="true" />
        """;

    private const string _validationCode = """
        <EditForm Model="@model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <MaskedInput Mask="@MaskedInput.Masks.PhoneUS" @bind-Value="model.Phone"
                ShowMask="false" Placeholder="(555) 000-0000" Required="true" />
            <ValidationMessage For="@(() => model.Phone)" class="text-sm text-destructive" />
        </EditForm>
        """;
}
