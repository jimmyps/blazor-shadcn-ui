@page "/components/avatar"

<PageTitle>Avatar - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Avatar"
        Description="An image element with a fallback for representing a user or entity." />

    <DemoSection
        Title="Basic Usage"
        Description="Display a user avatar with automatic fallback to initials.">
        <DemoBlock Code="@_basicCode">
            <div class="flex gap-4">
                <Avatar>
                    <AvatarImage Source="/images/avatar-icon.png" Alt="James" />
                    <AvatarFallback>SH</AvatarFallback>
                </Avatar>
                <Avatar>
                    <AvatarImage Source="https://unavailable-image.jpg" Alt="User" />
                    <AvatarFallback>JD</AvatarFallback>
                </Avatar>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Size Variants"
        Description="Avatars come in four different sizes.">
        <DemoBlock Code="@_sizesCode">
            <div class="flex items-center gap-6">
                <div class="flex flex-col items-center gap-2">
                    <Avatar Size="AvatarSize.Small">
                        <AvatarFallback>XS</AvatarFallback>
                    </Avatar>
                    <span class="text-xs text-muted-foreground">Small</span>
                </div>
                <div class="flex flex-col items-center gap-2">
                    <Avatar Size="AvatarSize.Default">
                        <AvatarFallback>MD</AvatarFallback>
                    </Avatar>
                    <span class="text-xs text-muted-foreground">Default</span>
                </div>
                <div class="flex flex-col items-center gap-2">
                    <Avatar Size="AvatarSize.Large">
                        <AvatarFallback>LG</AvatarFallback>
                    </Avatar>
                    <span class="text-xs text-muted-foreground">Large</span>
                </div>
                <div class="flex flex-col items-center gap-2">
                    <Avatar Size="AvatarSize.ExtraLarge">
                        <AvatarFallback>XL</AvatarFallback>
                    </Avatar>
                    <span class="text-xs text-muted-foreground">Extra Large</span>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Images"
        Description="Display actual user profile images with fallback support.">
        <DemoBlock Code="@_imagesCode">
            <div class="flex gap-4">
                <Avatar Size="AvatarSize.Large">
                    <AvatarImage Source="https://github.com/vercel.png" Alt="Vercel" />
                    <AvatarFallback>VC</AvatarFallback>
                </Avatar>
                <Avatar Size="AvatarSize.Large">
                    <AvatarImage Source="https://github.com/microsoft.png" Alt="Microsoft" />
                    <AvatarFallback>MS</AvatarFallback>
                </Avatar>
                <Avatar Size="AvatarSize.Large">
                    <AvatarImage Source="https://github.com/google.png" Alt="Google" />
                    <AvatarFallback>GG</AvatarFallback>
                </Avatar>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Icons"
        Description="Use icons as fallback content for generic user representations.">
        <DemoBlock Code="@_iconsCode">
            <div class="flex gap-4">
                <Avatar>
                    <AvatarFallback>
                        <LucideIcon Name="user" Size="20" />
                    </AvatarFallback>
                </Avatar>
                <Avatar Size="AvatarSize.Large">
                    <AvatarFallback>
                        <LucideIcon Name="circle-user" Size="24" />
                    </AvatarFallback>
                </Avatar>
                <Avatar Size="AvatarSize.ExtraLarge">
                    <AvatarFallback>
                        <LucideIcon Name="users" Size="32" />
                    </AvatarFallback>
                </Avatar>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="User List"
        Description="Common pattern for displaying a list of users or team members.">
        <DemoBlock Code="@_userListCode">
            <div class="border rounded-lg divide-y">
                <div class="flex items-center gap-4 p-4 hover:bg-accent transition-colors">
                    <Avatar>
                        <AvatarFallback>JD</AvatarFallback>
                    </Avatar>
                    <div class="flex-1">
                        <p class="font-medium">John Doe</p>
                        <p class="text-sm text-muted-foreground">john.doe@example.com</p>
                    </div>
                </div>
                <div class="flex items-center gap-4 p-4 hover:bg-accent transition-colors">
                    <Avatar>
                        <AvatarFallback>AS</AvatarFallback>
                    </Avatar>
                    <div class="flex-1">
                        <p class="font-medium">Alice Smith</p>
                        <p class="text-sm text-muted-foreground">alice.smith@example.com</p>
                    </div>
                </div>
                <div class="flex items-center gap-4 p-4 hover:bg-accent transition-colors">
                    <Avatar>
                        <AvatarFallback>BJ</AvatarFallback>
                    </Avatar>
                    <div class="flex-1">
                        <p class="font-medium">Bob Johnson</p>
                        <p class="text-sm text-muted-foreground">bob.johnson@example.com</p>
                    </div>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Avatar Group"
        Description="Stack avatars to show multiple users or team members compactly.">
        <DemoBlock Code="@_groupCode">
            <div class="flex -space-x-4">
                <Avatar Class="border-2 border-background">
                    <AvatarFallback>AB</AvatarFallback>
                </Avatar>
                <Avatar Class="border-2 border-background">
                    <AvatarFallback>CD</AvatarFallback>
                </Avatar>
                <Avatar Class="border-2 border-background">
                    <AvatarFallback>EF</AvatarFallback>
                </Avatar>
                <Avatar Class="border-2 border-background">
                    <AvatarFallback>GH</AvatarFallback>
                </Avatar>
                <Avatar Class="border-2 border-background">
                    <AvatarFallback Class="bg-primary text-primary-foreground">+5</AvatarFallback>
                </Avatar>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Custom Styles"
        Description="Customize avatar appearance with additional CSS classes.">
        <DemoBlock Code="@_customCode">
            <div class="flex gap-4">
                <Avatar Size="AvatarSize.Large">
                    <AvatarFallback Class="bg-gradient-to-br from-purple-500 to-pink-500 text-white">AB</AvatarFallback>
                </Avatar>
                <Avatar Size="AvatarSize.Large">
                    <AvatarFallback Class="bg-gradient-to-br from-blue-500 to-cyan-500 text-white">CD</AvatarFallback>
                </Avatar>
                <Avatar Size="AvatarSize.Large">
                    <AvatarFallback Class="bg-gradient-to-br from-green-500 to-emerald-500 text-white">EF</AvatarFallback>
                </Avatar>
                <Avatar Size="AvatarSize.Large">
                    <AvatarFallback Class="bg-gradient-to-br from-orange-500 to-red-500 text-white">GH</AvatarFallback>
                </Avatar>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Status Indicator"
        Description="Add status indicators to show online/offline/busy states.">
        <DemoBlock Code="@_statusCode">
            <div class="flex gap-6">
                <div class="relative inline-block">
                    <Avatar Size="AvatarSize.Large">
                        <AvatarFallback>JD</AvatarFallback>
                    </Avatar>
                    <span class="absolute bottom-0 right-0 block h-3 w-3 rounded-full bg-green-500 ring-2 ring-background"></span>
                </div>
                <div class="relative inline-block">
                    <Avatar Size="AvatarSize.Large">
                        <AvatarFallback>AS</AvatarFallback>
                    </Avatar>
                    <span class="absolute bottom-0 right-0 block h-3 w-3 rounded-full bg-yellow-500 ring-2 ring-background"></span>
                </div>
                <div class="relative inline-block">
                    <Avatar Size="AvatarSize.Large">
                        <AvatarFallback>BJ</AvatarFallback>
                    </Avatar>
                    <span class="absolute bottom-0 right-0 block h-3 w-3 rounded-full bg-red-500 ring-2 ring-background"></span>
                </div>
                <div class="relative inline-block">
                    <Avatar Size="AvatarSize.Large">
                        <AvatarFallback>MK</AvatarFallback>
                    </Avatar>
                    <span class="absolute bottom-0 right-0 block h-3 w-3 rounded-full bg-gray-400 ring-2 ring-background"></span>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Accessibility"
        Description="Always provide descriptive alt text on AvatarImage. Use meaningful initials or icons in AvatarFallback. Avatars are purely presentational — if clickable, wrap in a button with a proper aria-label. If using status indicators, add aria-label to convey state to screen readers." />

    <DemoSection Title="API Reference" Description="Avatar component parameters and their types.">
        <DemoPropsTable Rows="_avatarProps" />
    </DemoSection>

    <DemoSection Title="AvatarImage Parameters" Description="Parameters for the AvatarImage sub-component.">
        <DemoPropsTable Rows="_avatarImageProps" />
    </DemoSection>

    <DemoSection Title="AvatarFallback Parameters" Description="Parameters for the AvatarFallback sub-component.">
        <DemoPropsTable Rows="_avatarFallbackProps" />
    </DemoSection>

    <DemoPageNav />
</div>

@code {
    private static readonly IReadOnlyList<DemoPropRow> _avatarProps =
    [
        new("Size",  "AvatarSize", "Default", "Controls dimensions: Small (32px), Default (40px), Large (48px), ExtraLarge (64px)."),
        new("Class", "string?",    null,      "Additional CSS classes for the avatar container."),
    ];

    private static readonly IReadOnlyList<DemoPropRow> _avatarImageProps =
    [
        new("Source", "string?", null, "URL of the image. Falls back to AvatarFallback on load error."),
        new("Alt",    "string?", null, "Alternative text for the image (required for accessibility)."),
        new("Class",  "string?", null, "Additional CSS classes for the image element."),
    ];

    private static readonly IReadOnlyList<DemoPropRow> _avatarFallbackProps =
    [
        new("Class", "string?", null, "Additional CSS classes. Useful for custom background colors."),
    ];

    private const string _basicCode =
        """
        <Avatar>
            <AvatarImage Source="/images/avatar-icon.png" Alt="James" />
            <AvatarFallback>SH</AvatarFallback>
