@page "/components/toggle"

<PageTitle>Toggle - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Toggle"
        Description="A two-state button that can be either on or off." />

    <DemoSection
        Title="Basic"
        Description="A simple toggle button that tracks its pressed state.">
        <DemoBlock Code="@_basicCode">
            <div class="space-y-2">
                <Toggle @bind-Pressed="isPressed">
                    <LucideIcon Name="bold" Class="h-4 w-4" />
                </Toggle>
                <p class="text-sm text-muted-foreground">Pressed: @isPressed</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Variants"
        Description="Default and outline visual styles.">
        <DemoBlock Code="@_variantsCode">
            <div class="flex gap-4">
                <Toggle Variant="ToggleVariant.Default">Default</Toggle>
                <Toggle Variant="ToggleVariant.Outline">Outline</Toggle>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Sizes"
        Description="Small, default, and large size options.">
        <DemoBlock Code="@_sizesCode">
            <div class="flex gap-4 items-center">
                <Toggle Size="ToggleSize.Small">Small</Toggle>
                <Toggle Size="ToggleSize.Default">Default</Toggle>
                <Toggle Size="ToggleSize.Large">Large</Toggle>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_toggleProps" />
    </DemoSection>

    <DemoPageNav />
</div>

@code {
    private bool isPressed = false;

    private static readonly IReadOnlyList<DemoPropRow> _toggleProps =
    [
        new("Pressed",  "@bind-Pressed / bool", "false",           "Whether the toggle is pressed."),
        new("Variant",  "ToggleVariant",         "Default",         "Default or Outline visual style."),
        new("Size",     "ToggleSize",             "Default",         "Small, Default, or Large."),
        new("Disabled", "bool",                   "false",           "Disables the toggle."),
    ];

    private const string _basicCode =
        """
        <Toggle>
            <LucideIcon Name="bold" Class="h-4 w-4" />
        </Toggle>
        """;

    private const string _variantsCode =
        """
        <Toggle Variant="ToggleVariant.Default">Default</Toggle>
        <Toggle Variant="ToggleVariant.Outline">Outline</Toggle>
        """;

    private const string _sizesCode =
        """
        <Toggle Size="ToggleSize.Small">Small</Toggle>
        <Toggle Size="ToggleSize.Default">Default</Toggle>
        <Toggle Size="ToggleSize.Large">Large</Toggle>
        """;
}
