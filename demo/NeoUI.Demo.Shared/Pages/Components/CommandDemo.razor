@page "/components/command"

<PageTitle>Command - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Command"
        Description="Fast, composable, unstyled command menu for Blazor." />

    <DemoSection
        Title="Command Palette (Overlay)"
        Description="A full command palette activated with a keyboard shortcut.">
        <DemoBlock Code="@_paletteCode">
            <div class="flex flex-col gap-4">
                <div class="flex gap-4 items-center">
                    <Button Variant="ButtonVariant.Outline" @onclick="OpenPalette">
                        <LucideIcon Name="search" Size="16" Class="mr-2" />
                        Search commands...
                        <kbd class="pointer-events-none inline-flex h-5 select-none items-center gap-1 rounded border bg-muted px-1.5 font-mono text-[10px] font-medium text-muted-foreground opacity-100 ml-4">
                            <span class="text-xs">⌘</span>K
                        </kbd>
                    </Button>
                </div>
                @if (!string.IsNullOrEmpty(paletteSelectedValue))
                {
                    <p class="text-sm">Last selected: <strong>@paletteSelectedValue</strong></p>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    @if (isPaletteOpen)
    {
        <div class="fixed inset-0 z-50 bg-background/80 backdrop-blur-sm" @onclick="ClosePalette">
            <div class="fixed left-[50%] top-[50%] z-50 w-full max-w-lg translate-x-[-50%] translate-y-[-50%]" @onclick="StopClick">
                <div class="overflow-hidden rounded-md border bg-popover text-popover-foreground shadow-md">
                    <CommandContent OnValueChange="HandlePaletteValueChange">
                        <CommandInput Placeholder="Type a command or search..." />
                        <CommandList>
                            <CommandEmpty>No results found.</CommandEmpty>
                            <CommandGroup Heading="Suggestions">
                                <CommandItem Value="calendar">
                                    <LucideIcon Name="calendar" Size="16" Class="mr-2" /> Calendar
                                </CommandItem>
                                <CommandItem Value="emoji">
                                    <LucideIcon Name="smile" Size="16" Class="mr-2" /> Search Emoji
                                </CommandItem>
                                <CommandItem Value="calculator">
                                    <LucideIcon Name="calculator" Size="16" Class="mr-2" /> Calculator
                                </CommandItem>
                            </CommandGroup>
                            <CommandSeparator />
                            <CommandGroup Heading="Settings">
                                <CommandItem Value="profile">
                                    <LucideIcon Name="user" Size="16" Class="mr-2" /> Profile
                                    <CommandShortcut>⌘P</CommandShortcut>
                                </CommandItem>
                                <CommandItem Value="billing">
                                    <LucideIcon Name="credit-card" Size="16" Class="mr-2" /> Billing
                                    <CommandShortcut>⌘B</CommandShortcut>
                                </CommandItem>
                                <CommandItem Value="settings">
                                    <LucideIcon Name="settings" Size="16" Class="mr-2" /> Settings
                                    <CommandShortcut>⌘S</CommandShortcut>
                                </CommandItem>
                            </CommandGroup>
                        </CommandList>
                    </CommandContent>
                </div>
            </div>
        </div>
    }

    <DemoSection
        Title="Basic Command Menu"
        Description="Embedded command menu with search and items.">
        <DemoBlock Code="@_basicCode">
            <div class="rounded-lg border bg-background shadow-md w-full max-w-sm">
                <CommandContent OnValueChange="HandleBasicValueChange">
                    <CommandInput Placeholder="Type a command or search..." />
                    <CommandList>
                        <CommandEmpty>No results found.</CommandEmpty>
                        <CommandGroup Heading="Suggestions">
                            <CommandItem Value="calendar">
                                <LucideIcon Name="calendar" Size="16" Class="mr-2" /> Calendar
                            </CommandItem>
                            <CommandItem Value="emoji">
                                <LucideIcon Name="smile" Size="16" Class="mr-2" /> Search Emoji
                            </CommandItem>
                            <CommandItem Value="calculator">
                                <LucideIcon Name="calculator" Size="16" Class="mr-2" /> Calculator
                            </CommandItem>
                        </CommandGroup>
                        <CommandSeparator />
                        <CommandGroup Heading="Settings">
                            <CommandItem Value="profile">
                                <LucideIcon Name="user" Size="16" Class="mr-2" /> Profile
                            </CommandItem>
                            <CommandItem Value="billing">
                                <LucideIcon Name="credit-card" Size="16" Class="mr-2" /> Billing
                            </CommandItem>
                            <CommandItem Value="settings">
                                <LucideIcon Name="settings" Size="16" Class="mr-2" /> Settings
                            </CommandItem>
                        </CommandGroup>
                    </CommandList>
                </CommandContent>
            </div>
            @if (!string.IsNullOrEmpty(basicSelectedValue))
            {
                <p class="mt-2 text-sm">Selected: <strong>@basicSelectedValue</strong></p>
            }
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Grouped Commands"
        Description="Organize commands into logical groups with headings.">
        <DemoBlock Code="@_groupedCode">
            <div class="rounded-lg border bg-background shadow-md w-full max-w-sm">
                <CommandContent OnValueChange="HandleGroupedValueChange">
                    <CommandInput Placeholder="Search..." />
                    <CommandList>
                        <CommandEmpty>No results found.</CommandEmpty>
                        <CommandGroup Heading="Navigation">
                            <CommandItem Value="home">
                                <LucideIcon Name="house" Size="16" Class="mr-2" /> Home
                            </CommandItem>
                            <CommandItem Value="dashboard">
                                <LucideIcon Name="layout-dashboard" Size="16" Class="mr-2" /> Dashboard
                            </CommandItem>
                            <CommandItem Value="projects">
                                <LucideIcon Name="folder" Size="16" Class="mr-2" /> Projects
                            </CommandItem>
                        </CommandGroup>
                        <CommandSeparator />
                        <CommandGroup Heading="Account">
                            <CommandItem Value="account-settings">
                                <LucideIcon Name="settings" Size="16" Class="mr-2" /> Account Settings
                            </CommandItem>
                            <CommandItem Value="notifications">
                                <LucideIcon Name="bell" Size="16" Class="mr-2" /> Notifications
                            </CommandItem>
                            <CommandItem Value="logout">
                                <LucideIcon Name="log-out" Size="16" Class="mr-2" /> Logout
                            </CommandItem>
                        </CommandGroup>
                        <CommandSeparator />
                        <CommandGroup Heading="Actions">
                            <CommandItem Value="new-doc">
                                <LucideIcon Name="file-plus" Size="16" Class="mr-2" /> New Document
                            </CommandItem>
                            <CommandItem Value="import">
                                <LucideIcon Name="upload" Size="16" Class="mr-2" /> Import
                            </CommandItem>
                        </CommandGroup>
                    </CommandList>
                </CommandContent>
            </div>
            @if (!string.IsNullOrEmpty(groupedSelectedValue))
            {
                <p class="mt-2 text-sm">Selected: <strong>@groupedSelectedValue</strong></p>
            }
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Keyboard Shortcuts"
        Description="Show keyboard shortcuts alongside commands.">
        <DemoBlock Code="@_shortcutsCode">
            <div class="rounded-lg border bg-background shadow-md w-full max-w-sm">
                <CommandContent OnValueChange="HandleShortcutsValueChange">
                    <CommandInput Placeholder="Search commands..." />
                    <CommandList>
                        <CommandEmpty>No results found.</CommandEmpty>
                        <CommandGroup Heading="File">
                            <CommandItem Value="new-file">
                                <LucideIcon Name="file" Size="16" Class="mr-2" /> New File
                                <CommandShortcut>⌘N</CommandShortcut>
                            </CommandItem>
                            <CommandItem Value="open-file">
                                <LucideIcon Name="folder-open" Size="16" Class="mr-2" /> Open File
                                <CommandShortcut>⌘O</CommandShortcut>
                            </CommandItem>
                            <CommandItem Value="save-file">
                                <LucideIcon Name="save" Size="16" Class="mr-2" /> Save
                                <CommandShortcut>⌘S</CommandShortcut>
                            </CommandItem>
                        </CommandGroup>
                        <CommandSeparator />
                        <CommandGroup Heading="Edit">
                            <CommandItem Value="undo">
                                <LucideIcon Name="undo" Size="16" Class="mr-2" /> Undo
                                <CommandShortcut>⌘Z</CommandShortcut>
                            </CommandItem>
                            <CommandItem Value="redo">
                                <LucideIcon Name="redo" Size="16" Class="mr-2" /> Redo
                                <CommandShortcut>⌘⇧Z</CommandShortcut>
                            </CommandItem>
                        </CommandGroup>
                    </CommandList>
                </CommandContent>
            </div>
            @if (!string.IsNullOrEmpty(shortcutsSelectedValue))
            {
                <p class="mt-2 text-sm">Selected: <strong>@shortcutsSelectedValue</strong></p>
            }
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Disabled Items"
        Description="Disable specific items that are currently unavailable.">
        <DemoBlock Code="@_disabledCode">
            <div class="rounded-lg border bg-background shadow-md w-full max-w-sm">
                <CommandContent OnValueChange="HandleDisabledValueChange">
                    <CommandInput Placeholder="Search..." />
                    <CommandList>
                        <CommandEmpty>No results found.</CommandEmpty>
                        <CommandGroup Heading="Actions">
                            <CommandItem Value="edit">
                                <LucideIcon Name="pencil" Size="16" Class="mr-2" /> Edit
                            </CommandItem>
                            <CommandItem Value="copy">
                                <LucideIcon Name="copy" Size="16" Class="mr-2" /> Copy
                            </CommandItem>
                            <CommandItem Value="paste" Disabled="true">
                                <LucideIcon Name="clipboard" Size="16" Class="mr-2" /> Paste (unavailable)
                            </CommandItem>
                            <CommandItem Value="delete" Disabled="true">
                                <LucideIcon Name="trash-2" Size="16" Class="mr-2" /> Delete (unavailable)
                            </CommandItem>
                        </CommandGroup>
                    </CommandList>
                </CommandContent>
            </div>
            @if (!string.IsNullOrEmpty(disabledSelectedValue))
            {
                <p class="mt-2 text-sm">Selected: <strong>@disabledSelectedValue</strong></p>
            }
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Empty State"
        Description="Show a custom message when no results match.">
        <DemoBlock Code="@_emptyCode">
            <div class="rounded-lg border bg-background shadow-md w-full max-w-sm">
                <CommandContent>
                    <CommandInput Placeholder="Type something that won't match..." />
                    <CommandList>
                        <CommandEmpty>
                            <div class="flex flex-col items-center gap-2 py-6">
                                <LucideIcon Name="search-x" Size="32" Class="text-muted-foreground" />
                                <p class="text-sm font-medium">No results found</p>
                                <p class="text-xs text-muted-foreground">Try a different search term</p>
                            </div>
                        </CommandEmpty>
                        <CommandGroup Heading="No matches here">
                            <CommandItem Value="impossible-to-find-zzz">Hidden item</CommandItem>
                        </CommandGroup>
                    </CommandList>
                </CommandContent>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Keyboard Navigation"
        Description="Use arrow keys to navigate items, Enter to select, and Escape to close the palette." />

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_commandProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private bool isPaletteOpen = false;
    private string? paletteSelectedValue;
    private string? basicSelectedValue;
    private string? groupedSelectedValue;
    private string? shortcutsSelectedValue;
    private string? disabledSelectedValue;

    private void OpenPalette() => isPaletteOpen = true;
    private void ClosePalette() => isPaletteOpen = false;
    private void StopClick(MouseEventArgs e) { /* stop propagation handled by ordering */ }

    private void HandlePaletteValueChange(string value)
    {
        paletteSelectedValue = value;
        isPaletteOpen = false;
    }

    private void HandleBasicValueChange(string value) => basicSelectedValue = value;
    private void HandleGroupedValueChange(string value) => groupedSelectedValue = value;
    private void HandleShortcutsValueChange(string value) => shortcutsSelectedValue = value;
    private void HandleDisabledValueChange(string value) => disabledSelectedValue = value;

    private static readonly IReadOnlyList<DemoPropRow> _commandProps =
    [
        new("OnValueChange", "EventCallback&lt;string&gt;", "—",    "Callback invoked when a command item is selected."),
        new("ChildContent",  "RenderFragment?",            "null",  "CommandInput and CommandList elements."),
        new("Disabled",      "bool",                       "false", "On CommandItem: prevents selection when true."),
        new("Value",         "string",                     "—",     "On CommandItem: the value passed to OnValueChange."),
        new("Heading",       "string?",                    "null",  "On CommandGroup: heading text for the group."),
        new("Placeholder",   "string?",                    "null",  "On CommandInput: placeholder text."),
    ];

    private const string _paletteCode = """
        <!-- Trigger button -->
        <Button Variant="ButtonVariant.Outline" @onclick="OpenPalette">
            Search commands... <kbd>⌘K</kbd>
        </Button>

        <!-- Overlay (outside DemoBlock) -->
        @if (isPaletteOpen)
        {
            <div class="fixed inset-0 z-50 bg-background/80 backdrop-blur-sm" @onclick="ClosePalette">
                <div class="fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg">
                    <div class="overflow-hidden rounded-md border bg-popover shadow-md">
                        <CommandContent OnValueChange="HandleSelect">
                            <CommandInput Placeholder="Type a command or search..." />
                            <CommandList>
                                <CommandEmpty>No results found.</CommandEmpty>
                                <CommandGroup Heading="Suggestions">
                                    <CommandItem Value="calendar">Calendar</CommandItem>
                                </CommandGroup>
                            </CommandList>
                        </CommandContent>
                    </div>
                </div>
            </div>
        }
        """;

    private const string _basicCode = """
        <div class="rounded-lg border bg-background shadow-md w-full max-w-sm">
            <CommandContent OnValueChange="HandleValueChange">
                <CommandInput Placeholder="Type a command or search..." />
                <CommandList>
                    <CommandEmpty>No results found.</CommandEmpty>
                    <CommandGroup Heading="Suggestions">
                        <CommandItem Value="calendar">
                            <LucideIcon Name="calendar" Size="16" Class="mr-2" /> Calendar
                        </CommandItem>
                    </CommandGroup>
                </CommandList>
            </CommandContent>
        </div>
        """;

    private const string _groupedCode = """
        <CommandContent>
            <CommandInput Placeholder="Search..." />
            <CommandList>
                <CommandGroup Heading="Navigation">
                    <CommandItem Value="home">Home</CommandItem>
                    <CommandItem Value="dashboard">Dashboard</CommandItem>
                </CommandGroup>
                <CommandSeparator />
                <CommandGroup Heading="Account">
                    <CommandItem Value="settings">Settings</CommandItem>
                    <CommandItem Value="logout">Logout</CommandItem>
                </CommandGroup>
            </CommandList>
        </CommandContent>
        """;

    private const string _shortcutsCode = """
        <CommandItem Value="new-file">
            <LucideIcon Name="file" Size="16" Class="mr-2" /> New File
            <CommandShortcut>⌘N</CommandShortcut>
        </CommandItem>
        """;

    private const string _disabledCode = """
        <CommandItem Value="paste" Disabled="true">
            <LucideIcon Name="clipboard" Size="16" Class="mr-2" /> Paste (unavailable)
        </CommandItem>
        """;

    private const string _emptyCode = """
        <CommandEmpty>
            <div class="flex flex-col items-center gap-2 py-6">
                <LucideIcon Name="search-x" Size="32" Class="text-muted-foreground" />
                <p class="text-sm font-medium">No results found</p>
                <p class="text-xs text-muted-foreground">Try a different search term</p>
            </div>
        </CommandEmpty>
        """;
}
