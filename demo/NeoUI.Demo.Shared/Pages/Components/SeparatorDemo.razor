@page "/components/separator"

<PageTitle>Separator - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Separator"
        Description="Visually or semantically separates content." />

    <DemoSection
        Title="Horizontal"
        Description="Default separator spanning the full width.">
        <DemoBlock Code="@_horizontalCode">
            <div class="space-y-4 max-w-md">
                <div>
                    <h3 class="text-sm font-medium">NeoUI</h3>
                    <p class="text-sm text-muted-foreground">A Blazor UI component library</p>
                </div>
                <Separator Orientation="SeparatorOrientation.Horizontal" />
                <div class="space-y-1">
                    <h4 class="text-sm font-medium leading-none">Components</h4>
                    <p class="text-sm text-muted-foreground">Pre-built, production-ready components</p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Vertical"
        Description="Separator for horizontally arranged content.">
        <DemoBlock Code="@_verticalCode">
            <div class="flex h-20 items-center space-x-4 text-sm">
                <div>Button</div>
                <Separator Orientation="SeparatorOrientation.Vertical" />
                <div>Input</div>
                <Separator Orientation="SeparatorOrientation.Vertical" />
                <div>Badge</div>
                <Separator Orientation="SeparatorOrientation.Vertical" />
                <div>Separator</div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Decorative vs Semantic"
        Description="Control ARIA attributes for accessibility.">
        <DemoBlock Code="@_ariaCode">
            <div class="space-y-6 max-w-md">
                <div>
                    <h3 class="text-sm font-semibold mb-2">Decorative (Default)</h3>
                    <p class="text-xs text-muted-foreground mb-4">role="none" - Hidden from screen readers</p>
                    <p class="text-sm">Section 1</p>
                    <Separator Decorative="true" Class="my-4" />
                    <p class="text-sm">Section 2</p>
                </div>
                <div>
                    <h3 class="text-sm font-semibold mb-2">Semantic</h3>
                    <p class="text-xs text-muted-foreground mb-4">role="separator" - Announced to screen readers</p>
                    <h4 class="text-sm font-medium">Settings</h4>
                    <Separator Decorative="false" Class="my-4" />
                    <h4 class="text-sm font-medium">Privacy</h4>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Custom Styling"
        Description="Override styles with the Class parameter.">
        <DemoBlock Code="@_stylingCode">
            <div class="space-y-4 max-w-md">
                <div>
                    <p class="text-sm">Default separator</p>
                    <Separator Class="my-4" />
                </div>
                <div>
                    <p class="text-sm">Thicker separator</p>
                    <Separator Class="my-4 h-[2px]" />
                </div>
                <div>
                    <p class="text-sm">Colored separator</p>
                    <Separator Class="my-4 bg-primary" />
                </div>
                <div>
                    <p class="text-sm">Dashed separator</p>
                    <Separator Class="my-4 border-t border-dashed border-border h-0" />
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="In Lists"
        Description="Separating list items or menu options.">
        <DemoBlock Code="@_listCode">
            <div class="max-w-md border rounded-lg">
                <div class="p-4">
                    <h3 class="font-medium">Profile Settings</h3>
                    <p class="text-sm text-muted-foreground">Manage your account</p>
                </div>
                <Separator />
                <div class="p-4">
                    <h3 class="font-medium">Preferences</h3>
                    <p class="text-sm text-muted-foreground">Customize your experience</p>
                </div>
                <Separator />
                <div class="p-4">
                    <h3 class="font-medium">Notifications</h3>
                    <p class="text-sm text-muted-foreground">Configure alerts</p>
                </div>
                <Separator />
                <div class="p-4">
                    <h3 class="font-medium">Security</h3>
                    <p class="text-sm text-muted-foreground">Password and authentication</p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_separatorProps" />
    </DemoSection>

    <DemoPageNav />
</div>
