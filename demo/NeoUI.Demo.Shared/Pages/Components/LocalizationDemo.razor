@page "/components/localization"
@inject ILocalizer Localizer

<PageTitle>Localization - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Localization"
        Description="A DI-registered service that resolves all component chrome strings — placeholders, ARIA labels, button labels, empty states — without modifying library source." />

    <!-- ── Overview ─────────────────────────────────────────────────────── -->
    <DemoSection
        Title="Overview"
        Description="Every string NeoUI components render as UI chrome — placeholders, button labels, ARIA attributes, empty states, pagination text — is resolved through a single DI-registered <code>ILocalizer</code> abstraction. The library ships with English defaults for all keys out of the box.">
        <div class="space-y-4">
            <Alert>
                <AlertDescription>
                    <code>ILocalizer</code> has <strong>no dependency on <code>IStringLocalizer</code></strong> or any specific
                    localization framework. You choose your own strategy: a few <code>Set()</code> calls at startup, a subclass
                    backed by <code>.resx</code> resource files, JSON, a database — the interface is yours to implement.
                </AlertDescription>
            </Alert>
            <div class="grid gap-4 md:grid-cols-2">
                <Card Class="bg-muted/50">
                    <CardHeader>
                        <CardTitle Class="text-sm font-medium">
                            Library Chrome
                            <span class="text-xs font-normal text-muted-foreground ml-1.5">via <code>ILocalizer</code></span>
                        </CardTitle>
                        <CardDescription>
                            Strings owned by the library: placeholders, button labels, empty states,
                            pagination text, ARIA labels, and screen-reader text.
                        </CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="flex flex-wrap gap-1.5">
                            @foreach (var ex in new[] { "Search...", "No results found", "Rows per page", "Next", "Add tag…", "Close" })
                            {
                                <span class="font-mono text-xs bg-muted rounded px-1.5 py-0.5">@ex</span>
                            }
                        </div>
                    </CardContent>
                </Card>
                <Card Class="bg-muted/50">
                    <CardHeader>
                        <CardTitle Class="text-sm font-medium">
                            Culture-Aware Formatting
                            <span class="text-xs font-normal text-muted-foreground ml-1.5">automatic</span>
                        </CardTitle>
                        <CardDescription>
                            Calendar month/day names, date display formats, and numeric separators follow
                            <code>CultureInfo.CurrentCulture</code> automatically — no <code>ILocalizer</code> keys required.
                        </CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="flex flex-wrap gap-1.5">
                            @foreach (var ex in new[] { "\"March\" → \"März\"", "1,234.56 → 1.234,56" })
                            {
                                <span class="font-mono text-xs bg-muted rounded px-1.5 py-0.5">@ex</span>
                            }
                        </div>
                    </CardContent>
                </Card>
            </div>
            <Alert Variant="AlertVariant.Info">
                <AlertDescription>
                    <strong>Application data</strong> — column headers, option labels, and content text — is your
                    responsibility. <code>ILocalizer</code> covers only the library's own UI chrome.
                </AlertDescription>
            </Alert>
        </div>
    </DemoSection>

    <!-- ── Live Language Preview ─────────────────────────────────────────── -->
    <DemoSection
        Title="Live Language Preview"
        Description="Select a language below to see component strings update in real time. Each option builds a <code>DefaultLocalizer</code> pre-populated with its translations, then passes strings as explicit parameters — the same technique you use in production.">
        <DemoBlock Code="@LocalizationDemoCode.LivePreview">
            <div class="space-y-5">
                <div class="flex flex-wrap items-center gap-3">
                    <span class="text-sm font-medium text-muted-foreground">Language:</span>
                    <ToggleGroup Type="ToggleGroupType.Single" Value="@_previewLang" ValueChanged="OnPreviewLangChanged">
                        @foreach (var lang in _languages)
                        {
                            <ToggleGroupItem Value="@lang.Code" Class="gap-1.5 text-xs px-2.5">
                                <span>@lang.Flag</span>
                                <span>@lang.Name</span>
                            </ToggleGroupItem>
                        }
                    </ToggleGroup>
                </div>
                <div class="grid gap-4 sm:grid-cols-2">
                    <div class="space-y-1.5">
                        <p class="text-xs font-medium text-muted-foreground">Combobox</p>
                        <Combobox TItem="string"
                                  Items="@_frameworks"
                                  ValueSelector="@(s => s)"
                                  DisplaySelector="@(s => s)"
                                  Placeholder="@_previewLocalizer["Combobox.Placeholder"]"
                                  SearchPlaceholder="@_previewLocalizer["Combobox.SearchPlaceholder"]"
                                  EmptyMessage="@_previewLocalizer["Combobox.EmptyMessage"]"
                                  PopoverWidth="w-[260px]" />
                    </div>
                    <div class="space-y-1.5">
                        <p class="text-xs font-medium text-muted-foreground">MultiSelect</p>
                        <MultiSelect TItem="string"
                                     Items="@_frameworks"
                                     ValueSelector="@(s => s)"
                                     DisplaySelector="@(s => s)"
                                     @bind-Values="_liveMultiValues"
                                     Placeholder="@_previewLocalizer["MultiSelect.Placeholder"]"
                                     SearchPlaceholder="@_previewLocalizer["MultiSelect.SearchPlaceholder"]"
                                     EmptyMessage="@_previewLocalizer["MultiSelect.EmptyMessage"]"
                                     SelectAllLabel="@_previewLocalizer["MultiSelect.SelectAll"]"
                                     ClearLabel="@_previewLocalizer["MultiSelect.Clear"]"
                                     CloseLabel="@_previewLocalizer["MultiSelect.Close"]"
                                     PopoverWidth="w-[260px]" />
                    </div>
                    <div class="space-y-1.5">
                        <p class="text-xs font-medium text-muted-foreground">TagInput</p>
                        <TagInput @bind-Tags="_liveTags"
                                  Placeholder="@_previewLocalizer["TagInput.Placeholder"]" />
                    </div>
                    <div class="space-y-1.5">
                        <p class="text-xs font-medium text-muted-foreground">DatePicker</p>
                        <DatePicker Placeholder="@_previewLocalizer["DatePicker.Placeholder"]" />
                    </div>
                </div>
                <div class="space-y-1.5">
                    <p class="text-xs font-medium text-muted-foreground">Pagination</p>
                    <Pagination>
                        <PaginationContent>
                            <PaginationItem><PaginationPrevious Href="#" Text="@_previewLocalizer["Pagination.Previous"]" /></PaginationItem>
                            <PaginationItem><PaginationLink Href="#" IsActive="true">1</PaginationLink></PaginationItem>
                            <PaginationItem><PaginationLink Href="#">2</PaginationLink></PaginationItem>
                            <PaginationItem><PaginationLink Href="#">3</PaginationLink></PaginationItem>
                            <PaginationItem><PaginationNext Href="#" Text="@_previewLocalizer["Pagination.Next"]" /></PaginationItem>
                        </PaginationContent>
                    </Pagination>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <!-- ── Default strings ────────────────────────────────────────────────── -->
    <DemoSection
        Title="Default Behavior"
        Description="When no explicit string parameters are passed, components fall back to the injected <code>ILocalizer</code>. The library ships with English defaults for every component.">
        <DemoBlock Code="@LocalizationDemoCode.DefaultBehavior">
            <div class="space-y-6">
                <div class="space-y-1.5">
                    <p class="text-xs font-medium text-muted-foreground">Combobox — no Placeholder/SearchPlaceholder/EmptyMessage parameters</p>
                    <Combobox TItem="string"
                              Items="@_frameworks"
                              ValueSelector="@(s => s)"
                              DisplaySelector="@(s => s)"
                              PopoverWidth="w-[260px]" />
                </div>
                <div class="space-y-1.5">
                    <p class="text-xs font-medium text-muted-foreground">TagInput — no Placeholder parameter</p>
                    <div class="max-w-md">
                        <TagInput @bind-Tags="_defaultTags" />
                    </div>
                </div>
                <div class="space-y-1.5">
                    <p class="text-xs font-medium text-muted-foreground">PaginationPrevious / PaginationNext — no Text parameter</p>
                    <Pagination>
                        <PaginationContent>
                            <PaginationItem><PaginationPrevious Href="#" /></PaginationItem>
                            <PaginationItem><PaginationLink Href="#" IsActive="true">1</PaginationLink></PaginationItem>
                            <PaginationItem><PaginationNext Href="#" /></PaginationItem>
                        </PaginationContent>
                    </Pagination>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <!-- ── Per-instance override ──────────────────────────────────────────── -->
    <DemoSection
        Title="Per-Instance Override"
        Description="Pass an explicit string parameter to any component to override the localizer for that instance. All string parameters are nullable — existing code passing explicit strings continues to work unchanged.">
        <DemoBlock Code="@LocalizationDemoCode.PerInstanceOverride">
            <div class="space-y-6">
                <div class="space-y-1.5">
                    <p class="text-xs font-medium text-muted-foreground">German overrides via parameters (no global config needed)</p>
                    <Combobox TItem="string"
                              Items="@_frameworks"
                              ValueSelector="@(s => s)"
                              DisplaySelector="@(s => s)"
                              Placeholder="Framework auswählen..."
                              SearchPlaceholder="Suchen..."
                              EmptyMessage="Keine Ergebnisse gefunden."
                              PopoverWidth="w-[260px]" />
                </div>
                <div class="space-y-1.5">
                    <p class="text-xs font-medium text-muted-foreground">Custom Pagination labels</p>
                    <Pagination>
                        <PaginationContent>
                            <PaginationItem><PaginationPrevious Href="#" Text="Zurück" /></PaginationItem>
                            <PaginationItem><PaginationLink Href="#" IsActive="true">1</PaginationLink></PaginationItem>
                            <PaginationItem><PaginationNext Href="#" Text="Weiter" /></PaginationItem>
                        </PaginationContent>
                    </Pagination>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <!-- ── Option A — startup Set() override ────────────────────────────── -->
    <DemoSection
        Title="Option A — Startup-Time Override"
        Description="Configure the <code>DefaultLocalizer</code> at startup using the <code>AddNeoUIComponents</code> overload. All components using that key will render the customized string globally, with no component-level changes required.">
        <div class="rounded-lg border overflow-hidden bg-muted/50">
            <pre class="p-4 text-xs overflow-x-auto font-mono leading-relaxed">@LocalizationDemoCode.PatternA</pre>
        </div>
    </DemoSection>

    <!-- ── Option B — IStringLocalizer<T> integration ───────────────────── -->
    <DemoSection
        Title="@("Option B — Full IStringLocalizer<T> Integration")"
        Description="Subclass <code>DefaultLocalizer</code> to integrate with ASP.NET Core's <code>IStringLocalizer&lt;T&gt;</code> and <code>.resx</code> resource files. Only keys found in the resource file are substituted; the rest fall back to English defaults automatically.">
        <div class="rounded-lg border overflow-hidden bg-muted/50">
            <pre class="p-4 text-xs overflow-x-auto font-mono leading-relaxed">@LocalizationDemoCode.PatternB</pre>
        </div>
    </DemoSection>

    <!-- ── Scoped vs Singleton ───────────────────────────────────────────── -->
    <DemoSection
        Title="DI Lifetime: Scoped vs Singleton"
        Description="<code>ILocalizer</code> is registered as <strong>Scoped</strong> by <code>AddNeoUIComponents()</code> — each Blazor Server circuit and each WebAssembly session gets its own independent instance.">
        <div class="space-y-4">
            <div class="grid gap-4 md:grid-cols-2">
                <div class="p-4 border rounded-lg space-y-2">
                    <p class="text-sm font-medium">Scoped <span class="text-xs font-normal text-muted-foreground ml-1">(default)</span></p>
                    <p class="text-sm text-muted-foreground">One instance per Blazor Server circuit or WebAssembly session. Required for Option B so each user's <code>CultureInfo</code> is resolved independently.</p>
                </div>
                <div class="p-4 border rounded-lg space-y-2">
                    <p class="text-sm font-medium">Singleton</p>
                    <p class="text-sm text-muted-foreground">One shared instance for the entire application lifetime. Safe for Option A (static startup keys) and avoids per-circuit allocation. Incompatible with per-user culture switching.</p>
                </div>
            </div>
            <div class="rounded-lg border overflow-hidden bg-muted/50">
                <pre class="p-4 text-xs overflow-x-auto font-mono leading-relaxed">@LocalizationDemoCode.ScopedVsSingleton</pre>
            </div>
        </div>
    </DemoSection>

    <!-- ── Live key resolver ─────────────────────────────────────────────── -->
    <DemoSection
        Title="Live Key Lookup"
        Description="Try any localization key to see the resolved string from the currently active <code>ILocalizer</code>.">
        <DemoBlock Code="@LocalizationDemoCode.LiveLookup">
            <div class="space-y-3 max-w-md">
                <div class="flex gap-2">
                    <Input @bind-Value="_lookupKey"
                           Placeholder="e.g. Combobox.Placeholder"
                           Class="flex-1" />
                    <Button Variant="ButtonVariant.Outline" OnClick="RunLookup">Resolve</Button>
                </div>
                @if (_lookupResult is not null)
                {
                    <div class="flex items-center gap-2 rounded-md border bg-muted/50 px-3 py-2 text-sm">
                        <span class="font-mono text-muted-foreground">@_lookupKey</span>
                        <span class="text-muted-foreground">→</span>
                        <span class="font-medium">@_lookupResult</span>
                    </div>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <!-- ── Key reference table ───────────────────────────────────────────── -->
    <DemoSection
        Title="Key Reference"
        Description="All built-in localization keys shipped with <code>DefaultLocalizer</code> and their English default values.">
        <div class="rounded-lg border overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/50">
                            <th class="px-4 py-3 text-left font-medium text-muted-foreground">Key</th>
                            <th class="px-4 py-3 text-left font-medium text-muted-foreground">Default Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (key, value) in _keyReference)
                        {
                            <tr class="border-b last:border-0 hover:bg-muted/30 transition-colors">
                                <td class="px-4 py-2.5 font-mono text-xs text-foreground">@key</td>
                                <td class="px-4 py-2.5 text-muted-foreground">@value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </DemoSection>

    <DemoPageNav />
</div>

@code {
