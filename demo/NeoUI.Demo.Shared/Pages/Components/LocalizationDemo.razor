    private string _previewLang = "en";
    private ILocalizer _previewLocalizer = BuildPreviewLocalizer("en");
    private IReadOnlyList<string>? _liveTags;
    private IEnumerable<string>? _liveMultiValues;

    private static ILocalizer BuildPreviewLocalizer(string lang)
    {
        var loc = new DefaultLocalizer();
        if (_langTranslations.TryGetValue(lang, out var keys))
            foreach (var (key, value) in keys)
                loc.Set(key, value);
        return loc;
    }

    private void OnPreviewLangChanged(string? lang)
    {
        _previewLang = lang ?? "en";
        _previewLocalizer = BuildPreviewLocalizer(_previewLang);
    }

    // ── Shared ───────────────────────────────────────────────────────────────
    private IReadOnlyList<string>? _defaultTags;
    private string _lookupKey = "Combobox.Placeholder";
    private string? _lookupResult;

    private static readonly IReadOnlyList<string> _frameworks =
        ["Blazor", "React", "Vue", "Angular", "Svelte", "SolidJS"];

    private void RunLookup()
    {
        _lookupResult = string.IsNullOrWhiteSpace(_lookupKey)
            ? null
            : Localizer[_lookupKey];
    }

