@page "/components/selection-indicator"

<PageTitle>Selection Indicator - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Selection Indicator"
        Description="A composable, spring-animated indicator that slides between the active item in any selection container — Tabs, ToggleGroup, navigation links, or your own custom markup." />

    @* ── Tabs ──────────────────────────────────────────────────────────────── *@
    <DemoSection
        Title="Tabs"
        Description="Drop SelectionIndicator as the last child of TabsList. Pass Class to each TabsTrigger to clear its individual active background so the indicator shows through.">
        <DemoBlock Code="@_tabsCode">
            <Tabs DefaultValue="overview">
                <TabsList>
                    <TabsTrigger Value="overview"
                                 Class="relative z-1 data-[state=active]:bg-transparent data-[state=active]:shadow-none">
                        Overview
                    </TabsTrigger>
                    <TabsTrigger Value="analytics"
                                 Class="relative z-1 data-[state=active]:bg-transparent data-[state=active]:shadow-none">
                        Analytics
                    </TabsTrigger>
                    <TabsTrigger Value="reports"
                                 Class="relative z-1 data-[state=active]:bg-transparent data-[state=active]:shadow-none">
                        Reports
                    </TabsTrigger>
                    <TabsTrigger Value="settings"
                                 Class="relative z-1 data-[state=active]:bg-transparent data-[state=active]:shadow-none">
                        Settings
                    </TabsTrigger>
                    <SelectionIndicator Class="[--si-duration:500ms] [--si-easing:cubic-bezier(0.68,-0.55,0.27,1.35)]" />
                </TabsList>
                <TabsContent Value="overview">
                    <div class="rounded-lg border bg-card p-6 text-sm text-muted-foreground">Overview content</div>
                </TabsContent>
                <TabsContent Value="analytics">
                    <div class="rounded-lg border bg-card p-6 text-sm text-muted-foreground">Analytics content</div>
                </TabsContent>
                <TabsContent Value="reports">
                    <div class="rounded-lg border bg-card p-6 text-sm text-muted-foreground">Reports content</div>
                </TabsContent>
                <TabsContent Value="settings">
                    <div class="rounded-lg border bg-card p-6 text-sm text-muted-foreground">Settings content</div>
                </TabsContent>
            </Tabs>
        </DemoBlock>
    </DemoSection>

    @* ── Segmented Control (ToggleGroup) ───────────────────────────────────── *@
    <DemoSection
        Title="Segmented Control"
        Description="A ToggleGroup in Single mode styled as a segmented control. Use Selector=&quot;[aria-checked=true]&quot; — ToggleGroupItem marks selection via aria-checked rather than data-state.">
        <DemoBlock Code="@_segmentedCode">
            <div class="space-y-4">
                <ToggleGroup Type="ToggleGroupType.Single"
                             @bind-Value="@_alignment"
                             Class="bg-muted p-1 rounded-md gap-0">
                    <ToggleGroupItem Value="left"    Class="relative z-1 bg-transparent aria-checked:hover:bg-transparent"><LucideIcon Name="align-left"    Class="h-4 w-4" /></ToggleGroupItem>
                    <ToggleGroupItem Value="center"  Class="relative z-1 bg-transparent aria-checked:hover:bg-transparent"><LucideIcon Name="align-center"  Class="h-4 w-4" /></ToggleGroupItem>
                    <ToggleGroupItem Value="right"   Class="relative z-1 bg-transparent aria-checked:hover:bg-transparent"><LucideIcon Name="align-right"   Class="h-4 w-4" /></ToggleGroupItem>
                    <ToggleGroupItem Value="justify" Class="relative z-1 bg-transparent aria-checked:hover:bg-transparent"><LucideIcon Name="align-justify" Class="h-4 w-4" /></ToggleGroupItem>
                    <SelectionIndicator Selector="[aria-checked=true]" />
                </ToggleGroup>
                <p class="text-sm text-muted-foreground">Alignment: <strong>@(_alignment ?? "none")</strong></p>
            </div>
        </DemoBlock>
    </DemoSection>

    @* ── DropdownMenu Radio ─────────────────────────────────────────────────── *@
    <DemoSection
        Title="DropdownMenu Radio"
        Description="Place SelectionIndicator inside DropdownMenuRadioGroup. The indicator slides vertically to highlight the checked item — works because SelectionIndicator now tracks top and height in addition to left and width.">
        <DemoBlock Code="@_dropdownCode">
            <DropdownMenu>
                <DropdownMenuTrigger AsChild="true">
                    <Button Variant="ButtonVariant.Outline">
                        <LucideIcon Name="layout-grid" Class="h-4 w-4 mr-2" />
                        View as @_viewMode
                    </Button>
                </DropdownMenuTrigger>
                <DropdownMenuContent Class="w-40">
                    <DropdownMenuLabel>View As</DropdownMenuLabel>
                    <DropdownMenuSeparator />
                    <DropdownMenuRadioGroup @bind-Value="@_viewMode">
                        <DropdownMenuRadioItem TValue="string" Value="@("List")"    CloseOnSelect="false" Class="relative z-1 hover:bg-transparent focus:bg-transparent">List</DropdownMenuRadioItem>
                        <DropdownMenuRadioItem TValue="string" Value="@("Grid")"    CloseOnSelect="false" Class="relative z-1 hover:bg-transparent focus:bg-transparent">Grid</DropdownMenuRadioItem>
                        <DropdownMenuRadioItem TValue="string" Value="@("Columns")" CloseOnSelect="false" Class="relative z-1 hover:bg-transparent focus:bg-transparent">Columns</DropdownMenuRadioItem>
                        <SelectionIndicator Selector="[data-state=checked]"
                                            Hover="true"
                                            Class="inset-x-1 bg-accent data-[si-hover]:bg-accent/50 rounded-sm shadow-none" />
                    </DropdownMenuRadioGroup>
                </DropdownMenuContent>
            </DropdownMenu>
        </DemoBlock>
    </DemoSection>

    @* ── DropdownMenu Items (hover-only) ───────────────────────────────────── *@
    <DemoSection
        Title="DropdownMenu (Hover Only)"
        Description="Regular menu items have no persistent selected state, so the indicator works purely in hover mode. Use HoverTarget to scope hover detection to &quot;[role=menuitem]&quot; so labels and separators are ignored. The indicator snaps instantly to the first hovered item and animates between items thereafter.">
        <DemoBlock Code="@_dropdownHoverCode">
            <DropdownMenu>
                <DropdownMenuTrigger AsChild="true">
                    <Button Variant="ButtonVariant.Outline">
                        <LucideIcon Name="plus" Class="h-4 w-4 mr-2" />
                        Create New
                    </Button>
                </DropdownMenuTrigger>
                <DropdownMenuContent Class="w-44">
                    <DropdownMenuLabel>Create New</DropdownMenuLabel>
                    <DropdownMenuSeparator />
                    <DropdownMenuItem Class="relative z-1 hover:bg-transparent focus:bg-transparent">
                        <LucideIcon Name="file" Class="h-4 w-4 mr-2" />Document
                    </DropdownMenuItem>
                    <DropdownMenuItem Class="relative z-1 hover:bg-transparent focus:bg-transparent">
                        <LucideIcon Name="folder" Class="h-4 w-4 mr-2" />Folder
                    </DropdownMenuItem>
                    <DropdownMenuItem Class="relative z-1 hover:bg-transparent focus:bg-transparent">
                        <LucideIcon Name="image" Class="h-4 w-4 mr-2" />Image
                    </DropdownMenuItem>
                    <DropdownMenuItem Class="relative z-1 hover:bg-transparent focus:bg-transparent">
                        <LucideIcon Name="link" Class="h-4 w-4 mr-2" />Link
                    </DropdownMenuItem>
                    <SelectionIndicator
                        Hover="true"
                        HoverTarget="[role=menuitem]"
                        Class="inset-x-1 bg-accent rounded-sm shadow-none" />
                </DropdownMenuContent>
            </DropdownMenu>
        </DemoBlock>
    </DemoSection>

    @* ── Pagination ─────────────────────────────────────────────────────────── *@
    <DemoSection
        Title="Pagination"
        Description="PaginationLink sets aria-current=&quot;page&quot; on the active page. Use Selector=&quot;[aria-current=page]&quot; and suppress PaginationLink's own active background so the indicator shows through.">
        <DemoBlock Code="@_paginationCode">
            <div class="space-y-4">
                <div class="inline-flex items-center bg-muted p-1 rounded-lg gap-0">
                    @for (var i = 1; i <= 5; i++)
                    {
                        var page = i;
                        <PaginationLink IsActive="@(_page == page)"
                                        OnClick="@(() => _page = page)"
                                        Class="relative z-1 border-transparent bg-transparent hover:bg-transparent w-9 h-9">
                            @(page)
                        </PaginationLink>
                    }
                    <SelectionIndicator Selector="[aria-current=page]" />
                </div>
                <p class="text-sm text-muted-foreground">Page: <strong>@_page</strong> of 5</p>
            </div>
        </DemoBlock>
    </DemoSection>


    <DemoSection
        Title="Navigation Underline"
        Description="Use the Class parameter to override the default pill appearance. Here Class replaces the vertical inset and background with a thin bottom border that acts as an underline.">
        <DemoBlock Code="@_navCode">
            <div class="space-y-4">
                <div class="inline-flex items-stretch border-b border-border">
                    @foreach (var item in _navItems)
                    {
                        <button class="@NavLinkClass(item)"
                                data-active="@(_activeNav == item ? "true" : null)"
                                @onclick="@(() => _activeNav = item)">
                            @item
                        </button>
                    }
                    <SelectionIndicator
                        Selector="[data-active=true]"
                        Class="rounded-none bg-foreground [--si-height:2px]" />
                </div>
                <p class="text-sm text-muted-foreground">Active: <strong>@_activeNav</strong></p>
            </div>
        </DemoBlock>
    </DemoSection>

    @* ── Custom Container ──────────────────────────────────────────────────── *@
    <DemoSection
        Title="Custom Container"
        Description="SelectionIndicator works with any markup — not just NeoUI components. Set data-active=&quot;true&quot; on whichever element should be active and add the indicator as a sibling. No context or event wiring needed.">
        <DemoBlock Code="@_customCode">
            <div class="space-y-4">
                <div class="inline-flex bg-muted rounded-lg p-1">
                    @foreach (var period in _periods)
                    {
                        <button class="@PeriodClass(period)"
                                data-active="@(_period == period ? "true" : null)"
                                @onclick="@(() => _period = period)">
                            @period
                        </button>
                    }
                    <SelectionIndicator Selector="[data-active=true]" />
                </div>
                <p class="text-sm text-muted-foreground">Period: <strong>@_period</strong></p>
            </div>
        </DemoBlock>
    </DemoSection>

    @* ── API Reference ─────────────────────────────────────────────────────── *@
    <DemoSection Title="API Reference" Description="SelectionIndicator parameters.">
        <DemoPropsTable Rows="_props" />
    </DemoSection>

    <DemoPageNav />
</div>

@code {
    private string? _alignment = "center";
    private string  _activeNav  = "Overview";
    private string  _period     = "1M";
    private string  _viewMode   = "List";
    private int     _page       = 1;

    private static readonly string[] _navItems  = ["Overview", "Changelog", "Examples", "API"];
    private static readonly string[] _periods   = ["1D", "7D", "1M", "3M", "1Y", "All"];

    private string NavLinkClass(string item) => ClassNames.cn(
        "relative z-1 px-4 py-2 text-sm font-medium transition-colors",
        _activeNav == item
            ? "text-foreground"
            : "text-muted-foreground hover:text-foreground");

    private string PeriodClass(string p) => ClassNames.cn(
        "relative z-1 px-3 py-1 text-xs font-medium rounded-md transition-colors",
        _period == p
            ? "text-foreground"
            : "text-muted-foreground hover:text-foreground");
}
