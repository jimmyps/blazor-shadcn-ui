@page "/components/badge"

<PageTitle>Badge - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Badge"
        Description="Displays a badge or a component that looks like a badge." />

    <DemoSection
        Title="Variants"
        Description="Four badge variants for different use cases.">
        <DemoBlock Code="@_variantsCode">
            <div class="flex flex-wrap gap-4">
                <Badge Variant="BadgeVariant.Default">Default</Badge>
                <Badge Variant="BadgeVariant.Secondary">Secondary</Badge>
                <Badge Variant="BadgeVariant.Destructive">Destructive</Badge>
                <Badge Variant="BadgeVariant.Outline">Outline</Badge>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Usage Examples"
        Description="Common use cases for badges.">
        <DemoBlock Code="@_usageCode">
            <div class="space-y-6">
                <div class="space-y-3">
                    <h3 class="text-lg font-medium">Status Indicators</h3>
                    <div class="flex flex-wrap gap-3">
                        <div class="flex items-center gap-2">
                            <span class="text-sm">Active:</span>
                            <Badge Variant="BadgeVariant.Default">Active</Badge>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-sm">Pending:</span>
                            <Badge Variant="BadgeVariant.Secondary">Pending</Badge>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-sm">Error:</span>
                            <Badge Variant="BadgeVariant.Destructive">Error</Badge>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-sm">Draft:</span>
                            <Badge Variant="BadgeVariant.Outline">Draft</Badge>
                        </div>
                    </div>
                </div>
                <div class="space-y-3">
                    <h3 class="text-lg font-medium">Notification Counts</h3>
                    <div class="flex flex-wrap gap-4 items-center">
                        <div class="flex items-center gap-2">
                            <span class="text-sm">Messages</span>
                            <Badge Variant="BadgeVariant.Default">3</Badge>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-sm">Unread</span>
                            <Badge Variant="BadgeVariant.Destructive">12</Badge>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-sm">Completed</span>
                            <Badge Variant="BadgeVariant.Secondary">24</Badge>
                        </div>
                    </div>
                </div>
                <div class="space-y-3">
                    <h3 class="text-lg font-medium">Tags/Labels</h3>
                    <div class="flex flex-wrap gap-2">
                        <Badge Variant="BadgeVariant.Outline">React</Badge>
                        <Badge Variant="BadgeVariant.Outline">TypeScript</Badge>
                        <Badge Variant="BadgeVariant.Outline">Tailwind CSS</Badge>
                        <Badge Variant="BadgeVariant.Outline">Blazor</Badge>
                        <Badge Variant="BadgeVariant.Outline">C#</Badge>
                    </div>
                </div>
                <div class="space-y-3">
                    <h3 class="text-lg font-medium">Feature Flags</h3>
                    <div class="flex flex-wrap gap-4 items-center">
                        <div class="flex items-center gap-2">
                            <span class="text-sm">New Feature</span>
                            <Badge Variant="BadgeVariant.Default">NEW</Badge>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-sm">Beta</span>
                            <Badge Variant="BadgeVariant.Secondary">BETA</Badge>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-sm">Deprecated</span>
                            <Badge Variant="BadgeVariant.Destructive">DEPRECATED</Badge>
                        </div>
                    </div>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="In Lists"
        Description="Badges combined with other components.">
        <DemoBlock Code="@_inListsCode">
            <div class="max-w-md border rounded-lg divide-y">
                <div class="p-4 flex items-center justify-between">
                    <div class="space-y-1">
                        <h4 class="text-sm font-medium">Project Alpha</h4>
                        <p class="text-sm text-muted-foreground">Active development</p>
                    </div>
                    <Badge Variant="BadgeVariant.Default">In Progress</Badge>
                </div>
                <div class="p-4 flex items-center justify-between">
                    <div class="space-y-1">
                        <h4 class="text-sm font-medium">Project Beta</h4>
                        <p class="text-sm text-muted-foreground">Under review</p>
                    </div>
                    <Badge Variant="BadgeVariant.Secondary">Review</Badge>
                </div>
                <div class="p-4 flex items-center justify-between">
                    <div class="space-y-1">
                        <h4 class="text-sm font-medium">Project Gamma</h4>
                        <p class="text-sm text-muted-foreground">Deployment failed</p>
                    </div>
                    <Badge Variant="BadgeVariant.Destructive">Failed</Badge>
                </div>
                <div class="p-4 flex items-center justify-between">
                    <div class="space-y-1">
                        <h4 class="text-sm font-medium">Project Delta</h4>
                        <p class="text-sm text-muted-foreground">Planning phase</p>
                    </div>
                    <Badge Variant="BadgeVariant.Outline">Draft</Badge>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Icons"
        Description="Badges can include icons or other content.">
        <DemoBlock Code="@_withIconsCode">
            <div class="flex flex-wrap gap-4">
                <Badge Variant="BadgeVariant.Default">
                    <LucideIcon Name="check" Size="12" Class="mr-1" />
                    Verified
                </Badge>
                <Badge Variant="BadgeVariant.Destructive">
                    <LucideIcon Name="x" Size="12" Class="mr-1" />
                    Closed
                </Badge>
                <Badge Variant="BadgeVariant.Secondary">
                    <LucideIcon Name="star" Size="12" Class="mr-1" />
                    Featured
                </Badge>
                <Badge Variant="BadgeVariant.Outline">
                    <LucideIcon Name="heart" Size="12" Class="mr-1" />
                    Favorite
                </Badge>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Custom Styling"
        Description="Override styles with the Class parameter.">
        <DemoBlock Code="@_customStylingCode">
            <div class="flex flex-wrap gap-4">
                <Badge Variant="BadgeVariant.Default" Class="text-lg px-4 py-1">Large Badge</Badge>
                <Badge Variant="BadgeVariant.Secondary" Class="rounded-sm">Square Corners</Badge>
                <Badge Variant="BadgeVariant.Outline" Class="border-2 border-blue-500 text-blue-500">Custom Color</Badge>
                <Badge Variant="BadgeVariant.Default" Class="bg-gradient-to-r from-purple-500 to-pink-500 border-0">Gradient</Badge>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Accessibility"
        Description="Keep text concise (1–2 words or small numbers). Don't rely solely on color to convey meaning — always include text. Ensure the badge's meaning is clear from surrounding content." />

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_badgeProps" />
    </DemoSection>

    <DemoPageNav />
</div>

@code {
    private static readonly IReadOnlyList<DemoPropRow> _badgeProps =
    [
        new("Variant",      "BadgeVariant",    "Default",  "Visual style variant. Options: Default, Secondary, Destructive, Outline."),
        new("Class",        "string?",          null,       "Additional CSS classes to apply to the badge element."),
        new("ChildContent", "RenderFragment?",  null,       "The content to display inside the badge (text, icons, numbers, etc.)."),
    ];

    private const string _variantsCode =
        """
        <Badge Variant="BadgeVariant.Default">Default</Badge>
        <Badge Variant="BadgeVariant.Secondary">Secondary</Badge>
        <Badge Variant="BadgeVariant.Destructive">Destructive</Badge>
        <Badge Variant="BadgeVariant.Outline">Outline</Badge>
        """;

    private const string _usageCode =
        """
        <Badge Variant="BadgeVariant.Default">Active</Badge>
        <Badge Variant="BadgeVariant.Secondary">Pending</Badge>
        <Badge Variant="BadgeVariant.Destructive">Error</Badge>
        <Badge Variant="BadgeVariant.Outline">Draft</Badge>
        """;

    private const string _inListsCode =
        """
        <div class="flex items-center justify-between p-4">
            <div>
                <h4 class="text-sm font-medium">Project Alpha</h4>
                <p class="text-sm text-muted-foreground">Active development</p>
            </div>
            <Badge Variant="BadgeVariant.Default">In Progress</Badge>
        </div>
        """;

    private const string _withIconsCode =
        """
        <Badge Variant="BadgeVariant.Default">
            <LucideIcon Name="check" Size="12" Class="mr-1" />
            Verified
        </Badge>
        <Badge Variant="BadgeVariant.Destructive">
            <LucideIcon Name="x" Size="12" Class="mr-1" />
            Closed
        </Badge>
        """;

    private const string _customStylingCode =
        """
        <Badge Variant="BadgeVariant.Default" Class="text-lg px-4 py-1">Large Badge</Badge>
        <Badge Variant="BadgeVariant.Secondary" Class="rounded-sm">Square Corners</Badge>
        <Badge Variant="BadgeVariant.Outline" Class="border-2 border-blue-500 text-blue-500">Custom Color</Badge>
        """;
}
