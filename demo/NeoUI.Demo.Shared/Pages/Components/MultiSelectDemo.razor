@page "/components/multi-select"

<PageTitle>Multi Select - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Multi Select"
        Description="A searchable multi-select component that allows selecting multiple options with checkbox indicators and tag display." />

    <DemoSection
        Title="Basic Multi Select"
        Description="Select multiple programming languages. Selected items appear as tags.">
        <DemoBlock Code="@_basicCode">
            <div class="flex flex-col gap-2">
                <MultiSelect TItem="Language"
                            Items="languages"
                            @bind-Values="selectedLanguages"
                            ValueSelector="@(l => l.Value)"
                            DisplaySelector="@(l => l.Label)"
                            Placeholder="Select languages..."
                            SearchPlaceholder="Search languages..."
                            EmptyMessage="No language found."
                            PopoverWidth="w-[300px]" />
                @if (selectedLanguages?.Any() == true)
                {
                    <p class="text-sm">Selected (display): <strong>@string.Join(", ", selectedLanguages.Select(GetLanguageLabel))</strong></p>
                    <p class="text-sm">Selected (values): <strong>[@string.Join(", ", selectedLanguages)]</strong></p>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Tech Stack Selector"
        Description="Select your tech stack. Uses ShowSelectAll and MaxDisplayTags to control tag display.">
        <DemoBlock Code="@_techStackCode">
            <div class="flex flex-col gap-2">
                <MultiSelect TItem="Technology"
                            Items="technologies"
                            @bind-Values="selectedTechnologies"
                            ValueSelector="@(t => t.Value)"
                            DisplaySelector="@(t => t.Label)"
                            Placeholder="Select technologies..."
                            SearchPlaceholder="Search..."
                            ShowSelectAll="true"
                            SelectAllLabel="Select All"
                            MaxDisplayTags="3"
                            PopoverWidth="w-[320px]" />
                @if (selectedTechnologies?.Any() == true)
                {
                    <p class="text-sm">
                        Selected (@selectedTechnologies.Count()):
                        <strong>@string.Join(", ", selectedTechnologies.Select(GetTechnologyLabel))</strong>
                    </p>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Country Selector"
        Description="Select countries with overflow indicator (+N more).">
        <DemoBlock Code="@_countryCode">
            <div class="flex flex-col gap-2">
                <MultiSelect TItem="Country"
                            Items="countries"
                            @bind-Values="selectedCountries"
                            ValueSelector="@(c => c.Code)"
                            DisplaySelector="@(c => c.Name)"
                            Placeholder="Select countries..."
                            SearchPlaceholder="Search country..."
                            MaxDisplayTags="2"
                            ShowSelectAll="true"
                            PopoverWidth="w-[280px]" />
                @if (selectedCountries?.Any() == true)
                {
                    <p class="text-sm">
                        Selected (@selectedCountries.Count()):
                        <strong>@string.Join(", ", selectedCountries.Select(GetCountryName))</strong>
                    </p>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Without Select All"
        Description="Multi Select without the Select All option.">
        <DemoBlock Code="@_withoutSelectAllCode">
            <div class="flex flex-col gap-2">
                <MultiSelect TItem="Framework"
                            Items="frameworks"
                            @bind-Values="selectedFrameworks"
                            ValueSelector="@(f => f.Value)"
                            DisplaySelector="@(f => f.Label)"
                            Placeholder="Select frameworks..."
                            SearchPlaceholder="Search..."
                            ShowSelectAll="false"
                            PopoverWidth="w-[250px]" />
                @if (selectedFrameworks?.Any() == true)
                {
                    <p class="text-sm">Selected (display): <strong>@string.Join(", ", selectedFrameworks.Select(GetFrameworkLabel))</strong></p>
                    <p class="text-sm">Selected (values): <strong>[@string.Join(", ", selectedFrameworks)]</strong></p>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Prevent Auto Close"
        Description="The dropdown can be configured to stay open when clicking outside.">
        <DemoBlock Code="@_autoCloseCode">
            <ChildContent>
                <div class="flex flex-col gap-2">
                    <MultiSelect TItem="Framework"
                                Items="frameworks"
                                @bind-Values="autoCloseFrameworks"
                                ValueSelector="@(f => f.Value)"
                                DisplaySelector="@(f => f.Label)"
                                Placeholder="Select frameworks..."
                                SearchPlaceholder="Search..."
                                AutoClose="false"
                                PopoverWidth="w-[280px]" />
                    @if (autoCloseFrameworks?.Any() == true)
                    {
                        <p class="text-sm">Selected: <strong>@string.Join(", ", autoCloseFrameworks.Select(GetFrameworkLabel))</strong></p>
                    }
                </div>
            </ChildContent>
            <AdditionalContent>
                <p class="text-sm text-muted-foreground">
                    With <code class="bg-muted px-1 py-0.5 rounded">AutoClose="false"</code>, the dropdown stays open when you click outside. Use the Close button or press Escape to close it.
                </p>
            </AdditionalContent>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Match Trigger Width"
        Description="With MatchTriggerWidth=&quot;true&quot;, the dropdown automatically matches the width of the trigger element.">
        <DemoBlock Code="@_matchWidthCode">
            <div class="flex flex-col gap-4">
                <div class="w-72">
                    <label class="text-sm font-medium mb-2 block">Fixed width container (w-72)</label>
                    <MultiSelect TItem="Language"
                                Items="languages"
                                @bind-Values="matchWidthLanguages"
                                ValueSelector="@(l => l.Value)"
                                DisplaySelector="@(l => l.Label)"
                                Placeholder="Select languages..."
                                SearchPlaceholder="Search..."
                                MatchTriggerWidth="true"
                                Class="w-full" />
                </div>
                <div class="w-[500px]">
                    <label class="text-sm font-medium mb-2 block">Wider container (500px)</label>
                    <MultiSelect TItem="Technology"
                                Items="technologies"
                                @bind-Values="matchWidthTechnologies"
                                ValueSelector="@(t => t.Value)"
                                DisplaySelector="@(t => t.Label)"
                                Placeholder="Select technologies..."
                                SearchPlaceholder="Search..."
                                ShowSelectAll="true"
                                MatchTriggerWidth="true"
                                Class="w-full" />
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Disabled State"
        Description="Multi Select in disabled state with pre-selected values.">
        <DemoBlock Code="@_disabledCode">
            <MultiSelect TItem="Language"
                        Items="languages"
                        Values="@disabledValues"
                        ValueSelector="@(l => l.Value)"
                        DisplaySelector="@(l => l.Label)"
                        Placeholder="Disabled multiselect"
                        Disabled="true"
                        PopoverWidth="w-[300px]" />
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Form Integration"
        Description="Example of Multi Select in a form layout.">
        <DemoBlock Code="@_formCode">
            <div class="space-y-4 max-w-md border rounded-lg p-6">
                <div class="space-y-2">
                    <label class="text-sm font-medium">Skills</label>
                    <MultiSelect TItem="Language"
                                Items="languages"
                                @bind-Values="formSkills"
                                ValueSelector="@(l => l.Value)"
                                DisplaySelector="@(l => l.Label)"
                                Placeholder="Select your skills..."
                                SearchPlaceholder="Search skills..."
                                ShowSelectAll="true"
                                MatchTriggerWidth="true" />
                    <p class="text-xs text-muted-foreground">Select all programming languages you know.</p>
                </div>
                <div class="space-y-2">
                    <label class="text-sm font-medium">Preferred Frameworks</label>
                    <MultiSelect TItem="Framework"
                                Items="frameworks"
                                @bind-Values="formFrameworks"
                                ValueSelector="@(f => f.Value)"
                                DisplaySelector="@(f => f.Label)"
                                Placeholder="Select frameworks..."
                                SearchPlaceholder="Search frameworks..."
                                MaxDisplayTags="2"
                                MatchTriggerWidth="true" />
                    <p class="text-xs text-muted-foreground">Choose your preferred frameworks.</p>
                </div>
                <div class="pt-4 border-t">
                    <Button Variant="ButtonVariant.Default" OnClick="HandleFormSubmit">
                        Submit
                    </Button>
                    @if (formSubmitted)
                    {
                        <div class="text-sm text-green-600 mt-2 space-y-1">
                            <p>Form submitted!</p>
                            <p>Skills: <strong>@(formSkills?.Any() == true ? string.Join(", ", formSkills.Select(GetLanguageLabel)) : "None")</strong></p>
                            <p>Frameworks: <strong>@(formFrameworks?.Any() == true ? string.Join(", ", formFrameworks.Select(GetFrameworkLabel)) : "None")</strong></p>
                        </div>
                    }
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Infinite Scroll"
        Description="Load items in batches as the user scrolls to the bottom of the list.">
        <DemoBlock Code="@_infiniteScrollCode">
            <AdditionalContent>
                <Alert Variant="AlertVariant.Info">
                    <Icon><LucideIcon Name="info" Size="16" /></Icon>
                    <ChildContent>
                        <AlertDescription>
                            Open the dropdown and scroll to the bottom to trigger <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">OnLoadMore</code>.
                            A spinner appears during the simulated 600 ms fetch. Once all @_msTotalItems items are loaded,
                            <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">EndOfListMessage</code> is shown instead.
                        </AlertDescription>
                    </ChildContent>
                </Alert>
            </AdditionalContent>
            <ChildContent>
                <div class="flex flex-col gap-2">
                    <MultiSelect TItem="NumberedMsItem"
                                Items="@_msDisplayedItems"
                                @bind-Values="_msPagedValues"
                                ValueSelector="@(x => x.Value)"
                                DisplaySelector="@(x => x.Label)"
                                Placeholder="Select options..."
                                SearchPlaceholder="Search options..."
                                OnLoadMore="@HandleMsLoadMore"
                                IsLoading="@_msPagedLoading"
                                EndOfListMessage="@MsEndMessage"
                                SearchQueryChanged="@HandleMsInfiniteSearch"
                                PopoverWidth="w-[300px]" />
                    <p class="text-xs text-muted-foreground">
                        @if (!string.IsNullOrWhiteSpace(_msSearchQuery))
                        {
                            <span>@_msFilteredTotal results for "@_msSearchQuery"</span>
                        }
                        else
                        {
                            <span>@Math.Min(_msDisplayedCount, _msTotalItems) / @_msTotalItems items loaded</span>
                        }
                        @if (_msPagedValues?.Any() == true)
                        {
                            <span> · @_msPagedValues.Count() selected</span>
                        }
                    </p>
                </div>
            </ChildContent>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Server-Side Search"
        Description="Use SearchQueryChanged to drive filtering externally. The built-in text filter is bypassed and the consumer controls the displayed items.">
        <DemoBlock Code="@_searchQueryChangedCode">
            <AdditionalContent>
                <Alert Variant="AlertVariant.Info">
                    <Icon><LucideIcon Name="info" Size="16" /></Icon>
                    <ChildContent>
                        <AlertDescription>
                            The search input fires <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">SearchQueryChanged</code> on every keystroke.
                            A 300 ms simulated delay mimics a server round-trip. Because <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">SearchQueryChanged</code> has a delegate,
                            the component's built-in text filter is completely bypassed — the consumer decides what <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">Items</code> to show.
                            On close, the callback fires with an empty string so the consumer can reload the default list.
                        </AlertDescription>
                    </ChildContent>
                </Alert>
            </AdditionalContent>
            <ChildContent>
                <div class="flex flex-col gap-2">
                    <MultiSelect TItem="PersonItem"
                                Items="@_filteredPeople"
                                @bind-Values="_selectedPeople"
                                ValueSelector="@(p => p.Value)"
                                DisplaySelector="@(p => p.Label)"
                                Placeholder="Search and select people..."
                                SearchPlaceholder="Type to search..."
                                SearchQueryChanged="@HandlePeopleSearch"
                                IsLoading="@_peopleSearching"
                                PopoverWidth="w-[320px]" />
                    <p class="text-xs text-muted-foreground">
                        @_filteredPeople.Count / @_allPeople.Count matches
                        @if (_selectedPeople?.Any() == true)
                        {
                            <span> · @_selectedPeople.Count() selected</span>
                        }
                    </p>
                </div>
            </ChildContent>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="API Reference"
        Description="Component parameters and their types.">
        <DemoPropsTable Rows="_multiSelectProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private IEnumerable<string>? selectedLanguages;
    private IEnumerable<string>? selectedTechnologies;
    private IEnumerable<string>? selectedCountries;
    private IEnumerable<string>? selectedFrameworks;
    private IEnumerable<string>? autoCloseFrameworks;
    private IEnumerable<string> disabledValues = new[] { "csharp", "typescript" };
    private IEnumerable<string>? matchWidthLanguages;
    private IEnumerable<string>? matchWidthTechnologies;
    private IEnumerable<string>? formSkills;
    private IEnumerable<string>? formFrameworks;
    private bool formSubmitted;

    private readonly List<Language> languages = new()
    {
        new Language { Value = "csharp", Label = "C#" },
        new Language { Value = "typescript", Label = "TypeScript" },
        new Language { Value = "javascript", Label = "JavaScript" },
        new Language { Value = "python", Label = "Python" },
        new Language { Value = "java", Label = "Java" },
        new Language { Value = "go", Label = "Go" },
        new Language { Value = "rust", Label = "Rust" },
        new Language { Value = "php", Label = "PHP" }
    };

    private readonly List<Technology> technologies = new()
    {
        new Technology { Value = "react", Label = "React" },
        new Technology { Value = "vue", Label = "Vue.js" },
        new Technology { Value = "angular", Label = "Angular" },
        new Technology { Value = "blazor", Label = "Blazor" },
        new Technology { Value = "nextjs", Label = "Next.js" },
        new Technology { Value = "nodejs", Label = "Node.js" },
        new Technology { Value = "dotnet", Label = ".NET" },
        new Technology { Value = "docker", Label = "Docker" },
        new Technology { Value = "kubernetes", Label = "Kubernetes" },
        new Technology { Value = "aws", Label = "AWS" }
    };

    private readonly List<Framework> frameworks = new()
    {
        new Framework { Value = "nextjs", Label = "Next.js" },
        new Framework { Value = "sveltekit", Label = "SvelteKit" },
        new Framework { Value = "nuxtjs", Label = "Nuxt.js" },
        new Framework { Value = "remix", Label = "Remix" },
        new Framework { Value = "astro", Label = "Astro" },
        new Framework { Value = "blazor", Label = "Blazor" }
    };

    private readonly List<Country> countries = new()
    {
        new Country { Code = "US", Name = "United States" },
        new Country { Code = "GB", Name = "United Kingdom" },
        new Country { Code = "CA", Name = "Canada" },
        new Country { Code = "AU", Name = "Australia" },
        new Country { Code = "DE", Name = "Germany" },
        new Country { Code = "FR", Name = "France" },
        new Country { Code = "JP", Name = "Japan" },
        new Country { Code = "BR", Name = "Brazil" },
        new Country { Code = "MX", Name = "Mexico" },
        new Country { Code = "NL", Name = "Netherlands" }
    };

    private string GetLanguageLabel(string value) =>
        languages.FirstOrDefault(l => l.Value == value)?.Label ?? value;

    private string GetTechnologyLabel(string value) =>
        technologies.FirstOrDefault(t => t.Value == value)?.Label ?? value;

    private string GetFrameworkLabel(string value) =>
        frameworks.FirstOrDefault(f => f.Value == value)?.Label ?? value;

    private string GetCountryName(string code) =>
        countries.FirstOrDefault(c => c.Code == code)?.Name ?? code;

    private void HandleFormSubmit()
    {
        formSubmitted = true;
        StateHasChanged();
    }

    // Infinite Scroll demo
    private static readonly IReadOnlyList<NumberedMsItem> _masterMsItems =
        Enumerable.Range(1, 50).Select(i => new NumberedMsItem { Value = $"ms-item-{i}", Label = $"Option {i}" }).ToList();
    private List<NumberedMsItem> _msDisplayedItems = new();
    private bool _msPagedLoading;
    private IEnumerable<string>? _msPagedValues;
    private const int _msPageSize = 10;
    private const int _msTotalItems = 50;
    private string _msSearchQuery = string.Empty;
    private int _msFilteredTotal;
    private int _msDisplayedCount;

    private IReadOnlyList<NumberedMsItem> GetFilteredMsItems(string query) =>
        string.IsNullOrWhiteSpace(query)
            ? _masterMsItems
            : _masterMsItems.Where(x => x.Label.Contains(query, StringComparison.OrdinalIgnoreCase)).ToList();

    // Server-Side Search demo
    private readonly List<PersonItem> _allPeople = new()
    {
        new PersonItem { Value = "alice", Label = "Alice Johnson" },
        new PersonItem { Value = "bob", Label = "Bob Smith" },
        new PersonItem { Value = "carol", Label = "Carol White" },
        new PersonItem { Value = "dave", Label = "Dave Brown" },
        new PersonItem { Value = "eve", Label = "Eve Davis" },
        new PersonItem { Value = "frank", Label = "Frank Miller" },
        new PersonItem { Value = "grace", Label = "Grace Wilson" },
        new PersonItem { Value = "hank", Label = "Hank Moore" },
        new PersonItem { Value = "iris", Label = "Iris Taylor" },
        new PersonItem { Value = "jack", Label = "Jack Anderson" },
        new PersonItem { Value = "kate", Label = "Kate Thomas" },
        new PersonItem { Value = "liam", Label = "Liam Jackson" },
        new PersonItem { Value = "mia", Label = "Mia Martinez" },
        new PersonItem { Value = "noah", Label = "Noah Garcia" },
        new PersonItem { Value = "olivia", Label = "Olivia Rodriguez" },
    };
    private List<PersonItem> _filteredPeople = new();
    private IEnumerable<string>? _selectedPeople;
    private bool _peopleSearching;

    protected override void OnInitialized()
    {
        var filtered = GetFilteredMsItems(string.Empty);
        _msFilteredTotal = filtered.Count;
        _msDisplayedCount = _msPageSize;
        _msDisplayedItems = filtered.Take(_msDisplayedCount).ToList();
        _filteredPeople = new(_allPeople);
    }

    private async Task HandleMsLoadMore()
    {
        _msPagedLoading = true;
        StateHasChanged();
        await Task.Delay(600);
        _msDisplayedCount += _msPageSize;
        var filtered = GetFilteredMsItems(_msSearchQuery);
        _msFilteredTotal = filtered.Count;
        _msDisplayedItems = filtered.Take(_msDisplayedCount).ToList();
        _msPagedLoading = false;
    }

    private string? MsEndMessage =>
        _msDisplayedCount >= _msFilteredTotal && _msFilteredTotal > 0
            ? $"All {_msFilteredTotal} options loaded"
            : null;

    private Task HandleMsInfiniteSearch(string query)
    {
        _msSearchQuery = query;
        _msDisplayedCount = _msPageSize;
        var filtered = GetFilteredMsItems(query);
        _msFilteredTotal = filtered.Count;
        _msDisplayedItems = filtered.Take(_msDisplayedCount).ToList();
        return Task.CompletedTask;
    }

    private async Task HandlePeopleSearch(string query)
    {
        _peopleSearching = true;
        StateHasChanged();
        await Task.Delay(300);
        _filteredPeople = string.IsNullOrWhiteSpace(query)
            ? new(_allPeople)
            : _allPeople.Where(p => p.Label.Contains(query, StringComparison.OrdinalIgnoreCase)).ToList();
        _peopleSearching = false;
    }

    public class Language
    {
        public required string Value { get; set; }
        public required string Label { get; set; }
    }

    public class Technology
    {
        public required string Value { get; set; }
        public required string Label { get; set; }
    }

    public class Framework
    {
        public required string Value { get; set; }
        public required string Label { get; set; }
    }

    public class Country
    {
        public required string Code { get; set; }
        public required string Name { get; set; }
    }

    public class NumberedMsItem
    {
        public required string Value { get; set; }
        public required string Label { get; set; }
    }

    public class PersonItem
    {
        public required string Value { get; set; }
        public required string Label { get; set; }
    }

}
