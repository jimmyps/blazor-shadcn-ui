@page "/components/card"

<PageTitle>Card - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Card"
        Description="Displays structured content in a visually distinct container with sections for headers, content, and footers." />

    <DemoSection
        Title="Basic Card"
        Description="A simple card with header, content, and footer sections.">
        <DemoBlock Code="@_basicCode">
            <div class="grid gap-4" style="max-width: 400px;">
                <Card>
                    <CardHeader>
                        <CardTitle>Card Title</CardTitle>
                        <CardDescription>Card description goes here.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <p class="text-sm">This is the main content area of the card.</p>
                    </CardContent>
                    <CardFooter>
                        <Button Size="ButtonSize.Small">Action</Button>
                    </CardFooter>
                </Card>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Login Form Example"
        Description="Card component used for a login form (matching shadcn/ui example).">
        <DemoBlock Code="@_loginFormCode">
            <div class="grid gap-4" style="max-width: 400px;">
                <Card>
                    <CardHeader>
                        <CardTitle>Login to your account</CardTitle>
                        <CardDescription>Enter your email below to login to your account</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="space-y-4">
                            <div class="space-y-2">
                                <label class="text-sm font-medium" for="email">Email</label>
                                <input id="email" type="email" placeholder="m@example.com"
                                    class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" />
                            </div>
                            <div class="space-y-2">
                                <label class="text-sm font-medium" for="password">Password</label>
                                <input id="password" type="password"
                                    class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" />
                            </div>
                        </div>
                    </CardContent>
                    <CardFooter>
                        <div class="flex flex-col w-full gap-2">
                            <Button Class="w-full">Login</Button>
                            <Button Variant="ButtonVariant.Outline" Class="w-full">Login with Google</Button>
                        </div>
                    </CardFooter>
                </Card>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Card Grid Layout"
        Description="Multiple cards in a responsive grid layout.">
        <DemoBlock Code="@_gridCode">
            <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                <Card>
                    <CardHeader>
                        <CardTitle>Total Revenue</CardTitle>
                        <CardDescription>January - December 2024</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="text-2xl font-bold">$45,231.89</div>
                        <p class="text-xs text-muted-foreground">+20.1% from last year</p>
                    </CardContent>
                </Card>
                <Card>
                    <CardHeader>
                        <CardTitle>Active Users</CardTitle>
                        <CardDescription>Current active subscriptions</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="text-2xl font-bold">+2,350</div>
                        <p class="text-xs text-muted-foreground">+180.1% from last month</p>
                    </CardContent>
                </Card>
                <Card>
                    <CardHeader>
                        <CardTitle>New Customers</CardTitle>
                        <CardDescription>This month</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="text-2xl font-bold">+573</div>
                        <p class="text-xs text-muted-foreground">+12.5% from last month</p>
                    </CardContent>
                </Card>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Card with Action Buttons"
        Description="Cards with footer action buttons in different layouts.">
        <DemoBlock Code="@_actionsCode">
            <div class="grid gap-4 md:grid-cols-2">
                <Card>
                    <CardHeader>
                        <CardTitle>Create Project</CardTitle>
                        <CardDescription>Deploy your new project in one-click.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <p class="text-sm text-muted-foreground">Your project will be created with default settings.</p>
                    </CardContent>
                    <CardFooter Class="gap-2">
                        <Button Variant="ButtonVariant.Outline">Cancel</Button>
                        <Button>Deploy</Button>
                    </CardFooter>
                </Card>
                <Card>
                    <CardHeader>
                        <CardTitle>Team Members</CardTitle>
                        <CardDescription>Invite your team to collaborate.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="space-y-2">
                            <div class="flex items-center gap-2">
                                <div class="h-8 w-8 rounded-full bg-primary/10 flex items-center justify-center text-sm font-medium">JD</div>
                                <span class="text-sm">John Doe</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <div class="h-8 w-8 rounded-full bg-primary/10 flex items-center justify-center text-sm font-medium">JS</div>
                                <span class="text-sm">Jane Smith</span>
                            </div>
                        </div>
                    </CardContent>
                    <CardFooter>
                        <Button Size="ButtonSize.Small" Class="w-full">Invite Team Member</Button>
                    </CardFooter>
                </Card>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Content-Only Cards"
        Description="Cards without footers, suitable for displaying information.">
        <DemoBlock Code="@_contentOnlyCode">
            <div class="grid gap-4 md:grid-cols-2" style="max-width: 800px;">
                <Card>
                    <CardHeader>
                        <CardTitle>Notifications</CardTitle>
                        <CardDescription>You have 3 unread messages.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="space-y-4">
                            <div class="flex items-start gap-3">
                                <div class="h-2 w-2 rounded-full bg-blue-500 mt-2"></div>
                                <div class="flex-1 space-y-1">
                                    <p class="text-sm font-medium">Your call has been confirmed.</p>
                                    <p class="text-xs text-muted-foreground">5 minutes ago</p>
                                </div>
                            </div>
                            <div class="flex items-start gap-3">
                                <div class="h-2 w-2 rounded-full bg-blue-500 mt-2"></div>
                                <div class="flex-1 space-y-1">
                                    <p class="text-sm font-medium">You have a new message!</p>
                                    <p class="text-xs text-muted-foreground">1 hour ago</p>
                                </div>
                            </div>
                        </div>
                    </CardContent>
                </Card>
                <Card>
                    <CardHeader>
                        <CardTitle>System Status</CardTitle>
                        <CardDescription>All systems operational.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="space-y-3">
                            <div class="flex justify-between items-center">
                                <span class="text-sm">API Status</span>
                                <span class="text-xs text-green-600 font-medium">Operational</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="text-sm">Database</span>
                                <span class="text-xs text-green-600 font-medium">Operational</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="text-sm">Storage</span>
                                <span class="text-xs text-green-600 font-medium">Operational</span>
                            </div>
                        </div>
                    </CardContent>
                </Card>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Custom Styling"
        Description="Cards with custom CSS classes for extended styling.">
        <DemoBlock Code="@_customCode">
            <div class="grid gap-4 md:grid-cols-2" style="max-width: 800px;">
                <Card Class="border-2 border-primary">
                    <CardHeader>
                        <CardTitle>Featured Card</CardTitle>
                        <CardDescription>With custom border color</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <p class="text-sm">This card has a custom border using the Class parameter.</p>
                    </CardContent>
                </Card>
                <Card Class="shadow-lg">
                    <CardHeader>
                        <CardTitle>Enhanced Shadow</CardTitle>
                        <CardDescription>With larger shadow effect</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <p class="text-sm">This card uses an enhanced shadow for more depth.</p>
                    </CardContent>
                </Card>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Accessibility"
        Description="Semantic HTML structure with proper heading hierarchy. Sufficient color contrast (WCAG 2.1 AA). Responsive layout and dark mode compatible via CSS variables." />

    <DemoSection
        Title="Usage"
        Description="Common card patterns and code examples.">
        <div class="rounded-lg border bg-card p-4">
            <h3 class="text-sm font-medium mb-2">Basic Card Structure</h3>
            <pre class="text-xs bg-muted p-3 rounded overflow-x-auto"><code>&lt;Card&gt;
    &lt;CardHeader&gt;
        &lt;CardTitle&gt;Title&lt;/CardTitle&gt;
        &lt;CardDescription&gt;Description&lt;/CardDescription&gt;
    &lt;/CardHeader&gt;
    &lt;CardContent&gt;
        Content goes here
    &lt;/CardContent&gt;
    &lt;CardFooter&gt;
        &lt;Button&gt;Action&lt;/Button&gt;
    &lt;/CardFooter&gt;
&lt;/Card&gt;</code></pre>
        </div>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_cardProps" />
    </DemoSection>

    <DemoPageNav />
</div>

@code {
    private static readonly IReadOnlyList<DemoPropRow> _cardProps =
    [
        new("Class",        "string?",          null, "Additional CSS classes for the Card root element."),
        new("ChildContent", "RenderFragment?",  null, "Card body. Compose with CardHeader, CardContent, and CardFooter sub-components."),
    ];

    private const string _basicCode =
        """
        <Card>
            <CardHeader>
                <CardTitle>Card Title</CardTitle>
                <CardDescription>Card description goes here.</CardDescription>
            </CardHeader>
            <CardContent>
                <p class="text-sm">This is the main content area of the card.</p>
            </CardContent>
            <CardFooter>
                <Button Size="ButtonSize.Small">Action</Button>
            </CardFooter>
        </Card>
        """;

    private const string _loginFormCode =
        """
        <Card>
            <CardHeader>
                <CardTitle>Login to your account</CardTitle>
                <CardDescription>Enter your email below to login</CardDescription>
            </CardHeader>
            <CardContent>
                <!-- form fields -->
            </CardContent>
            <CardFooter>
                <Button Class="w-full">Login</Button>
            </CardFooter>
        </Card>
        """;

    private const string _gridCode =
        """
        <div class="grid gap-4 md:grid-cols-3">
            <Card>
                <CardHeader>
                    <CardTitle>Total Revenue</CardTitle>
                    <CardDescription>January - December 2024</CardDescription>
                </CardHeader>
                <CardContent>
                    <div class="text-2xl font-bold">$45,231.89</div>
                </CardContent>
            </Card>
            <!-- more cards... -->
        </div>
        """;

    private const string _actionsCode =
        """
        <Card>
            <CardHeader>
                <CardTitle>Create Project</CardTitle>
                <CardDescription>Deploy your new project in one-click.</CardDescription>
            </CardHeader>
            <CardContent>...</CardContent>
            <CardFooter Class="gap-2">
                <Button Variant="ButtonVariant.Outline">Cancel</Button>
                <Button>Deploy</Button>
