@page "/components/filter/custom"
@namespace NeoUI.Demo.Shared.Pages.Components.Filter

<PageTitle>Filter Builder - Custom Controls - NeoUI</PageTitle>

<div class="space-y-8 max-w-7xl">

    <DemoPageHeader
        Title="Custom Controls"
        Description="Use custom RenderFragment controls for specialized input scenarios like sliders, ratings, and more." />

    <DemoSection Title="Custom Value Input" Description="Provide a RenderFragment&lt;FilterCondition&gt; as ChildContent on FilterField to replace the default value widget.">
        <DemoBlock Code="@_customCode">
            <FilterBuilder TData="CustomItem" @bind-Filters="_filters">
                <FilterFields>
                    <FilterField Field="Name" Label="Name" Type="FilterFieldType.Text" />
                    <FilterField Field="Rating" Label="Rating" Type="FilterFieldType.Custom">
                        <ChildContent Context="condition">
                            <div class="flex items-center gap-0.5">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    var star = i;
                                    var current = condition.Value?.ToString();
                                    <button type="button"
                                            class="@(current == star.ToString() ? "text-yellow-400" : "text-muted-foreground") text-xl hover:text-yellow-400 transition-colors"
                                            aria-label="@($"Rate {star} out of 5")"
                                            @onclick="() => SetRating(condition, star)">
                                        ★
                                    </button>
                                }
                            </div>
                        </ChildContent>
                    </FilterField>
                </FilterFields>
            </FilterBuilder>
            @if (_filters.Conditions.Any(c => c.Field == "Rating"))
            {
                var r = _filters.Conditions.First(c => c.Field == "Rating");
                <p class="mt-3 text-xs text-muted-foreground">Rating filter: @r.Operator @r.Value ★</p>
            }
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="Usage Pattern" Description="Any Blazor markup can be used as the custom control.">
        <div class="bg-muted p-6 rounded-lg">
            <pre class="text-sm overflow-x-auto font-mono"><code>@_usageCode</code></pre>
        </div>
    </DemoSection>

    <DemoPageNav />
</div>

@code {
    private FilterGroup _filters = new();

    private void SetRating(FilterCondition condition, int star)
    {
        condition.Value = star.ToString();
    }

    private static readonly string _customCode = """
        <FilterField Field="Rating" Label="Rating" Type="FilterFieldType.Custom">
            <ChildContent Context="condition">
                <div class="flex items-center gap-0.5">
                    @for (int i = 1; i <= 5; i++)
                    {
                        var star = i;
                        <button type="button"
                                @onclick="() => condition.Value = star.ToString()">
                            ★
                        </button>
                    }
                </div>
            </ChildContent>
        </FilterField>
        """;

    private static readonly string _usageCode = """
        <FilterField Field="MyField"
                     Label="My Custom Field"
                     Type="FilterFieldType.Custom">
            <ChildContent Context="condition">
                @* 'condition' is a FilterCondition — set condition.Value to the selected value *@
                <MyCustomInput @bind-Value="condition.Value" />
            </ChildContent>
        </FilterField>
        """;

    public class CustomItem
    {
        public string Name { get; set; } = string.Empty;
        public int Rating { get; set; }
    }
}
