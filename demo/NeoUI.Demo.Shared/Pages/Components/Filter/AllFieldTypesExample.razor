@page "/components/filter/all-types"
@namespace NeoUI.Demo.Shared.Pages.Components.Filter

<PageTitle>Filter Builder - All Field Types - NeoUI</PageTitle>

<div class="space-y-8 max-w-7xl">

    <DemoPageHeader
        Title="All Field Types"
        Description="Demonstrates all 8 field types with inline chip editing. Click the filter button, pick a field, then change the operator and value directly in each chip." />

    <DemoSection Title="Employee Directory" Description="Try adding multiple filters. Each chip shows field | operator | value inline.">
        <DemoBlock Code="@_code">
            <div class="space-y-4">
                <div class="flex items-center justify-between">
                    <h2 class="text-lg font-semibold">Employees</h2>
                    <span class="text-sm text-muted-foreground">@filteredEmployees.Count of @allEmployees.Count shown</span>
                </div>

                <FilterBuilder TData="Employee"
                               @bind-Filters="activeFilters"
                               OnFilterChange="HandleFilterChange">
                    <FilterFields>
                        <FilterField Field="Name"       Label="Name"           Icon="user"
                                     Type="FilterFieldType.Text" />
                        <FilterField Field="Salary"     Label="Salary"         Icon="dollar-sign"
                                     Type="FilterFieldType.Number"
                                     EditorType="FilterEditorType.Currency"
                                     Min="0" />
                        <FilterField Field="HireDate"   Label="Hire Date"      Icon="calendar"
                                     Type="FilterFieldType.Date" />
                        <FilterField Field="Department" Label="Department"     Icon="building-2"
                                     Type="FilterFieldType.Select"
                                     Options="@departmentOptions" />
                        <FilterField Field="Skills"     Label="Skills"         Icon="zap"
                                     Type="FilterFieldType.MultiSelect"
                                     Options="@skillOptions" />
                        <FilterField Field="IsActive"   Label="Active"         Icon="activity"
                                     Type="FilterFieldType.Boolean" />
                        <FilterField Field="Email"      Label="Email"          Icon="mail"
                                     Type="FilterFieldType.Text" Placeholder="Search email..." />
                        <FilterField Field="Phone"      Label="Phone"          Icon="phone"
                                     Type="FilterFieldType.Text"
                                     EditorType="FilterEditorType.Masked"
                                     Placeholder="+1 (000) 000-0000" />
                    </FilterFields>
                </FilterBuilder>

                <DataTable TData="Employee" Data="@filteredEmployees" InitialPageSize="10">
                    <Columns>
                        <DataTableColumn TData="Employee" TValue="string"  Property="@(e => e.Name)"             Header="Name"       Sortable />
                        <DataTableColumn TData="Employee" TValue="string"  Property="@(e => e.Department)"       Header="Department" Sortable>
                            <CellTemplate Context="emp">
                                <Badge Variant="BadgeVariant.Secondary">@emp.Department</Badge>
                            </CellTemplate>
                        </DataTableColumn>
                        <DataTableColumn TData="Employee" TValue="decimal" Property="@(e => e.Salary)"           Header="Salary"     Sortable Alignment="ColumnAlignment.Right">
                            <CellTemplate Context="emp">
                                <span>$@emp.Salary.ToString("N0")</span>
                            </CellTemplate>
                        </DataTableColumn>
                        <DataTableColumn TData="Employee" TValue="string"  Property="@(e => e.HireDateDisplay)"  Header="Hire Date"  Sortable />
                        <DataTableColumn TData="Employee" TValue="string"  Property="@(e => e.Email)"            Header="Email" />
                        <DataTableColumn TData="Employee" TValue="bool"    Property="@(e => e.IsActive)"         Header="Active"     Sortable>
                            <CellTemplate Context="emp">
                                @if (emp.IsActive)
                                {
                                    <Badge Variant="BadgeVariant.Default">Active</Badge>
                                }
                                else
                                {
                                    <Badge Variant="BadgeVariant.Outline">Inactive</Badge>
                                }
                            </CellTemplate>
                        </DataTableColumn>
                    </Columns>
                </DataTable>
            </div>
        </DemoBlock>
    </DemoSection>

    @* Field Types Reference *@
    <DemoSection Title="Editor Types" Description="All available EditorType values and when to use them.">
        <div class="overflow-x-auto">
            <table class="w-full text-sm border-collapse">
                <thead>
                    <tr class="border-b">
                        <th class="text-left py-2 pr-4 font-medium">EditorType</th>
                        <th class="text-left py-2 pr-4 font-medium">Component</th>
                        <th class="text-left py-2 font-medium">Use case</th>
                    </tr>
                </thead>
                <tbody class="divide-y">
                    <tr><td class="py-2 pr-4 font-mono text-xs">Auto</td><td class="pr-4">inferred from Type</td><td class="text-muted-foreground">Default — picks the right component automatically</td></tr>
                    <tr><td class="py-2 pr-4 font-mono text-xs">Input</td><td class="pr-4">Input</td><td class="text-muted-foreground">Plain text input (Text fields)</td></tr>
                    <tr><td class="py-2 pr-4 font-mono text-xs">Numeric</td><td class="pr-4">NumericInput</td><td class="text-muted-foreground">Decimal/integer fields</td></tr>
                    <tr><td class="py-2 pr-4 font-mono text-xs">Currency</td><td class="pr-4">CurrencyInput</td><td class="text-muted-foreground">Price/monetary fields</td></tr>
                    <tr><td class="py-2 pr-4 font-mono text-xs">Masked</td><td class="pr-4">MaskedInput</td><td class="text-muted-foreground">Phone, IBAN, postal codes</td></tr>
                    <tr><td class="py-2 pr-4 font-mono text-xs">Date</td><td class="pr-4">DatePicker</td><td class="text-muted-foreground">Single date</td></tr>
                    <tr><td class="py-2 pr-4 font-mono text-xs">DateRange</td><td class="pr-4">DateRangePicker</td><td class="text-muted-foreground">Date range (from/to)</td></tr>
                    <tr><td class="py-2 pr-4 font-mono text-xs">Boolean</td><td class="pr-4">Switch</td><td class="text-muted-foreground">True/false toggle</td></tr>
                    <tr><td class="py-2 pr-4 font-mono text-xs">Select</td><td class="pr-4">select element</td><td class="text-muted-foreground">Single value from a list</td></tr>
                    <tr><td class="py-2 pr-4 font-mono text-xs">MultiSelect</td><td class="pr-4">MultiSelect</td><td class="text-muted-foreground">Multiple values — List&lt;Customer&gt; etc.</td></tr>
                    <tr><td class="py-2 pr-4 font-mono text-xs">Custom</td><td class="pr-4">RenderFragment</td><td class="text-muted-foreground">Any custom control via ChildContent</td></tr>
                </tbody>
            </table>
        </div>
    </DemoSection>

    <DemoPageNav />
</div>

@code {
    private FilterGroup activeFilters = new();
    private List<Employee> allEmployees = new();
    private List<Employee> filteredEmployees = new();

    private readonly List<SelectOption> departmentOptions =
    [
        new("Engineering", "Engineering"),
        new("Sales",       "Sales"),
        new("Marketing",   "Marketing"),
        new("HR",          "Human Resources"),
        new("Finance",     "Finance"),
    ];

    private readonly List<SelectOption> skillOptions =
    [
        new("csharp",    "C#"),
        new("blazor",    "Blazor"),
        new("sql",       "SQL"),
        new("azure",     "Azure"),
        new("react",     "React"),
        new("python",    "Python"),
    ];

    protected override void OnInitialized()
    {
        allEmployees =
        [
            new() { Id = 1,  Name = "Alice Johnson",  Department = "Engineering", Salary = 95000,  HireDate = new DateOnly(2020, 3,  15), Email = "alice@company.com",  IsActive = true,  Skills = ["csharp", "blazor", "azure"] },
            new() { Id = 2,  Name = "Bob Smith",      Department = "Sales",       Salary = 75000,  HireDate = new DateOnly(2021, 7,  22), Email = "bob@company.com",    IsActive = true,  Skills = ["sql"] },
            new() { Id = 3,  Name = "Carol White",    Department = "Marketing",   Salary = 68000,  HireDate = new DateOnly(2019, 1,  10), Email = "carol@company.com",  IsActive = false, Skills = ["react"] },
            new() { Id = 4,  Name = "David Brown",    Department = "Engineering", Salary = 105000, HireDate = new DateOnly(2018, 5,  3),  Email = "david@company.com",  IsActive = true,  Skills = ["csharp", "azure", "python"] },
            new() { Id = 5,  Name = "Eve Davis",      Department = "HR",          Salary = 62000,  HireDate = new DateOnly(2022, 9,  18), Email = "eve@company.com",    IsActive = true,  Skills = ["sql"] },
            new() { Id = 6,  Name = "Frank Miller",   Department = "Finance",     Salary = 88000,  HireDate = new DateOnly(2020, 11, 5),  Email = "frank@company.com",  IsActive = true,  Skills = ["sql", "python"] },
            new() { Id = 7,  Name = "Grace Lee",      Department = "Engineering", Salary = 92000,  HireDate = new DateOnly(2021, 2,  14), Email = "grace@company.com",  IsActive = true,  Skills = ["csharp", "blazor"] },
            new() { Id = 8,  Name = "Henry Wilson",   Department = "Sales",       Salary = 71000,  HireDate = new DateOnly(2019, 6,  30), Email = "henry@company.com",  IsActive = false, Skills = ["react"] },
            new() { Id = 9,  Name = "Iris Martinez",  Department = "Marketing",   Salary = 70000,  HireDate = new DateOnly(2022, 4,  12), Email = "iris@company.com",   IsActive = true,  Skills = ["react", "python"] },
            new() { Id = 10, Name = "Jack Anderson",  Department = "Engineering", Salary = 110000, HireDate = new DateOnly(2017, 8,  25), Email = "jack@company.com",   IsActive = true,  Skills = ["csharp", "azure", "blazor"] },
        ];
        filteredEmployees = allEmployees.ToList();
    }

    private void HandleFilterChange(FilterGroup filters)
    {
        filteredEmployees = allEmployees.ApplyFilters(filters).ToList();
    }

    private static readonly string _code = """
        <FilterBuilder TData="Employee"
                       @bind-Filters="activeFilters"
                       OnFilterChange="HandleFilterChange">
            <FilterFields>
                <FilterField Field="Name"       Label="Name"       Icon="user"        Type="FilterFieldType.Text" />
                <FilterField Field="Salary"     Label="Salary"     Icon="dollar-sign" Type="FilterFieldType.Number"
                             EditorType="FilterEditorType.Currency" Min="0" />
                <FilterField Field="HireDate"   Label="Hire Date"  Icon="calendar"    Type="FilterFieldType.Date" />
                <FilterField Field="Department" Label="Department" Icon="building-2"  Type="FilterFieldType.Select"
                             Options="@departmentOptions" />
                <FilterField Field="Skills"     Label="Skills"     Icon="zap"         Type="FilterFieldType.MultiSelect"
                             Options="@skillOptions" />
                <FilterField Field="IsActive"   Label="Active"     Icon="activity"    Type="FilterFieldType.Boolean" />
                <FilterField Field="Phone"      Label="Phone"      Icon="phone"       Type="FilterFieldType.Text"
                             EditorType="FilterEditorType.Masked" Placeholder="+1 (000) 000-0000" />
            </FilterFields>
        </FilterBuilder>
        """;

    public class Employee
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Department { get; set; } = string.Empty;
        public decimal Salary { get; set; }
        public DateOnly HireDate { get; set; }
        public string HireDateDisplay => HireDate.ToString("MMM dd, yyyy");
        public string Email { get; set; } = string.Empty;
        public bool IsActive { get; set; }
        public List<string> Skills { get; set; } = new();
    }
}
