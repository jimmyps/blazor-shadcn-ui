@page "/components/filter/nested"
@namespace NeoUI.Demo.Shared.Pages.Components.Filter

<PageTitle>Filter Builder - Nested Groups - NeoUI</PageTitle>

<div class="space-y-8 max-w-7xl">

    <DemoPageHeader
        Title="Nested Groups"
        Description="Build complex filter logic with nested condition groups using AND/OR operators. Set AllowGroups=true on FilterBuilder to enable the predicate-tree editor." />

    <DemoSection Title="Interactive Predicate Tree" Description="Use [+ Add predicate] to add conditions and [+ Add group] to create nested sub-groups, each with their own AND/OR logic.">
        <DemoBlock Code="@_interactiveCode">
            <div class="space-y-4">
                <div class="flex items-center justify-between">
                    <h2 class="text-lg font-semibold">Orders</h2>
                    <span class="text-sm text-muted-foreground">@_filteredOrders.Count of @_allOrders.Count shown</span>
                </div>

                <FilterBuilder TData="Order"
                               @bind-Filters="_activeFilters"
                               AllowGroups="true"
                               OnFilterChange="HandleFilterChange">
                    <FilterFields>
                        <FilterField Field="Status"   Label="Status"   Icon="activity"    Type="FilterFieldType.Select"  Options="@_statusOptions" />
                        <FilterField Field="Priority" Label="Priority" Icon="circle-alert" Type="FilterFieldType.Select" Options="@_priorityOptions" />
                        <FilterField Field="Amount"   Label="Amount"   Icon="dollar-sign" Type="FilterFieldType.Number"
                                     EditorType="FilterEditorType.Currency" Min="0" />
                        <FilterField Field="Customer" Label="Customer" Icon="user"        Type="FilterFieldType.Text" />
                    </FilterFields>
                </FilterBuilder>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    @foreach (var order in _filteredOrders)
                    {
                        <Card>
                            <CardHeader>
                                <CardTitle>@order.OrderNumber</CardTitle>
                                <CardDescription>@order.Customer</CardDescription>
                            </CardHeader>
                            <CardContent>
                                <div class="flex items-center justify-between">
                                    <span class="font-semibold">$@order.Amount.ToString("N2")</span>
                                    <div class="flex gap-1">
                                        <Badge Variant="@GetStatusVariant(order.Status)">@order.Status</Badge>
                                        <Badge Variant="@GetPriorityVariant(order.Priority)">@order.Priority</Badge>
                                    </div>
                                </div>
                            </CardContent>
                        </Card>
                    }
                </div>

                @if (!_filteredOrders.Any())
                {
                    <div class="text-center py-12">
                        <p class="text-muted-foreground">No orders match your filters.</p>
                    </div>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="Programmatic Construction" Description="You can also build a FilterGroup with nested groups in code and pass it as a pre-seeded initial state.">
        <DemoBlock Code="@_nestedCode">
            <div class="space-y-4">
                <div class="flex items-center justify-between">
                    <h2 class="text-lg font-semibold">Preset: Urgent Pending or Processing</h2>
                    <span class="text-sm text-muted-foreground">@_presetFiltered.Count of @_allOrders.Count shown</span>
                </div>

                <FilterBuilder TData="Order"
                               @bind-Filters="_presetFilters"
                               AllowGroups="true"
                               OnFilterChange="HandlePresetFilterChange">
                    <FilterFields>
                        <FilterField Field="Status"   Label="Status"   Icon="activity"    Type="FilterFieldType.Select"  Options="@_statusOptions" />
                        <FilterField Field="Priority" Label="Priority" Icon="circle-alert" Type="FilterFieldType.Select" Options="@_priorityOptions" />
                        <FilterField Field="Amount"   Label="Amount"   Icon="dollar-sign" Type="FilterFieldType.Number"
                                     EditorType="FilterEditorType.Currency" Min="0" />
                        <FilterField Field="Customer" Label="Customer" Icon="user"        Type="FilterFieldType.Text" />
                    </FilterFields>
                </FilterBuilder>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="Searchable Field Picker" Description="When your field list grows beyond ~15 items, set FieldPickerVariant to Combobox for a searchable picker that replaces the dropdown menu. Sub-menu quick-select for option-backed fields is not available in this mode.">
        <DemoBlock Code="@_comboboxPickerCode">
            <div class="space-y-4">
                <div class="flex items-center justify-between">
                    <h2 class="text-lg font-semibold">Employees</h2>
                    <span class="text-sm text-muted-foreground">@_filteredEmployees.Count of @_allEmployees.Count shown</span>
                </div>

                <FilterBuilder TData="Employee"
                               @bind-Filters="_employeeFilters"
                               AllowGroups="true"
                               FieldPickerVariant="FilterFieldPickerVariant.Combobox"
                               ComboboxSearchInterval="500"
                               OnFilterChange="HandleEmployeeFilterChange">
                    <FilterFields>
                        <FilterField Field="FirstName"   Label="First Name"        Icon="user"           Type="FilterFieldType.Text" />
                        <FilterField Field="LastName"    Label="Last Name"         Icon="user"           Type="FilterFieldType.Text" />
                        <FilterField Field="Email"       Label="Email"             Icon="mail"           Type="FilterFieldType.Text" />
                        <FilterField Field="Phone"       Label="Phone"             Icon="phone"          Type="FilterFieldType.Text" />
                        <FilterField Field="Department"  Label="Department"        Icon="building-2"     Type="FilterFieldType.Select" Options="@_departmentOptions" />
                        <FilterField Field="JobTitle"    Label="Job Title"         Icon="briefcase"      Type="FilterFieldType.Text" />
                        <FilterField Field="Location"    Label="Location"          Icon="map-pin"        Type="FilterFieldType.Select" Options="@_locationOptions" />
                        <FilterField Field="EmployeeType" Label="Employee Type"    Icon="users"          Type="FilterFieldType.Select" Options="@_employeeTypeOptions" />
                        <FilterField Field="Status"      Label="Status"            Icon="activity"       Type="FilterFieldType.Select" Options="@_employeeStatusOptions" />
                        <FilterField Field="StartDate"   Label="Start Date"        Icon="calendar"       Type="FilterFieldType.Date" />
                        <FilterField Field="EndDate"     Label="End Date"          Icon="calendar-x"     Type="FilterFieldType.Date" />
                        <FilterField Field="Salary"      Label="Salary"            Icon="dollar-sign"    Type="FilterFieldType.Number" EditorType="FilterEditorType.Currency" Min="0" />
                        <FilterField Field="Bonus"       Label="Bonus"             Icon="gift"           Type="FilterFieldType.Number" EditorType="FilterEditorType.Currency" Min="0" />
                        <FilterField Field="YearsExp"    Label="Years Experience"  Icon="award"          Type="FilterFieldType.Number" Min="0" />
                        <FilterField Field="ManagerId"   Label="Manager"           Icon="user-check"     Type="FilterFieldType.Text" />
                        <FilterField Field="TeamSize"    Label="Team Size"         Icon="users-round"    Type="FilterFieldType.Number" Min="0" />
                        <FilterField Field="IsRemote"    Label="Remote"            Icon="wifi"           Type="FilterFieldType.Select" Options="@_boolOptions" />
                        <FilterField Field="HasEquipment" Label="Has Equipment"    Icon="laptop"         Type="FilterFieldType.Select" Options="@_boolOptions" />
                        <FilterField Field="Office"      Label="Office Floor"      Icon="building"       Type="FilterFieldType.Number" Min="1" />
                        <FilterField Field="Notes"       Label="Notes"             Icon="notebook-pen"   Type="FilterFieldType.Text" />
                        <FilterField Field="Tags"        Label="Tags"              Icon="tag"            Type="FilterFieldType.Text" />
                        <FilterField Field="LastReview"  Label="Last Review Date"  Icon="clipboard-list" Type="FilterFieldType.Date" />
                    </FilterFields>
                </FilterBuilder>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    @foreach (var emp in _filteredEmployees)
                    {
                        <Card>
                            <CardHeader>
                                <CardTitle>@emp.FirstName @emp.LastName</CardTitle>
                                <CardDescription>@emp.JobTitle · @emp.Department</CardDescription>
                            </CardHeader>
                            <CardContent>
                                <div class="flex items-center justify-between">
                                    <span class="text-sm text-muted-foreground">@emp.Location</span>
                                    <Badge Variant="@GetEmployeeStatusVariant(emp.Status)">@emp.Status</Badge>
                                </div>
                            </CardContent>
                        </Card>
                    }
                </div>

                @if (!_filteredEmployees.Any())
                {
                    <div class="text-center py-12">
                        <p class="text-muted-foreground">No employees match your filters.</p>
                    </div>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="LINQ Support" Description="The ApplyFilters extension fully resolves nested groups at runtime.">
        <div class="bg-muted p-6 rounded-lg">
            <pre class="text-sm overflow-x-auto font-mono"><code>@_linqCode</code></pre>
        </div>
    </DemoSection>

    <DemoPageSubNav ParentSlug="filter" />
</div>

@code {
    private FilterGroup _activeFilters = new();
    private FilterGroup _presetFilters = BuildPresetFilters();
    private FilterGroup _employeeFilters = new();
    private List<Order> _allOrders = new();
    private List<Order> _filteredOrders = new();
    private List<Order> _presetFiltered = new();
    private List<Employee> _allEmployees = new();
    private List<Employee> _filteredEmployees = new();

    private readonly List<SelectOption> _statusOptions =
    [
        new("Pending",    "Pending"),
        new("Processing", "Processing"),
        new("Shipped",    "Shipped"),
        new("Delivered",  "Delivered"),
        new("Cancelled",  "Cancelled"),
    ];

    private readonly List<SelectOption> _priorityOptions =
    [
        new("Low",    "Low"),
        new("Medium", "Medium"),
        new("High",   "High"),
    ];

    private readonly List<SelectOption> _departmentOptions =
    [
        new("Engineering",  "Engineering"),
        new("Product",      "Product"),
        new("Design",       "Design"),
        new("Marketing",    "Marketing"),
        new("Sales",        "Sales"),
        new("HR",           "HR"),
        new("Finance",      "Finance"),
        new("Legal",        "Legal"),
    ];

    private readonly List<SelectOption> _locationOptions =
    [
        new("New York",     "New York"),
        new("San Francisco","San Francisco"),
        new("London",       "London"),
        new("Berlin",       "Berlin"),
        new("Remote",       "Remote"),
    ];

    private readonly List<SelectOption> _employeeTypeOptions =
    [
        new("Full-time",    "Full-time"),
        new("Part-time",    "Part-time"),
        new("Contractor",   "Contractor"),
        new("Intern",       "Intern"),
    ];

    private readonly List<SelectOption> _employeeStatusOptions =
    [
        new("Active",       "Active"),
        new("On Leave",     "On Leave"),
        new("Terminated",   "Terminated"),
    ];

    private readonly List<SelectOption> _boolOptions =
    [
        new("Yes", "Yes"),
        new("No",  "No"),
    ];

    protected override void OnInitialized()
    {
        _allOrders =
        [
            new() { Id = 1,  OrderNumber = "ORD-001", Customer = "Alice Johnson", Status = "Pending",    Priority = "High",   Amount = 1250.00m },
            new() { Id = 2,  OrderNumber = "ORD-002", Customer = "Bob Smith",     Status = "Processing", Priority = "Medium", Amount = 450.50m  },
            new() { Id = 3,  OrderNumber = "ORD-003", Customer = "Carol White",   Status = "Shipped",    Priority = "Low",    Amount = 89.99m   },
            new() { Id = 4,  OrderNumber = "ORD-004", Customer = "David Brown",   Status = "Delivered",  Priority = "High",   Amount = 3200.00m },
            new() { Id = 5,  OrderNumber = "ORD-005", Customer = "Eve Davis",     Status = "Pending",    Priority = "Medium", Amount = 175.25m  },
            new() { Id = 6,  OrderNumber = "ORD-006", Customer = "Frank Miller",  Status = "Cancelled",  Priority = "Low",    Amount = 299.99m  },
            new() { Id = 7,  OrderNumber = "ORD-007", Customer = "Grace Lee",     Status = "Processing", Priority = "High",   Amount = 5500.00m },
            new() { Id = 8,  OrderNumber = "ORD-008", Customer = "Henry Wilson",  Status = "Pending",    Priority = "Medium", Amount = 650.00m  },
            new() { Id = 9,  OrderNumber = "ORD-009", Customer = "Iris Martinez", Status = "Shipped",    Priority = "High",   Amount = 2100.75m },
            new() { Id = 10, OrderNumber = "ORD-010", Customer = "Jack Anderson", Status = "Delivered",  Priority = "Low",    Amount = 55.00m   },
        ];
        _filteredOrders  = _allOrders.ToList();
        _presetFiltered  = _allOrders.ApplyFilters(_presetFilters).ToList();

        _allEmployees =
        [
            new() { FirstName = "Alice",    LastName = "Johnson",   JobTitle = "Senior Engineer",    Department = "Engineering",  Location = "New York",      Status = "Active",      StartDate = new DateTime(2019, 3, 15) },
            new() { FirstName = "Bob",      LastName = "Smith",     JobTitle = "Product Manager",    Department = "Product",      Location = "San Francisco", Status = "Active",      StartDate = new DateTime(2020, 7, 1)  },
            new() { FirstName = "Carol",    LastName = "White",     JobTitle = "UX Designer",        Department = "Design",       Location = "London",        Status = "Active",      StartDate = new DateTime(2021, 1, 10) },
            new() { FirstName = "David",    LastName = "Brown",     JobTitle = "Marketing Lead",     Department = "Marketing",    Location = "Remote",        Status = "On Leave",    StartDate = new DateTime(2018, 5, 20) },
            new() { FirstName = "Eve",      LastName = "Davis",     JobTitle = "Sales Director",     Department = "Sales",        Location = "New York",      Status = "Active",      StartDate = new DateTime(2017, 11, 8) },
            new() { FirstName = "Frank",    LastName = "Miller",    JobTitle = "HR Specialist",      Department = "HR",           Location = "Berlin",        Status = "Active",      StartDate = new DateTime(2022, 4, 3)  },
            new() { FirstName = "Grace",    LastName = "Lee",       JobTitle = "Staff Engineer",     Department = "Engineering",  Location = "San Francisco", Status = "Active",      StartDate = new DateTime(2016, 9, 12) },
            new() { FirstName = "Henry",    LastName = "Wilson",    JobTitle = "Finance Analyst",    Department = "Finance",      Location = "London",        Status = "Active",      StartDate = new DateTime(2023, 2, 14) },
            new() { FirstName = "Iris",     LastName = "Martinez",  JobTitle = "Legal Counsel",      Department = "Legal",        Location = "New York",      Status = "Active",      StartDate = new DateTime(2020, 6, 22) },
            new() { FirstName = "Jack",     LastName = "Anderson",  JobTitle = "Engineering Manager",Department = "Engineering",  Location = "Remote",        Status = "Terminated",  StartDate = new DateTime(2015, 8, 30) },
        ];
        _filteredEmployees = _allEmployees.ToList();
    }

    private void HandleFilterChange(FilterGroup filters)
    {
        _filteredOrders = _allOrders.ApplyFilters(filters).ToList();
    }

    private void HandlePresetFilterChange(FilterGroup filters)
    {
        _presetFiltered = _allOrders.ApplyFilters(filters).ToList();
    }

    private void HandleEmployeeFilterChange(FilterGroup filters)
    {
        _filteredEmployees = _allEmployees.ApplyFilters(filters).ToList();
    }

    // (Status = "Pending" OR Status = "Processing") AND Amount > 500
    private static FilterGroup BuildPresetFilters() => new()
    {
        Logic = LogicalOperator.And,
        Conditions =
        [
            new FilterCondition { Field = "Amount", Operator = FilterOperator.GreaterThan, Value = 500m }
        ],
        NestedGroups =
        [
            new FilterGroup
            {
                Logic = LogicalOperator.Or,
                Conditions =
                [
                    new FilterCondition { Field = "Status", Operator = FilterOperator.Equals, Value = "Pending" },
                    new FilterCondition { Field = "Status", Operator = FilterOperator.Equals, Value = "Processing" }
                ]
            }
        ]
    };

    private static BadgeVariant GetEmployeeStatusVariant(string status) => status switch
    {
        "Active"     => BadgeVariant.Default,
        "On Leave"   => BadgeVariant.Secondary,
        "Terminated" => BadgeVariant.Destructive,
        _            => BadgeVariant.Outline,
    };

    private static BadgeVariant GetStatusVariant(string status) => status switch
    {
        "Delivered"  => BadgeVariant.Default,
        "Shipped"    => BadgeVariant.Secondary,
        "Processing" => BadgeVariant.Secondary,
        "Cancelled"  => BadgeVariant.Destructive,
        _            => BadgeVariant.Outline,
    };

    private static BadgeVariant GetPriorityVariant(string priority) => priority switch
    {
        "High"   => BadgeVariant.Destructive,
        "Medium" => BadgeVariant.Secondary,
        _        => BadgeVariant.Outline,
    };

    public class Order
    {
        public int Id { get; set; }
        public string OrderNumber { get; set; } = string.Empty;
        public string Customer { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string Priority { get; set; } = string.Empty;
        public decimal Amount { get; set; }
    }

    public class Employee
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Phone { get; set; } = string.Empty;
        public string Department { get; set; } = string.Empty;
        public string JobTitle { get; set; } = string.Empty;
        public string Location { get; set; } = string.Empty;
        public string EmployeeType { get; set; } = "Full-time";
        public string Status { get; set; } = string.Empty;
        public DateTime? StartDate { get; set; }
        public DateTime? EndDate { get; set; }
        public decimal Salary { get; set; }
        public decimal Bonus { get; set; }
        public int YearsExp { get; set; }
        public string ManagerId { get; set; } = string.Empty;
        public int TeamSize { get; set; }
        public string IsRemote { get; set; } = "No";
        public string HasEquipment { get; set; } = "Yes";
        public int Office { get; set; }
        public string Notes { get; set; } = string.Empty;
        public string Tags { get; set; } = string.Empty;
        public DateTime? LastReview { get; set; }
    }
}
