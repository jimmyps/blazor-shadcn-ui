@page "/components/collapsible"

<PageTitle>Collapsible - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Collapsible"
        Description="An interactive component which expands/collapses a panel." />

    <DemoSection
        Title="AsChild Pattern"
        Description="Use AsChild to compose triggers with your own styled Button components.">
        <DemoBlock Code="@_asChildCode">
            <div class="grid md:grid-cols-2 gap-6">
                <div class="space-y-3 p-4 border rounded-lg">
                    <h3 class="text-lg font-medium">Without AsChild</h3>
                    <p class="text-sm text-muted-foreground">CollapsibleTrigger renders its own button with inline classes.</p>
                    <Collapsible Class="border rounded-lg max-w-sm">
                        <div class="px-4 py-3">
                            <CollapsibleTrigger Class="flex w-full h-9 items-center justify-between text-sm font-medium hover:bg-accent hover:text-accent-foreground rounded-md px-3 [&_svg]:transition-transform [&_svg]:duration-200 data-[state=open]:[&_svg]:rotate-180">
                                <span>Show more</span>
                                <LucideIcon Name="chevron-down" Size="16" />
                            </CollapsibleTrigger>
                        </div>
                        <CollapsibleContent Class="px-4 pb-4">
                            <p class="text-sm text-muted-foreground">Hidden content revealed!</p>
                        </CollapsibleContent>
                    </Collapsible>
                </div>

                <div class="space-y-3 p-4 border rounded-lg">
                    <h3 class="text-lg font-medium">With AsChild</h3>
                    <p class="text-sm text-muted-foreground">Button receives trigger behavior via TriggerContext.</p>
                    <Collapsible Class="border rounded-lg max-w-sm">
                        <div class="px-4 py-3">
                            <CollapsibleTrigger AsChild>
                                <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" Class="w-full justify-between">
                                    <span>Toggle Section</span>
                                    <LucideIcon Name="chevron-down" Size="16" />
                                </Button>
                            </CollapsibleTrigger>
                        </div>
                        <CollapsibleContent Class="px-4 pb-4">
                            <p class="text-sm text-muted-foreground">Content using Button with AsChild!</p>
                        </CollapsibleContent>
                    </Collapsible>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Basic Usage"
        Description="A simple collapsible with trigger and content.">
        <DemoBlock Code="@_basicCode">
            <div class="max-w-md">
                <Collapsible Class="border rounded-lg">
                    <div class="px-4 py-3">
                        <CollapsibleTrigger Class="flex w-full items-center justify-between rounded-md hover:bg-accent hover:text-accent-foreground [&_svg]:transition-transform [&_svg]:duration-200 data-[state=open]:[&_svg]:rotate-180">
                            <span>Can I use this in my project?</span>
                            <LucideIcon Name="chevron-down" Size="16" />
                        </CollapsibleTrigger>
                    </div>
                    <CollapsibleContent Class="px-4 pb-4">
                        <div class="text-sm text-muted-foreground">
                            Yes! This component is free to use in your projects.
                        </div>
                    </CollapsibleContent>
                </Collapsible>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Controlled Mode"
        Description="Control the open state programmatically.">
        <DemoBlock Code="@_controlledCode">
            <div class="max-w-md space-y-4">
                <div class="flex gap-2">
                    <Button Size="ButtonSize.Small" @onclick="@(() => isControlledOpen = true)">Open</Button>
                    <Button Size="ButtonSize.Small" Variant="ButtonVariant.Outline" @onclick="@(() => isControlledOpen = false)">Close</Button>
                    <Button Size="ButtonSize.Small" Variant="ButtonVariant.Secondary" @onclick="@(() => isControlledOpen = !isControlledOpen)">Toggle</Button>
                </div>
                <Collapsible Open="@isControlledOpen"
                             OpenChanged="@((bool open) => isControlledOpen = open)"
                             Class="border rounded-lg">
                    <div class="px-4 py-3">
                        <CollapsibleTrigger Class="flex w-full items-center justify-between rounded-md hover:bg-accent hover:text-accent-foreground">
                            <span>Controlled Content (@(isControlledOpen ? "Open" : "Closed"))</span>
                            <LucideIcon Name="@(isControlledOpen ? "chevron-up" : "chevron-down")" Size="16" />
                        </CollapsibleTrigger>
                    </div>
                    <CollapsibleContent Class="px-4 pb-4">
                        <div class="text-sm">
                            The parent component controls this collapsible's state.
                        </div>
                    </CollapsibleContent>
                </Collapsible>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Disabled State"
        Description="Disable interaction with the collapsible.">
        <DemoBlock Code="@_disabledCode">
            <div class="max-w-md">
                <Collapsible Disabled Class="border rounded-lg opacity-50">
                    <div class="px-4 py-3">
                        <CollapsibleTrigger Class="flex w-full items-center justify-between rounded-md hover:bg-accent hover:text-accent-foreground [&_svg]:transition-transform [&_svg]:duration-200 data-[state=open]:[&_svg]:rotate-180">
                            <span>Disabled Collapsible</span>
                            <LucideIcon Name="chevron-down" Size="16" />
                        </CollapsibleTrigger>
                    </div>
                    <CollapsibleContent Class="px-4 pb-4">
                        <div class="text-sm">This content cannot be toggled.</div>
                    </CollapsibleContent>
                </Collapsible>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Accordion Style (Multiple Collapsibles)"
        Description="Multiple collapsibles working independently.">
        <DemoBlock Code="@_accordionCode">
            <div class="max-w-md space-y-2">
                @foreach (var item in faqItems)
                {
                    <Collapsible Class="border rounded-lg">
                        <div class="px-4 py-3">
                            <CollapsibleTrigger Class="flex w-full items-center justify-between text-left [&_svg]:transition-transform [&_svg]:duration-200 data-[state=open]:[&_svg]:rotate-180">
                                <span class="font-medium">@item.Question</span>
                                <LucideIcon Name="chevron-down" Size="16" />
                            </CollapsibleTrigger>
                        </div>
                        <CollapsibleContent Class="px-4 pb-4 border-t">
                            <div class="pt-4 text-sm text-muted-foreground">
                                @item.Answer
                            </div>
                        </CollapsibleContent>
                    </Collapsible>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Icons and Badges"
        Description="Enhance collapsibles with visual indicators.">
        <DemoBlock Code="@_iconsCode">
            <div class="max-w-md space-y-2">
                <Collapsible Class="border rounded-lg">
                    <div class="px-4 py-3">
                        <CollapsibleTrigger Class="flex w-full items-center justify-between [&>svg]:transition-transform [&>svg]:duration-200 data-[state=open]:[&>svg]:rotate-180">
                            <div class="flex items-center gap-2">
                                <LucideIcon Name="star" Size="16" />
                                <span class="font-medium">Premium Features</span>
                                <Badge Variant="BadgeVariant.Default" Class="text-[10px] px-1.5 py-0">New</Badge>
                            </div>
                            <LucideIcon Name="chevron-down" Size="16" />
                        </CollapsibleTrigger>
                    </div>
                    <CollapsibleContent Class="px-4 pb-4">
                        <div class="space-y-2 text-sm">
                            <div class="flex items-center gap-2">
                                <LucideIcon Name="check" Size="14" Class="text-green-500" />
                                <span>Advanced analytics</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <LucideIcon Name="check" Size="14" Class="text-green-500" />
                                <span>Priority support</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <LucideIcon Name="check" Size="14" Class="text-green-500" />
                                <span>Custom branding</span>
                            </div>
                        </div>
                    </CollapsibleContent>
                </Collapsible>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Nested Collapsibles"
        Description="Collapsibles can contain other collapsibles for hierarchical content.">
        <DemoBlock Code="@_nestedCode">
            <div class="max-w-md">
                <Collapsible Class="border rounded-lg">
                    <div class="px-4 py-3">
                        <CollapsibleTrigger Class="flex w-full items-center justify-between [&_svg]:transition-transform [&_svg]:duration-200 data-[state=open]:[&_svg]:rotate-180">
                            <span class="font-medium">Parent Section</span>
                            <LucideIcon Name="chevron-down" Size="16" />
                        </CollapsibleTrigger>
                    </div>
                    <CollapsibleContent Class="px-4 pb-4">
                        <div class="space-y-2">
                            <p class="text-sm text-muted-foreground mb-2">This parent contains nested collapsibles.</p>
                            <Collapsible Class="border rounded-md">
                                <div class="px-3 py-2 bg-muted/50">
                                    <CollapsibleTrigger Class="flex w-full items-center justify-between text-sm [&_svg]:transition-transform [&_svg]:duration-200 data-[state=open]:[&_svg]:rotate-180">
                                        <span>Child Section 1</span>
                                        <LucideIcon Name="chevron-down" Size="14" />
                                    </CollapsibleTrigger>
                                </div>
                                <CollapsibleContent Class="px-3 py-2 text-sm text-muted-foreground">
                                    Nested content for child section 1.
                                </CollapsibleContent>
                            </Collapsible>
                            <Collapsible Class="border rounded-md">
                                <div class="px-3 py-2 bg-muted/50">
                                    <CollapsibleTrigger Class="flex w-full items-center justify-between text-sm [&_svg]:transition-transform [&_svg]:duration-200 data-[state=open]:[&_svg]:rotate-180">
                                        <span>Child Section 2</span>
                                        <LucideIcon Name="chevron-down" Size="14" />
                                    </CollapsibleTrigger>
                                </div>
                                <CollapsibleContent Class="px-3 py-2 text-sm text-muted-foreground">
                                    Nested content for child section 2.
                                </CollapsibleContent>
                            </Collapsible>
                        </div>
                    </CollapsibleContent>
                </Collapsible>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Smooth Animations"
        Description="Add CSS transitions for smooth expand/collapse effects.">
        <DemoBlock Code="@_animationsCode">
            <div class="max-w-md">
                <Collapsible Class="border rounded-lg overflow-hidden">
                    <div class="px-4 py-3">
                        <CollapsibleTrigger Class="flex w-full items-center justify-between rounded-md hover:bg-accent hover:text-accent-foreground [&_svg]:transition-transform [&_svg]:duration-200 data-[state=open]:[&_svg]:rotate-180">
                            <span>Animated Content</span>
                            <LucideIcon Name="chevron-down" Size="16" />
                        </CollapsibleTrigger>
                    </div>
                    <CollapsibleContent Class="px-4 pb-4 transition-all duration-300 ease-in-out">
                        <div class="text-sm animate-in fade-in duration-500">
                            <p class="mb-2">This content animates smoothly when expanding and collapsing.</p>
                            <p class="text-muted-foreground">CSS transitions create a polished user experience.</p>
                        </div>
                    </CollapsibleContent>
                </Collapsible>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Accessibility Notes"
        Description="Best practices for accessible collapsibles.">
        <div class="border rounded-lg p-6 space-y-3 bg-muted/50">
            <p class="text-sm">
                ✓ <strong>Keyboard navigation:</strong> Trigger responds to Space and Enter keys.
            </p>
            <p class="text-sm">
                ✓ <strong>ARIA attributes:</strong> aria-expanded reflects the current state.
            </p>
            <p class="text-sm">
                ✓ <strong>Screen readers:</strong> Content uses region role and aria-hidden.
            </p>
            <p class="text-sm">
                ✓ <strong>Focus management:</strong> Focus remains on trigger after expanding/collapsing.
            </p>
            <p class="text-sm">
                ✓ <strong>Semantic HTML:</strong> Proper button elements for triggers.
            </p>
        </div>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_collapsibleProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private bool isControlledOpen = false;

    private List<FaqItem> faqItems = new()
    {
        new FaqItem
        {
            Question = "What is a collapsible component?",
            Answer = "A collapsible is an interactive component that allows users to show or hide content by clicking a trigger element. It's commonly used for FAQs, accordion menus, and expandable sections."
        },
        new FaqItem
        {
            Question = "How is it different from an accordion?",
            Answer = "While both use similar patterns, an accordion typically allows only one section to be open at a time, whereas individual collapsibles can all be open simultaneously. Collapsibles are the building blocks for creating accordions."
        },
        new FaqItem
        {
            Question = "Can I nest collapsibles?",
            Answer = "Yes! Collapsibles can be nested to create hierarchical expandable content structures, perfect for navigation menus or multi-level FAQs."
        },
        new FaqItem
        {
            Question = "Is it accessible?",
            Answer = "Absolutely. The component follows WCAG 2.1 guidelines with proper ARIA attributes, keyboard navigation support, and screen reader compatibility."
        }
    };

    private class FaqItem
    {
        public string Question { get; set; } = string.Empty;
        public string Answer { get; set; } = string.Empty;
    }

}
