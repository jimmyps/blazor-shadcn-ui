@page "/components/datatable"
@inject MockDataService MockDataService

<PageTitle>Data Table - NeoUI</PageTitle>

<div class="space-y-8 max-w-7xl">

    <DemoPageHeader
        Title="Data Table"
        Description="A powerful and flexible data table component with sorting, filtering, pagination, and row selection." />

    <DemoSection
        Title="Basic Table"
        Description="A simple table with automatic sorting and pagination. Toggle the style options below to explore layout variants.">
        <DemoBlock Code="@_basicTableCode">
            <ChildContent>
                <div class="flex flex-wrap gap-x-6 gap-y-3 mb-4 p-3 rounded-md border bg-muted/30">
                    <label class="flex items-center gap-2 cursor-pointer select-none">
                        <Switch @bind-Checked="_dense" Size="SwitchSize.Small" />
                        <span class="text-sm">Dense layout</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer select-none">
                        <Switch @bind-Checked="_headerBackground" Size="SwitchSize.Small" />
                        <span class="text-sm">Header background</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer select-none">
                        <Switch @bind-Checked="_headerBorder" Size="SwitchSize.Small" />
                        <span class="text-sm">Header borders</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer select-none">
                        <Switch @bind-Checked="_cellBorder" Size="SwitchSize.Small" />
                        <span class="text-sm">Cell borders</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer select-none">
                        <Switch @bind-Checked="_columnsVisibility" Size="SwitchSize.Small" />
                        <span class="text-sm">Columns button</span>
                    </label>
                </div>
                <DataTable TData="Person" Data="@people"
                           Dense="@_dense"
                           HeaderBackground="@_headerBackground"
                           HeaderBorder="@_headerBorder"
                           CellBorder="@_cellBorder"
                           ColumnsVisibility="@_columnsVisibility"
                           InitialPageSize="5">
                    <Columns>
                        <DataTableColumn TData="Person" TValue="int" Property="@(p => p.Id)" Header="ID" Sortable Alignment="ColumnAlignment.Right" />
                        <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Name)" Header="Name" Sortable />
                        <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Email)" Header="Email" Sortable />
                        <DataTableColumn TData="Person" TValue="int" Property="@(p => p.Age)" Header="Age" Sortable Alignment="ColumnAlignment.Right" />
                    </Columns>
                </DataTable>
            </ChildContent>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Row Selection"
        Description="Table with multiple row selection using checkboxes.">
        <DemoBlock Code="@_rowSelectionCode">
            <ChildContent>
                <div class="flex items-center gap-2 mb-2">
                    <input type="checkbox"
                           id="enableKeyboardNavDataTable"
                           checked="@enableKeyboardNavigation"
                           @onchange="@((e) => enableKeyboardNavigation = (bool)(e.Value ?? true))"
                           class="h-4 w-4 rounded border-gray-300 text-primary focus:ring-2 focus:ring-primary" />
                    <label for="enableKeyboardNavDataTable" class="text-sm font-medium">Enable keyboard navigation</label>
                </div>
                <DataTable TData="Person"
                           Data="@people"
                           SelectionMode="DataTableSelectionMode.Multiple"
                           EnableKeyboardNavigation="@enableKeyboardNavigation"
                           @bind-SelectedItems="@selectedPeople"
                           InitialPageSize="5">
                    <Columns>
                        <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Name)" Header="Name" Sortable />
                        <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Email)" Header="Email" />
                        <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Role)" Header="Role" />
                    </Columns>
                </DataTable>
                @if (selectedPeople.Any())
                {
                    <div class="p-4 bg-muted rounded-md mt-2">
                        <p class="text-sm font-medium">Selected: @selectedPeople.Count people</p>
                        <div class="flex flex-wrap gap-2 mt-2">
                            @foreach (var person in selectedPeople)
                            {
                                <Badge>@person.Name</Badge>
                            }
                        </div>
                    </div>
                }
            </ChildContent>
            <AdditionalContent>
                <p class="text-sm text-muted-foreground">Use arrow keys to navigate rows, and Enter/Space to toggle selection. Enable keyboard navigation via the checkbox above.</p>
            </AdditionalContent>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Custom Cell Templates"
        Description="Use custom templates to render cells with badges, buttons, and other components.">
        <DemoBlock Code="@_customCellCode">
            <DataTable TData="Person" Data="@people" ShowPagination="false">
                <Columns>
                    <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Name)" Header="Name" Sortable />
                    <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Status)" Header="Status" Sortable>
                        <CellTemplate Context="person">
                            <Badge Variant="@(person.Status == "Active" ? BadgeVariant.Default : BadgeVariant.Outline)">
                                @person.Status
                            </Badge>
                        </CellTemplate>
                    </DataTableColumn>
                    <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Role)" Header="Role">
                        <CellTemplate Context="person">
                            <Badge Variant="BadgeVariant.Secondary">@person.Role</Badge>
                        </CellTemplate>
                    </DataTableColumn>
                    <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Email)" Header="Actions">
                        <CellTemplate Context="person">
                            <div class="flex gap-2">
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="@(() => ShowDetails(person))">
                                    View
                                </Button>
                                <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" OnClick="@(() => EditPerson(person))">
                                    Edit
                                </Button>
                            </div>
                        </CellTemplate>
                    </DataTableColumn>
                </Columns>
            </DataTable>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Server-Side Data"
        Description="Use the ServerData callback to load, sort, filter and paginate data on the server. The component passes a DataTableRequest with the current page, page size, sort column and search text. Returns DataTableResult&lt;T&gt; with the page of items and total count.">
        <DemoBlock Code="@_serverDataCode">
            <DataTable TData="Order" ServerData="@LoadOrders" InitialPageSize="10"
                       PageSizes="@(new[]{ 10, 25, 50 })">
                <Columns>
                    <DataTableColumn TData="Order" TValue="int" Property="@(o => o.Id)" Header="ID" Sortable Width="80px" />
                    <DataTableColumn TData="Order" TValue="string" Property="@(o => o.Customer)" Header="Customer" Sortable Filterable />
                    <DataTableColumn TData="Order" TValue="string" Property="@(o => o.Product)" Header="Product" Sortable Filterable />
                    <DataTableColumn TData="Order" TValue="string" Property="@(o => o.Status)" Header="Status" />
                    <DataTableColumn TData="Order" TValue="decimal" Property="@(o => o.Amount)" Header="Amount" Sortable Alignment="ColumnAlignment.Right" />
                </Columns>
            </DataTable>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Infinite Scroll (Server-Side)"
        Description="Set ItemsProvider to a DataTableVirtualProvider delegate. The component renders rows via Virtualize so only visible rows are in the DOM. The delegate receives StartIndex, Count, SortDescriptors, and SearchText — no page/pageSize math needed. Sorting and search trigger a virtualizer refresh automatically.">
        <DemoBlock Code="@_infiniteScrollServerCode">
            <DataTable TData="Order"
                       ItemsProvider="@LoadOrdersVirtual"
                       ItemHeight="40"
                       Height="360px">
                <Columns>
                    <DataTableColumn TData="Order" TValue="int"     Property="@(o => o.Id)"       Header="ID"       Sortable Alignment="ColumnAlignment.Right" />
                    <DataTableColumn TData="Order" TValue="string"  Property="@(o => o.Customer)"  Header="Customer" Sortable Filterable />
                    <DataTableColumn TData="Order" TValue="string"  Property="@(o => o.Product)"   Header="Product"  Sortable Filterable />
                    <DataTableColumn TData="Order" TValue="string"  Property="@(o => o.Status)"    Header="Status" />
                    <DataTableColumn TData="Order" TValue="decimal" Property="@(o => o.Amount)"    Header="Amount"   Sortable Alignment="ColumnAlignment.Right" />
                </Columns>
            </DataTable>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Virtualize (Client-Side)"
        Description="Set Virtualize=true to keep all data in memory but only render visible DOM rows. Search and sort still run client-side. Useful for large in-memory datasets (500–20k rows) where you don't want pagination.">
        <DemoBlock Code="@_virtualizeClientCode">
            <DataTable TData="Order"
                       Data="@_allOrders"
                       Virtualize="true"
                       ItemHeight="40"
                       Height="360px">
                <Columns>
                    <DataTableColumn TData="Order" TValue="int"     Property="@(o => o.Id)"       Header="ID"       Sortable Alignment="ColumnAlignment.Right" />
                    <DataTableColumn TData="Order" TValue="string"  Property="@(o => o.Customer)"  Header="Customer" Sortable Filterable />
                    <DataTableColumn TData="Order" TValue="string"  Property="@(o => o.Product)"   Header="Product"  Sortable Filterable />
                    <DataTableColumn TData="Order" TValue="string"  Property="@(o => o.Status)"    Header="Status" />
                    <DataTableColumn TData="Order" TValue="decimal" Property="@(o => o.Amount)"    Header="Amount"   Sortable Alignment="ColumnAlignment.Right" />
                </Columns>
            </DataTable>
        </DemoBlock>
    </DemoSection>

        <DemoSection
        Title="Column Pinning"
        Description="Pin columns to the left or right edge so they stay visible while scrolling horizontally. Add Pinned=&quot;ColumnPinnedSide.Left&quot; or Pinned=&quot;ColumnPinnedSide.Right&quot; to any column. Set an explicit Width on pinned columns so offsets can be calculated correctly.">
        <DemoBlock Code="@_columnPinningCode">
            <DataTable TData="PinnedEmployee" Data="@_pinnedEmployees" ShowPagination="false">
                <Columns>
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Name)"
                        Header="Name" Width="200px" Pinned="ColumnPinnedSide.Left" Sortable>
                        <CellTemplate Context="e">
                            <div>
                                <p class="font-medium">@e.Name</p>
                                <p class="text-xs text-muted-foreground">@e.Email</p>
                            </div>
                        </CellTemplate>
                    </DataTableColumn>
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Department)" Header="Department" Width="140px" Sortable />
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Title)"      Header="Title"      Width="180px" />
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Location)"   Header="Location"   Width="130px" />
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Manager)"    Header="Manager"    Width="160px" />
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.StartDate)"  Header="Start Date" Width="120px" Sortable />
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Salary)"     Header="Salary"     Width="110px" Alignment="ColumnAlignment.Right" />
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Status)"     Header="Status"     Width="100px">
                        <CellTemplate Context="e">
                            <Badge Variant="@(e.Status == "Active" ? BadgeVariant.Default : BadgeVariant.Secondary)">@e.Status</Badge>
                        </CellTemplate>
                    </DataTableColumn>
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Name)"
                        Header="Actions" Width="90px" Pinned="ColumnPinnedSide.Right" Alignment="ColumnAlignment.Center">
                        <CellTemplate Context="e">
                            <div class="flex items-center justify-center gap-1">
                                <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" Class="size-7">
                                    <LucideIcon Name="pencil" Size="13" />
                                </Button>
                                <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" Class="size-7 text-destructive hover:text-destructive">
                                    <LucideIcon Name="trash-2" Size="13" />
                                </Button>
                            </div>
                        </CellTemplate>
                    </DataTableColumn>
                </Columns>
            </DataTable>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Self Referencing Rows (Chart of Accounts)"
        Description="Set ChildrenProperty to render a self-referencing hierarchy in-place. Rows expand and collapse with chevrons. When searching, ancestor rows containing matching descendants are automatically expanded. Combined here with column pinning to keep Account Name visible while scrolling across all the accounting columns.">
        <DemoBlock Code="@_treeRowsCode">
            <DataTable TData="CoaAccount" Data="@_coaAccounts"
                       ChildrenProperty="@(a => a.Children)"
                       ValueField="@(a => a.Code)"
                       ShowPagination="false">
                <Columns>
                    <DataTableColumn TData="CoaAccount" TValue="string" Property="@(a => a.Name)"
                        Header="Account Name" Width="220px" Pinned="ColumnPinnedSide.Left" Sortable />
                    <DataTableColumn TData="CoaAccount" TValue="string" Property="@(a => a.Code)"
                        Header="Code" Width="80px" />
                    <DataTableColumn TData="CoaAccount" TValue="string" Property="@(a => a.Type)"
                        Header="Type" Width="120px">
                        <CellTemplate Context="a">
                            <Badge Variant="@(a.Type switch {
                                "Asset"     => BadgeVariant.Default,
                                "Liability" => BadgeVariant.Destructive,
                                "Equity"    => BadgeVariant.Secondary,
                                "Revenue"   => BadgeVariant.Outline,
                                _           => BadgeVariant.Secondary })">@a.Type</Badge>
                        </CellTemplate>
                    </DataTableColumn>
                    <DataTableColumn TData="CoaAccount" TValue="string" Property="@(a => a.Description)"
                        Header="Description" Width="240px" />
                    <DataTableColumn TData="CoaAccount" TValue="string" Property="@(a => a.Currency)"
                        Header="Currency" Width="90px" />
                    <DataTableColumn TData="CoaAccount" TValue="string" Property="@(a => a.Balance)"
                        Header="Balance" Width="130px" Alignment="ColumnAlignment.Right">
                        <CellTemplate Context="a">
                            <span class="@(a.Balance.StartsWith("-") ? "text-destructive font-mono text-sm" : "font-mono text-sm")">@a.Balance</span>
                        </CellTemplate>
                    </DataTableColumn>
                    <DataTableColumn TData="CoaAccount" TValue="string" Property="@(a => a.Status)"
                        Header="Status" Width="90px">
                        <CellTemplate Context="a">
                            @if (!string.IsNullOrEmpty(a.Status))
                            {
                                <Badge Variant="@(a.Status == "Active" ? BadgeVariant.Default : BadgeVariant.Secondary)">@a.Status</Badge>
                            }
                        </CellTemplate>
                    </DataTableColumn>
                    <DataTableColumn TData="CoaAccount" TValue="string" Property="@(a => a.Code)"
                        Header="Actions" Width="80px" Pinned="ColumnPinnedSide.Right" Alignment="ColumnAlignment.Center">
                        <CellTemplate Context="a">
                            @if (!string.IsNullOrEmpty(a.CreatedBy))
                            {
                                <div class="flex items-center justify-center gap-1">
                                    <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" Class="size-7">
                                        <LucideIcon Name="pencil" Size="13" />
                                    </Button>
                                    <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" Class="size-7 text-destructive hover:text-destructive">
                                        <LucideIcon Name="trash-2" Size="13" />
                                    </Button>
                                </div>
                            }
                        </CellTemplate>
                    </DataTableColumn>
                </Columns>
            </DataTable>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Column Resizing &amp; Reordering"
        Description="Enable Resizable to add drag handles on column headers for width adjustment. Enable Reorderable to let users drag columns into a new order — columns shift smoothly into place as you drag. Both work independently or together. Per-column Resizable/Reorderable overrides the table-level default.">
        <DemoBlock Code="@_resizeReorderCode">
            <DataTable TData="PinnedEmployee" Data="@_pinnedEmployees"
                       TableContainerClass="border-0"
                       SyncWidthOnResize="true"
                       Striped="true"
                       HeaderBorder="true"
                       Resizable="true"
                       Reorderable="true"
                       ShowPagination="false"
                       OnColumnResize="@(args => _lastResizeEvent = $"{args.ColumnId}: {args.Width}")"
                       OnColumnReorder="@(args => _lastReorderEvent = $"{args.ColumnId} → index {args.NewIndex}")">
                <Columns>
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Name)"       Header="Name"       Width="160px" Sortable CellClass="truncate" HeaderClass="overflow-hidden" />
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Department)" Header="Department" Width="140px" Sortable CellClass="truncate" HeaderClass="overflow-hidden" />
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Title)"      Header="Title"      Width="180px" CellClass="truncate" HeaderClass="overflow-hidden" />
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Location)"   Header="Location"   Width="130px" CellClass="truncate" HeaderClass="overflow-hidden" />
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Salary)"     Header="Salary"     Width="110px" Alignment="ColumnAlignment.Right" CellClass="truncate" HeaderClass="overflow-hidden" />
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Status)"     Header="Status"     Width="100px" HeaderClass="overflow-hidden">
                        <CellTemplate Context="e">
                            <Badge Variant="@(e.Status == "Active" ? BadgeVariant.Default : BadgeVariant.Secondary)">@e.Status</Badge>
                        </CellTemplate>
                    </DataTableColumn>
                </Columns>
            </DataTable>
            @if (!string.IsNullOrEmpty(_lastResizeEvent) || !string.IsNullOrEmpty(_lastReorderEvent))
            {
                <div class="mt-3 flex gap-4 text-sm text-muted-foreground">
                    @if (!string.IsNullOrEmpty(_lastResizeEvent))
                    {
                        <span>Last resize: <code class="text-foreground">@_lastResizeEvent</code></span>
                    }
                    @if (!string.IsNullOrEmpty(_lastReorderEvent))
                    {
                        <span>Last reorder: <code class="text-foreground">@_lastReorderEvent</code></span>
                    }
                </div>
            }
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Row Context Menu"
        Description="Right-click any row to open a context menu scoped to that row. The RowContextMenu render fragment receives a DataTableRowMenuContext with the row's item, current selection, and visible column IDs. Use any ContextMenuItem, ContextMenuSeparator, or sub-menu components inside it.">
        <DemoBlock Code="@_rowContextMenuCode">
            <DataTable TData="PinnedEmployee" Data="@_pinnedEmployees"
                       EnableKeyboardNavigation="false"
                       ShowPagination="false">
                <Columns>
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Name)"       Header="Name"       Sortable />
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Department)" Header="Department" Sortable />
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Title)"      Header="Title" />
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Salary)"     Header="Salary" Alignment="ColumnAlignment.Right" />
                    <DataTableColumn TData="PinnedEmployee" TValue="string" Property="@(e => e.Status)"     Header="Status">
                        <CellTemplate Context="e">
                            <Badge Variant="@(e.Status == "Active" ? BadgeVariant.Default : BadgeVariant.Secondary)">@e.Status</Badge>
                        </CellTemplate>
                    </DataTableColumn>
                </Columns>
                <RowContextMenu Context="ctx">
                    <ContextMenuItem OnClick="@(() => _ctxAction = $"Edit: {ctx.Item.Name}")">
                        <LucideIcon Name="pencil" Size="14" Class="mr-2" />
                        Edit
                    </ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => _ctxAction = $"View: {ctx.Item.Name}")">
                        <LucideIcon Name="eye" Size="14" Class="mr-2" />
                        View Details
                    </ContextMenuItem>
                    <ContextMenuSeparator />
                    <ContextMenuItem OnClick="@(() => _ctxAction = $"Copy: {ctx.Item.Name}")">
                        <LucideIcon Name="copy" Size="14" Class="mr-2" />
                        Copy Row
                    </ContextMenuItem>
                    @if (ctx.SelectedItems.Count > 1)
                    {
                        <ContextMenuSeparator />
                        <ContextMenuItem OnClick="@(() => _ctxAction = $"Export {ctx.SelectedItems.Count} rows")">
                            <LucideIcon Name="download" Size="14" Class="mr-2" />
                            Export @ctx.SelectedItems.Count Selected
                        </ContextMenuItem>
                    }
                    <ContextMenuSeparator />
                    <ContextMenuItem Class="text-destructive focus:text-destructive"
                                     OnClick="@(() => _ctxAction = $"Delete: {ctx.Item.Name}")">
                        <LucideIcon Name="trash-2" Size="14" Class="mr-2" />
                        Delete
                    </ContextMenuItem>
                </RowContextMenu>
            </DataTable>
            @if (!string.IsNullOrEmpty(_ctxAction))
            {
                <div class="mt-3 text-sm text-muted-foreground">
                    Last action: <code class="text-foreground">@_ctxAction</code>
                </div>
            }
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Sortable Row Reorder"
        Description="Use AdditionalRowAttributes to attach data-sortable-id to each table row. Wrap the DataTable in a Sortable root and SortableContent, then add a drag handle column via CellTemplate.">
        <DemoBlock Code="@_sortableRowsCode">
            <Sortable TItem="SortableTask"
                      Items="@_sortableRows"
                      OnItemsReordered="@(r => _sortableRows = r)"
                      GetItemId="@(t => t.Id)">
                <SortableContent Class="block">
                    <DataTable TData="SortableTask"
                               Data="@_sortableRows"
                               AdditionalRowAttributes="@(t => new Dictionary<string, object> { ["data-sortable-id"] = t.Id })"
                               ShowPagination="false"
                               ShowToolbar="false">
                        <Columns>
                            <DataTableColumn TData="SortableTask" TValue="string" Property="@(t => t.Id)" Header="" Width="44px">
                                <CellTemplate Context="row">
                                    <SortableItemHandle Class="mx-auto" />
                                </CellTemplate>
                            </DataTableColumn>
                            <DataTableColumn TData="SortableTask" TValue="string" Property="@(t => t.Name)" Header="Task" Sortable />
                            <DataTableColumn TData="SortableTask" TValue="string" Property="@(t => t.Assignee)" Header="Assignee" />
                            <DataTableColumn TData="SortableTask" TValue="string" Property="@(t => t.Status)" Header="Status">
                                <CellTemplate Context="row">
                                    <Badge Variant="@(row.Status == "Done" ? BadgeVariant.Default : row.Status == "In Progress" ? BadgeVariant.Secondary : BadgeVariant.Outline)">
                                        @row.Status
                                    </Badge>
                                </CellTemplate>
                            </DataTableColumn>
                        </Columns>
                    </DataTable>
                </SortableContent>
                <SortableOverlay Class="rounded opacity-80" />
            </Sortable>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Global Search &amp; Column Visibility"
        Description="Search across all columns and toggle column visibility.">
        <DemoBlock Code="@_searchCode">
            <DataTable TData="Person" Data="@people" InitialPageSize="10">
                <Columns>
                    <DataTableColumn TData="Person" TValue="int" Property="@(p => p.Id)" Header="ID" Sortable />
                    <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Name)" Header="Name" Sortable />
                    <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Email)" Header="Email" />
                    <DataTableColumn TData="Person" TValue="int" Property="@(p => p.Age)" Header="Age" Sortable />
                    <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Role)" Header="Role" />
                    <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Status)" Header="Status">
                        <CellTemplate Context="person">
                            <Badge Variant="@(person.Status == "Active" ? BadgeVariant.Default : BadgeVariant.Secondary)">
                                @person.Status
                            </Badge>
                        </CellTemplate>
                    </DataTableColumn>
                </Columns>
            </DataTable>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Empty State"
        Description="Displays a message when there's no data to show.">
        <DemoBlock Code="@_emptyStateCode">
            <DataTable TData="Person" Data="@emptyPeople" InitialPageSize="5">
                <Columns>
                    <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Name)" Header="Name" />
                    <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Email)" Header="Email" />
                </Columns>
            </DataTable>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Loading State"
        Description="Shows a loading indicator while data is being fetched.">
        <DemoBlock Code="@_loadingCode">
            <div class="flex gap-2 mb-4">
                <Button OnClick="@(() => isLoading = !isLoading)">
                    Toggle Loading
                </Button>
            </div>
            <DataTable TData="Person" Data="@people" IsLoading="@isLoading" InitialPageSize="5">
                <Columns>
                    <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Name)" Header="Name" Sortable />
                    <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Email)" Header="Email" />
                    <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Role)" Header="Role" />
                </Columns>
            </DataTable>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Without Toolbar"
        Description="A minimal table without the toolbar (no search or column visibility).">
        <DemoBlock Code="@_withoutToolbarCode">
            <DataTable TData="Person" Data="@people" ShowToolbar="false" InitialPageSize="5">
                <Columns>
                    <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Name)" Header="Name" Sortable />
                    <DataTableColumn TData="Person" TValue="string" Property="@(p => p.Email)" Header="Email" />
                    <DataTableColumn TData="Person" TValue="int" Property="@(p => p.Age)" Header="Age" Sortable />
                </Columns>
            </DataTable>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Custom Toolbar Actions"
