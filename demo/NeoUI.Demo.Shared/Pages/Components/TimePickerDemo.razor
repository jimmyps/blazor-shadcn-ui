@page "/components/time-picker"
@using System.ComponentModel.DataAnnotations

<PageTitle>TimePicker - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="TimePicker"
        Description="Time selection with hour, minute, and optional second selectors. Supports both 12-hour and 24-hour formats." />

    <DemoSection
        Title="Default (24-Hour)"
        Description="A basic time picker with 24-hour format.">
        <DemoBlock Code="@_defaultCode">
            <div class="flex flex-col gap-4">
                <TimePicker @bind-SelectedTime="selectedTime1" />
                <p class="text-sm text-muted-foreground">Selected: @(selectedTime1?.ToString("HH:mm") ?? "None")</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="12-Hour Format"
        Description="Time picker with 12-hour format and AM/PM selector.">
        <DemoBlock Code="@_12HourCode">
            <div class="flex flex-col gap-4">
                <TimePicker @bind-SelectedTime="selectedTime2" Use12Hour="true" />
                <p class="text-sm text-muted-foreground">Selected: @(FormatTime12Hour(selectedTime2))</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Seconds"
        Description="Time picker with seconds selector enabled.">
        <DemoBlock Code="@_secondsCode">
            <div class="flex flex-col gap-4">
                <TimePicker @bind-SelectedTime="selectedTime3" ShowSeconds="true" />
                <p class="text-sm text-muted-foreground">Selected: @(selectedTime3?.ToString("HH:mm:ss") ?? "None")</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="15-Minute Intervals"
        Description="Restrict minute selection to 15-minute intervals.">
        <DemoBlock Code="@_15minCode">
            <div class="flex flex-col gap-4">
                <TimePicker @bind-SelectedTime="selectedTime4" MinuteStep="15" Placeholder="Select time (15 min steps)" />
                <p class="text-sm text-muted-foreground">Selected: @(selectedTime4?.ToString("HH:mm") ?? "None")</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="30-Minute Intervals"
        Description="Restrict minute selection to 30-minute intervals.">
        <DemoBlock Code="@_30minCode">
            <div class="flex flex-col gap-4">
                <TimePicker @bind-SelectedTime="selectedTime6" MinuteStep="30" Use12Hour="true" Placeholder="Select time (30 min steps)" />
                <p class="text-sm text-muted-foreground">Selected: @(FormatTime12Hour(selectedTime6))</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Time Range Constraints"
        Description="Time picker with minimum and maximum time constraints (9 AM - 5 PM).">
        <DemoBlock Code="@_constraintsCode">
            <div class="flex flex-col gap-4">
                <TimePicker @bind-SelectedTime="selectedTime5"
                            MinTime="@(new TimeOnly(9, 0, 0))"
                            MaxTime="@(new TimeOnly(17, 0, 0))"
                            Use12Hour="true"
                            Placeholder="Business hours only" />
                <p class="text-sm text-muted-foreground">Selected: @(FormatTime12Hour(selectedTime5))</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="In a Form"
        Description="TimePicker integrated with form fields.">
        <DemoBlock Code="@_formCode">
            <div class="flex flex-col gap-4 max-w-sm">
                <Field>
                    <FieldLabel>Appointment Time</FieldLabel>
                    <TimePicker @bind-SelectedTime="appointmentTime"
                                MinuteStep="15"
                                Use12Hour="true"
                                Placeholder="Select appointment time" />
                    <FieldDescription>Select your preferred appointment time.</FieldDescription>
                </Field>
                <p class="text-sm text-muted-foreground">Selected: @(FormatTime12Hour(appointmentTime))</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Meeting Schedule"
        Description="Multiple time pickers for meeting start and end times.">
        <DemoBlock Code="@_meetingCode">
            <div class="flex flex-col gap-4 max-w-sm">
                <Field>
                    <FieldLabel>Meeting Start</FieldLabel>
                    <TimePicker @bind-SelectedTime="meetingStart" MinuteStep="15" Placeholder="Start time" />
                </Field>
                <Field>
                    <FieldLabel>Meeting End</FieldLabel>
                    <TimePicker @bind-SelectedTime="meetingEnd" MinuteStep="15" Placeholder="End time" />
                </Field>
                <p class="text-sm text-muted-foreground">
                    Duration:
                    @if (meetingStart.HasValue && meetingEnd.HasValue)
                    {
                        var duration = meetingEnd.Value.ToTimeSpan() - meetingStart.Value.ToTimeSpan();
                        <span class="font-medium">@((int)duration.TotalHours) hours @duration.Minutes minutes</span>
                    }
                    else
                    {
                        <span>Select both times</span>
                    }
                </p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Disabled State"
        Description="A disabled time picker.">
        <DemoBlock Code="@_disabledCode">
            <TimePicker @bind-SelectedTime="selectedTime7" Disabled="true" Placeholder="Disabled picker" />
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_timePickerProps" />
    </DemoSection>

    <DemoPageNav />
</div>

@code {
    private TimeOnly? selectedTime1;
    private TimeOnly? selectedTime2;
    private TimeOnly? selectedTime3;
    private TimeOnly? selectedTime4;
    private TimeOnly? selectedTime5;
    private TimeOnly? selectedTime6;
    private TimeOnly? selectedTime7;
    private TimeOnly? appointmentTime;
    private TimeOnly? meetingStart;
    private TimeOnly? meetingEnd;

    private string FormatTime12Hour(TimeOnly? time)
    {
        if (!time.HasValue) return "None";
        var t = time.Value;
        var hour = t.Hour % 12;
        if (hour == 0) hour = 12;
        var period = t.Hour >= 12 ? "PM" : "AM";
        return $"{hour}:{t.Minute:D2} {period}";
    }

}
