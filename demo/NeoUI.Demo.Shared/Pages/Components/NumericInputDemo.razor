@page "/components/numeric-input"

<PageTitle>Numeric Input - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Numeric Input"
        Description="A type-safe numeric input component with support for various numeric types." />

    <DemoSection
        Title="Integer Input"
        Description="A simple integer input with placeholder.">
        <DemoBlock Code="@_intCode">
            <ChildContent>
                <div class="max-w-md">
                    <NumericInput TValue="int" @bind-Value="quantity" Placeholder="Enter quantity..." />
                    <p class="text-xs text-muted-foreground mt-2">Current value: @quantity</p>
                </div>
            </ChildContent>
            <AdditionalContent>
                <Alert Variant="AlertVariant.Info">
                    <Icon><LucideIcon Name="info" Size="16" /></Icon>
                    <ChildContent>
                        <AlertTitle>Optimized for Performance &amp; Best Typing Experience</AlertTitle>
                        <AlertDescription>
                            <p class="mb-3">
                                By default, NumericInput uses <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">UpdateOn="Change"</code> for better performance and UX.
                            </p>
                            <div class="space-y-3">
                                <div>
                                    <p class="font-medium mb-2">Benefits:</p>
                                    <ul class="list-disc list-inside space-y-1 ml-2 text-sm">
                                        <li><strong>Better typing UX:</strong> No interruptions while typing — validation tooltips won't get in your way</li>
                                        <li><strong>Better performance:</strong> Value updates and validation only run when you tab away (blur)</li>
                                        <li><strong>Fewer re-renders:</strong> Your bound value updates once on blur, not on every keystroke</li>
                                    </ul>
                                </div>
                                <div>
                                    <p class="font-medium mb-2">UpdateOn Modes:</p>
                                    <div class="grid gap-2 text-sm">
                                        <div>
                                            <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">UpdateOn="Change"</code>
                                            <span class="text-muted-foreground ml-2">→ Updates on blur (default, recommended)</span>
                                        </div>
                                        <div>
                                            <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">UpdateOn="Input"</code>
                                            <span class="text-muted-foreground ml-2">→ Updates on every keystroke</span>
                                        </div>
                                    </div>
                                </div>
                                <p class="text-xs text-muted-foreground flex items-start gap-1.5">
                                    <LucideIcon Name="lightbulb" Size="14" Class="mt-0.5 flex-shrink-0" />
                                    <span><strong>Tip:</strong> Use <code class="px-1 py-0.5 bg-muted rounded">UpdateOn="Input"</code> only when you need real-time updates (e.g. live calculation, instant range validation), or when targeting WebAssembly where interactivity is fully client-side.</span>
                                </p>
                            </div>
                        </AlertDescription>
                    </ChildContent>
                </Alert>
            </AdditionalContent>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Decimal Input"
        Description="Decimal input for precise values like currency.">
        <DemoBlock Code="@_decimalCode">
            <div class="max-w-md space-y-2">
                <label class="text-sm font-medium">Price</label>
                <NumericInput TValue="decimal" @bind-Value="price" Placeholder="0.00" Step="0.01" Min="0" Max="10000" />
                <p class="text-xs text-muted-foreground">Current value: @price.ToString("C")</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Double Input"
        Description="Double precision floating point input.">
        <DemoBlock Code="@_doubleCode">
            <div class="max-w-md space-y-2">
                <label class="text-sm font-medium">Percentage</label>
                <NumericInput TValue="double" @bind-Value="percentage" Placeholder="0.0" Step="0.1" Min="0" Max="100" />
                <p class="text-xs text-muted-foreground">Current value: @percentage%</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Float Input"
        Description="Single precision floating point input.">
        <DemoBlock Code="@_floatCode">
            <div class="max-w-md space-y-2">
                <label class="text-sm font-medium">Rating</label>
                <NumericInput TValue="float" @bind-Value="rating" Placeholder="0.0" Step="0.1" Min="0" Max="5" />
                <p class="text-xs text-muted-foreground">Current value: @rating</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Min/Max Constraints"
        Description="Input with minimum and maximum value validation.">
        <DemoBlock Code="@_constraintsCode">
            <div class="max-w-md space-y-2">
                <label class="text-sm font-medium">Age (18-120)</label>
                <NumericInput TValue="int" @bind-Value="age" Min="18" Max="120" Step="1" Placeholder="Enter age" />
                <p class="text-xs text-muted-foreground">Current value: @age</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Disabled"
        Description="Input with disabled state.">
        <DemoBlock Code="@_disabledCode">
            <div class="max-w-md">
                <NumericInput TValue="int" Placeholder="Disabled input" Disabled="true" Value="42" />
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Required"
        Description="Input with HTML5 required validation.">
        <DemoBlock Code="@_requiredCode">
            <div class="max-w-md">
                <form class="space-y-4">
                    <div class="space-y-2">
                        <label class="text-sm font-medium">Quantity (required)</label>
                        <NumericInput TValue="int" @bind-Value="requiredQuantity" Placeholder="Enter quantity" Required="true" Min="1" />
                    </div>
                    <button type="submit" class="inline-flex items-center justify-center rounded-md text-sm font-medium h-10 px-4 py-2 bg-primary text-primary-foreground hover:bg-primary/90">
                        Submit
                    </button>
                </form>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Label"
        Description="Inputs with labels and helper text.">
        <DemoBlock Code="@_withLabelCode">
            <div class="max-w-md space-y-4">
                <div class="space-y-2">
                    <label for="amount-input" class="text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70">
                        Amount
                    </label>
                    <NumericInput TValue="decimal" @bind-Value="amount" Id="amount-input" Placeholder="0.00" Step="0.01" AriaLabel="Amount" />
                    <p class="text-sm text-muted-foreground">
                        Current value: @amount.ToString("C")
                    </p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Error State"
        Description="Input with error visualization using aria-invalid.">
        <DemoBlock Code="@_errorCode">
            <div class="max-w-md space-y-2">
                <label class="text-sm font-medium">Invalid value</label>
                <NumericInput TValue="int" @bind-Value="errorValue" AriaInvalid="true" Placeholder="This field has an error" />
                <p class="text-sm text-destructive">Please enter a valid number. Current: @errorValue</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Readonly"
        Description="Input in readonly mode - focusable but not editable.">
        <DemoBlock Code="@_readonlyCode">
            <div class="max-w-md">
                <NumericInput TValue="decimal" Value="99.99m" Readonly="true" Placeholder="Readonly value" />
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_numericInputProps" />
    </DemoSection>

    <DemoPageNav />
</div>

@code {
    private int quantity = 10;
    private decimal price = 29.99m;
    private double percentage = 75.5;
    private float rating = 4.5f;
    private decimal amount = 100.00m;
    private int age = 25;
    private int requiredQuantity;
    private int errorValue = -1;

}
