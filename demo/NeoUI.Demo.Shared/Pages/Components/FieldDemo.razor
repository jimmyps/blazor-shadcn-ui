@page "/components/field"

<PageTitle>Field - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Field"
        Description="A flexible form field component that handles layout, labels, hints, and validation states." />

    <DemoSection
        Title="Basic Forms"
        Description="Combine Field with various form controls.">
        <DemoBlock Code="@_basicCode">
            <div class="space-y-4 max-w-sm">
                <Field>
                    <FieldLabel>Username</FieldLabel>
                    <FieldContent>
                        <NeoUI.Blazor.Input Type="InputType.Text" Placeholder="Enter username" />
                    </FieldContent>
                    <FieldHint>Must be at least 3 characters.</FieldHint>
                </Field>
                <Field>
                    <FieldLabel>Email</FieldLabel>
                    <FieldContent>
                        <NeoUI.Blazor.Input Type="InputType.Email" Placeholder="name@example.com" />
                    </FieldContent>
                </Field>
                <Field>
                    <FieldLabel>Role</FieldLabel>
                    <FieldContent>
                        <Select TValue="string" @bind-Value="selectedRole">
                            <SelectTrigger>
                                <SelectValue Placeholder="Select a role..." />
                            </SelectTrigger>
                            <SelectContent>
                                <SelectItem Value="@("admin")" TValue="string">Admin</SelectItem>
                                <SelectItem Value="@("editor")" TValue="string">Editor</SelectItem>
                                <SelectItem Value="@("viewer")" TValue="string">Viewer</SelectItem>
                            </SelectContent>
                        </Select>
                    </FieldContent>
                </Field>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Validation Examples"
        Description="Show valid and invalid states with appropriate messages.">
        <DemoBlock Code="@_validationCode">
            <div class="space-y-4 max-w-sm">
                <Field IsInvalid="false">
                    <FieldLabel>Username</FieldLabel>
                    <FieldContent>
                        <NeoUI.Blazor.Input Type="InputType.Text" Value="johndoe" />
                    </FieldContent>
                    <FieldHint>Username is available.</FieldHint>
                </Field>
                <Field IsInvalid="true">
                    <FieldLabel>Email</FieldLabel>
                    <FieldContent>
                        <NeoUI.Blazor.Input Type="InputType.Email" Value="not-valid" AriaInvalid="true" />
                    </FieldContent>
                    <FieldError>Please enter a valid email address.</FieldError>
                </Field>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Horizontal Orientation"
        Description="Display label and field side by side with horizontal layout.">
        <DemoBlock Code="@_horizontalCode">
            <div class="space-y-4 max-w-lg">
                <Field Orientation="FieldOrientation.Horizontal">
                    <FieldLabel>Name</FieldLabel>
                    <FieldContent>
                        <NeoUI.Blazor.Input Type="InputType.Text" Placeholder="Enter your name" />
                    </FieldContent>
                </Field>
                <Field Orientation="FieldOrientation.Horizontal">
                    <FieldLabel>Email</FieldLabel>
                    <FieldContent>
                        <NeoUI.Blazor.Input Type="InputType.Email" Placeholder="name@example.com" />
                    </FieldContent>
                </Field>
                <Field Orientation="FieldOrientation.Horizontal">
                    <FieldLabel>Department</FieldLabel>
                    <FieldContent>
                        <Select TValue="string" @bind-Value="selectedDept">
                            <SelectTrigger>
                                <SelectValue Placeholder="Select a department..." />
                            </SelectTrigger>
                            <SelectContent>
                                <SelectItem Value="@("engineering")" TValue="string">Engineering</SelectItem>
                                <SelectItem Value="@("design")" TValue="string">Design</SelectItem>
                                <SelectItem Value="@("marketing")" TValue="string">Marketing</SelectItem>
                            </SelectContent>
                        </Select>
                    </FieldContent>
                </Field>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Responsive Orientation"
        Description="Switch between vertical and horizontal based on screen size.">
        <DemoBlock Code="@_responsiveCode">
            <div class="space-y-4 max-w-lg">
                <Field Orientation="FieldOrientation.Responsive">
                    <FieldLabel>Username</FieldLabel>
                    <FieldContent>
                        <NeoUI.Blazor.Input Type="InputType.Text" Placeholder="Enter username" />
                    </FieldContent>
                    <FieldHint>Vertical on mobile, horizontal on larger screens.</FieldHint>
                </Field>
                <Field Orientation="FieldOrientation.Responsive">
                    <FieldLabel>Bio</FieldLabel>
                    <FieldContent>
                        <textarea
                            class="flex min-h-[60px] w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
                            placeholder="Tell us about yourself..."
                            rows="3"></textarea>
                    </FieldContent>
                </Field>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Field Groups"
        Description="Group related fields together using FieldGroup.">
        <DemoBlock Code="@_groupCode">
            <div class="max-w-sm">
                <FieldGroup>
                    <FieldGroupTitle>Personal Information</FieldGroupTitle>
                    <FieldGroupDescription>Your basic profile details.</FieldGroupDescription>
                    <Field>
                        <FieldLabel>First Name</FieldLabel>
                        <FieldContent>
                            <NeoUI.Blazor.Input Type="InputType.Text" Placeholder="John" />
                        </FieldContent>
                    </Field>
                    <Field>
                        <FieldLabel>Last Name</FieldLabel>
                        <FieldContent>
                            <NeoUI.Blazor.Input Type="InputType.Text" Placeholder="Doe" />
                        </FieldContent>
                    </Field>
                    <Field>
                        <FieldLabel>Date of Birth</FieldLabel>
                        <FieldContent>
                            <NeoUI.Blazor.Input Type="InputType.Date" />
                        </FieldContent>
                    </Field>
                </FieldGroup>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="FieldSets"
        Description="Visually contained groups of fields with border and title.">
        <DemoBlock Code="@_fieldSetCode">
            <div class="max-w-sm">
                <FieldSet>
                    <FieldSetLegend>Contact Information</FieldSetLegend>
                    <Field>
                        <FieldLabel>Phone</FieldLabel>
                        <FieldContent>
                            <NeoUI.Blazor.Input Type="InputType.Tel" Placeholder="(555) 000-0000" />
                        </FieldContent>
                    </Field>
                    <Field>
                        <FieldLabel>Address</FieldLabel>
                        <FieldContent>
                            <NeoUI.Blazor.Input Type="InputType.Text" Placeholder="123 Main St" />
                        </FieldContent>
                    </Field>
                    <Field>
                        <FieldLabel>City</FieldLabel>
                        <FieldContent>
                            <NeoUI.Blazor.Input Type="InputType.Text" Placeholder="New York" />
                        </FieldContent>
                    </Field>
                </FieldSet>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Field with Title"
        Description="Use FieldTitle for section headings within a form.">
        <DemoBlock Code="@_fieldTitleCode">
            <div class="max-w-sm space-y-6">
                <FieldTitle Title="Account Settings" Description="Manage your account details and preferences." />
                <Field>
                    <FieldLabel>Username</FieldLabel>
                    <FieldContent>
                        <NeoUI.Blazor.Input Type="InputType.Text" Value="john_doe" />
                    </FieldContent>
                </Field>
                <Field>
                    <FieldLabel>Language</FieldLabel>
                    <FieldContent>
                        <Select TValue="string" @bind-Value="selectedLang">
                            <SelectTrigger>
                                <SelectValue Placeholder="Select language..." />
                            </SelectTrigger>
                            <SelectContent>
                                <SelectItem Value="@("en")" TValue="string">English</SelectItem>
                                <SelectItem Value="@("fr")" TValue="string">French</SelectItem>
                                <SelectItem Value="@("de")" TValue="string">German</SelectItem>
                            </SelectContent>
                        </Select>
                    </FieldContent>
                </Field>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_fieldProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private string? selectedRole;
    private string? selectedDept;
    private string? selectedLang;

    private static readonly IReadOnlyList<DemoPropRow> _fieldProps =
    [
        new("Orientation", "FieldOrientation", "Vertical",   "Layout orientation. Options: Vertical, Horizontal, Responsive."),
        new("IsInvalid",   "bool",             "false",      "Marks the field as invalid, applying error styling."),
        new("Class",       "string?",          "null",       "Additional CSS classes for the root element."),
        new("ChildContent","RenderFragment?",  "null",       "FieldLabel, FieldContent, FieldHint, FieldError sub-components."),
    ];

    private const string _basicCode = """
        <Field>
            <FieldLabel>Username</FieldLabel>
            <FieldContent>
                <Input Type="InputType.Text" Placeholder="Enter username" />
            </FieldContent>
            <FieldHint>Must be at least 3 characters.</FieldHint>
        </Field>
        """;

    private const string _validationCode = """
        <!-- Valid state -->
        <Field IsInvalid="false">
            <FieldLabel>Username</FieldLabel>
            <FieldContent>
                <Input Type="InputType.Text" Value="johndoe" />
            </FieldContent>
            <FieldHint>Username is available.</FieldHint>
        </Field>

        <!-- Invalid state -->
        <Field IsInvalid="true">
            <FieldLabel>Email</FieldLabel>
            <FieldContent>
                <Input Type="InputType.Email" Value="not-valid" AriaInvalid="true" />
            </FieldContent>
            <FieldError>Please enter a valid email address.</FieldError>
        </Field>
        """;

    private const string _horizontalCode = """
        <Field Orientation="FieldOrientation.Horizontal">
            <FieldLabel>Name</FieldLabel>
            <FieldContent>
                <Input Type="InputType.Text" Placeholder="Enter your name" />
            </FieldContent>
        </Field>
        """;

    private const string _responsiveCode = """
        <Field Orientation="FieldOrientation.Responsive">
            <FieldLabel>Username</FieldLabel>
            <FieldContent>
                <Input Type="InputType.Text" Placeholder="Enter username" />
            </FieldContent>
            <FieldHint>Vertical on mobile, horizontal on larger screens.</FieldHint>
        </Field>
        """;

    private const string _groupCode = """
        <FieldGroup>
            <FieldGroupTitle>Personal Information</FieldGroupTitle>
            <FieldGroupDescription>Your basic profile details.</FieldGroupDescription>
            <Field>
                <FieldLabel>First Name</FieldLabel>
                <FieldContent><Input Type="InputType.Text" Placeholder="John" /></FieldContent>
            </Field>
            <Field>
                <FieldLabel>Last Name</FieldLabel>
                <FieldContent><Input Type="InputType.Text" Placeholder="Doe" /></FieldContent>
            </Field>
        </FieldGroup>
        """;

    private const string _fieldSetCode = """
        <FieldSet>
            <FieldSetLegend>Contact Information</FieldSetLegend>
            <Field>
                <FieldLabel>Phone</FieldLabel>
                <FieldContent><Input Type="InputType.Tel" Placeholder="(555) 000-0000" /></FieldContent>
            </Field>
            <Field>
                <FieldLabel>Address</FieldLabel>
                <FieldContent><Input Type="InputType.Text" Placeholder="123 Main St" /></FieldContent>
            </Field>
        </FieldSet>
        """;

    private const string _fieldTitleCode = """
        <FieldTitle Title="Account Settings" Description="Manage your account details and preferences." />
        <Field>
            <FieldLabel>Username</FieldLabel>
            <FieldContent><Input Type="InputType.Text" Value="john_doe" /></FieldContent>
        </Field>
        """;
}
