@page "/components/select"

<PageTitle>Select - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Select"
        Description="Displays a list of options for the user to pick from—triggered by a button." />

    <DemoSection
        Title="Basic Select"
        Description="A simple select with a list of options.">
        <DemoBlock Code="@_basicCode">
            <div class="flex items-center gap-4">
                <Select @bind-Value="selectedFruit" TValue="string" Class="w-[280px]">
                    <SelectTrigger>
                        <SelectValue Placeholder="Select a fruit" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectItem Value="@("apple")" Text="Apple" TValue="string">Apple</SelectItem>
                        <SelectItem Value="@("banana")" Text="Banana" TValue="string">Banana</SelectItem>
                        <SelectItem Value="@("blueberry")" Text="Blueberry" TValue="string">Blueberry</SelectItem>
                        <SelectItem Value="@("grapes")" Text="Grapes" TValue="string">Grapes</SelectItem>
                        <SelectItem Value="@("pineapple")" Text="Pineapple" TValue="string">Pineapple</SelectItem>
                    </SelectContent>
                </Select>
                @if (!string.IsNullOrEmpty(selectedFruit))
                {
                    <p class="text-sm">Selected: <strong>@selectedFruit</strong></p>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Grouped Options"
        Description="Organize related items into labeled groups.">
        <DemoBlock Code="@_groupedCode">
            <div class="flex items-center gap-4">
                <Select @bind-Value="selectedAnimal" TValue="string" Class="w-[280px]">
                    <SelectTrigger>
                        <SelectValue Placeholder="Select an animal" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectGroup>
                            <SelectLabel>Mammals</SelectLabel>
                            <SelectItem Value="@("cat")" Text="Cat" TValue="string">Cat</SelectItem>
                            <SelectItem Value="@("dog")" Text="Dog" TValue="string">Dog</SelectItem>
                            <SelectItem Value="@("elephant")" Text="Elephant" TValue="string">Elephant</SelectItem>
                        </SelectGroup>
                        <SelectGroup>
                            <SelectLabel>Birds</SelectLabel>
                            <SelectItem Value="@("eagle")" Text="Eagle" TValue="string">Eagle</SelectItem>
                            <SelectItem Value="@("parrot")" Text="Parrot" TValue="string">Parrot</SelectItem>
                        </SelectGroup>
                    </SelectContent>
                </Select>
                @if (!string.IsNullOrEmpty(selectedAnimal))
                {
                    <p class="text-sm">Selected: <strong>@selectedAnimal</strong></p>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Scrollable Long List"
        Description="Handle many options with automatic scrolling (max-h-60).">
        <DemoBlock Code="@_scrollableCode">
            <div class="flex items-center gap-4">
                <Select @bind-Value="selectedCountry" TValue="string" Class="w-[280px]">
                    <SelectTrigger>
                        <SelectValue Placeholder="Select a country" />
                    </SelectTrigger>
                    <SelectContent>
                        @foreach (var country in countries)
                        {
                            <SelectItem Value="@country" TValue="string">@country</SelectItem>
                        }
                    </SelectContent>
                </Select>
                @if (!string.IsNullOrEmpty(selectedCountry))
                {
                    <p class="text-sm">Selected: <strong>@selectedCountry</strong></p>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Generic Type Support"
        Description="Select component supports generic types (int, enum, custom types).">
        <DemoBlock Code="@_genericCode">
            <div class="flex items-center gap-4">
                <Select @bind-Value="selectedNumber" TValue="int" Class="w-[280px]">
                    <SelectTrigger>
                        <SelectValue Placeholder="Select a number" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectItem Value="1" Text="One" TValue="int">One</SelectItem>
                        <SelectItem Value="2" Text="Two" TValue="int">Two</SelectItem>
                        <SelectItem Value="3" Text="Three" TValue="int">Three</SelectItem>
                        <SelectItem Value="4" Text="Four" TValue="int">Four</SelectItem>
                        <SelectItem Value="5" Text="Five" TValue="int">Five</SelectItem>
                    </SelectContent>
                </Select>
                @if (selectedNumber > 0)
                {
                    <p class="text-sm">Selected: <strong>@selectedNumber</strong></p>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Infinite Scroll"
        Description="Load items in batches as the user scrolls to the bottom of the SelectContent dropdown.">
        <DemoBlock Code="@_infiniteScrollCode">
            <AdditionalContent>
                <Alert Variant="AlertVariant.Info">
                    <Icon><LucideIcon Name="info" Size="16" /></Icon>
                    <ChildContent>
                        <AlertDescription>
                            Open the dropdown and scroll down to trigger <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">OnLoadMore</code> on <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">SelectContent</code>.
                            A spinner appears during the simulated 600 ms fetch. Once all @_sTotalItems items are loaded,
                            <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">EndOfListMessage</code> is shown instead of the spinner.
                        </AlertDescription>
                    </ChildContent>
                </Alert>
            </AdditionalContent>
            <ChildContent>
                <div class="flex items-center gap-4">
                    <Select @bind-Value="_sPagedValue" TValue="string" Class="w-[280px]">
                        <SelectTrigger>
                            <SelectValue Placeholder="Select an option..." />
                        </SelectTrigger>
                        <SelectContent OnLoadMore="@HandleSelectLoadMore"
                                       IsLoading="@_sPagedLoading"
                                       EndOfListMessage="@SelectEndMessage">
                            @foreach (var item in _sPagedItems)
                            {
                                <SelectItem Value="@item.Value" Text="@item.Label" TValue="string">@item.Label</SelectItem>
                            }
                        </SelectContent>
                    </Select>
                    @if (!string.IsNullOrEmpty(_sPagedValue))
                    {
                        <p class="text-sm">Selected: <strong>@_sPagedValue</strong></p>
                    }
                </div>
            </ChildContent>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Bottom Sheet (Mobile)"
        Description="Use Presentation=BottomSheet to render the options in a Drawer that slides up from the bottom. Recommended for mobile-first UIs.">
        <DemoBlock Code="@_bottomSheetCode">
            <div class="flex items-center gap-4">
                <Select @bind-Value="selectedBottomSheet" TValue="string" Class="w-[280px]">
                    <SelectTrigger>
                        <SelectValue Placeholder="Select a city" />
                    </SelectTrigger>
                    <SelectContent Presentation="SelectPresentation.BottomSheet">
                        <SelectItem Value="@("nyc")" Text="New York" TValue="string">New York</SelectItem>
                        <SelectItem Value="@("london")" Text="London" TValue="string">London</SelectItem>
                        <SelectItem Value="@("tokyo")" Text="Tokyo" TValue="string">Tokyo</SelectItem>
                        <SelectItem Value="@("paris")" Text="Paris" TValue="string">Paris</SelectItem>
                        <SelectItem Value="@("sydney")" Text="Sydney" TValue="string">Sydney</SelectItem>
                        <SelectItem Value="@("berlin")" Text="Berlin" TValue="string">Berlin</SelectItem>
                    </SelectContent>
                </Select>
                @if (!string.IsNullOrEmpty(selectedBottomSheet))
                {
                    <p class="text-sm">Selected: <strong>@selectedBottomSheet</strong></p>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_selectProps" />
    </DemoSection>

    <DemoPageNav />
</div>

@code {
    private string? selectedFruit;
    private string? selectedAnimal;
    private string? selectedCountry;
    private int selectedNumber;
    private string? selectedBottomSheet;

    private readonly string[] countries = new[]
    {
        "Afghanistan", "Albania", "Algeria", "Andorra", "Angola",
        "Argentina", "Armenia", "Australia", "Austria", "Azerbaijan",
        "Bahamas", "Bahrain", "Bangladesh", "Barbados", "Belarus",
        "Belgium", "Belize", "Benin", "Bhutan", "Bolivia",
        "Bosnia and Herzegovina", "Botswana", "Brazil", "Brunei", "Bulgaria",
        "Burkina Faso", "Burundi", "Cambodia", "Cameroon", "Canada",
        "Cape Verde", "Central African Republic", "Chad", "Chile", "China",
        "Colombia", "Comoros", "Congo", "Costa Rica", "Croatia",
        "Cuba", "Cyprus", "Czech Republic", "Denmark", "Djibouti",
        "Dominica", "Dominican Republic", "East Timor", "Ecuador", "Egypt"
    };

    // Infinite Scroll demo
    private List<SelectNumberedItem> _sPagedItems = new();
    private bool _sPagedLoading;
    private int _sPagedPage;
    private string? _sPagedValue;
    private const int _sPageSize = 8;
    private const int _sTotalItems = 40;

    protected override void OnInitialized() => LoadSelectPage();

    private void LoadSelectPage()
    {
        var start = _sPagedPage * _sPageSize;
        var end = Math.Min(start + _sPageSize, _sTotalItems);
        for (var i = start; i < end; i++)
            _sPagedItems.Add(new SelectNumberedItem { Value = $"item-{i + 1}", Label = $"Item {i + 1}" });
        _sPagedPage++;
    }

    private async Task HandleSelectLoadMore()
    {
        if (_sPagedLoading || _sPagedItems.Count >= _sTotalItems) return;
        _sPagedLoading = true;
        StateHasChanged();
        await Task.Delay(600);
        LoadSelectPage();
        _sPagedLoading = false;
    }

    private string? SelectEndMessage =>
        _sPagedItems.Count >= _sTotalItems ? $"All {_sTotalItems} items loaded" : null;

    public class SelectNumberedItem
    {
        public required string Value { get; set; }
        public required string Label { get; set; }
    }

}
