@page "/components/typography"

<PageTitle>Typography - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Typography"
        Description="Semantic text styling with consistent typography." />

    <DemoSection
        Title="Headings"
        Description="Four heading levels with proportional sizing and weight.">
        <DemoBlock Code="@_headingsCode">
            <div class="space-y-4">
                <Typography Variant="TypographyVariant.H1">Heading 1</Typography>
                <Typography Variant="TypographyVariant.H2">Heading 2</Typography>
                <Typography Variant="TypographyVariant.H3">Heading 3</Typography>
                <Typography Variant="TypographyVariant.H4">Heading 4</Typography>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Body Text"
        Description="Paragraph and utility text variants for content hierarchy.">
        <DemoBlock Code="@_bodyCode">
            <div class="space-y-4">
                <Typography Variant="TypographyVariant.P">
                    This is a paragraph with default styling. It uses the P variant which provides proper line height and spacing.
                </Typography>
                <Typography Variant="TypographyVariant.Lead">
                    This is lead text, slightly larger and perfect for introductions or important paragraphs.
                </Typography>
                <Typography Variant="TypographyVariant.Large">
                    This is large text for emphasis.
                </Typography>
                <Typography Variant="TypographyVariant.Small">
                    This is small text for fine print or secondary information.
                </Typography>
                <Typography Variant="TypographyVariant.Muted">
                    This is muted text with reduced opacity for de-emphasized content.
                </Typography>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Special Elements"
        Description="Blockquote and inline code for rich content formatting.">
        <DemoBlock Code="@_specialCode">
            <div class="space-y-4">
                <Typography Variant="TypographyVariant.Blockquote">
                    "The only way to do great work is to love what you do." - Steve Jobs
                </Typography>
                <div>
                    <Typography Variant="TypographyVariant.P">
                        Inline code example: <Typography Variant="TypographyVariant.InlineCode">npm install neoui</Typography>
                    </Typography>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_typographyProps" />
    </DemoSection>

    <DemoPageNav />
</div>

@code {
    private static readonly IReadOnlyList<DemoPropRow> _typographyProps =
    [
        new("Variant",      "TypographyVariant", "P",   "Visual style. Options: H1, H2, H3, H4, P, Lead, Large, Small, Muted, Blockquote, InlineCode."),
        new("ChildContent", "RenderFragment?",   null,  "The text content to display."),
    ];

    private const string _headingsCode =
        """
        <Typography Variant="TypographyVariant.H1">Heading 1</Typography>
        <Typography Variant="TypographyVariant.H2">Heading 2</Typography>
        <Typography Variant="TypographyVariant.H3">Heading 3</Typography>
        <Typography Variant="TypographyVariant.H4">Heading 4</Typography>
        """;

    private const string _bodyCode =
        """
        <Typography Variant="TypographyVariant.P">Paragraph text.</Typography>
        <Typography Variant="TypographyVariant.Lead">Lead text.</Typography>
        <Typography Variant="TypographyVariant.Large">Large text.</Typography>
        <Typography Variant="TypographyVariant.Small">Small text.</Typography>
        <Typography Variant="TypographyVariant.Muted">Muted text.</Typography>
        """;

    private const string _specialCode =
        """
        <Typography Variant="TypographyVariant.Blockquote">
            "The only way to do great work is to love what you do." - Steve Jobs
        </Typography>

        <Typography Variant="TypographyVariant.P">
            Inline code example: <Typography Variant="TypographyVariant.InlineCode">npm install neoui</Typography>
        </Typography>
        """;
}
