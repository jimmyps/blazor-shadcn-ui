@page "/components/combobox"

<PageTitle>Combobox - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Combobox"
        Description="A searchable select component that combines autocomplete with a dropdown interface." />

    <DemoSection
        Title="Basic Combobox"
        Description="Select a framework from the searchable list. Click to deselect.">
        <DemoBlock Code="@_basicCode">
            <div class="flex flex-col gap-2">
                <Combobox TItem="Framework"
                         Items="frameworks"
                         @bind-Value="selectedFramework"
                         ValueSelector="@(f => f.Value)"
                         DisplaySelector="@(f => f.Label)"
                         Placeholder="Select framework..."
                         SearchPlaceholder="Search framework..."
                         EmptyMessage="No framework found."
                         PopoverWidth="w-[200px]" />
                @if (!string.IsNullOrEmpty(selectedFramework))
                {
                    <p class="text-sm">Selected: <strong>@GetFrameworkLabel(selectedFramework)</strong></p>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Programming Language"
        Description="Wider combobox with programming languages.">
        <DemoBlock Code="@_languageCode">
            <div class="flex flex-col gap-2">
                <Combobox TItem="ProgrammingLanguage"
                         Items="languages"
                         @bind-Value="selectedLanguage"
                         ValueSelector="@(l => l.Value)"
                         DisplaySelector="@(l => l.Label)"
                         Placeholder="Select language..."
                         SearchPlaceholder="Search language..."
                         EmptyMessage="No language found."
                         PopoverWidth="w-[250px]" />
                @if (!string.IsNullOrEmpty(selectedLanguage))
                {
                    <p class="text-sm">Selected: <strong>@GetLanguageLabel(selectedLanguage)</strong></p>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Country Selector"
        Description="Large dataset with search functionality.">
        <DemoBlock Code="@_countryCode">
            <div class="flex flex-col gap-2">
                <Combobox TItem="Country"
                         Items="countries"
                         @bind-Value="selectedCountry"
                         ValueSelector="@(c => c.Code)"
                         DisplaySelector="@(c => c.Name)"
                         Placeholder="Select country..."
                         SearchPlaceholder="Search country..."
                         EmptyMessage="No country found."
                         PopoverWidth="w-[280px]" />
                @if (!string.IsNullOrEmpty(selectedCountry))
                {
                    <p class="text-sm">Selected: <strong>@GetCountryName(selectedCountry)</strong> (@selectedCountry)</p>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Match Trigger Width"
        Description="With MatchTriggerWidth='true', the dropdown automatically matches the width of the trigger element.">
        <DemoBlock Code="@_matchWidthCode">
            <div class="flex flex-col gap-4">
                <div class="w-64">
                    <label class="text-sm font-medium mb-2 block">Fixed width container (w-64)</label>
                    <Combobox TItem="Framework"
                             Items="frameworks"
                             @bind-Value="matchWidthValue1"
                             ValueSelector="@(f => f.Value)"
                             DisplaySelector="@(f => f.Label)"
                             Placeholder="Select framework..."
                             SearchPlaceholder="Search..."
                             MatchTriggerWidth="true"
                             Class="w-full" />
                </div>
                <div class="w-96">
                    <label class="text-sm font-medium mb-2 block">Wider container (w-96)</label>
                    <Combobox TItem="Country"
                             Items="countries"
                             @bind-Value="matchWidthValue2"
                             ValueSelector="@(c => c.Code)"
                             DisplaySelector="@(c => c.Name)"
                             Placeholder="Select country..."
                             SearchPlaceholder="Search country..."
                             MatchTriggerWidth="true"
                             Class="w-full" />
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Disabled State"
        Description="Combobox in disabled state.">
        <DemoBlock Code="@_disabledCode">
            <Combobox TItem="Framework"
                     Items="frameworks"
                     @bind-Value="disabledValue"
                     ValueSelector="@(f => f.Value)"
                     DisplaySelector="@(f => f.Label)"
                     Placeholder="Disabled combobox"
                     Disabled="true"
                     PopoverWidth="w-[200px]" />
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Form Integration"
        Description="Example of comboboxes in a form layout.">
        <DemoBlock Code="@_formCode">
            <div class="space-y-4 max-w-md border rounded-lg p-6">
                <div class="space-y-2">
                    <label class="text-sm font-medium">Framework</label>
                    <Combobox TItem="Framework"
                             Items="frameworks"
                             @bind-Value="formFramework"
                             ValueSelector="@(f => f.Value)"
                             DisplaySelector="@(f => f.Label)"
                             Placeholder="Select framework..."
                             SearchPlaceholder="Search framework..."
                             Class="w-full"
                             MatchTriggerWidth="true" />
                    <p class="text-xs text-muted-foreground">Choose your preferred framework.</p>
                </div>
                <div class="space-y-2">
                    <label class="text-sm font-medium">Language</label>
                    <Combobox TItem="ProgrammingLanguage"
                             Items="languages"
                             @bind-Value="formLanguage"
                             ValueSelector="@(l => l.Value)"
                             DisplaySelector="@(l => l.Label)"
                             Placeholder="Select language..."
                             SearchPlaceholder="Search language..."
                             Class="w-full"
                             MatchTriggerWidth="true" />
                    <p class="text-xs text-muted-foreground">Choose your primary language.</p>
                </div>
                <div class="pt-4 border-t">
                    <Button Variant="ButtonVariant.Default" OnClick="HandleFormSubmit">Submit</Button>
                    @if (formSubmitted)
                    {
                        <p class="text-sm text-green-600 mt-2">
                            ✓ Form submitted! Framework: <strong>@GetFrameworkLabel(formFramework)</strong>,
                            Language: <strong>@GetLanguageLabel(formLanguage)</strong>
                        </p>
                    }
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Async Filtering"
        Description="Use SearchQueryChanged to bypass the built-in filter and run a server-side or async search on every keystroke.">
        <DemoBlock Code="@_asyncFilterCode">
            <AdditionalContent>
                <Alert Variant="AlertVariant.Info">
                    <Icon><LucideIcon Name="info" Size="16" /></Icon>
                    <ChildContent>
                        <AlertDescription>
                            The search input fires <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">SearchQueryChanged</code> on every keystroke.
                            A 300 ms simulated delay mimics a server round-trip. Because <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">SearchQueryChanged</code> has a delegate,
                            the component's built-in text filter is completely bypassed — the consumer decides what <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">Items</code> to show.
                            On close, the callback fires with an empty string so the consumer can reload the default list.
                        </AlertDescription>
                    </ChildContent>
                </Alert>
            </AdditionalContent>
            <ChildContent>
                <div class="flex flex-col gap-2">
                    <Combobox TItem="Framework"
                             Items="@_asyncFilteredFrameworks"
                             @bind-Value="_asyncSelectedFramework"
                             ValueSelector="@(f => f.Value)"
                             DisplaySelector="@(f => f.Label)"
                             Placeholder="Select framework..."
                             SearchPlaceholder="Type to search..."
                             SearchQueryChanged="@HandleFrameworkSearch"
                             IsLoading="@_frameworkSearching"
                             PopoverWidth="w-[240px]" />
                    <p class="text-xs text-muted-foreground">
                        @_asyncFilteredFrameworks.Count / @frameworks.Count matches
                        @if (!string.IsNullOrEmpty(_asyncSelectedFramework))
                        {
                            <span> · Selected: <strong>@_asyncSelectedFramework</strong></span>
                        }
                    </p>
                </div>
            </ChildContent>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="Infinite Scroll"
        Description="Load items in batches as the user scrolls to the bottom of the list.">
        <DemoBlock Code="@_infiniteScrollCode">
            <AdditionalContent>
                <Alert Variant="AlertVariant.Info">
                    <Icon><LucideIcon Name="info" Size="16" /></Icon>
                    <ChildContent>
                        <AlertDescription>
                            Open the dropdown and scroll to the bottom to trigger <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">OnLoadMore</code>.
                            A spinner appears during the simulated 600 ms fetch. Once all @_comboboxTotalItems items are loaded,
                            <code class="px-1.5 py-0.5 text-xs bg-muted rounded font-mono">EndOfListMessage</code> is shown in place of the spinner.
                        </AlertDescription>
                    </ChildContent>
                </Alert>
            </AdditionalContent>
            <ChildContent>
                <div class="flex flex-col gap-2">
                    <Combobox TItem="NumberedItem"
                             Items="@_displayedItems"
                             @bind-Value="_pagedSelection"
                             ValueSelector="@(x => x.Value)"
                             DisplaySelector="@(x => x.Label)"
                             Placeholder="Select an option..."
                             SearchPlaceholder="Search options..."
                             OnLoadMore="@HandleComboboxLoadMore"
                             IsLoading="@_pagedLoading"
                             EndOfListMessage="@ComboboxEndMessage"
                             SearchQueryChanged="@HandleComboboxInfiniteSearch"
                             PopoverWidth="w-[240px]" />
                    <p class="text-xs text-muted-foreground">
                        @if (!string.IsNullOrWhiteSpace(_comboboxSearchQuery))
                        {
                            <span>@_comboboxFilteredTotal results for "@_comboboxSearchQuery"</span>
                        }
                        else
                        {
                            <span>@Math.Min(_comboboxDisplayedCount, _comboboxTotalItems) / @_comboboxTotalItems items loaded</span>
                        }
                        @if (!string.IsNullOrEmpty(_pagedSelection))
                        {
                            <span> · Selected: <strong>@GetComboboxInfiniteLabel(_pagedSelection)</strong></span>
                        }
                    </p>
                </div>
            </ChildContent>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_comboboxProps" />
    </DemoSection>

    <DemoPageNav />
</div>

@code {
    private string? selectedFramework;
    private string? selectedLanguage;
    private string? selectedCountry;
    private string? disabledValue = "next.js";
    private string? matchWidthValue1;
    private string? matchWidthValue2;
    private string? formFramework;
    private string? formLanguage;
    private bool formSubmitted;

    private readonly List<Framework> frameworks = new()
    {
        new Framework { Value = "next.js", Label = "Next.js" },
        new Framework { Value = "sveltekit", Label = "SvelteKit" },
        new Framework { Value = "nuxt.js", Label = "Nuxt.js" },
        new Framework { Value = "remix", Label = "Remix" },
        new Framework { Value = "astro", Label = "Astro" },
        new Framework { Value = "gatsby", Label = "Gatsby" },
        new Framework { Value = "blazor", Label = "Blazor" }
    };

    private readonly List<ProgrammingLanguage> languages = new()
    {
        new ProgrammingLanguage { Value = "csharp", Label = "C#" },
        new ProgrammingLanguage { Value = "typescript", Label = "TypeScript" },
        new ProgrammingLanguage { Value = "javascript", Label = "JavaScript" },
        new ProgrammingLanguage { Value = "python", Label = "Python" },
        new ProgrammingLanguage { Value = "java", Label = "Java" },
        new ProgrammingLanguage { Value = "go", Label = "Go" },
        new ProgrammingLanguage { Value = "rust", Label = "Rust" },
        new ProgrammingLanguage { Value = "php", Label = "PHP" },
        new ProgrammingLanguage { Value = "ruby", Label = "Ruby" },
        new ProgrammingLanguage { Value = "swift", Label = "Swift" }
    };

    private readonly List<Country> countries = new()
    {
        new Country { Code = "US", Name = "United States" },
        new Country { Code = "GB", Name = "United Kingdom" },
        new Country { Code = "CA", Name = "Canada" },
        new Country { Code = "AU", Name = "Australia" },
        new Country { Code = "DE", Name = "Germany" },
        new Country { Code = "FR", Name = "France" },
        new Country { Code = "JP", Name = "Japan" },
        new Country { Code = "CN", Name = "China" },
        new Country { Code = "IN", Name = "India" },
        new Country { Code = "BR", Name = "Brazil" },
        new Country { Code = "MX", Name = "Mexico" },
        new Country { Code = "ES", Name = "Spain" },
        new Country { Code = "IT", Name = "Italy" },
        new Country { Code = "NL", Name = "Netherlands" },
        new Country { Code = "SE", Name = "Sweden" }
    };

    private string GetFrameworkLabel(string? value) =>
        frameworks.FirstOrDefault(f => f.Value == value)?.Label ?? value ?? "";

    private string GetLanguageLabel(string? value) =>
        languages.FirstOrDefault(l => l.Value == value)?.Label ?? value ?? "";

    private string GetCountryName(string? code) =>
        countries.FirstOrDefault(c => c.Code == code)?.Name ?? code ?? "";

    private void HandleFormSubmit()
    {
        formSubmitted = true;
        StateHasChanged();
    }

    // Infinite Scroll demo
    private static readonly IReadOnlyList<NumberedItem> _masterComboboxItems =
        Enumerable.Range(1, 50).Select(i => new NumberedItem { Value = $"item-{i}", Label = $"Option {i}" }).ToList();
    private List<NumberedItem> _displayedItems = new();
    private bool _pagedLoading;
    private string? _pagedSelection;
    private string _comboboxSearchQuery = string.Empty;
    private int _comboboxFilteredTotal;
    private int _comboboxDisplayedCount;
    private const int _comboboxPageSize = 10;
    private const int _comboboxTotalItems = 50;

    private IReadOnlyList<NumberedItem> GetFilteredComboboxItems(string query) =>
        string.IsNullOrWhiteSpace(query)
            ? _masterComboboxItems
            : _masterComboboxItems.Where(x => x.Label.Contains(query, StringComparison.OrdinalIgnoreCase)).ToList();

    // Async Filtering demo
    private List<Framework> _asyncFilteredFrameworks = new();
    private string? _asyncSelectedFramework;
    private bool _frameworkSearching;

    protected override void OnInitialized()
    {
        var filtered = GetFilteredComboboxItems(string.Empty);
        _comboboxFilteredTotal = filtered.Count;
        _comboboxDisplayedCount = _comboboxPageSize;
        _displayedItems = filtered.Take(_comboboxDisplayedCount).ToList();
        _asyncFilteredFrameworks = new(frameworks);
    }

    private async Task HandleComboboxLoadMore()
    {
        _pagedLoading = true;
        StateHasChanged();
        await Task.Delay(600);
        _comboboxDisplayedCount += _comboboxPageSize;
        var filtered = GetFilteredComboboxItems(_comboboxSearchQuery);
        _comboboxFilteredTotal = filtered.Count;
        _displayedItems = filtered.Take(_comboboxDisplayedCount).ToList();
        _pagedLoading = false;
    }

    private string? ComboboxEndMessage =>
        _comboboxDisplayedCount >= _comboboxFilteredTotal && _comboboxFilteredTotal > 0
            ? $"All {_comboboxFilteredTotal} options loaded"
            : null;

    private string GetComboboxInfiniteLabel(string? value) =>
        _masterComboboxItems.FirstOrDefault(x => x.Value == value)?.Label ?? value ?? "";

    private Task HandleComboboxInfiniteSearch(string query)
    {
        _comboboxSearchQuery = query;
        _comboboxDisplayedCount = _comboboxPageSize;
        var filtered = GetFilteredComboboxItems(query);
        _comboboxFilteredTotal = filtered.Count;
        _displayedItems = filtered.Take(_comboboxDisplayedCount).ToList();
        // Ensure selected item is always findable for the trigger label
        if (!string.IsNullOrEmpty(_pagedSelection) && _displayedItems.All(x => x.Value != _pagedSelection))
        {
            var selected = _masterComboboxItems.FirstOrDefault(x => x.Value == _pagedSelection);
            if (selected != null) _displayedItems.Add(selected);
        }
        return Task.CompletedTask;
    }

    private async Task HandleFrameworkSearch(string query)
    {
        _frameworkSearching = true;
        StateHasChanged();
        await Task.Delay(300);
        _asyncFilteredFrameworks = string.IsNullOrWhiteSpace(query)
            ? new(frameworks)
            : frameworks.Where(f => f.Label.Contains(query, StringComparison.OrdinalIgnoreCase)).ToList();
        _frameworkSearching = false;
    }

    public class NumberedItem
    {
        public required string Value { get; set; }
        public required string Label { get; set; }
    }

    public class Framework
    {
        public required string Value { get; set; }
        public required string Label { get; set; }
    }

    public class ProgrammingLanguage
    {
        public required string Value { get; set; }
        public required string Label { get; set; }
    }

    public class Country
    {
        public required string Code { get; set; }
        public required string Name { get; set; }
    }

}
