@page "/components/rating"

<PageTitle>Rating - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Rating"
        Description="A rating component for selecting a value with interactive icons." />

    <DemoSection
        Title="Basic"
        Description="A simple star rating with default settings.">
        <DemoBlock Code="@_basicCode">
            <div class="space-y-2">
                <Rating @bind-Value="basicValue" />
                <p class="text-sm text-muted-foreground">Value: @basicValue</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Half Ratings"
        Description="Allow half-star ratings for more granular control.">
        <DemoBlock Code="@_halfCode">
            <div class="space-y-2">
                <Rating @bind-Value="halfValue" AllowHalf="true" />
                <p class="text-sm text-muted-foreground">Value: @halfValue</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Icon Types"
        Description="Different icon types: Star, Heart, and Circle.">
        <DemoBlock Code="@_iconTypesCode">
            <div class="space-y-4">
                <div class="space-y-2">
                    <p class="text-sm font-medium">Star:</p>
                    <Rating @bind-Value="starValue" IconType="RatingIconType.Star" />
                </div>
                <div class="space-y-2">
                    <p class="text-sm font-medium">Heart:</p>
                    <Rating @bind-Value="heartValue" IconType="RatingIconType.Heart" />
                </div>
                <div class="space-y-2">
                    <p class="text-sm font-medium">Circle:</p>
                    <Rating @bind-Value="circleValue" IconType="RatingIconType.Circle" />
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Sizes"
        Description="Small, Medium, and Large sizes.">
        <DemoBlock Code="@_sizesCode">
            <div class="space-y-4">
                <div class="space-y-2">
                    <p class="text-sm font-medium">Small:</p>
                    <Rating @bind-Value="sizeValue" Size="RatingSize.Small" />
                </div>
                <div class="space-y-2">
                    <p class="text-sm font-medium">Medium:</p>
                    <Rating @bind-Value="sizeValue" Size="RatingSize.Medium" />
                </div>
                <div class="space-y-2">
                    <p class="text-sm font-medium">Large:</p>
                    <Rating @bind-Value="sizeValue" Size="RatingSize.Large" />
                </div>
                <p class="text-sm text-muted-foreground">Value: @sizeValue</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Custom Max Rating"
        Description="Set a custom maximum rating (default is 5).">
        <DemoBlock Code="@_maxCode">
            <div class="space-y-2">
                <Rating @bind-Value="maxValue" MaxRating="10" Size="RatingSize.Small" />
                <p class="text-sm text-muted-foreground">Value: @maxValue / 10</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Disabled"
        Description="Disabled state prevents interaction.">
        <DemoBlock Code="@_disabledCode">
            <Rating Value="3.5" Disabled="true" AllowHalf="true" />
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Read-Only"
        Description="Read-only state displays the rating without allowing changes.">
        <DemoBlock Code="@_readOnlyCode">
            <Rating Value="4" ReadOnly="true" />
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Allow Clear"
        Description="Click the same rating again to clear it (AllowClear is true by default).">
        <DemoBlock Code="@_clearCode">
            <div class="space-y-2">
                <Rating @bind-Value="clearValue" AllowClear="true" />
                <p class="text-sm text-muted-foreground">Value: @clearValue (Click the same star twice to clear)</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="No Clear"
        Description="Prevent clearing by setting AllowClear to false.">
        <DemoBlock Code="@_noClearCode">
            <div class="space-y-2">
                <Rating @bind-Value="noClearValue" AllowClear="false" />
                <p class="text-sm text-muted-foreground">Value: @noClearValue</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Keyboard Support"
        Description="Use arrow keys to adjust, number keys (1-5) to set directly, or 0 to clear." />

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_ratingProps" />
    </DemoSection>

    <DemoPageNav />
</div>

@code {
    private double basicValue = 0;
    private double halfValue = 2.5;
    private double starValue = 3;
    private double heartValue = 4;
    private double circleValue = 2;
    private double sizeValue = 3;
    private double maxValue = 5;
    private double clearValue = 3;
    private double noClearValue = 3;

}
