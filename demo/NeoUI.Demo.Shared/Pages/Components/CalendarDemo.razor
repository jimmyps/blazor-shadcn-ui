@page "/components/calendar"

<PageTitle>Calendar - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Calendar"
        Description="A date field component that allows users to enter and edit date. Supports single date selection with full keyboard navigation." />

    <DemoSection
        Title="Default"
        Description="A basic calendar for date selection.">
        <DemoBlock Code="@_defaultCode">
            <div class="flex flex-col gap-4">
                <Calendar @bind-SelectedDate="selectedDate1" />
                <p class="text-sm text-muted-foreground">
                    Selected: @(selectedDate1?.ToString("D") ?? "None")
                </p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Dropdown Mode"
        Description="Use dropdown selects for quick month and year navigation.">
        <DemoBlock Code="@_dropdownCode">
            <div class="flex flex-col gap-4">
                <Calendar @bind-SelectedDate="selectedDate5" CaptionLayout="CalendarCaptionLayout.Dropdown" />
                <p class="text-sm text-muted-foreground">
                    Selected: @(selectedDate5?.ToString("D") ?? "None")
                </p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Date Constraints"
        Description="Limit selection to a specific date range.">
        <DemoBlock Code="@_constraintsCode">
            <div class="flex flex-col gap-4">
                <Calendar @bind-SelectedDate="selectedDate2"
                          MinDate="DateOnly.FromDateTime(DateTime.Today)"
                          MaxDate="DateOnly.FromDateTime(DateTime.Today.AddMonths(3))" />
                <p class="text-sm text-muted-foreground">
                    Selected: @(selectedDate2?.ToString("D") ?? "None")
                    <br />
                    <span class="text-xs">Range: Today to 3 months from now</span>
                </p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Disable Weekends"
        Description="Use a custom function to disable specific dates.">
        <DemoBlock Code="@_disableWeekendsCode">
            <div class="flex flex-col gap-4">
                <Calendar @bind-SelectedDate="selectedDate3" IsDateDisabled="IsWeekend" />
                <p class="text-sm text-muted-foreground">
                    Selected: @(selectedDate3?.ToString("D") ?? "None")
                    <br />
                    <span class="text-xs">Weekends are disabled</span>
                </p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Initial Month"
        Description="Start with a specific month displayed.">
        <DemoBlock Code="@_initialMonthCode">
            <div class="flex flex-col gap-4">
                <Calendar @bind-SelectedDate="selectedDate4" InitialMonth="new DateOnly(2025, 12, 1)" />
                <p class="text-sm text-muted-foreground">
                    Selected: @(selectedDate4?.ToString("D") ?? "None")
                    <br />
                    <span class="text-xs">Starts at December 2025</span>
                </p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Side by Side"
        Description="Multiple calendars for comparison or date range selection.">
        <DemoBlock Code="@_sideBySideCode">
            <div class="space-y-2">
                <div class="flex gap-4">
                    <Calendar @bind-SelectedDate="rangeStart" />
                    <Calendar @bind-SelectedDate="rangeEnd" />
                </div>
                <p class="text-sm text-muted-foreground">
                    From: @(rangeStart?.ToString("D") ?? "None") — To: @(rangeEnd?.ToString("D") ?? "None")
                </p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_calendarProps" />
    </DemoSection>

    <DemoPageNav />
</div>

@code {
    private DateOnly? selectedDate1;
    private DateOnly? selectedDate2;
    private DateOnly? selectedDate3;
    private DateOnly? selectedDate4;
    private DateOnly? selectedDate5;
    private DateOnly? rangeStart;
    private DateOnly? rangeEnd;

    private static readonly IReadOnlyList<DemoPropRow> _calendarProps =
    [
        new("SelectedDate",    "DateOnly?",             null,      "The currently selected date."),
        new("MinDate",         "DateOnly?",             null,      "The minimum selectable date."),
        new("MaxDate",         "DateOnly?",             null,      "The maximum selectable date."),
        new("InitialMonth",    "DateOnly?",             null,      "The month displayed when the calendar first renders."),
        new("IsDateDisabled",  "Func<DateOnly, bool>?", null,      "A function that returns true for dates that should be disabled."),
        new("CaptionLayout",   "CalendarCaptionLayout", "Buttons", "Controls month/year navigation style. Options: Buttons, Dropdown."),
        new("Class",           "string?",               null,      "Additional CSS classes appended to the root element."),
    ];

    private bool IsWeekend(DateOnly date) =>
        date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday;

    private const string _defaultCode =
        """
        <Calendar @bind-SelectedDate="selectedDate" />
        """;

    private const string _dropdownCode =
        """
        <Calendar @bind-SelectedDate="selectedDate" CaptionLayout="CalendarCaptionLayout.Dropdown" />
        """;

    private const string _constraintsCode =
        """
        <Calendar @bind-SelectedDate="selectedDate"
                  MinDate="DateOnly.FromDateTime(DateTime.Today)"
                  MaxDate="DateOnly.FromDateTime(DateTime.Today.AddMonths(3))" />
        """;

    private const string _disableWeekendsCode =
        """
        <Calendar @bind-SelectedDate="selectedDate" IsDateDisabled="IsWeekend" />

        @code {
            private bool IsWeekend(DateOnly date) =>
                date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday;
        }
        """;

    private const string _initialMonthCode =
        """
        <Calendar @bind-SelectedDate="selectedDate" InitialMonth="new DateOnly(2025, 12, 1)" />
        """;

    private const string _sideBySideCode =
        """
        <div class="flex gap-4">
            <Calendar @bind-SelectedDate="rangeStart" />
            <Calendar @bind-SelectedDate="rangeEnd" />
        </div>
        """;
}
