@page "/components/input"
@using System.ComponentModel.DataAnnotations

<PageTitle>Input - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Input"
        Description="Displays a form input field or a component that looks like an input field." />

    <DemoSection
        Title="Default"
        Description="A simple text input.">
        <DemoBlock Code="@_defaultCode">
            <div class="w-full max-w-sm">
                <NeoUI.Blazor.Input Type="InputType.Text" Placeholder="Email" />
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="UpdateOn Behavior"
        Description="Control when the bound value is updated — on each keystroke (Input) or when the field loses focus (Change).">
        <DemoBlock Code="@_updateOnCode">
            <ChildContent>
                <div class="space-y-4 max-w-sm">
                    <div class="space-y-2">
                        <Label>UpdateOn Input (default)</Label>
                        <NeoUI.Blazor.Input Type="InputType.Text" Placeholder="Type here..."
                            @bind-Value="updateOnInputValue" UpdateOn="InputUpdateMode.Input" />
                        <p class="text-sm text-muted-foreground">Value: <strong>@updateOnInputValue</strong></p>
                    </div>
                    <div class="space-y-2">
                        <Label>UpdateOn Change (on blur)</Label>
                        <NeoUI.Blazor.Input Type="InputType.Text" Placeholder="Type then click away..."
                            @bind-Value="updateOnChangeValue" UpdateOn="InputUpdateMode.Change" />
                        <p class="text-sm text-muted-foreground">Value: <strong>@updateOnChangeValue</strong></p>
                    </div>
                </div>
            </ChildContent>
            <AdditionalContent>
                <Alert Variant="AlertVariant.Default">
                    <AlertTitle>
                        <LucideIcon Name="circle-alert" Size="16" Class="mr-2 inline" />
                        @@bind-Value and UpdateOn
                    </AlertTitle>
                    <AlertDescription>
                        When using <code>@@bind-Value</code>, the <code>UpdateOn</code> parameter controls when the bound property is updated.
                        Use <code>InputUpdateMode.Input</code> for real-time updates on every keystroke, or
                        <code>InputUpdateMode.Change</code> to update only when the input loses focus.
                    </AlertDescription>
                </Alert>
            </AdditionalContent>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Input Types"
        Description="Various HTML input types for different data scenarios.">
        <DemoBlock Code="@_typesCode">
            <div class="grid grid-cols-1 gap-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Text</Label>
                    <NeoUI.Blazor.Input Type="InputType.Text" Placeholder="Enter text" />
                </div>
                <div class="space-y-2">
                    <Label>Email</Label>
                    <NeoUI.Blazor.Input Type="InputType.Email" Placeholder="name@example.com" />
                </div>
                <div class="space-y-2">
                    <Label>Password</Label>
                    <NeoUI.Blazor.Input Type="InputType.Password" Placeholder="Enter password" />
                </div>
                <div class="space-y-2">
                    <Label>Number</Label>
                    <NeoUI.Blazor.Input Type="InputType.Number" Placeholder="0" />
                </div>
                <div class="space-y-2">
                    <Label>Date</Label>
                    <NeoUI.Blazor.Input Type="InputType.Date" />
                </div>
                <div class="space-y-2">
                    <Label>Time</Label>
                    <NeoUI.Blazor.Input Type="InputType.Time" />
                </div>
                <div class="space-y-2">
                    <Label>URL</Label>
                    <NeoUI.Blazor.Input Type="InputType.Url" Placeholder="https://example.com" />
                </div>
                <div class="space-y-2">
                    <Label>Search</Label>
                    <NeoUI.Blazor.Input Type="InputType.Search" Placeholder="Search..." />
                </div>
                <div class="space-y-2">
                    <Label>Tel</Label>
                    <NeoUI.Blazor.Input Type="InputType.Tel" Placeholder="(555) 000-0000" />
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="File"
        Description="File inputs allow users to select one or multiple files.">
        <DemoBlock Code="@_fileCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Upload file</Label>
                    <NeoUI.Blazor.Input Type="InputType.File" />
                </div>
                <div class="space-y-2">
                    <Label>Upload multiple files</Label>
                    <NeoUI.Blazor.Input Type="InputType.File" multiple />
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Disabled"
        Description="Disabled inputs cannot be interacted with.">
        <DemoBlock Code="@_disabledCode">
            <div class="w-full max-w-sm">
                <NeoUI.Blazor.Input Type="InputType.Text" Placeholder="Disabled input" Disabled="true" />
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Required"
        Description="Mark inputs as required for form validation.">
        <DemoBlock Code="@_requiredCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Email <span class="text-destructive">*</span></Label>
                    <NeoUI.Blazor.Input Type="InputType.Email" Placeholder="name@example.com" Required="true" ShowValidationError="true" />
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Label"
        Description="Pair inputs with descriptive labels.">
        <DemoBlock Code="@_withLabelCode">
            <div class="grid w-full max-w-sm items-center gap-1.5">
                <Label For="email">Email</Label>
                <NeoUI.Blazor.Input Type="InputType.Email" Id="email" Placeholder="Email" />
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Accessibility (ARIA)"
        Description="Enhance accessibility with ARIA attributes.">
        <DemoBlock Code="@_ariaCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Search</Label>
                    <NeoUI.Blazor.Input Type="InputType.Search" Placeholder="Search..."
                        AriaLabel="Search the website"
                        AriaDescribedBy="search-hint" />
                    <p id="search-hint" class="text-sm text-muted-foreground">Type keywords to search the documentation.</p>
                </div>
                <div class="space-y-2">
                    <Label>Invalid field</Label>
                    <NeoUI.Blazor.Input Type="InputType.Text" Value="bad@email"
                        AriaInvalid="true"
                        AriaDescribedBy="email-error" />
                    <p id="email-error" class="text-sm text-destructive">Please enter a valid email address.</p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Two-Way Binding"
        Description="Two-way data binding: bind to a C# property with the bind-Value syntax.">
        <DemoBlock Code="@_bindingCode">
            <div class="space-y-4 max-w-sm">
                <div class="space-y-2">
                    <Label>Name</Label>
                    <NeoUI.Blazor.Input Type="InputType.Text" @bind-Value="boundValue" Placeholder="Type your name" />
                </div>
                <p class="text-sm">Value: <strong>@boundValue</strong></p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Custom Styling"
        Description="Apply custom CSS classes to customize the appearance.">
        <DemoBlock Code="@_customStylingCode">
            <div class="space-y-4 max-w-sm">
                <NeoUI.Blazor.Input Type="InputType.Text" Placeholder="Rounded full" Class="rounded-full px-4" />
                <NeoUI.Blazor.Input Type="InputType.Text" Placeholder="Large text" Class="text-lg h-14" />
                <NeoUI.Blazor.Input Type="InputType.Text" Placeholder="Custom colors" Class="border-blue-500 focus-visible:ring-blue-500" />
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Validation with EditContext"
        Description="Integrate with Blazor forms and data annotations for validation.">
        <DemoBlock Code="@_validationCode">
            <div class="max-w-sm">
                <EditForm Model="@validationModel" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />
                    <div class="space-y-4">
                        <div class="space-y-2">
                            <Label For="val-name">Name <span class="text-destructive">*</span></Label>
                            <NeoUI.Blazor.Input Type="InputType.Text" Id="val-name"
                                @bind-Value="validationModel.Name" Placeholder="Enter your full name" />
                            <ValidationMessage For="@(() => validationModel.Name)" class="text-sm text-destructive" />
                        </div>
                        <div class="space-y-2">
                            <Label For="val-email">Email <span class="text-destructive">*</span></Label>
                            <NeoUI.Blazor.Input Type="InputType.Email" Id="val-email"
                                @bind-Value="validationModel.Email" Placeholder="name@example.com" />
                            <ValidationMessage For="@(() => validationModel.Email)" class="text-sm text-destructive" />
                        </div>
                        <Button Type="ButtonType.Submit">Submit</Button>
                    </div>
                </EditForm>
                @if (formSubmitted)
                {
                    <p class="mt-4 text-sm text-green-600 font-medium">Form submitted successfully!</p>
                }
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_inputProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private string? boundValue;
    private string? updateOnInputValue;
    private string? updateOnChangeValue;
    private bool formSubmitted = false;

    private InputValidationModel validationModel = new();

    private void HandleValidSubmit()
    {
        formSubmitted = true;
    }

    private class InputValidationModel
    {
        [Required(ErrorMessage = "Name is required")]
        [MinLength(2, ErrorMessage = "Name must be at least 2 characters")]
        public string? Name { get; set; }

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email address")]
        public string? Email { get; set; }
    }

    private static readonly IReadOnlyList<DemoPropRow> _inputProps =
    [
        new("Type",               "InputType",   "Text",   "HTML input type. Options: Text, Email, Password, Number, Date, File, Search, Tel, Url, Time."),
        new("Value",              "string?",     "null",   "Current value. Use @bind-Value for two-way binding."),
        new("Placeholder",        "string?",     "null",   "Placeholder text shown when input is empty."),
        new("Disabled",           "bool",        "false",  "Disables the input when true."),
        new("Required",           "bool",        "false",  "Marks the input as required for native form validation."),
        new("UpdateOn",           "InputUpdateMode", "Input", "When to update the bound value. Options: Input (every keystroke), Change (on blur)."),
        new("ShowValidationError","bool",        "false",  "Shows browser native validation tooltip on invalid state."),
        new("AriaLabel",          "string?",     "null",   "ARIA label for accessibility when no visible label exists."),
        new("AriaDescribedBy",    "string?",     "null",   "ID of element that describes this input."),
        new("AriaInvalid",        "bool",        "false",  "Marks the input as invalid for screen readers."),
        new("Class",              "string?",     "null",   "Additional CSS classes appended to the input element."),
    ];

    private const string _defaultCode = """
        <Input Type="InputType.Text" Placeholder="Email" />
        """;

    private const string _updateOnCode = """
        <!-- Updates on every keystroke -->
        <Input Type="InputType.Text" @bind-Value="value" UpdateOn="InputUpdateMode.Input" />

        <!-- Updates only when field loses focus -->
        <Input Type="InputType.Text" @bind-Value="value" UpdateOn="InputUpdateMode.Change" />
        """;

    private const string _typesCode = """
        <Input Type="InputType.Text" Placeholder="Enter text" />
        <Input Type="InputType.Email" Placeholder="name@example.com" />
        <Input Type="InputType.Password" Placeholder="Enter password" />
        <Input Type="InputType.Number" Placeholder="0" />
        <Input Type="InputType.Date" />
        <Input Type="InputType.File" />
        """;

    private const string _fileCode = """
        <Input Type="InputType.File" />
        <Input Type="InputType.File" multiple />
        """;

    private const string _disabledCode = """
        <Input Type="InputType.Text" Placeholder="Disabled input" Disabled="true" />
        """;

    private const string _requiredCode = """
        <Input Type="InputType.Email" Placeholder="name@example.com" Required="true" ShowValidationError="true" />
        """;

    private const string _withLabelCode = """
        <div class="grid w-full max-w-sm items-center gap-1.5">
            <Label For="email">Email</Label>
            <Input Type="InputType.Email" Id="email" Placeholder="Email" />
        </div>
        """;

    private const string _ariaCode = """
        <Input Type="InputType.Search"
            AriaLabel="Search the website"
            AriaDescribedBy="search-hint" />

        <Input Type="InputType.Text"
            AriaInvalid="true"
            AriaDescribedBy="email-error" />
        """;

    private const string _bindingCode = """
        <Input Type="InputType.Text" @bind-Value="name" Placeholder="Type your name" />
        <p>Value: @name</p>

        @code {
            private string? name;
        }
        """;

    private const string _customStylingCode = """
        <Input Type="InputType.Text" Placeholder="Rounded full" Class="rounded-full px-4" />
        <Input Type="InputType.Text" Placeholder="Large text" Class="text-lg h-14" />
        """;

    private const string _validationCode = """
        <EditForm Model="@model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <div class="space-y-4">
                <div class="space-y-2">
                    <Label For="name">Name</Label>
                    <Input Type="InputType.Text" Id="name" @bind-Value="model.Name" />
                    <ValidationMessage For="@(() => model.Name)" class="text-sm text-destructive" />
                </div>
                <Button Type="ButtonType.Submit">Submit</Button>
            </div>
        </EditForm>
        """;
}
