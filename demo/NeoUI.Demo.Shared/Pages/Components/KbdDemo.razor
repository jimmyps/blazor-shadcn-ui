@page "/components/kbd"

<PageTitle>Kbd - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Kbd"
        Description="Displays keyboard shortcuts and key combinations." />

    <DemoSection
        Title="Basic"
        Description="Display single keyboard keys.">
        <DemoBlock Code="@_basicCode">
            <div class="flex gap-2 items-center">
                <span class="text-sm">Press</span>
                <Kbd>Enter</Kbd>
                <span class="text-sm">to submit</span>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Key Combinations"
        Description="Combine multiple keys to show shortcuts.">
        <DemoBlock Code="@_combinationsCode">
            <div class="space-y-3">
                <div class="flex gap-2 items-center">
                    <Kbd>Ctrl</Kbd>
                    <span>+</span>
                    <Kbd>C</Kbd>
                    <span class="text-sm text-muted-foreground ml-2">Copy</span>
                </div>
                <div class="flex gap-2 items-center">
                    <Kbd>Ctrl</Kbd>
                    <span>+</span>
                    <Kbd>V</Kbd>
                    <span class="text-sm text-muted-foreground ml-2">Paste</span>
                </div>
                <div class="flex gap-2 items-center">
                    <Kbd>Ctrl</Kbd>
                    <span>+</span>
                    <Kbd>Z</Kbd>
                    <span class="text-sm text-muted-foreground ml-2">Undo</span>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Symbols"
        Description="Use symbols for Mac-style keyboard shortcuts.">
        <DemoBlock Code="@_symbolsCode">
            <div class="space-y-3">
                <div class="flex gap-2 items-center">
                    <Kbd>⌘</Kbd>
                    <span>+</span>
                    <Kbd>K</Kbd>
                    <span class="text-sm text-muted-foreground ml-2">Open command palette</span>
                </div>
                <div class="flex gap-2 items-center">
                    <Kbd>⌘</Kbd>
                    <span>+</span>
                    <Kbd>⇧</Kbd>
                    <span>+</span>
                    <Kbd>P</Kbd>
                    <span class="text-sm text-muted-foreground ml-2">Command palette (alternative)</span>
                </div>
                <div class="flex gap-2 items-center">
                    <Kbd>⌘</Kbd>
                    <span>+</span>
                    <Kbd>B</Kbd>
                    <span class="text-sm text-muted-foreground ml-2">Toggle sidebar</span>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Usage Examples"
        Description="Common keyboard shortcut displays.">
        <DemoBlock Code="@_usageCode">
            <div class="space-y-6">
                <div class="space-y-3">
                    <h3 class="text-lg font-medium">Editor Shortcuts</h3>
                    <div class="space-y-2">
                        <div class="flex justify-between items-center p-2 rounded hover:bg-accent">
                            <span class="text-sm">Save</span>
                            <div class="flex gap-1">
                                <Kbd>Ctrl</Kbd>
                                <span class="text-xs">+</span>
                                <Kbd>S</Kbd>
                            </div>
                        </div>
                        <div class="flex justify-between items-center p-2 rounded hover:bg-accent">
                            <span class="text-sm">Find</span>
                            <div class="flex gap-1">
                                <Kbd>Ctrl</Kbd>
                                <span class="text-xs">+</span>
                                <Kbd>F</Kbd>
                            </div>
                        </div>
                        <div class="flex justify-between items-center p-2 rounded hover:bg-accent">
                            <span class="text-sm">Replace</span>
                            <div class="flex gap-1">
                                <Kbd>Ctrl</Kbd>
                                <span class="text-xs">+</span>
                                <Kbd>H</Kbd>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="space-y-3">
                    <h3 class="text-lg font-medium">Navigation</h3>
                    <div class="space-y-2">
                        <div class="flex justify-between items-center p-2 rounded hover:bg-accent">
                            <span class="text-sm">Go to line</span>
                            <div class="flex gap-1">
                                <Kbd>Ctrl</Kbd>
                                <span class="text-xs">+</span>
                                <Kbd>G</Kbd>
                            </div>
                        </div>
                        <div class="flex justify-between items-center p-2 rounded hover:bg-accent">
                            <span class="text-sm">Quick open</span>
                            <div class="flex gap-1">
                                <Kbd>Ctrl</Kbd>
                                <span class="text-xs">+</span>
                                <Kbd>P</Kbd>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="space-y-3">
                    <h3 class="text-lg font-medium">Arrow Keys</h3>
                    <div class="flex gap-2 items-center">
                        <span class="text-sm">Use arrow keys to navigate:</span>
                        <Kbd>↑</Kbd>
                        <Kbd>↓</Kbd>
                        <Kbd>←</Kbd>
                        <Kbd>→</Kbd>
                    </div>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Accessibility"
        Description="The Kbd component uses semantic &lt;kbd&gt; HTML elements which are recognized by assistive technologies as keyboard input indicators." />

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_kbdProps" />
    </DemoSection>

    <DemoPageNav />
</div>
