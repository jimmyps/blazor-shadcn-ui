@page "/components/toggle-group"

<PageTitle>Toggle Group - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Toggle Group"
        Description="A set of two-state buttons that can be toggled on or off." />

    <DemoSection
        Title="Single Selection"
        Description="Only one item can be selected at a time (radio behavior).">
        <DemoBlock Code="@_singleCode">
            <div class="space-y-2">
                <ToggleGroup Type="ToggleGroupType.Single" @bind-Value="alignment">
                    <ToggleGroupItem Value="left">
                        <LucideIcon Name="align-left" Class="h-4 w-4" />
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="center">
                        <LucideIcon Name="align-center" Class="h-4 w-4" />
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="right">
                        <LucideIcon Name="align-right" Class="h-4 w-4" />
                    </ToggleGroupItem>
                </ToggleGroup>
                <p class="text-sm text-muted-foreground">Selected: @alignment</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Multiple Selection"
        Description="Multiple items can be selected simultaneously (checkbox behavior).">
        <DemoBlock Code="@_multipleCode">
            <div class="space-y-2">
                <ToggleGroup Type="ToggleGroupType.Multiple" @bind-Values="styles">
                    <ToggleGroupItem Value="bold">
                        <LucideIcon Name="bold" Class="h-4 w-4" />
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="italic">
                        <LucideIcon Name="italic" Class="h-4 w-4" />
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="underline">
                        <LucideIcon Name="underline" Class="h-4 w-4" />
                    </ToggleGroupItem>
                </ToggleGroup>
                <p class="text-sm text-muted-foreground">Selected: @string.Join(", ", styles ?? new List<string>())</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Text Formatting"
        Description="Common use case for text editors with live preview.">
        <DemoBlock Code="@_formattingCode">
            <div class="space-y-4">
                <ToggleGroup Type="ToggleGroupType.Multiple" @bind-Values="formatting">
                    <ToggleGroupItem Value="bold">
                        <LucideIcon Name="bold" Class="h-4 w-4" />
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="italic">
                        <LucideIcon Name="italic" Class="h-4 w-4" />
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="strikethrough">
                        <LucideIcon Name="strikethrough" Class="h-4 w-4" />
                    </ToggleGroupItem>
                </ToggleGroup>
                <div class="p-4 border rounded-lg">
                    <p class="@GetFormattingClass()">Sample text with formatting</p>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Scrollable"
        Description="Enable horizontal scrolling for many options in a constrained width. Ideal for mobile filter bars.">
        <DemoBlock Code="@_scrollableCode">
            <div class="space-y-4 max-w-xs">
                <p class="text-xs text-muted-foreground">Resize the window — items scroll instead of wrapping.</p>
                <ToggleGroup Type="ToggleGroupType.Single" Scrollable="true" @bind-Value="scrollableFilter">
                    <ToggleGroupItem Value="all">All</ToggleGroupItem>
                    <ToggleGroupItem Value="design">Design</ToggleGroupItem>
                    <ToggleGroupItem Value="frontend">Frontend</ToggleGroupItem>
                    <ToggleGroupItem Value="backend">Backend</ToggleGroupItem>
                    <ToggleGroupItem Value="devops">DevOps</ToggleGroupItem>
                    <ToggleGroupItem Value="mobile">Mobile</ToggleGroupItem>
                    <ToggleGroupItem Value="security">Security</ToggleGroupItem>
                </ToggleGroup>
                <p class="text-sm text-muted-foreground">Filter: @scrollableFilter</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_toggleGroupProps" />
    </DemoSection>

    <DemoPageNav />
</div>

@code {
    private string? alignment = "left";
    private List<string>? styles = new();
    private List<string>? formatting = new();
    private string? scrollableFilter = "all";

    private string GetFormattingClass()
    {
        var classes = new List<string>();
        if (formatting?.Contains("bold") == true) classes.Add("font-bold");
        if (formatting?.Contains("italic") == true) classes.Add("italic");
        if (formatting?.Contains("strikethrough") == true) classes.Add("line-through");
        return string.Join(" ", classes);
    }

}
