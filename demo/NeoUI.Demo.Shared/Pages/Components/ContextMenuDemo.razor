@page "/components/context-menu"

<PageTitle>Context Menu - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Context Menu"
        Description="Displays a menu to the user — such as a set of actions or functions — triggered by a button or right-click." />

    <DemoSection
        Title="Default"
        Description="Right-click the area below to open the context menu.">
        <DemoBlock Code="@_defaultCode">
            <ContextMenu>
                <ContextMenuTrigger Class="flex h-[150px] w-full items-center justify-center rounded-md border border-dashed text-sm cursor-context-menu select-none">
                    Right click here
                </ContextMenuTrigger>
                <ContextMenuContent Class="w-64">
                    <ContextMenuItem OnClick="@(() => HandleAction("Back"))">Back</ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleAction("Forward"))" Disabled="true">Forward</ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleAction("Reload"))">Reload</ContextMenuItem>
                    <ContextMenuSeparator />
                    <ContextMenuItem OnClick="@(() => HandleAction("Save As"))">Save As...</ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleAction("Print"))">Print...</ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleAction("Cast"))">Cast to Device</ContextMenuItem>
                    <ContextMenuSeparator />
                    <ContextMenuItem OnClick="@(() => HandleAction("View Source"))">View Page Source</ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleAction("Inspect"))">Inspect</ContextMenuItem>
                </ContextMenuContent>
            </ContextMenu>
            @if (!string.IsNullOrEmpty(lastAction))
            {
                <p class="mt-2 text-sm">Last action: <strong>@lastAction</strong></p>
            }
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Icons"
        Description="Add Lucide icons to context menu items for improved usability.">
        <DemoBlock Code="@_iconsCode">
            <ContextMenu>
                <ContextMenuTrigger Class="flex h-[150px] w-full items-center justify-center rounded-md border border-dashed text-sm cursor-context-menu select-none">
                    Right click for icon menu
                </ContextMenuTrigger>
                <ContextMenuContent Class="w-56">
                    <ContextMenuItem OnClick="@(() => HandleIconsAction("Open"))">
                        <LucideIcon Name="folder-open" Size="16" Class="mr-2" /> Open
                    </ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleIconsAction("Edit"))">
                        <LucideIcon Name="pencil" Size="16" Class="mr-2" /> Edit
                    </ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleIconsAction("Copy"))">
                        <LucideIcon Name="copy" Size="16" Class="mr-2" /> Copy
                        <ContextMenuShortcut>⌘C</ContextMenuShortcut>
                    </ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleIconsAction("Paste"))">
                        <LucideIcon Name="clipboard-paste" Size="16" Class="mr-2" /> Paste
                        <ContextMenuShortcut>⌘V</ContextMenuShortcut>
                    </ContextMenuItem>
                    <ContextMenuSeparator />
                    <ContextMenuItem OnClick="@(() => HandleIconsAction("Delete"))" Class="text-destructive focus:text-destructive">
                        <LucideIcon Name="trash-2" Size="16" Class="mr-2" /> Delete
                        <ContextMenuShortcut>⌫</ContextMenuShortcut>
                    </ContextMenuItem>
                </ContextMenuContent>
            </ContextMenu>
            @if (!string.IsNullOrEmpty(iconsAction))
            {
                <p class="mt-2 text-sm">Last action: <strong>@iconsAction</strong></p>
            }
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Labels and Groups"
        Description="Organize menu items using labels and separators.">
        <DemoBlock Code="@_groupsCode">
            <ContextMenu>
                <ContextMenuTrigger Class="flex h-[150px] w-full items-center justify-center rounded-md border border-dashed text-sm cursor-context-menu select-none">
                    Right click for grouped menu
                </ContextMenuTrigger>
                <ContextMenuContent Class="w-56">
                    <ContextMenuLabel>File Operations</ContextMenuLabel>
                    <ContextMenuSeparator />
                    <ContextMenuItem OnClick="@(() => HandleGroupsAction("New"))">New File</ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleGroupsAction("Open"))">Open...</ContextMenuItem>
                    <ContextMenuSeparator />
                    <ContextMenuLabel>Edit Operations</ContextMenuLabel>
                    <ContextMenuSeparator />
                    <ContextMenuItem OnClick="@(() => HandleGroupsAction("Cut"))">Cut</ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleGroupsAction("Copy"))">Copy</ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleGroupsAction("Paste"))">Paste</ContextMenuItem>
                </ContextMenuContent>
            </ContextMenu>
            @if (!string.IsNullOrEmpty(groupsAction))
            {
                <p class="mt-2 text-sm">Last action: <strong>@groupsAction</strong></p>
            }
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Destructive Item"
        Description="Destructive actions are styled to draw attention to their danger.">
        <DemoBlock Code="@_destructiveCode">
            <ContextMenu>
                <ContextMenuTrigger Class="flex h-[150px] w-full items-center justify-center rounded-md border border-dashed text-sm cursor-context-menu select-none">
                    Right click for destructive actions
                </ContextMenuTrigger>
                <ContextMenuContent Class="w-64">
                    <ContextMenuItem OnClick="@(() => HandleDestructiveAction("Edit"))">Edit</ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleDestructiveAction("Duplicate"))">Duplicate</ContextMenuItem>
                    <ContextMenuSeparator />
                    <ContextMenuItem OnClick="@(() => HandleDestructiveAction("Archive"))">Archive</ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleDestructiveAction("Move to Trash"))" Class="text-destructive focus:text-destructive">
                        Move to Trash
                    </ContextMenuItem>
                </ContextMenuContent>
            </ContextMenu>
            @if (!string.IsNullOrEmpty(destructiveAction))
            {
                <p class="mt-2 text-sm">Last action: <strong>@destructiveAction</strong></p>
            }
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Inset Items"
        Description="Use Inset to align items that don't have an icon with items that do.">
        <DemoBlock Code="@_insetCode">
            <ContextMenu>
                <ContextMenuTrigger Class="flex h-[150px] w-full items-center justify-center rounded-md border border-dashed text-sm cursor-context-menu select-none">
                    Right click for inset demo
                </ContextMenuTrigger>
                <ContextMenuContent Class="w-64">
                    <ContextMenuItem OnClick="@(() => HandleInsetAction("Back"))">
                        <LucideIcon Name="chevron-left" Size="16" Class="mr-2" /> Back
                    </ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleInsetAction("Forward"))" Disabled="true" Inset="true">Forward</ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleInsetAction("Reload"))" Inset="true">Reload</ContextMenuItem>
                    <ContextMenuSeparator />
                    <ContextMenuLabel Inset="true">Developer Tools</ContextMenuLabel>
                    <ContextMenuItem OnClick="@(() => HandleInsetAction("Inspect"))" Inset="true">Inspect Element</ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleInsetAction("Console"))" Inset="true">Developer Console</ContextMenuItem>
                </ContextMenuContent>
            </ContextMenu>
            @if (!string.IsNullOrEmpty(insetAction))
            {
                <p class="mt-2 text-sm">Last action: <strong>@insetAction</strong></p>
            }
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="On Image"
        Description="Context menus can be triggered on any element, including images.">
        <DemoBlock Code="@_imageCode">
            <ContextMenu>
                <ContextMenuTrigger>
                    <img
                        alt="placeholder"
                        class="rounded-md cursor-context-menu select-none w-[300px]"
                        src="https://images.unsplash.com/photo-1588345921523-c2dcdb7f1dcd?w=800&dpr=2&q=80"
                         />
                </ContextMenuTrigger>
                <ContextMenuContent Class="w-64">
                    <ContextMenuItem OnClick="@(() => HandleImageAction("Open"))">Open Image in New Tab</ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleImageAction("Save"))">Save Image As...</ContextMenuItem>
                    <ContextMenuSeparator />
                    <ContextMenuItem OnClick="@(() => HandleImageAction("Copy"))">Copy Image</ContextMenuItem>
                    <ContextMenuItem OnClick="@(() => HandleImageAction("Copy Link"))">Copy Image Link</ContextMenuItem>
                    <ContextMenuSeparator />
                    <ContextMenuItem OnClick="@(() => HandleImageAction("Inspect"))">Inspect</ContextMenuItem>
                </ContextMenuContent>
            </ContextMenu>
            @if (!string.IsNullOrEmpty(imageAction))
            {
                <p class="mt-2 text-sm">Last action: <strong>@imageAction</strong></p>
            }
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Checkbox Items"
        Description="Toggle states using checkbox menu items.">
        <DemoBlock Code="@_checkboxCode">
            <ContextMenu>
                <ContextMenuTrigger Class="flex h-[150px] w-full items-center justify-center rounded-md border border-dashed text-sm cursor-context-menu select-none">
                    Right click for checkbox items
                </ContextMenuTrigger>
                <ContextMenuContent Class="w-56">
                    <ContextMenuLabel>View Options</ContextMenuLabel>
                    <ContextMenuSeparator />
                    <ContextMenuCheckboxItem @bind-Checked="@showToolbar">Show Toolbar</ContextMenuCheckboxItem>
                    <ContextMenuCheckboxItem @bind-Checked="@showSidebar">Show Sidebar</ContextMenuCheckboxItem>
                    <ContextMenuCheckboxItem @bind-Checked="@showStatusBar">Show Status Bar</ContextMenuCheckboxItem>
                </ContextMenuContent>
            </ContextMenu>
            <div class="mt-2 flex gap-4 text-sm">
                <span>Toolbar: <strong>@(showToolbar ? "on" : "off")</strong></span>
                <span>Sidebar: <strong>@(showSidebar ? "on" : "off")</strong></span>
                <span>Status Bar: <strong>@(showStatusBar ? "on" : "off")</strong></span>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Radio Items"
        Description="Single-selection using radio menu items.">
        <DemoBlock Code="@_radioCode">
            <ContextMenu>
                <ContextMenuTrigger Class="flex h-[150px] w-full items-center justify-center rounded-md border border-dashed text-sm cursor-context-menu select-none">
                    Right click for radio items
                </ContextMenuTrigger>
                <ContextMenuContent Class="w-56">
                    <ContextMenuLabel>View Mode</ContextMenuLabel>
                    <ContextMenuSeparator />
                    <ContextMenuRadioGroup TValue="string" @bind-Value="@selectedViewMode">
                        <ContextMenuRadioItem TValue="string" Value="@("grid")">Grid View</ContextMenuRadioItem>
                        <ContextMenuRadioItem TValue="string" Value="@("list")">List View</ContextMenuRadioItem>
                        <ContextMenuRadioItem TValue="string" Value="@("compact")">Compact View</ContextMenuRadioItem>
                    </ContextMenuRadioGroup>
                </ContextMenuContent>
            </ContextMenu>
            <p class="mt-2 text-sm">View mode: <strong>@selectedViewMode</strong></p>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Submenus"
        Description="Organize complex menus with nested submenus.">
        <DemoBlock Code="@_submenuCode">
            <ContextMenu>
                <ContextMenuTrigger Class="flex h-[150px] w-full items-center justify-center rounded-md border border-dashed text-sm cursor-context-menu select-none">
                    Right click for submenu
                </ContextMenuTrigger>
                <ContextMenuContent Class="w-64">
                    <ContextMenuItem OnClick="@(() => HandleSubmenuAction("Open"))">Open</ContextMenuItem>
                    <ContextMenuSub>
                        <ContextMenuSubTrigger>Open With</ContextMenuSubTrigger>
                        <ContextMenuSubContent Class="w-48">
                            <ContextMenuItem OnClick="@(() => HandleSubmenuAction("Browser"))">Browser</ContextMenuItem>
                            <ContextMenuItem OnClick="@(() => HandleSubmenuAction("VS Code"))">VS Code</ContextMenuItem>
                            <ContextMenuItem OnClick="@(() => HandleSubmenuAction("Other"))">Other...</ContextMenuItem>
                        </ContextMenuSubContent>
                    </ContextMenuSub>
                    <ContextMenuSeparator />
                    <ContextMenuSub>
                        <ContextMenuSubTrigger>Share</ContextMenuSubTrigger>
                        <ContextMenuSubContent>
                            <ContextMenuItem OnClick="@(() => HandleSubmenuAction("Email"))">Email</ContextMenuItem>
                            <ContextMenuItem OnClick="@(() => HandleSubmenuAction("Copy Link"))">Copy Link</ContextMenuItem>
                        </ContextMenuSubContent>
                    </ContextMenuSub>
                    <ContextMenuSeparator />
                    <ContextMenuItem OnClick="@(() => HandleSubmenuAction("Delete"))" Class="text-destructive focus:text-destructive">Delete</ContextMenuItem>
                </ContextMenuContent>
            </ContextMenu>
            @if (!string.IsNullOrEmpty(submenuAction))
            {
                <p class="mt-2 text-sm">Last action: <strong>@submenuAction</strong></p>
            }
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="Features">
        <ul class="list-disc list-inside space-y-2 text-sm">
            <li>Opens on right-click (contextmenu event)</li>
            <li>Positioned at mouse cursor location</li>
            <li>Closes on outside click or Escape key</li>
            <li>Full keyboard navigation (↑/↓, Enter, Escape)</li>
            <li>Support for disabled items</li>
            <li>Keyboard shortcut hints</li>
            <li>Separator and label components</li>
        </ul>
    </DemoSection>

    <DemoSection Title="Keyboard Navigation">
        <div class="grid gap-2 text-sm">
            <div class="flex gap-4">
                <kbd class="px-2 py-1 bg-muted rounded">↑/↓</kbd>
                <span>Navigate items</span>
            </div>
            <div class="flex gap-4">
                <kbd class="px-2 py-1 bg-muted rounded">Enter/Space</kbd>
                <span>Select item</span>
            </div>
            <div class="flex gap-4">
                <kbd class="px-2 py-1 bg-muted rounded">Escape</kbd>
                <span>Close menu</span>
            </div>
        </div>
    </DemoSection>

    <DemoSection Title="Installation">
        <div class="bg-muted p-4 rounded-md">
            <code class="text-sm">@@using NeoUI.Blazor</code>
        </div>
    </DemoSection>

    <DemoSection Title="Usage">
        <div class="bg-muted p-4 rounded-md">
            <pre class="text-sm overflow-x-auto"><code>&lt;ContextMenu&gt;
    &lt;ContextMenuTrigger&gt;
        &lt;div&gt;Right click here&lt;/div&gt;
    &lt;/ContextMenuTrigger&gt;
    &lt;ContextMenuContent&gt;
        &lt;ContextMenuItem OnClick="HandleCopy"&gt;
            Copy
            &lt;ContextMenuShortcut&gt;⌘C&lt;/ContextMenuShortcut&gt;
        &lt;/ContextMenuItem&gt;
        &lt;ContextMenuSeparator /&gt;
        &lt;ContextMenuItem&gt;Delete&lt;/ContextMenuItem&gt;
    &lt;/ContextMenuContent&gt;
&lt;/ContextMenu&gt;</code></pre>
        </div>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_contextMenuProps" />
    </DemoSection>

    <DemoPageNav />

</div>

@code {
    private string? lastAction;
    private string? iconsAction;
    private string? groupsAction;
    private string? destructiveAction;
    private string? insetAction;
    private string? imageAction;
    private string? submenuAction;

    private bool showToolbar = true;
    private bool showSidebar = false;
    private bool showStatusBar = true;
    private string selectedViewMode = "grid";

    private void HandleAction(string action) => lastAction = action;
    private void HandleIconsAction(string action) => iconsAction = action;
    private void HandleGroupsAction(string action) => groupsAction = action;
    private void HandleDestructiveAction(string action) => destructiveAction = action;
    private void HandleInsetAction(string action) => insetAction = action;
    private void HandleImageAction(string action) => imageAction = action;
    private void HandleSubmenuAction(string action) => submenuAction = action;

    private static readonly IReadOnlyList<DemoPropRow> _contextMenuProps =
    [
        new("ChildContent",  "RenderFragment?",       "null",  "ContextMenuTrigger and ContextMenuContent."),
        new("Disabled",      "bool",                  "false", "On ContextMenuItem: prevents interaction when true."),
        new("Inset",         "bool",                  "false", "On ContextMenuItem/Label: adds left padding to align with icon items."),
        new("Checked",       "bool",                  "false", "On ContextMenuCheckboxItem: the checked state. Use @bind-Checked."),
        new("Value",         "TValue",                "—",     "On ContextMenuRadioItem: the value this item represents."),
        new("Class",         "string?",               "null",  "Additional CSS classes."),
        new("OnClick",       "EventCallback",         "—",     "On ContextMenuItem: callback invoked when the item is clicked."),
    ];

    private const string _defaultCode = """
        <ContextMenu>
            <ContextMenuTrigger Class="flex h-[150px] w-full items-center justify-center rounded-md border border-dashed">
                Right click here
            </ContextMenuTrigger>
            <ContextMenuContent Class="w-64">
                <ContextMenuItem>Back</ContextMenuItem>
                <ContextMenuItem Disabled="true">Forward</ContextMenuItem>
                <ContextMenuSeparator />
                <ContextMenuItem>Save As...</ContextMenuItem>
                <ContextMenuItem>Print...</ContextMenuItem>
            </ContextMenuContent>
        </ContextMenu>
        """;

    private const string _iconsCode = """
        <ContextMenuContent Class="w-56">
            <ContextMenuItem>
                <LucideIcon Name="folder-open" Size="16" Class="mr-2" /> Open
            </ContextMenuItem>
            <ContextMenuItem>
                <LucideIcon Name="copy" Size="16" Class="mr-2" /> Copy
                <ContextMenuShortcut>⌘C</ContextMenuShortcut>
            </ContextMenuItem>
            <ContextMenuSeparator />
            <ContextMenuItem Class="text-destructive focus:text-destructive">
                <LucideIcon Name="trash-2" Size="16" Class="mr-2" /> Delete
            </ContextMenuItem>
        </ContextMenuContent>
        """;

    private const string _groupsCode = """
        <ContextMenuContent>
            <ContextMenuLabel>File Operations</ContextMenuLabel>
            <ContextMenuSeparator />
            <ContextMenuItem>New File</ContextMenuItem>
            <ContextMenuSeparator />
            <ContextMenuLabel>Edit Operations</ContextMenuLabel>
            <ContextMenuSeparator />
            <ContextMenuItem>Cut</ContextMenuItem>
            <ContextMenuItem>Copy</ContextMenuItem>
        </ContextMenuContent>
        """;

    private const string _destructiveCode = """
        <ContextMenuContent>
            <ContextMenuItem>Edit</ContextMenuItem>
            <ContextMenuItem>Duplicate</ContextMenuItem>
            <ContextMenuSeparator />
            <ContextMenuItem Class="text-destructive focus:text-destructive">
                Move to Trash
            </ContextMenuItem>
        </ContextMenuContent>
        """;

    private const string _insetCode = """
        <ContextMenuContent>
            <ContextMenuItem>
                <LucideIcon Name="chevron-left" Size="16" Class="mr-2" /> Back
            </ContextMenuItem>
            <ContextMenuItem Inset="true">Forward</ContextMenuItem>
            <ContextMenuSeparator />
            <ContextMenuLabel Inset="true">Developer Tools</ContextMenuLabel>
            <ContextMenuItem Inset="true">Inspect Element</ContextMenuItem>
        </ContextMenuContent>
        """;

    private const string _imageCode = """
        <ContextMenu>
            <ContextMenuTrigger>
                <img src="image.jpg" alt="Photo" class="rounded-md cursor-context-menu" />
            </ContextMenuTrigger>
            <ContextMenuContent>
                <ContextMenuItem>Open Image in New Tab</ContextMenuItem>
                <ContextMenuItem>Save Image As...</ContextMenuItem>
                <ContextMenuSeparator />
                <ContextMenuItem>Copy Image</ContextMenuItem>
            </ContextMenuContent>
        </ContextMenu>
        """;

    private const string _checkboxCode = """
        <ContextMenuContent>
            <ContextMenuLabel>View Options</ContextMenuLabel>
            <ContextMenuSeparator />
            <ContextMenuCheckboxItem @bind-Checked="showToolbar">Show Toolbar</ContextMenuCheckboxItem>
            <ContextMenuCheckboxItem @bind-Checked="showSidebar">Show Sidebar</ContextMenuCheckboxItem>
        </ContextMenuContent>
        """;

    private const string _radioCode = """
        <ContextMenuContent>
            <ContextMenuLabel>View Mode</ContextMenuLabel>
            <ContextMenuSeparator />
            <ContextMenuRadioGroup TValue="string" @bind-Value="selectedViewMode">
                <ContextMenuRadioItem TValue="string" Value="@("grid")">Grid View</ContextMenuRadioItem>
                <ContextMenuRadioItem TValue="string" Value="@("list")">List View</ContextMenuRadioItem>
            </ContextMenuRadioGroup>
        </ContextMenuContent>
        """;

    private const string _submenuCode = """
        <ContextMenuContent>
            <ContextMenuItem>Open</ContextMenuItem>
            <ContextMenuSub>
                <ContextMenuSubTrigger>Open With</ContextMenuSubTrigger>
                <ContextMenuSubContent>
                    <ContextMenuItem>Browser</ContextMenuItem>
                    <ContextMenuItem>VS Code</ContextMenuItem>
                </ContextMenuSubContent>
            </ContextMenuSub>
        </ContextMenuContent>
        """;
}
