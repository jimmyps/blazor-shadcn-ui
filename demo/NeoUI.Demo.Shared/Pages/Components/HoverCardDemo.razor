@page "/components/hover-card"

<PageTitle>Hover Card - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Hover Card"
        Description="For sighted users to preview content available behind a link." />

    <DemoSection
        Title="Default"
        Description="Hover over the trigger to display additional content.">
        <DemoBlock Code="@_defaultCode">
            <div class="flex items-center gap-2">
                <p class="text-sm">Hover over</p>
                <HoverCard>
                    <HoverCardTrigger Class="underline">@@nextjs</HoverCardTrigger>
                    <HoverCardContent>
                        <div class="flex justify-between space-x-4">
                            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-purple-500 to-pink-500 text-white font-bold text-lg">
                                N
                            </div>
                            <div class="space-y-1 flex-1">
                                <h4 class="text-sm font-semibold">@@nextjs</h4>
                                <p class="text-sm text-muted-foreground">
                                    The React Framework – created and maintained by @@vercel.
                                </p>
                                <div class="flex items-center pt-2">
                                    <span class="text-xs text-muted-foreground">Joined December 2021</span>
                                </div>
                            </div>
                        </div>
                    </HoverCardContent>
                </HoverCard>
                <p class="text-sm">for more information.</p>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="AsChild Pattern"
        Description="Use AsChild to compose triggers with your own styled elements.">
        <DemoBlock Code="@_asChildCode">
            <div class="grid md:grid-cols-2 gap-6">
                <div class="space-y-3 p-4 border rounded-lg">
                    <h3 class="text-lg font-medium">Without AsChild</h3>
                    <p class="text-sm text-muted-foreground">HoverCardTrigger renders its own div element.</p>
                    <HoverCard>
                        <HoverCardTrigger Class="underline cursor-pointer">@@username</HoverCardTrigger>
                        <HoverCardContent>
                            <p class="text-sm">User profile info</p>
                        </HoverCardContent>
                    </HoverCard>
                </div>
                <div class="space-y-3 p-4 border rounded-lg">
                    <h3 class="text-lg font-medium">With AsChild</h3>
                    <p class="text-sm text-muted-foreground">Button receives hover/focus behavior via TriggerContext.</p>
                    <HoverCard>
                        <HoverCardTrigger AsChild>
                            <Button Variant="ButtonVariant.Link">@@johndoe</Button>
                        </HoverCardTrigger>
                        <HoverCardContent>
                            <div class="flex gap-3">
                                <div class="h-10 w-10 rounded-full bg-gradient-to-br from-blue-500 to-teal-500 flex items-center justify-center text-white font-bold">
                                    JD
                                </div>
                                <div>
                                    <h4 class="text-sm font-semibold">John Doe</h4>
                                    <p class="text-xs text-muted-foreground">Software Developer</p>
                                </div>
                            </div>
                        </HoverCardContent>
                    </HoverCard>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="User Profile Card"
        Description="Common use case for showing user information on hover.">
        <DemoBlock Code="@_userProfileCode">
            <div class="text-sm">
                Article written by
                <HoverCard>
                    <HoverCardTrigger Class="font-semibold text-primary hover:underline cursor-pointer">
                        @@johndoe
                    </HoverCardTrigger>
                    <HoverCardContent>
                        <div class="flex gap-4">
                            <div class="h-16 w-16 rounded-full bg-gradient-to-br from-blue-500 to-teal-500 flex items-center justify-center text-white font-bold text-2xl">
                                JD
                            </div>
                            <div class="space-y-2 flex-1">
                                <div>
                                    <h4 class="text-sm font-semibold leading-none">John Doe</h4>
                                    <p class="text-sm text-muted-foreground">@@johndoe</p>
                                </div>
                                <p class="text-sm">Full-stack developer passionate about creating beautiful user experiences.</p>
                                <div class="flex gap-4 text-xs text-muted-foreground">
                                    <div><span class="font-semibold text-foreground">2.5k</span> followers</div>
                                    <div><span class="font-semibold text-foreground">890</span> following</div>
                                </div>
                            </div>
                        </div>
                    </HoverCardContent>
                </HoverCard>
                on January 15, 2024.
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Product Preview"
        Description="Show product details on hover.">
        <DemoBlock Code="@_productCode">
            <div class="flex flex-wrap gap-4">
                <HoverCard OpenDelay="300">
                    <HoverCardTrigger Class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background hover:bg-accent hover:text-accent-foreground h-10 px-4 py-2">
                        View Product
                    </HoverCardTrigger>
                    <HoverCardContent>
                        <div class="space-y-3">
                            <div class="h-32 w-full rounded-md bg-gradient-to-br from-orange-400 to-rose-400"></div>
                            <div class="space-y-1">
                                <h4 class="text-sm font-semibold">Premium Headphones</h4>
                                <p class="text-sm text-muted-foreground">High-quality wireless headphones with active noise cancellation.</p>
                                <div class="flex items-center justify-between pt-2">
                                    <span class="text-lg font-bold">$299.99</span>
                                    <span class="text-xs text-muted-foreground">★★★★★ (4.8)</span>
                                </div>
                            </div>
                        </div>
                    </HoverCardContent>
                </HoverCard>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_hoverCardProps" />
    </DemoSection>

    <DemoPageNav />
</div>

@code {
    private static readonly IReadOnlyList<DemoPropRow> _hoverCardProps =
    [
        new("OpenDelay",    "int",             "700",  "Delay in milliseconds before the card opens on hover."),
        new("CloseDelay",   "int",             "300",  "Delay in milliseconds before the card closes."),
        new("Side",         "string?",         null,   "The preferred side to show the card. Options: top, right, bottom, left."),
        new("Align",        "string?",         null,   "Alignment relative to the trigger. Options: start, center, end."),
        new("ChildContent", "RenderFragment?", null,   "Nest HoverCardTrigger and HoverCardContent here."),
    ];

    private const string _defaultCode =
        """
        <HoverCard>
            <HoverCardTrigger Class="underline">@nextjs</HoverCardTrigger>
            <HoverCardContent>
                <h4 class="text-sm font-semibold">@nextjs</h4>
                <p class="text-sm text-muted-foreground">The React Framework by @vercel.</p>
            </HoverCardContent>
        </HoverCard>
        """;

    private const string _asChildCode =
        """
        <!-- Without AsChild: HoverCardTrigger wraps content in its own element -->
        <HoverCard>
            <HoverCardTrigger Class="underline cursor-pointer">@username</HoverCardTrigger>
            <HoverCardContent><p class="text-sm">User profile info</p></HoverCardContent>
        </HoverCard>

        <!-- With AsChild: trigger behavior applied to the child element -->
        <HoverCard>
            <HoverCardTrigger AsChild>
                <Button Variant="ButtonVariant.Link">@johndoe</Button>
            </HoverCardTrigger>
            <HoverCardContent><p class="text-sm">Profile card</p></HoverCardContent>
        </HoverCard>
        """;

    private const string _userProfileCode =
        """
        <HoverCard>
            <HoverCardTrigger Class="font-semibold text-primary hover:underline cursor-pointer">
                @johndoe
            </HoverCardTrigger>
            <HoverCardContent>
                <h4 class="text-sm font-semibold">John Doe</h4>
                <p class="text-sm text-muted-foreground">Full-stack developer.</p>
            </HoverCardContent>
        </HoverCard>
        """;

    private const string _productCode =
        """
        <HoverCard OpenDelay="300">
            <HoverCardTrigger Class="inline-flex items-center justify-center rounded-md border h-10 px-4 py-2">
                View Product
            </HoverCardTrigger>
            <HoverCardContent>
                <div class="h-32 w-full rounded-md bg-gradient-to-br from-orange-400 to-rose-400"></div>
                <h4 class="text-sm font-semibold mt-2">Premium Headphones</h4>
                <span class="text-lg font-bold">$299.99</span>
            </HoverCardContent>
        </HoverCard>
        """;
}
