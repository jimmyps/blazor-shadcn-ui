@page "/components/empty"

<PageTitle>Empty - NeoUI</PageTitle>

<div class="space-y-8 max-w-4xl">

    <DemoPageHeader
        Title="Empty"
        Description="Displays an empty state when there's no data or content to show." />

    <DemoSection
        Title="Basic"
        Description="A simple empty state with icon, title, and description.">
        <DemoBlock Code="@_basicCode">
            <Empty>
                <EmptyIcon>
                    <LucideIcon Name="inbox" Class="h-10 w-10" />
                </EmptyIcon>
                <EmptyTitle>No messages</EmptyTitle>
                <EmptyDescription>
                    You don't have any messages yet. Start a conversation to see messages here.
                </EmptyDescription>
            </Empty>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="With Actions"
        Description="An empty state with action buttons to guide the user forward.">
        <DemoBlock Code="@_withActionsCode">
            <Empty>
                <EmptyIcon>
                    <LucideIcon Name="file-text" Class="h-10 w-10" />
                </EmptyIcon>
                <EmptyTitle>No documents</EmptyTitle>
                <EmptyDescription>
                    Get started by creating your first document.
                </EmptyDescription>
                <EmptyActions>
                    <Button>Create Document</Button>
                </EmptyActions>
            </Empty>
        </DemoBlock>
    </DemoSection>

    <DemoSection
        Title="Usage Examples"
        Description="Common empty state scenarios.">
        <DemoBlock Code="@_usageCode">
            <div class="space-y-6">
                <div class="space-y-3">
                    <h3 class="text-lg font-medium">No Search Results</h3>
                    <Empty>
                        <EmptyIcon>
                            <LucideIcon Name="search" Class="h-10 w-10" />
                        </EmptyIcon>
                        <EmptyTitle>No results found</EmptyTitle>
                        <EmptyDescription>
                            We couldn't find any results for your search. Try using different keywords.
                        </EmptyDescription>
                    </Empty>
                </div>
                <div class="space-y-3">
                    <h3 class="text-lg font-medium">Empty Shopping Cart</h3>
                    <Empty>
                        <EmptyIcon>
                            <LucideIcon Name="shopping-cart" Class="h-10 w-10" />
                        </EmptyIcon>
                        <EmptyTitle>Your cart is empty</EmptyTitle>
                        <EmptyDescription>
                            Add items to your cart to get started with your purchase.
                        </EmptyDescription>
                        <EmptyActions>
                            <Button>Continue Shopping</Button>
                        </EmptyActions>
                    </Empty>
                </div>
                <div class="space-y-3">
                    <h3 class="text-lg font-medium">No Notifications</h3>
                    <Empty Class="min-h-[300px]">
                        <EmptyIcon>
                            <LucideIcon Name="bell" Class="h-10 w-10" />
                        </EmptyIcon>
                        <EmptyTitle>All caught up!</EmptyTitle>
                        <EmptyDescription>
                            You don't have any notifications at the moment.
                        </EmptyDescription>
                    </Empty>
                </div>
            </div>
        </DemoBlock>
    </DemoSection>

    <DemoSection Title="API Reference" Description="Component parameters and their types.">
        <DemoPropsTable Rows="_emptyProps" />
    </DemoSection>

    <DemoPageNav />
</div>

@code {
    private static readonly IReadOnlyList<DemoPropRow> _emptyProps =
    [
        new("Class", "string?", null, "Additional CSS classes applied to the container."),
    ];

    private const string _basicCode =
        """
        <Empty>
            <EmptyIcon>
                <LucideIcon Name="inbox" Class="h-10 w-10" />
            </EmptyIcon>
            <EmptyTitle>No messages</EmptyTitle>
            <EmptyDescription>
                You don't have any messages yet.
            </EmptyDescription>
        </Empty>
        """;

    private const string _withActionsCode =
        """
        <Empty>
            <EmptyIcon>
                <LucideIcon Name="file-text" Class="h-10 w-10" />
            </EmptyIcon>
            <EmptyTitle>No documents</EmptyTitle>
            <EmptyDescription>
                Get started by creating your first document.
            </EmptyDescription>
            <EmptyActions>
                <Button>Create Document</Button>
            </EmptyActions>
        </Empty>
        """;

    private const string _usageCode =
        """
        <!-- No search results -->
        <Empty>
            <EmptyIcon><LucideIcon Name="search" Class="h-10 w-10" /></EmptyIcon>
            <EmptyTitle>No results found</EmptyTitle>
            <EmptyDescription>Try using different keywords.</EmptyDescription>
        </Empty>

        <!-- Empty cart with action -->
        <Empty>
            <EmptyIcon><LucideIcon Name="shopping-cart" Class="h-10 w-10" /></EmptyIcon>
            <EmptyTitle>Your cart is empty</EmptyTitle>
            <EmptyDescription>Add items to your cart to get started.</EmptyDescription>
            <EmptyActions><Button>Continue Shopping</Button></EmptyActions>
        </Empty>
        """;
}
