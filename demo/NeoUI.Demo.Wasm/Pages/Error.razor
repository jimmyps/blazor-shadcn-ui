@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<div class="flex items-center justify-center min-h-[60vh]">
    <div class="max-w-2xl w-full space-y-6">
        <Card>
            <CardHeader>
                <div class="flex items-center gap-3">
                    <div class="h-12 w-12 rounded-full bg-destructive/10 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-destructive">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" x2="12" y1="8" y2="12"></line>
                            <line x1="12" x2="12.01" y1="16" y2="16"></line>
                        </svg>
                    </div>
                    <div>
                        <CardTitle>An Error Occurred</CardTitle>
                        <CardDescription>We encountered an unexpected problem</CardDescription>
                    </div>
                </div>
            </CardHeader>
            <CardContent class="space-y-4">
                <Alert Variant="AlertVariant.Destructive">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path>
                        <path d="M12 9v4"></path>
                        <path d="M12 17h.01"></path>
                    </svg>
                    <AlertTitle>Error</AlertTitle>
                    <AlertDescription>
                        An error occurred while processing your request.
                    </AlertDescription>
                </Alert>

                @if (ShowRequestId)
                {
                    <div class="p-4 bg-muted rounded-lg space-y-2">
                        <p class="text-sm font-medium">Request Information</p>
                        <div class="flex items-center gap-2">
                            <span class="text-sm text-muted-foreground">Request ID:</span>
                            <code class="relative rounded bg-muted-foreground/20 px-2 py-1 font-mono text-xs">@RequestId</code>
                        </div>
                        <p class="text-xs text-muted-foreground">
                            Please provide this ID when contacting support for assistance.
                        </p>
                    </div>
                }

                <div class="space-y-3">
                    <h3 class="text-sm font-medium">What you can do:</h3>
                    <div class="space-y-2">
                        <div class="flex items-start gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary mt-0.5 flex-shrink-0">
                                <polyline points="9 11 12 14 22 4"></polyline>
                                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                            </svg>
                            <p class="text-sm text-muted-foreground">Try refreshing the page</p>
                        </div>
                        <div class="flex items-start gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary mt-0.5 flex-shrink-0">
                                <polyline points="9 11 12 14 22 4"></polyline>
                                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                            </svg>
                            <p class="text-sm text-muted-foreground">Return to the home page</p>
                        </div>
                        <div class="flex items-start gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary mt-0.5 flex-shrink-0">
                                <polyline points="9 11 12 14 22 4"></polyline>
                                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                            </svg>
                            <p class="text-sm text-muted-foreground">Contact support if the problem persists</p>
                        </div>
                    </div>
                </div>
            </CardContent>
            <CardFooter class="gap-2">
                <Button OnClick="@(() => NavigationManager.NavigateTo("/", true))" Class="flex-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
                        <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                    </svg>
                    Go Home
                </Button>
                <Button OnClick="@Reload" Variant="ButtonVariant.Outline" Class="flex-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
                        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
                        <path d="M3 3v5h5"></path>
                    </svg>
                    Reload Page
                </Button>
            </CardFooter>
        </Card>
    </div>
</div>

@code {
    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id;

    private void Reload() =>
        NavigationManager.NavigateTo(NavigationManager.Uri, true);
}
