@page "/screens/login-dialog"

<PageTitle>Login Dialog — NeoUI (Blazor)</PageTitle>

<div class="relative flex min-h-svh w-full items-center justify-center bg-muted p-6 md:p-10">
    <div class="absolute top-4 right-4">
        <ThemeSwitcher />
    </div>

    @if (!_open)
    {
        <Button OnClick="@(() => _open = true)">Open Login Dialog</Button>
    }

    <Dialog @bind-Open="_open">
        <DialogContent Class="sm:max-w-sm">
            <DialogHeader>
                <DialogTitle Class="text-2xl">Login</DialogTitle>
                <DialogDescription>
                    Enter your email below to login to your account
                </DialogDescription>
            </DialogHeader>
            <form>
                <div class="flex flex-col gap-6">
                    <div class="grid gap-2">
                        <Label For="email">Email</Label>
                        <Input Id="email"
                               Type="InputType.Email"
                               Placeholder="m@example.com"
                               Required="true" />
                    </div>
                    <div class="grid gap-2">
                        <div class="flex items-center">
                            <Label For="password">Password</Label>
                            <a href="#"
                               class="ml-auto inline-block text-sm underline-offset-4 hover:underline">
                                Forgot your password?
                            </a>
                        </div>
                        <Input Id="password" Type="InputType.Password" Required="true" />
                    </div>
                    <Button Class="w-full">Login</Button>
                    <Button Variant="ButtonVariant.Outline" Class="w-full">Login with Google</Button>
                </div>
                <div class="mt-4 text-center text-sm">
                    Don&apos;t have an account?
                    <a href="#" class="underline underline-offset-4">Sign up</a>
                </div>
            </form>
        </DialogContent>
    </Dialog>
</div>

@code {
    private bool _open = true;
}
