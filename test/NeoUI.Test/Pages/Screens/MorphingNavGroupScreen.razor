    // ── Split button helpers ──────────────────────────────────────────────────

    bool IsGroupActive(NavItem[] items) => items.Any(i => i.Key == activeSection);

    /// Icon for the left segment: active group member's icon, else last-chosen, else fallback.
    string SplitIcon(NavItem[] items, string lastKey, string fallback) =>
        items.FirstOrDefault(i => i.Key == activeSection)?.Icon
        ?? items.FirstOrDefault(i => i.Key == lastKey)?.Icon
        ?? fallback;

    /// Accessible label for the left segment.
    string SplitLabel(NavItem[] items, string lastKey) =>
        items.FirstOrDefault(i => i.Key == activeSection)?.Label
        ?? items.FirstOrDefault(i => i.Key == lastKey)?.Label
        ?? items[0].Label;

    // ── Color helpers ─────────────────────────────────────────────────────────

    string ColorBgClass(string c) => c switch
    {
        "blue" => "bg-blue-500/10",
        "violet" => "bg-violet-500/10",
        "emerald" => "bg-emerald-500/10",
        "amber" => "bg-amber-500/10",
        "rose" => "bg-rose-500/10",
        "sky" => "bg-sky-500/10",
        _ => "bg-primary/10",
    };

    string ColorTextClass(string c) => c switch
    {
        "blue" => "text-blue-500",
        "violet" => "text-violet-500",
        "emerald" => "text-emerald-500",
        "amber" => "text-amber-500",
        "rose" => "text-rose-500",
        "sky" => "text-sky-500",
        _ => "text-primary",
    };

    string BadgeClass(string status) => status switch
    {
        "Live" or "Active" or "Done" or "Paid" or "Secure" or "200"
            => "bg-emerald-500/10 text-emerald-600",
        "Trial" or "Test" or "Draft"
            => "bg-blue-500/10 text-blue-600",
        "Paused" or "Revoked" or "Failed" or "Dispute" or "422" or "500"
            => "bg-rose-500/10 text-rose-600",
        "Refunded"
            => "bg-amber-500/10 text-amber-600",
        _ => "bg-muted text-muted-foreground",
    };
}
