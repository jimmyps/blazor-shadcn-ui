@page "/screens/morphing-nav"
@layout NeoUI.Test.Layout.FullScreenLayout
@namespace NeoUI.Test.Pages.Screens

@*
    NeoUI-native morphing sidebar demo.
    Demonstrates SidebarCollapsedMode.Pill — the sidebar collapses into a floating pill nav bar.
    Compare with /screens/morphing-nav-benchmark which achieves the same result with raw HTML.
*@

<SidebarProvider CollapsedMode="SidebarCollapsedMode.Pill"
                 DefaultOpen="true"
                 HeightClass="h-screen">

    @* ── Full sidebar ─────────────────────────────────────────── *@
    <Sidebar Collapsible="true">

        <SidebarHeader>
            <div class="flex h-12 items-center justify-between px-4">
                <span class="text-lg font-semibold text-sidebar-foreground whitespace-nowrap">NeoUI App</span>
                <SidebarTrigger />
            </div>
        </SidebarHeader>

        <SidebarContent>
            <SidebarGroup>
                <button type="button"
                        class="flex w-full items-center gap-2 rounded-md border border-sidebar-border bg-sidebar-accent/30 px-3 py-1.5 text-sm text-muted-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground transition-colors"
                        @onclick="OpenCommand">
                    <LucideIcon Name="search" Size="14" />
                    <span class="flex-1 text-left">Search...</span>
                    <kbd class="font-mono text-xs opacity-50">⌘K</kbd>
                </button>
            </SidebarGroup>

            <SidebarGroup>
                <SidebarGroupContent>
                    <SidebarMenu>
                        @foreach (var (item, index) in navItems.Select((item, i) => (item, i)))
                        {
                            <SidebarMenuItem>
                                <SidebarMenuButton IsActive="@(activeItem == index)"
                                                   OnClick="@(() => activeItem = index)"
                                                   Tooltip="@item.Label">
                                    <LucideIcon Name="@item.Icon" Size="16" />
                                    <span>@item.Label</span>
                                </SidebarMenuButton>
                            </SidebarMenuItem>
                        }
                    </SidebarMenu>
                </SidebarGroupContent>
            </SidebarGroup>
            <SidebarSeparator />

            <SidebarGroup>
                <div class="flex items-center justify-between rounded-md px-2 py-1.5">
                    <span class="text-sm text-sidebar-foreground">Theme</span>
                    <DarkModeToggle />
                </div>
            </SidebarGroup>
        </SidebarContent>

        <SidebarRail />
    </Sidebar>

    @* ── Pill nav (auto-shows when sidebar collapses) ──────────── *@
    <SidebarPillNav>
        <ChildContent>
            @foreach (var (item, index) in navItems.Select((item, i) => (item, i)))
            {
                <SidebarPillNavItem Label="@item.Label"
                                    IsActive="@(activeItem == index)"
                                    OnClick="@(() => activeItem = index)">
                    <LucideIcon Name="@item.Icon" Size="16" />
                </SidebarPillNavItem>
            }
        </ChildContent>
        <TrailingContent>
            <SidebarPillNavItem Label="Search" OnClick="OpenCommand">
                <LucideIcon Name="search" Size="16" />
            </SidebarPillNavItem>
        </TrailingContent>
    </SidebarPillNav>

    @* ── Main content ─────────────────────────────────────────── *@
    <SidebarInset>

        @* Apple-style gradient fade — provides pill-nav clearance; content scrolls under it via <main>'s scroll *@
        <SidebarPillFade />

        <SidebarPillInset>

            <div class="p-6 pt-2 space-y-6">
                @* ── Page header ────────────────────────────────────────── *@
                <div class="flex flex-wrap items-start justify-between gap-4">
                    <div>
                        <h2 class="text-3xl font-bold tracking-tight text-foreground">@navItems[activeItem].Label</h2>
                        <p class="mt-1 text-sm text-muted-foreground">
                            March 2026 · <span class="font-medium text-foreground">Updated just now</span>
                        </p>
                    </div>
                    <div class="flex items-center gap-2">
                        <button type="button"
                                class="inline-flex items-center gap-1.5 rounded-md border border-border bg-card px-3 py-1.5 text-sm font-medium text-card-foreground shadow-sm hover:bg-accent hover:text-accent-foreground transition-colors">
                            <LucideIcon Name="download" Size="14" />
                            Export
                        </button>
                        <button type="button"
                                class="inline-flex items-center gap-1.5 rounded-md bg-primary px-3 py-1.5 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
                            <LucideIcon Name="plus" Size="14" />
                            New Report
                        </button>
                    </div>
                </div>

                @* ── KPI cards ───────────────────────────────────────────── *@
                <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                    @foreach (var card in kpiCards)
                    {
                        <Card Class="p-5">
                            <CardContent Class="p-0">
                                <div class="mb-3 flex items-start justify-between">
                                    <div class="@IconBgClass(card.Color) rounded-lg p-2">
                                        <LucideIcon Name="@card.Icon" Class="@($"{IconColorClass(card.Color)} h-4 w-4")" />
                                    </div>
                                    <span class="@(card.Positive ? "bg-emerald-500/10 text-emerald-600" : "bg-red-500/10 text-red-500") inline-flex items-center gap-0.5 rounded-full px-2 py-0.5 text-xs font-medium">
                                        <LucideIcon Name="@(card.Positive ? "arrow-up-right" : "arrow-down-right")" Size="10" />
                                        @card.Delta
                                    </span>
                                </div>
                                <p class="mb-1 truncate text-xs text-muted-foreground">@card.Label</p>
                                <p class="text-2xl font-bold tracking-tight text-card-foreground">@card.Value</p>
                                <p class="mt-1 text-xs text-muted-foreground">vs. last 30 days</p>
                            </CardContent>
                        </Card>
                    }
                </div>

                @* ── Bottom row ──────────────────────────────────────────── *@
                <div class="grid gap-4 lg:grid-cols-2">

                    @* Recent Activity *@
                    <Card Class="p-5">
                        <CardContent Class="p-0">
                            <div class="mb-4 flex items-center justify-between">
                                <h3 class="text-sm font-semibold text-card-foreground">Recent Activity</h3>
                                <button type="button"
                                        class="text-xs text-muted-foreground transition-colors hover:text-foreground">
                                    View all →
                                </button>
                            </div>
                            <div class="space-y-4">
                                @foreach (var entry in activityFeed)
                                {
                                    <div class="flex items-start gap-3">
                                        <div class="@($"{AvatarBgClass(entry.Color)} {AvatarTextClass(entry.Color)} flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-xs font-bold")">
                                            @entry.Initials
                                        </div>
                                        <div class="min-w-0 flex-1">
                                            <p class="text-sm leading-snug text-card-foreground">@entry.Description</p>
                                            <p class="mt-0.5 text-xs text-muted-foreground">@entry.Time</p>
                                        </div>
                                        <div class="mt-0.5 shrink-0 text-muted-foreground/50">
                                            <LucideIcon Name="@entry.ActionIcon" Size="13" />
                                        </div>
                                    </div>
                                }
                            </div>
                        </CardContent>
                    </Card>

                    @* Resource Health *@
                    <Card Class="p-5">
                        <CardContent Class="p-0">
                            <div class="mb-4 flex items-center justify-between">
                                <h3 class="text-sm font-semibold text-card-foreground">Resource Health</h3>
                                <span class="inline-flex items-center gap-1 rounded-full bg-emerald-500/10 px-2 py-0.5 text-xs font-medium text-emerald-600">
                                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                                    Operational
                                </span>
                            </div>
                            <div class="space-y-4">
                                @foreach (var metric in perfMetrics)
                                {
                                    <div class="space-y-1.5">
                                        <div class="flex items-center justify-between text-sm">
                                            <div class="flex items-center gap-2">
                                                <span class="@HealthDotClass(metric.Value) h-2 w-2 shrink-0 rounded-full"></span>
                                                <span class="font-medium text-card-foreground">@metric.Label</span>
                                            </div>
                                            <span class="@HealthTextClass(metric.Value) tabular-nums font-semibold">@metric.Value%</span>
                                        </div>
                                        <Progress Value="@metric.Value" Max="100" Class="h-1.5" />
                                        <p class="text-xs text-muted-foreground/70">@HealthStatusLabel(metric.Value)</p>
                                    </div>
                                }
                            </div>
                        </CardContent>
                    </Card>

                </div>
            </div>

        </SidebarPillInset>
    </SidebarInset>

    @* ── Command palette ───────────────────────────────────────────── *@
    <Dialog @bind-Open="_commandOpen">
        <DialogContent ShowClose="false"
                       Class="p-0 gap-0 overflow-hidden max-w-md sm:top-[20vh] sm:translate-y-0">
            <CommandContent OnValueChange="HandleCommand">
                <CommandInput Placeholder="Search or jump to..."
                              AutoFocus="true"
                              Class="border-0 border-b border-border rounded-none focus-visible:ring-0" />
                <CommandList Class="max-h-72">
                    <CommandEmpty>
                        <div class="flex items-center justify-center gap-2 py-6 text-sm text-muted-foreground">
                            <LucideIcon Name="search-x" Size="16" />
                            No results found.
                        </div>
                    </CommandEmpty>
                    <CommandGroup Heading="Navigate">
                        @foreach (var (item, index) in navItems.Select((item, i) => (item, i)))
                        {
                            var idx = index;
                            <CommandItem Value="@item.Label">
                                <LucideIcon Name="@item.Icon" Size="16" Class="mr-2" />
                                @item.Label
                            </CommandItem>
                        }
                    </CommandGroup>
                </CommandList>
            </CommandContent>
        </DialogContent>
    </Dialog>

</SidebarProvider>

@code {
    int activeItem = 0;
    bool _commandOpen;

    void OpenCommand() => _commandOpen = true;

    void HandleCommand(string value)
    {
        var idx = Array.FindIndex(navItems, item => item.Label == value);
        if (idx >= 0)
        {
            activeItem = idx;
            _commandOpen = false;
        }
    }

    record NavItem(string Icon, string Label);
    record PerfMetric(string Label, int Value);
    record KpiCard(string Icon, string Color, string Label, string Value, string Delta, bool Positive);
    record ActivityEntry(string Initials, string Color, string Description, string Time, string ActionIcon);

    readonly NavItem[] navItems =
    [
        new("layout-dashboard", "Dashboard"),
        new("bar-chart-3",      "Analytics"),
        new("users",            "Team"),
        new("file-text",        "Reports"),
        new("settings",         "Settings"),
    ];

    readonly PerfMetric[] perfMetrics =
    [
        new("System Load",  72),
        new("Memory Usage", 61),
        new("Network",      85),
        new("Storage",      68),
    ];

    readonly KpiCard[] kpiCards =
    [
        new("trending-up", "blue",    "Total Revenue", "$128,450", "+12.5%",  true),
        new("users",       "violet",  "Active Users",  "8,240",    "+4.8%",   true),
        new("user-plus",   "emerald", "New Signups",   "1,093",    "+18.2%",  true),
        new("user-minus",  "rose",    "Churn Rate",    "2.4%",     "-0.8%",   true),
        new("timer",       "amber",   "Avg. Session",  "4m 32s",   "-0.3%",   false),
        new("star",        "sky",     "NPS Score",     "72",       "+5 pts",  true),
    ];

    readonly ActivityEntry[] activityFeed =
    [
        new("JD", "violet",  "James submitted the Q3 financial report", "2 min ago",   "file-text"),
        new("SK", "emerald", "Sarah onboarded 3 new team members",      "1 hour ago",  "users"),
        new("MR", "blue",    "Mike deployed the dashboard redesign",    "3 hours ago", "rocket"),
        new("AL", "amber",   "Amy updated the budget forecast",         "Yesterday",   "bar-chart-3"),
        new("TW", "rose",    "Tom resolved 12 open support tickets",    "2 days ago",  "circle-check"),
    ];

    string IconBgClass(string c) => c switch
    {
        "blue" => "bg-blue-500/10",
        "violet" => "bg-violet-500/10",
        "emerald" => "bg-emerald-500/10",
        "amber" => "bg-amber-500/10",
        "rose" => "bg-rose-500/10",
        "sky" => "bg-sky-500/10",
        _ => "bg-primary/10",
    };

    string IconColorClass(string c) => c switch
    {
        "blue" => "text-blue-500",
        "violet" => "text-violet-500",
        "emerald" => "text-emerald-500",
        "amber" => "text-amber-500",
        "rose" => "text-rose-500",
        "sky" => "text-sky-500",
        _ => "text-primary",
    };

    string AvatarBgClass(string c) => c switch
    {
        "blue" => "bg-blue-500/15",
        "violet" => "bg-violet-500/15",
        "emerald" => "bg-emerald-500/15",
        "amber" => "bg-amber-500/15",
        "rose" => "bg-rose-500/15",
        "sky" => "bg-sky-500/15",
        _ => "bg-primary/15",
    };

    string AvatarTextClass(string c) => c switch
    {
        "blue" => "text-blue-600",
        "violet" => "text-violet-600",
        "emerald" => "text-emerald-600",
        "amber" => "text-amber-600",
        "rose" => "text-rose-600",
        "sky" => "text-sky-600",
        _ => "text-primary",
    };

    string HealthTextClass(int v) => v >= 85 ? "text-red-500" : v >= 70 ? "text-amber-500" : "text-emerald-600";
    string HealthDotClass(int v) => v >= 85 ? "bg-red-500" : v >= 70 ? "bg-amber-500" : "bg-emerald-500";
    string HealthStatusLabel(int v) => v >= 85 ? "Critical — attention required" : v >= 70 ? "Elevated — monitor closely" : "Normal — within expected range";
}
